---
interface Props {
  title: string;
  desc: string;
  href: string;
  icon: string;
  isSoon?: boolean;
  titleKey?: string;
  descKey?: string;
}

const { title, desc, href, icon, isSoon = false, titleKey, descKey } = Astro.props;
---

<a href={isSoon ? "#" : href}
   class={`tilt-card card-base group relative flex flex-col h-full p-5 rounded-xl overflow-hidden
           ${isSoon ? 'opacity-60 cursor-not-allowed' : 'active:scale-[0.98]'}`}>
  
  {isSoon && (
    <div class="absolute top-3 right-3 badge-muted z-10">
      Soon
    </div>
  )}

  <!-- Icon (Monochrome — all same color, changes to accent on hover) -->
  <div class="icon-mono w-10 h-10 mb-3.5">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icon} />
  </div>
  
  <!-- Title -->
  <h3 class="text-sm font-semibold text-matte-800 dark:text-white mb-1.5 transition-colors duration-150 group-hover:text-accent-blue leading-snug" data-i18n={titleKey || undefined}>
    {title}
  </h3>
  
  <!-- Description -->
  <p class="text-xs text-matte-400 dark:text-matte-300 leading-relaxed flex-1 tracking-wide" data-i18n={descKey || undefined}>
    {desc}
  </p>

  <!-- Hover accent line at bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-accent-blue scale-x-0 group-hover:scale-x-100 transition-transform duration-150 origin-left"></div>

  <!-- Gloss overlay for 3D tilt shine effect -->
  <div class="tilt-card-gloss"></div>
</a>