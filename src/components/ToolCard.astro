---
interface Props {
  title: string;
  desc: string;
  href: string;
  icon: string;
  color: string;
  isSoon?: boolean;
  titleKey?: string;
  descKey?: string;
}

const { title, desc, href, icon, color, isSoon = false, titleKey, descKey } = Astro.props;

const themeMap: Record<string, { border: string; iconBg: string; iconText: string; titleHover: string }> = {
  blue:    { border: "hover:border-blue-500",    iconBg: "bg-blue-100 dark:bg-blue-900/40",    iconText: "text-blue-600 dark:text-blue-400",    titleHover: "group-hover:text-blue-600" },
  emerald: { border: "hover:border-emerald-500", iconBg: "bg-emerald-100 dark:bg-emerald-900/40", iconText: "text-emerald-600 dark:text-emerald-400", titleHover: "group-hover:text-emerald-600" },
  rose:    { border: "hover:border-rose-500",    iconBg: "bg-rose-100 dark:bg-rose-900/40",    iconText: "text-rose-600 dark:text-rose-400",    titleHover: "group-hover:text-rose-600" },
  sky:     { border: "hover:border-sky-500",     iconBg: "bg-sky-100 dark:bg-sky-900/40",     iconText: "text-sky-600 dark:text-sky-400",     titleHover: "group-hover:text-sky-600" },
  indigo:  { border: "hover:border-indigo-500",  iconBg: "bg-indigo-100 dark:bg-indigo-900/40",  iconText: "text-indigo-600 dark:text-indigo-400",  titleHover: "group-hover:text-indigo-600" },
  amber:   { border: "hover:border-amber-500",   iconBg: "bg-amber-100 dark:bg-amber-900/40",   iconText: "text-amber-600 dark:text-amber-400",   titleHover: "group-hover:text-amber-600" },
  violet:  { border: "hover:border-violet-500",  iconBg: "bg-violet-100 dark:bg-violet-900/40",  iconText: "text-violet-600 dark:text-violet-400",  titleHover: "group-hover:text-violet-600" },
  pink:    { border: "hover:border-pink-500",    iconBg: "bg-pink-100 dark:bg-pink-900/40",    iconText: "text-pink-600 dark:text-pink-400",    titleHover: "group-hover:text-pink-600" },
  teal:    { border: "hover:border-teal-500",    iconBg: "bg-teal-100 dark:bg-teal-900/40",    iconText: "text-teal-600 dark:text-teal-400",    titleHover: "group-hover:text-teal-600" },
  orange:  { border: "hover:border-orange-500",  iconBg: "bg-orange-100 dark:bg-orange-900/40",  iconText: "text-orange-600 dark:text-orange-400",  titleHover: "group-hover:text-orange-600" },
  cyan:    { border: "hover:border-cyan-500",    iconBg: "bg-cyan-100 dark:bg-cyan-900/40",    iconText: "text-cyan-600 dark:text-cyan-400",    titleHover: "group-hover:text-cyan-600" },
  lime:    { border: "hover:border-lime-500",    iconBg: "bg-lime-100 dark:bg-lime-900/40",    iconText: "text-lime-600 dark:text-lime-400",    titleHover: "group-hover:text-lime-600" },
  yellow:  { border: "hover:border-yellow-500",  iconBg: "bg-yellow-100 dark:bg-yellow-900/40",  iconText: "text-yellow-600 dark:text-yellow-400",  titleHover: "group-hover:text-yellow-600" },
};

const theme = themeMap[color] || themeMap.blue;

const containerClasses = isSoon
  ? "opacity-60 cursor-not-allowed hover:border-slate-200 dark:hover:border-slate-700"
  : `hover:shadow-xl hover:-translate-y-1 ${theme.border}`;

const iconClasses = isSoon
  ? "bg-slate-100 dark:bg-slate-700 text-slate-400"
  : `${theme.iconBg} ${theme.iconText} group-hover:scale-110 group-hover:rotate-3`;

const titleClasses = isSoon
  ? "text-slate-600 dark:text-slate-300"
  : `text-slate-800 dark:text-slate-100 ${theme.titleHover}`;
---

<a href={isSoon ? "#" : href} class={`group relative flex flex-col h-full p-6 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 transition-all duration-300 shadow-sm ${containerClasses}`}>
  
  {isSoon && (
    <div class="absolute top-4 right-4 bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-400 text-[10px] font-bold px-2 py-1 rounded uppercase tracking-wider border border-slate-200 dark:border-slate-600">
      Soon
    </div>
  )}

  <div class={`w-12 h-12 rounded-xl flex items-center justify-center mb-4 transition-transform duration-300 ${iconClasses}`}>
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icon} />
  </div>
  
  <h3 class={`text-lg md:text-xl font-bold mb-2 transition-colors ${titleClasses}`} data-i18n={titleKey || undefined}>
    {title}
  </h3>
  
  <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed flex-1" data-i18n={descKey || undefined}>
    {desc}
  </p>
</a>