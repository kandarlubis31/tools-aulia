          <button id="lang-toggle-mobile" class="p-2 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:scale-110 hover:rotate-12 transition-all duration-300 text-xs font-bold uppercase">
