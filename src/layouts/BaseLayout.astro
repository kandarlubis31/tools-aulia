---
import { ClientRouter } from 'astro:transitions';

interface Props {
  pageTitle: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
}

const { 
  pageTitle, 
  description = "Koleksi tools developer favorit saya. Gratis, cepat, dan tanpa iklan.",
  ogImage = "/og-image.png",
  canonicalUrl,
  noIndex = false
} = Astro.props;

const pathname = Astro.url.pathname;
const currentPath = pathname.endsWith('/') && pathname.length > 1 ? pathname.slice(0, -1) : pathname;

const isHome = currentPath === '/';
const isPdfRoot = currentPath === '/pdf';
const isPdfTool = currentPath.startsWith('/pdf/');

let showBackBtn = !isHome;
let backLink = '/';
let backI18nKey = 'back.dashboard';
let backLabel = 'Kembali ke Dashboard';

if (isPdfTool) {
  backLink = '/pdf';
  backI18nKey = 'back.pdf_tools';
  backLabel = 'Kembali ke PDF Tools';
} else if (isPdfRoot) {
  backLink = '/';
  backI18nKey = 'back.dashboard';
  backLabel = 'Kembali ke Dashboard';
}
---

<!doctype html>
<html lang="id" class="scroll-smooth transition-colors duration-500 ease-in-out">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5" />
  <title>{pageTitle} | ToolsAulia</title>
  <meta name="original-title" content={pageTitle} />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <link rel="canonical" href={canonicalUrl || Astro.url.href} />
  <meta property="og:title" content={`${pageTitle} | ToolsAulia`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.url.origin).href} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="id_ID" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${pageTitle} | ToolsAulia`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.url.origin).href} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}
  
  <!-- Performance: Preconnect to critical origins -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
  <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com">
  
  <!-- Performance: Preload critical fonts -->
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" as="style" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <ClientRouter />

  <script is:inline>
    const setDarkMode = () => {
      const theme = localStorage.getItem('theme');
      const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      if (theme === 'dark' || (!theme && systemDark)) {
        document.documentElement.classList.add("dark");
        var metaTC = document.querySelector('meta[name="theme-color"]'); if (metaTC) metaTC.setAttribute('content', '#0f172a');
      } else {
        document.documentElement.classList.remove("dark");
        var metaTC = document.querySelector('meta[name="theme-color"]'); if (metaTC) metaTC.setAttribute('content', '#ffffff');
      }
    };
    setDarkMode();
    document.addEventListener('astro:after-swap', setDarkMode);
  </script>

  <!-- PWA & Theme -->
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#ffffff" />
  <link rel="apple-touch-icon" href="/pwa-192x192.png" />
  
  <!-- Performance: Defer non-critical PWA registration -->
  <script type="module" id="pwa-register-module">
    // Defer PWA registration to not block main thread
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        import('virtual:pwa-register').then(({ registerSW }) => {
          registerSW({
            immediate: true,
            onNeedRefresh() {
              const updateNotification = document.createElement('div');
              updateNotification.id = 'update-notification';
              updateNotification.className = 'fixed bottom-4 left-4 right-4 md:left-auto md:right-4 md:w-80 bg-slate-800 dark:bg-slate-700 text-white p-4 rounded-lg shadow-lg z-[100] flex items-center justify-between animate-slide-up';
              updateNotification.innerHTML = `
                <div class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                  </svg>
                  <div>
                    <p class="font-medium" data-i18n="update.title">Update Tersedia!</p>
                    <p class="text-xs text-slate-300" data-i18n="update.desc">Versi baru siap diinstall.</p>
                  </div>
                </div>
                <div class="flex gap-2">
                  <button id="update-dismiss" class="px-3 py-1 text-xs bg-slate-600 hover:bg-slate-500 rounded transition-colors" data-i18n="update.later">Nanti</button>
                  <button id="update-accept" class="px-3 py-1 text-xs bg-blue-600 hover:bg-blue-500 rounded transition-colors" data-i18n="update.update">Update</button>
                </div>
              `;
              document.body.appendChild(updateNotification);
              
              document.getElementById('update-accept')?.addEventListener('click', () => window.location.reload());
              document.getElementById('update-dismiss')?.addEventListener('click', () => updateNotification.remove());
            },
            onOfflineReady() {
              // Silent - ready for offline use
            },
          });
        }).catch(() => {});
      });
    }
  </script>
</head>  <body class="antialiased bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-200 transition-colors duration-500 ease-in-out min-h-screen flex flex-col font-sans selection:bg-indigo-500 selection:text-white">
  
  <div id="toast-container" class="fixed top-24 right-5 z-[100] flex flex-col gap-3 pointer-events-none"></div>
  <div id="offline-indicator" class="hidden fixed bottom-0 left-0 w-full bg-rose-600 text-white text-center py-2 text-sm font-bold z-[100] shadow-lg animate-slide-up">
    <span data-i18n="offline.msg">⚠️ Koneksi terputus. Anda sedang offline.</span>
  </div>
  <div id="navigation-loading" class="fixed top-0 left-0 w-full h-1 bg-slate-200 dark:bg-slate-800 z-[100] overflow-hidden hidden">
    <div class="h-full bg-gradient-to-r from-blue-500 to-indigo-500 w-0 transform origin-left transition-all duration-300"></div>
  </div>

  <div id="pwa-custom-modal" class="hidden fixed inset-0 z-[200] flex items-center justify-center p-4 bg-black/80 opacity-0 transition-opacity duration-300">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden transform scale-95 transition-transform duration-300">
        <div class="h-24 bg-gradient-to-tr from-sky-500 to-violet-600 flex items-center justify-center">
             <div class="w-16 h-16 bg-white rounded-2xl shadow-lg flex items-center justify-center">
                 <img src="/favicon.svg" alt="App Icon" class="w-10 h-10" />
             </div>
        </div>
        
        <div class="p-6 text-center">
            <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2" data-i18n="pwa.install_title">Install ToolsAulia</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400 mb-6" data-i18n="pwa.install_desc">
                Akses semua tools secara <strong>offline</strong>, lebih cepat, dan masuk langsung dari layar utama HP kamu.
            </p>
            
            <div class="space-y-3">
                <button id="pwa-confirm-install" class="w-full py-3 px-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl shadow-lg shadow-blue-500/30 transition-all transform hover:scale-[1.02]" data-i18n="pwa.install_now">
                    Install Sekarang
                </button>
                <button id="pwa-cancel-install" class="w-full py-3 px-4 bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 text-slate-700 dark:text-slate-300 font-medium rounded-xl transition-colors" data-i18n="pwa.later">
                    Nanti Saja
                </button>
            </div>
        </div>
    </div>
  </div>

  <header class="sticky top-0 z-50 w-full border-b border-slate-200 dark:border-slate-800 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md transition-all duration-300 hover:shadow-md hover:shadow-sky-500/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
      <a href="/" class="group flex items-center gap-2.5 font-bold text-xl tracking-tight z-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 rounded-md p-1 transition-all duration-300 hover:scale-105">
        <div class="relative w-8 h-8 rounded-lg bg-gradient-to-tr from-sky-500 to-violet-500 flex items-center justify-center text-white shadow-lg shadow-sky-500/20 group-hover:rotate-12 group-hover:scale-110 transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
        </div>
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-slate-800 to-slate-600 dark:from-white dark:to-slate-300">
          Tools<span class="text-sky-500">Aulia</span>
        </span>
      </a>
      
      <nav class="hidden md:flex items-center gap-1">
        <a href="/" class={`px-4 py-2 rounded-full text-sm font-medium transition-all ${isHome ? 'bg-slate-100 dark:bg-slate-800 text-sky-600 dark:text-sky-400' : 'text-slate-600 dark:text-slate-400 hover:text-sky-600 dark:hover:text-sky-400'}`} data-i18n="nav.home">Home</a>
        <a href="/pdf" class={`px-4 py-2 rounded-full text-sm font-medium transition-all ${isPdfRoot || isPdfTool ? 'bg-slate-100 dark:bg-slate-800 text-sky-600 dark:text-sky-400' : 'text-slate-600 dark:text-slate-400 hover:text-sky-600 dark:hover:text-sky-400'}`} data-i18n="nav.pdf_tools">PDF Tools</a>
        
        <button id="search-btn" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 transition-all duration-300 hover:scale-110 hover:text-sky-500" aria-label="Search tools" data-i18n-attr="aria-label" data-i18n="nav.search_aria">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </button>
        
        <div class="w-px h-6 bg-slate-200 dark:bg-slate-700 mx-2"></div>
        
        <button id="theme-toggle-desktop" class="relative p-2 rounded-full hover:bg-gradient-to-br hover:from-amber-100 hover:to-orange-100 dark:hover:bg-gradient-to-br dark:hover:from-slate-700 dark:hover:to-slate-600 text-slate-500 dark:text-slate-400 transition-all duration-300 hover:scale-110 group" aria-label="Toggle theme" data-i18n-attr="aria-label" data-i18n="nav.theme_aria">
