---
import { ClientRouter } from 'astro:transitions';
import { tools } from '../data/tools';
import '../styles/global.css';

// Derive search-friendly tool list from shared data
const searchTools = tools.map(t => ({
  name: t.title,
  url: t.href,
  category: t.category,
  descKey: t.descKey,
  descFallback: t.desc,
}));

interface Props {
  pageTitle: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
}

const { 
  pageTitle, 
  description = "Koleksi tools developer favorit saya. Gratis, cepat, dan tanpa iklan.",
  ogImage = "/og-image.png",
  canonicalUrl,
  noIndex = false
} = Astro.props;

const pathname = Astro.url.pathname;
const currentPath = pathname.endsWith('/') && pathname.length > 1 ? pathname.slice(0, -1) : pathname;

const isHome = currentPath === '/';
const isPdfRoot = currentPath === '/pdf';
const isPdfTool = currentPath.startsWith('/pdf/');

let showBackBtn = !isHome;
let backLink = '/';
let backI18nKey = 'back.dashboard';
let backLabel = 'Kembali ke Dashboard';

if (isPdfTool) {
  backLink = '/pdf';
  backI18nKey = 'back.pdf_tools';
  backLabel = 'Kembali ke PDF Tools';
} else if (isPdfRoot) {
  backLink = '/';
  backI18nKey = 'back.dashboard';
  backLabel = 'Kembali ke Dashboard';
}
---

<!doctype html>
<html lang="id" class="scroll-smooth">
<head>
