    const allPhrases = { ...dynamicPhrases, ...commonPhrases };

    const skipTags = ['SCRIPT','STYLE','NOSCRIPT','SVG','CODE','PRE','TEXTAREA','INPUT','SELECT'];

    function walkAndTranslate(node, lang) {
      if (!node) return;
      if (lang !== 'en') return;
      const walk = (n) => {
        if (n.nodeType === Node.TEXT_NODE) {
          const original = n.textContent || '';
          let modified = original;
          for (const [idText, enText] of Object.entries(allPhrases)) {
            if (modified === idText) { modified = enText; break; }
            if (idText.length <= 10) {
              const regex = new RegExp('(^|\\s)(' + idText.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')(?=\\s|$|[.,;:!?])', 'g');
              modified = modified.replace(regex, '$1' + enText);
            } else {
              modified = modified.split(idText).join(enText);
            }
          }
          if (modified !== original) n.textContent = modified;
        } else if (n.nodeType === Node.ELEMENT_NODE) {
          const el = n;
          if (skipTags.includes(el.tagName)) return;
          for (const attr of ['placeholder','aria-label','title']) {
            const val = el.getAttribute(attr);
            if (val && allPhrases[val]) {
              el.setAttribute(attr, allPhrases[val]);
            }
          }
          Array.from(el.childNodes).forEach(walk);
        }
      };
      walk(node);
    }

    function processI18n() {
      const lang = getLang();
      document.documentElement.lang = lang;

      // --- Translate Page Title ---
      const originalTitle = document.querySelector('meta[name="original-title"]')?.getAttribute('content') || '';
      if (originalTitle) {
        const translatedTitle = lang === 'en' ? (allPhrases[originalTitle] || originalTitle) : originalTitle;
        document.title = `${translatedTitle} | PakLubis Tools`;
      }

      const desktopLabel = document.getElementById('lang-label-desktop');
      const mobileLabel = document.getElementById('lang-label-mobile');
      if (desktopLabel) desktopLabel.textContent = lang.toUpperCase();
      if (mobileLabel) mobileLabel.textContent = lang.toUpperCase();

      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (!key) return;
        const attr = el.getAttribute('data-i18n-attr');
        const entry = translations[key];
        if (!entry) return;
        const text = entry[lang];
        if (attr) {
          if (attr === 'textContent') el.textContent = text;
          else el.setAttribute(attr, text);
        } else {
          el.textContent = text;
        }
      });

      walkAndTranslate(document.body, lang);
    }

    function translateNode(node) {
      walkAndTranslate(node, getLang());
    }

    window.i18n.translateNode = translateNode;

    document.addEventListener('astro:page-load', processI18n);
    processI18n();

    function toggleLang() {
      const newLang = getLang() === 'id' ? 'en' : 'id';
      setLang(newLang);
      window.location.reload();
    }

    document.addEventListener('astro:page-load', () => {
      document.getElementById('lang-toggle-desktop')?.addEventListener('click', toggleLang);
      document.getElementById('lang-toggle-mobile')?.addEventListener('click', toggleLang);
    });
  </script>
