  <!-- Pass search tools data to client scripts (avoids esbuild parse error) -->
  <script id="search-tools-json" type="application/json" set:html={JSON.stringify(searchTools)}></script>

  <!-- Performance: Load i18n phrases async to not block rendering -->
  <script src="/i18n-phrases.js" defer></script>
  
  <script is:inline>
    // Translation helper - handles case where phrases not yet loaded
    window._tToast = (msg) => {
      const lang = (typeof window !== 'undefined' && localStorage.getItem('lang')) || 'id';
      if (lang === 'id') return msg;
      // Check if phrases loaded, if not return original
      if (!window._i18nPhrases) return msg;
      // exact match
      if (window._i18nPhrases[msg]) return window._i18nPhrases[msg];
      // fallback: replace known phrases inside the message
      let result = msg;
      for (const [id, en] of Object.entries(window._i18nPhrases)) {
        if (result.includes(id)) result = result.split(id).join(en);
      }
      return result;
    };
    // window.showToast dipasang oleh module script dari composables
    // Lihat bagian <script> di bawah import useToast

    document.addEventListener('astro:page-load', () => {
      const pwaModal = document.getElementById('pwa-custom-modal');
      const pwaConfirmBtn = document.getElementById('pwa-confirm-install');
      const pwaCancelBtn = document.getElementById('pwa-cancel-install');

      window.installPWA = () => {
        if (!window.deferredPrompt) {
            window.showToast('Aplikasi mungkin sudah terinstall', 'success');
            return;
        }
        if (pwaModal) pwaModal.classList.remove('hidden');
        setTimeout(() => {
            if (pwaModal) pwaModal.classList.remove('opacity-0');
            var pwaDiv = pwaModal && pwaModal.querySelector('div'); if (pwaDiv) pwaDiv.classList.remove('scale-95');
            var pwaDiv = pwaModal && pwaModal.querySelector('div'); if (pwaDiv) pwaDiv.classList.add('scale-100');
        }, 10);
      };

      if (pwaConfirmBtn) pwaConfirmBtn.addEventListener('click', async () => {
        if (window.deferredPrompt) {
            window.deferredPrompt.prompt();
            const { outcome } = await window.deferredPrompt.userChoice;
            // Silent - user choice recorded
            window.deferredPrompt = null;
        }
        closePwaModal();
      });

      const closePwaModal = () => {
        if (pwaModal) pwaModal.classList.add('opacity-0');
        var pwaDiv2 = pwaModal && pwaModal.querySelector('div'); if (pwaDiv2) pwaDiv2.classList.add('scale-95');
        var pwaDiv2 = pwaModal && pwaModal.querySelector('div'); if (pwaDiv2) pwaDiv2.classList.remove('scale-100');
        setTimeout(function() { if (pwaModal) pwaModal.classList.add('hidden'); }, 300);
      };

      if (pwaCancelBtn) pwaCancelBtn.addEventListener('click', closePwaModal);
      if (pwaModal) pwaModal.addEventListener('click', (e) => {
        if(e.target === pwaModal) closePwaModal();
      });

      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        window.deferredPrompt = e;
        var installBtn = document.getElementById('install-pwa-btn'); if (installBtn) installBtn.classList.remove('hidden');
        var installMobile = document.getElementById('install-pwa-mobile'); if (installMobile) installMobile.classList.remove('hidden');
      });

      const backBtn = document.getElementById('back-btn');
      const backBtnText = document.getElementById('back-btn-text');
      const urlParams = new URLSearchParams(window.location.search);
      const fromCat = urlParams.get('from_cat');
      if (backBtn && fromCat && fromCat !== 'popular' && fromCat !== 'all') {
         backBtn.href = `/?cat=${fromCat}`;
         const catNames = {'dev': 'Developer', 'image': 'Image', 'calc': 'Kalkulator', 'file': 'File'};           if (backBtnText) {
           const i18n = window['i18n'];
           if (i18n && i18n.t) {
             backBtnText.textContent = i18n.t('back.category_' + fromCat, `Kembali ke ${catNames[fromCat] || 'Kategori'}`);
           } else {
             backBtnText.innerText = `Kembali ke ${catNames[fromCat] || 'Kategori'}`;
           }
         }
      }

      const updateOnlineStatus = () => {
        const indicator = document.getElementById('offline-indicator');
        if (!navigator.onLine) {
            if (indicator) indicator.classList.remove('hidden');
            window.showToast('Koneksi terputus.', 'error');
        } else {
            if(!(indicator && indicator.classList.contains('hidden'))) {
                if (indicator) indicator.classList.add('hidden');
                window.showToast('Kembali Online!', 'success');
            }
        }
      };
      window.addEventListener('online', updateOnlineStatus);
      window.addEventListener('offline', updateOnlineStatus);
      if(!navigator.onLine) { var offlineInd = document.getElementById('offline-indicator'); if (offlineInd) offlineInd.classList.remove('hidden'); }

      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const mobileLinks = document.querySelectorAll('.mobile-link');
      if (menuBtn && mobileMenu && !menuBtn.dataset.hasListener) {
        menuBtn.dataset.hasListener = 'true';
        menuBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          mobileMenu.classList.toggle('hidden');
          mobileMenu.classList.toggle('flex');
        });
        if (!window._menuDocHandler) {
          window._menuDocHandler = function(e) {
            var mb = document.getElementById('mobile-menu');
            var btn = document.getElementById('mobile-menu-btn');
            if (mb && btn && !btn.contains(e.target) && !mb.contains(e.target)) {
              mb.classList.add('hidden');
              mb.classList.remove('flex');
            }
          };
          document.addEventListener('click', window._menuDocHandler);
        }
        mobileLinks.forEach(function(link) {
          if (!link.dataset.hasCloseListener) {
            link.dataset.hasCloseListener = 'true';
            link.addEventListener('click', function() {
              mobileMenu.classList.add('hidden');
              mobileMenu.classList.remove('flex');
            });
          }
        });
      }
      
      const handleThemeToggle = () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        var metaTC2 = document.querySelector('meta[name="theme-color"]'); if (metaTC2) metaTC2.setAttribute('content', isDark ? '#0f172a' : '#ffffff');
      };
      
      const desktopToggle = document.getElementById('theme-toggle-desktop');
      if(desktopToggle && !desktopToggle.dataset.hasListener) {
          desktopToggle.dataset.hasListener = 'true';
          desktopToggle.addEventListener('click', handleThemeToggle);
      }
      
      const mobileToggle = document.getElementById('theme-toggle-mobile');
      if(mobileToggle && !mobileToggle.dataset.hasListener) {
          mobileToggle.dataset.hasListener = 'true';
          mobileToggle.addEventListener('click', handleThemeToggle);
      }

      const searchBtn = document.getElementById('search-btn');
      const searchModal = document.getElementById('search-modal');
      const searchInput = document.getElementById('search-modal-input');
      const closeSearch = document.getElementById('close-search');
      
      const openSearch = () => {
        if (searchModal) searchModal.classList.remove('hidden');
        if (searchInput) searchInput.focus();
      };
      const closeSearchModal = () => {
        if (searchModal) searchModal.classList.add('hidden');
        if(searchInput) searchInput.value = '';
      };
      
      if(searchBtn && !searchBtn.dataset.hasListener) {
          searchBtn.dataset.hasListener = 'true';
          searchBtn.addEventListener('click', openSearch);
      }
      
      if (closeSearch) closeSearch.addEventListener('click', closeSearchModal);
      if (searchModal) searchModal.addEventListener('click', (e) => {
        if (e.target === searchModal) closeSearchModal();
      });
      document.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
          e.preventDefault();
          openSearch();
        }
        if (e.key === 'Escape') closeSearchModal();
      });

      // Cache clear handlers
      var cacheClearHandler = function() {
        var confirmMsg = (window.i18n && window.i18n.t) ? window.i18n.t('confirm.clear_cache', 'Bersihkan cache dan reload halaman?') : 'Bersihkan cache dan reload halaman?';
        if (!confirm(confirmMsg)) return;
        // Clear localStorage
        try { localStorage.clear(); } catch(e) {}
        // Unregister service workers + clear caches, then reload
        var promises = [];
        if (navigator.serviceWorker) {
          promises.push(navigator.serviceWorker.getRegistrations().then(function(regs) {
            return Promise.all(regs.map(function(r) { return r.unregister(); }));
          }).catch(function() {}));
        }
        if (window.caches) {
          promises.push(caches.keys().then(function(names) {
            return Promise.all(names.map(function(n) { return caches.delete(n); }));
          }).catch(function() {}));
        }
        Promise.all(promises).then(function() {
          window.location.reload();
        }).catch(function() {
          window.location.reload();
        });
      };
      var cacheClearBtn = document.getElementById('cache-clear-btn');
      if (cacheClearBtn && !cacheClearBtn.dataset.hasListener) {
        cacheClearBtn.dataset.hasListener = 'true';
        cacheClearBtn.addEventListener('click', cacheClearHandler);
      }
      var cacheClearMobile = document.getElementById('cache-clear-mobile');
      if (cacheClearMobile && !cacheClearMobile.dataset.hasListener) {
        cacheClearMobile.dataset.hasListener = 'true';
        cacheClearMobile.addEventListener('click', cacheClearHandler);
      }

      const toolsList = JSON.parse(document.getElementById('search-tools-json')?.textContent || '[]');
      
      const searchInputEl = document.getElementById('search-modal-input');
      const searchResultsEl = document.getElementById('search-results');
      
      if (searchInputEl && searchResultsEl && !searchInputEl.dataset.hasListener) {
        searchInputEl.dataset.hasListener = 'true';
        
        var searchDebounceTimer;
        searchInputEl.addEventListener('input', function(e) {
          clearTimeout(searchDebounceTimer);
          searchDebounceTimer = setTimeout(() => {
            const query = e.target.value.toLowerCase().trim();
            if (!query) {
              searchResultsEl.innerHTML = '<div class="text-center py-8 text-slate-500 dark:text-slate-400"><p data-i18n="search.empty">Ketik untuk mencari tools</p></div>';
              if (window.i18n && window.i18n.translateNode) window.i18n.translateNode(searchResultsEl);
              return;
            }

            const filtered = toolsList.filter(t => {
              const enDesc = (window.i18n && window.i18n.t) ? window.i18n.t(t.descKey, '') : '';
              return t.name.toLowerCase().includes(query) ||
                     t.descFallback.toLowerCase().includes(query) ||
                     t.category.toLowerCase().includes(query) ||
                     enDesc.toLowerCase().includes(query);
            });

            if (filtered.length === 0) {
              searchResultsEl.innerHTML = '<div class="text-center py-8 text-slate-500 dark:text-slate-400"><p data-i18n="search.no_results">Tidak ada hasil untuk</p><p class="font-bold mt-1">"' + query + '"</p></div>';
              if (window.i18n && window.i18n.translateNode) window.i18n.translateNode(searchResultsEl);
              return;
            }

            searchResultsEl.innerHTML = filtered.map(t => {
              const descText = (window.i18n && window.i18n.t) ? window.i18n.t(t.descKey, t.descFallback) : t.descFallback;
              return `
              <a href="${t.url}" class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-matte-100 dark:hover:bg-surface-hover transition-colors duration-150 group">
                <div class="w-9 h-9 rounded-lg bg-matte-100 dark:bg-surface-hover flex items-center justify-center text-matte-400 group-hover:text-accent-blue transition-colors duration-150 shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l7.81-9.24a1 1 0 0 1 1.54 0l7.81 9.24A1 1 0 0 1 20 14h-7v7h-2v-7z"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs font-semibold text-matte-800 dark:text-white group-hover:text-accent-blue transition-colors duration-150 truncate">${t.name}</p>
                  <p class="text-2xs text-matte-400 truncate">${descText}</p>
                </div>
                <span class="shrink-0 text-2xs font-medium uppercase tracking-wide-2 text-matte-400 bg-matte-100 dark:bg-surface-hover px-2 py-0.5 rounded">${t.category}</span>
              </a>
            `;
            }).join('');
          }, 150);
        });
      }

      const navLoad = document.getElementById('navigation-loading');
      var navBar = navLoad && navLoad.querySelector('div');
      
      // Back to Top Button
      const backToTopBtn = document.getElementById('back-to-top');
      if (backToTopBtn) {
        const toggleBackToTop = () => {
          if (window.scrollY > 400) {
            backToTopBtn.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
          } else {
            backToTopBtn.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
          }
        };
        window.addEventListener('scroll', toggleBackToTop, { passive: true });
        backToTopBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        document.addEventListener('astro:after-swap', toggleBackToTop);
        setTimeout(toggleBackToTop, 200);
      }

      // Scroll Progress Bar
      const updateScrollProgress = () => {
        const bar = document.getElementById('scroll-progress-bar');
        if (!bar) return;
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        if (docHeight > 0) {
          const progress = Math.min((scrollTop / docHeight) * 100, 100);
          bar.style.width = progress + '%';
        } else {
          bar.style.width = '0%';
        }
      };
      window.addEventListener('scroll', updateScrollProgress, { passive: true });
      window.addEventListener('resize', updateScrollProgress, { passive: true });
      document.addEventListener('astro:after-swap', () => setTimeout(updateScrollProgress, 100));
      setTimeout(updateScrollProgress, 200);

      document.addEventListener('astro:after-preparation', () => {
        if (navLoad) navLoad.classList.remove('hidden');
        if(navBar) navBar.style.width = '30%';
      });
      document.addEventListener('astro:after-swap', () => {
        if(navBar) {
          navBar.style.width = '100%';
          setTimeout(() => {
            navBar.style.width = '0%';
            if (navLoad) navLoad.classList.add('hidden');
          }, 300);
        }
      });
    });
  </script>

  <script>
    import { translations, getLang, setLang, t } from '../i18n/translations';
    import { showToast } from '../composables/useToast';
    window.i18n = { getLang, setLang, translations, t };
    window.showToast = showToast;

    // Auto-generate dictionary from translations.ts for all unique tool headings/descriptions
    const dynamicPhrases = Object.values(translations).reduce((acc: Record<string, string>, item: any) => {
      if (item && item.id && item.en && item.id !== item.en) {
        acc[item.id] = item.en;
      }
      return acc;
    }, {});

    const commonPhrases = {
      'atau klik untuk pilih file (bisa banyak sekaligus)': 'or click to select files (multiple allowed)',
      'Aplikasi siap digunakan offline.': 'App ready for offline use.',
      'Hapus Riwayat': 'Clear History',
      'Merge Mode': 'Merge Mode',
      'Upload PDF Besar': 'Upload Large PDF',
      'Klik atau tarik file ke sini': 'Click or drag file here',
      'Tingkat Kompresi': 'Compression Level',
      'Ekstrem (Burik)': 'Extreme (Blurred)',
      'Kualitas Asli': 'Original Quality',
      'Metode ini akan mengubah teks menjadi gambar (Rasterize) untuk mengurangi ukuran file secara drastis. Teks mungkin tidak bisa diseleksi lagi.': 'This method will convert text to image (Rasterize) to drastically reduce file size. Text may no longer be selectable.',
      'Mulai Kompresi': 'Start Compression',
      'Memproses halaman': 'Processing page',
      'Selesai! File sedang didownload.': 'Done! File is being downloaded.',
      'Gagal mengompresi PDF.': 'Failed to compress PDF.',
      'Mohon upload file PDF!': 'Please upload a PDF file!',
      'Upload Gambar': 'Upload Image',
      'Pengaturan Kompresi': 'Compression Settings',
      'Hemat': 'Save',
      'Download Hasil': 'Download Result',
      'Preview Hasil': 'Result Preview',
      'Gambar berhasil diunduh!': 'Image downloaded successfully!',
      'Ketik di sini...': 'Type here...',
      'Hasil...': 'Result...',
      'Ketik teks biasa...': 'Type plain text...',
      'Tempel kode Base64...': 'Paste Base64 code...',
      'Hasil disalin!': 'Result copied!',
      'Metrik (kg/cm)': 'Metric (kg/cm)',
      'Imperial (lbs/ft)': 'Imperial (lbs/ft)',
      'Tinggi Badan': 'Height',
      'Berat Badan': 'Weight',
      'Jenis Kelamin': 'Gender',
      'Pria': 'Male',
      'Wanita': 'Female',
      'Hitung BMI Sekarang': 'Calculate BMI Now',
