    </div>
  </header>

  <div id="search-modal" class="hidden fixed inset-0 bg-black/50 z-[100] flex items-start justify-center pt-20 px-4">
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-xl w-full max-w-2xl animate-fade-in-down">
      <div class="p-4 border-b border-slate-200 dark:border-slate-700">
        <div class="relative">
          <input type="text" id="search-modal-input" placeholder="Cari tools..." class="w-full pl-10 pr-4 py-3 rounded-lg bg-slate-100 dark:bg-slate-700 border border-slate-200 dark:border-slate-600 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:scale-[1.02] text-slate-800 dark:text-slate-200 transition-all duration-300" autocomplete="off" data-i18n-attr="placeholder" data-i18n="search.placeholder">
          <button id="close-search" class="absolute inset-y-0 right-0 pr-3 flex items-center" aria-label="Close search" data-i18n-attr="aria-label" data-i18n="search.close_aria">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
