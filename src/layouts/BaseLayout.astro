---
import { ClientRouter } from 'astro:transitions';

interface Props {
  pageTitle: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
}

const { 
  pageTitle, 
  description = "Koleksi tools developer favorit saya. Gratis, cepat, dan tanpa iklan.",
  ogImage = "/og-image.png",
  canonicalUrl,
  noIndex = false
} = Astro.props;

const pathname = Astro.url.pathname;
const currentPath = pathname.endsWith('/') && pathname.length > 1 ? pathname.slice(0, -1) : pathname;

const isHome = currentPath === '/';
const isPdfRoot = currentPath === '/pdf';
const isPdfTool = currentPath.startsWith('/pdf/');

let showBackBtn = !isHome;
let backLink = '/';
let backLabel = 'Kembali ke Dashboard';

if (isPdfTool) {
  backLink = '/pdf';
  backLabel = 'Kembali ke PDF Tools';
} else if (isPdfRoot) {
  backLink = '/';
  backLabel = 'Kembali ke Dashboard';
}
---

<!doctype html>
<html lang="id" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{pageTitle} | PakLubis Tools</title>
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <link rel="canonical" href={canonicalUrl || Astro.url.href} />
  <meta property="og:title" content={`${pageTitle} | PakLubis Tools`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.url.origin).href} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="id_ID" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${pageTitle} | PakLubis Tools`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.url.origin).href} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <ClientRouter />

  <script is:inline>
    const setDarkMode = () => {
      const theme = localStorage.getItem('theme');
      const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      if (theme === 'dark' || (!theme && systemDark)) {
        document.documentElement.classList.add("dark");
        document.querySelector('meta[name="theme-color"]')?.setAttribute('content', '#0f172a');
      } else {
        document.documentElement.classList.remove("dark");
        document.querySelector('meta[name="theme-color"]')?.setAttribute('content', '#ffffff');
      }
    };
    setDarkMode();
    document.addEventListener('astro:after-swap', setDarkMode);
  </script>

  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#ffffff" />
  <link rel="apple-touch-icon" href="/pwa-192x192.png" />
  
  <script>
    import { registerSW } from 'virtual:pwa-register';
    
    registerSW({
      immediate: true,
      onNeedRefresh() {
        const updateNotification = document.createElement('div');
        updateNotification.id = 'update-notification';
        updateNotification.className = 'fixed bottom-4 left-4 right-4 md:left-auto md:right-4 md:w-80 bg-slate-800 dark:bg-slate-700 text-white p-4 rounded-lg shadow-lg z-[100] flex items-center justify-between animate-slide-up';
        updateNotification.innerHTML = `
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
            <div>
              <p class="font-medium">Update Tersedia!</p>
              <p class="text-xs text-slate-300">Versi baru siap diinstall.</p>
            </div>
          </div>
          <div class="flex gap-2">
            <button id="update-dismiss" class="px-3 py-1 text-xs bg-slate-600 hover:bg-slate-500 rounded transition-colors">Nanti</button>
            <button id="update-accept" class="px-3 py-1 text-xs bg-blue-600 hover:bg-blue-500 rounded transition-colors">Update</button>
          </div>
        `;
        document.body.appendChild(updateNotification);
        
        document.getElementById('update-accept')?.addEventListener('click', () => window.location.reload());
        document.getElementById('update-dismiss')?.addEventListener('click', () => updateNotification.remove());
      },
      onOfflineReady() {
        console.log('App siap digunakan offline.');
      },
    });
  </script>
</head>

<body class="antialiased bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-200 transition-colors duration-300 min-h-screen flex flex-col font-sans selection:bg-indigo-500 selection:text-white">
  
  <div id="toast-container" class="fixed top-24 right-5 z-[100] flex flex-col gap-3 pointer-events-none"></div>
  <div id="offline-indicator" class="hidden fixed bottom-0 left-0 w-full bg-rose-600 text-white text-center py-2 text-sm font-bold z-[100] shadow-lg animate-slide-up">
    ⚠️ Koneksi terputus. Anda sedang offline.
  </div>
  <div id="navigation-loading" class="fixed top-0 left-0 w-full h-1 bg-slate-200 dark:bg-slate-800 z-[100] overflow-hidden hidden">
    <div class="h-full bg-gradient-to-r from-blue-500 to-indigo-500 w-0 transform origin-left transition-all duration-300"></div>
  </div>

  <div id="pwa-custom-modal" class="hidden fixed inset-0 z-[200] flex items-center justify-center p-4 bg-black/80 opacity-0 transition-opacity duration-300">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden transform scale-95 transition-transform duration-300">
        <div class="h-24 bg-gradient-to-tr from-sky-500 to-violet-600 flex items-center justify-center">
             <div class="w-16 h-16 bg-white rounded-2xl shadow-lg flex items-center justify-center">
                 <img src="/favicon.svg" alt="App Icon" class="w-10 h-10" />
             </div>
        </div>
        
        <div class="p-6 text-center">
            <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Install ToolsAulia</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400 mb-6">
                Akses semua tools secara <strong>offline</strong>, lebih cepat, dan masuk langsung dari layar utama HP kamu.
            </p>
            
            <div class="space-y-3">
                <button id="pwa-confirm-install" class="w-full py-3 px-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl shadow-lg shadow-blue-500/30 transition-all transform hover:scale-[1.02]">
                    Install Sekarang
                </button>
                <button id="pwa-cancel-install" class="w-full py-3 px-4 bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 text-slate-700 dark:text-slate-300 font-medium rounded-xl transition-colors">
                    Nanti Saja
                </button>
            </div>
        </div>
    </div>
  </div>

  <header class="sticky top-0 z-50 w-full border-b border-slate-200 dark:border-slate-800 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
      <a href="/" class="group flex items-center gap-2.5 font-bold text-xl tracking-tight z-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 rounded-md p-1">
        <div class="relative w-8 h-8 rounded-lg bg-gradient-to-tr from-sky-500 to-violet-500 flex items-center justify-center text-white shadow-lg shadow-sky-500/20 group-hover:rotate-12 transition-transform duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
        </div>
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-slate-800 to-slate-600 dark:from-white dark:to-slate-300">
          Tools<span class="text-sky-500">Aulia</span>
        </span>
      </a>
      
      <nav class="hidden md:flex items-center gap-1">
        <a href="/" class={`px-4 py-2 rounded-full text-sm font-medium transition-all ${isHome ? 'bg-slate-100 dark:bg-slate-800 text-sky-600 dark:text-sky-400' : 'text-slate-600 dark:text-slate-400 hover:text-sky-600 dark:hover:text-sky-400'}`}>Home</a>
        <a href="/pdf" class={`px-4 py-2 rounded-full text-sm font-medium transition-all ${isPdfRoot || isPdfTool ? 'bg-slate-100 dark:bg-slate-800 text-sky-600 dark:text-sky-400' : 'text-slate-600 dark:text-slate-400 hover:text-sky-600 dark:hover:text-sky-400'}`}>PDF Tools</a>
        
        <button id="search-btn" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 transition-colors" aria-label="Search tools">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </button>
        
        <div class="w-px h-6 bg-slate-200 dark:bg-slate-700 mx-2"></div>
        
        <button id="theme-toggle-desktop" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 transition-colors" aria-label="Toggle theme">
          <svg id="sun-icon" class="hidden dark:block w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
          <svg id="moon-icon" class="block dark:hidden w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </button>
        
        <button id="install-pwa-btn" class="hidden p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 text-sky-500 dark:text-sky-400 transition-colors" aria-label="Install app">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </button>
      </nav>

      <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 dark:text-slate-300" aria-label="Toggle menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden absolute top-16 left-0 w-full bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 shadow-xl md:hidden flex-col p-2 gap-1 transition-all z-40 origin-top animate-fade-in-down">
      <div class="p-3">
        <input type="text" id="mobile-search" placeholder="Cari tools..." class="w-full pl-10 pr-4 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-slate-800 dark:text-slate-200">
      </div>
      <a href="/" class="block p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 font-medium text-slate-700 dark:text-slate-200 mobile-link">Dashboard</a>
      <a href="/pdf" class="block p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 font-medium text-slate-700 dark:text-slate-200 mobile-link">PDF Tools</a>
      
      <div class="border-t border-slate-100 dark:border-slate-800 pt-2 mt-2 px-3 pb-2">
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm text-slate-500 font-medium">Tema</span>
          <button id="theme-toggle-mobile" class="p-2 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:scale-105 transition-transform">
            <span class="dark:hidden flex items-center gap-2 text-xs font-bold uppercase">Gelap 🌙</span>
            <span class="hidden dark:flex items-center gap-2 text-xs font-bold uppercase">Terang ☀️</span>
          </button>
        </div>
        
        <button id="install-pwa-mobile" class="hidden w-full p-2 rounded-lg bg-sky-50 dark:bg-sky-900/20 text-sky-600 dark:text-sky-400 font-bold text-sm transition-colors flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Install App
        </button>
      </div>
    </div>
  </header>

  <div id="search-modal" class="hidden fixed inset-0 bg-black/50 z-[100] flex items-start justify-center pt-20 px-4">
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-xl w-full max-w-2xl animate-fade-in-down">
      <div class="p-4 border-b border-slate-200 dark:border-slate-700">
        <div class="relative">
          <input type="text" id="search-modal-input" placeholder="Cari tools..." class="w-full pl-10 pr-4 py-3 rounded-lg bg-slate-100 dark:bg-slate-700 border border-slate-200 dark:border-slate-600 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-slate-800 dark:text-slate-200" autocomplete="off">
          <button id="close-search" class="absolute inset-y-0 right-0 pr-3 flex items-center" aria-label="Close search">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
      </div>
      <div id="search-results" class="max-h-96 overflow-y-auto p-4">
        <div class="text-center py-8 text-slate-500 dark:text-slate-400">
          <p>Ketik untuk mencari tools</p>
        </div>
      </div>
    </div>
  </div>

  <main id="main-content" class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 py-8 md:py-12">
    { showBackBtn && (
      <div class="mb-8 animate-fade-in-down">
        <a id="back-btn" href={backLink} class="inline-flex items-center gap-3 text-sm font-semibold text-slate-500 hover:text-sky-600 dark:text-slate-400 dark:hover:text-sky-400 transition-colors group px-4 py-2.5 rounded-xl hover:bg-white dark:hover:bg-slate-800 border border-transparent hover:border-slate-200 dark:hover:border-slate-700 hover:shadow-sm">
          <div class="bg-slate-200 dark:bg-slate-800 p-1 rounded-md group-hover:bg-sky-100 dark:group-hover:bg-sky-900/30 group-hover:text-sky-600 transition-colors">
             <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
          </div>
          <span id="back-btn-text">{backLabel}</span>
        </a>
      </div>
    )}
    <slot />
  </main>

  <footer class="border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 mt-auto pb-safe">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
        <div>
          <h3 class="font-bold text-slate-800 dark:text-slate-200 mb-4">Tentang ToolsAulia</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-4 max-w-sm">
            Koleksi tools developer sederhana yang berjalan sepenuhnya di browser (Client-Side). Aman, cepat, dan tanpa upload data ke server.
          </p>
          <div class="flex gap-4">
            <a href="https://github.com/kandarlubis31" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors">Github</a>
            <a href="https://paklubis.my.id" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors">Website</a>
          </div>
        </div>
        <div>
          <h3 class="font-bold text-slate-800 dark:text-slate-200 mb-4">Kategori Tools</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/pdf" class="text-slate-600 dark:text-slate-400 hover:text-sky-600 dark:hover:text-sky-400 transition-colors">PDF Tools</a></li>
            <li><a href="/image" class="text-slate-600 dark:text-slate-400 hover:text-sky-600 dark:hover:text-sky-400 transition-colors">Image Tools</a></li>
            <li><a href="/dev" class="text-slate-600 dark:text-slate-400 hover:text-sky-600 dark:hover:text-sky-400 transition-colors">Developer Tools</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-slate-200 dark:border-slate-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-slate-500">
        <p>&copy; {new Date().getFullYear()} <span class="font-bold text-slate-700 dark:text-slate-300">Aulia Iskandar Lubis</span>.</p>
        <div class="flex items-center gap-4"><span class="text-xs">Made in Indonesia</span></div>
      </div>
    </div>
  </footer>

  <script is:inline>
    window.showToast = (message, type = 'success') => {
      const container = document.getElementById('toast-container');
      if (!container) return;
      const toast = document.createElement('div');
      const colors = { success: 'bg-emerald-500 text-white', error: 'bg-rose-500 text-white' };
      toast.className = `flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg transform transition-all duration-300 translate-x-10 opacity-0 min-w-[300px] backdrop-blur-sm ${colors[type] || colors.success}`;
      toast.innerHTML = `<span class="font-bold text-sm">${message}</span>`;
      container.appendChild(toast);
      requestAnimationFrame(() => toast.classList.remove('translate-x-10', 'opacity-0'));
      setTimeout(() => { toast.classList.add('translate-x-10', 'opacity-0'); setTimeout(() => toast.remove(), 300); }, 3000);
    };

    document.addEventListener('astro:page-load', () => {
      const pwaModal = document.getElementById('pwa-custom-modal');
      const pwaConfirmBtn = document.getElementById('pwa-confirm-install');
      const pwaCancelBtn = document.getElementById('pwa-cancel-install');

      window.installPWA = () => {
        if (!window.deferredPrompt) {
            window.showToast('Aplikasi mungkin sudah terinstall', 'success');
            return;
        }
        pwaModal?.classList.remove('hidden');
        setTimeout(() => {
            pwaModal?.classList.remove('opacity-0');
            pwaModal?.querySelector('div')?.classList.remove('scale-95');
            pwaModal?.querySelector('div')?.classList.add('scale-100');
        }, 10);
      };

      pwaConfirmBtn?.addEventListener('click', async () => {
        if (window.deferredPrompt) {
            window.deferredPrompt.prompt();
            const { outcome } = await window.deferredPrompt.userChoice;
            console.log(`User response: ${outcome}`);
            window.deferredPrompt = null;
        }
        closePwaModal();
      });

      const closePwaModal = () => {
        pwaModal?.classList.add('opacity-0');
        pwaModal?.querySelector('div')?.classList.add('scale-95');
        pwaModal?.querySelector('div')?.classList.remove('scale-100');
        setTimeout(() => pwaModal?.classList.add('hidden'), 300);
      };

      pwaCancelBtn?.addEventListener('click', closePwaModal);
      pwaModal?.addEventListener('click', (e) => {
        if(e.target === pwaModal) closePwaModal();
      });

      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        window.deferredPrompt = e;
        document.getElementById('install-pwa-btn')?.classList.remove('hidden');
        document.getElementById('install-pwa-mobile')?.classList.remove('hidden');
      });

      const backBtn = document.getElementById('back-btn');
      const backBtnText = document.getElementById('back-btn-text');
      const urlParams = new URLSearchParams(window.location.search);
      const fromCat = urlParams.get('from_cat');
      if (backBtn && fromCat && fromCat !== 'popular' && fromCat !== 'all') {
         backBtn.href = `/?cat=${fromCat}`;
         const catNames = {'dev': 'Developer', 'image': 'Image', 'calc': 'Kalkulator', 'file': 'File'};
         if (backBtnText) backBtnText.innerText = `Kembali ke ${catNames[fromCat] || 'Kategori'}`;
      }

      const updateOnlineStatus = () => {
        const indicator = document.getElementById('offline-indicator');
        if (!navigator.onLine) {
            indicator?.classList.remove('hidden');
            window.showToast('Koneksi terputus.', 'error');
        } else {
            if(!indicator?.classList.contains('hidden')) {
                indicator?.classList.add('hidden');
                window.showToast('Kembali Online!', 'success');
            }
        }
      };
      window.addEventListener('online', updateOnlineStatus);
      window.addEventListener('offline', updateOnlineStatus);
      if(!navigator.onLine) document.getElementById('offline-indicator')?.classList.remove('hidden');

      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const mobileLinks = document.querySelectorAll('.mobile-link');
      if (menuBtn && mobileMenu) {
        const newMenuBtn = menuBtn.cloneNode(true);
        menuBtn.parentNode?.replaceChild(newMenuBtn, menuBtn);
        newMenuBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          mobileMenu.classList.toggle('hidden');
          mobileMenu.classList.toggle('flex');
        });
        document.addEventListener('click', (e) => {
           if (!newMenuBtn.contains(e.target) && !mobileMenu.contains(e.target)) {
             mobileMenu.classList.add('hidden');
             mobileMenu.classList.remove('flex');
           }
        });
        mobileLinks.forEach(link => link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          mobileMenu.classList.remove('flex');
        }));
      }
      
      const handleThemeToggle = () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        document.querySelector('meta[name="theme-color"]')?.setAttribute('content', isDark ? '#0f172a' : '#ffffff');
      };
      
      const desktopToggle = document.getElementById('theme-toggle-desktop');
      if(desktopToggle) {
          const newToggle = desktopToggle.cloneNode(true);
          desktopToggle.parentNode?.replaceChild(newToggle, desktopToggle);
          newToggle.addEventListener('click', handleThemeToggle);
      }
      
      const mobileToggle = document.getElementById('theme-toggle-mobile');
      if(mobileToggle) {
          const newToggle = mobileToggle.cloneNode(true);
          mobileToggle.parentNode?.replaceChild(newToggle, mobileToggle);
          newToggle.addEventListener('click', handleThemeToggle);
      }

      const searchBtn = document.getElementById('search-btn');
      const searchModal = document.getElementById('search-modal');
      const searchInput = document.getElementById('search-modal-input');
      const closeSearch = document.getElementById('close-search');
      
      const openSearch = () => {
        searchModal?.classList.remove('hidden');
        searchInput?.focus();
      };
      const closeSearchModal = () => {
        searchModal?.classList.add('hidden');
        if(searchInput) searchInput.value = '';
      };
      
      if(searchBtn) {
          const newBtn = searchBtn.cloneNode(true);
          searchBtn.parentNode?.replaceChild(newBtn, searchBtn);
          newBtn.addEventListener('click', openSearch);
      }
      
      closeSearch?.addEventListener('click', closeSearchModal);
      searchModal?.addEventListener('click', (e) => {
        if (e.target === searchModal) closeSearchModal();
      });
      document.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
          e.preventDefault();
          openSearch();
        }
        if (e.key === 'Escape') closeSearchModal();
      });

      const navLoad = document.getElementById('navigation-loading');
      const navBar = navLoad?.querySelector('div');
      
      document.addEventListener('astro:after-preparation', () => {
        navLoad?.classList.remove('hidden');
        if(navBar) navBar.style.width = '30%';
      });
      document.addEventListener('astro:after-swap', () => {
        if(navBar) {
          navBar.style.width = '100%';
          setTimeout(() => {
            navBar.style.width = '0%';
            navLoad?.classList.add('hidden');
          }, 300);
        }
      });
    });
  </script>
</body>
</html>

<style is:global>
  html { font-family: 'Inter', system-ui, sans-serif; }
  
  ::-webkit-scrollbar { width: 8px; height: 8px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 99px; }
  .dark ::-webkit-scrollbar-thumb { background: #334155; }
  
  .animate-fade-in-down { animation: fadeInDown 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .animate-fade-in-up { animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .animate-slide-up { animation: slideUp 0.5s ease-out; }
  
  @keyframes fadeInDown { 
    from { opacity: 0; transform: translateY(-10px); } 
    to { opacity: 1; transform: translateY(0); } 
  }
  @keyframes fadeInUp { 
    from { opacity: 0; transform: translateY(20px); scale: 0.95; } 
    to { opacity: 1; transform: translateY(0); scale: 1; } 
  }
  @keyframes slideUp { 
    from { transform: translateY(100%); } 
    to { transform: translateY(0); } 
  }
  
  .pb-safe { padding-bottom: env(safe-area-inset-bottom); }
</style>