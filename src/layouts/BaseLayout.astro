          <svg id="sun-icon" class="hidden dark:block w-5 h-5 relative z-10 transition-transform duration-300 group-hover:rotate-45 group-hover:scale-110" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
          <svg id="moon-icon" class="block dark:hidden w-5 h-5 relative z-10 transition-transform duration-300 group-hover:-rotate-12 group-hover:scale-110" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </button>
        
        <button id="lang-toggle-desktop" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 transition-all duration-300 hover:scale-110 hover:text-emerald-500 hover:rotate-12" aria-label="Toggle language">
          <span id="lang-label-desktop" class="uppercase">ID</span>
        </button>
        
        <button id="install-pwa-btn" class="hidden p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 text-sky-500 dark:text-sky-400 transition-all duration-300 hover:scale-110 hover:text-emerald-500" aria-label="Install app" data-i18n-attr="aria-label" data-i18n="nav.install_aria">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </button>
      </nav>

      <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 dark:text-slate-300 transition-all duration-300 hover:scale-110 hover:text-sky-500" aria-label="Toggle menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden absolute top-16 left-0 w-full bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 shadow-xl md:hidden flex-col p-2 gap-1 transition-all z-40 origin-top animate-fade-in-down">
      <div class="p-3">
        <input type="text" id="mobile-search" placeholder="Cari tools..." class="w-full pl-10 pr-4 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:scale-105 text-slate-800 dark:text-slate-200 transition-all duration-300" data-i18n-attr="placeholder" data-i18n="search.mobile_placeholder">
      </div>        <a href="/" class="block p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 font-medium text-slate-700 dark:text-slate-200 mobile-link" data-i18n="nav.mobile_dashboard">Dashboard</a>        <a href="/pdf" class="block p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 font-medium text-slate-700 dark:text-slate-200 mobile-link" data-i18n="nav.mobile_pdf">PDF Tools</a>
      
      <div class="border-t border-slate-100 dark:border-slate-800 pt-2 mt-2 px-3 pb-2">
