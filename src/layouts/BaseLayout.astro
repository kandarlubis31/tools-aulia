---
import { ClientRouter } from 'astro:transitions';

interface Props {
  pageTitle: string;
  description?: string;
}

const { pageTitle, description = "Koleksi tools developer favorit saya. Gratis, cepat, dan tanpa iklan." } = Astro.props;

// Logic Path Default (Server Side Fallback)
const pathname = Astro.url.pathname;
const currentPath = pathname.endsWith('/') && pathname.length > 1 ? pathname.slice(0, -1) : pathname;

const isHome = currentPath === '/';
const isPdfRoot = currentPath === '/pdf';
const isPdfTool = currentPath.startsWith('/pdf/');

let showBackBtn = !isHome;
let backLink = '/';
let backLabel = 'Kembali ke Dashboard';

if (isPdfTool) {
  backLink = '/pdf';
  backLabel = 'Kembali ke PDF Tools';
} else if (isPdfRoot) {
  backLink = '/';
  backLabel = 'Kembali ke Dashboard';
}
---

<!doctype html>
<html lang="id" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle} | Aulia Tools</title>
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <ClientRouter />

  <script is:inline>
    const setDarkMode = () => {
      const theme = localStorage.getItem('theme');
      const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      if (theme === 'dark' || (!theme && systemDark)) {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    };
    setDarkMode();
    document.addEventListener('astro:after-swap', setDarkMode);
  </script>

  <script>
    import { registerSW } from 'virtual:pwa-register';
    registerSW({
      immediate: true,
      onNeedRefresh() {
        if(confirm('Update baru tersedia. Refresh sekarang?')) window.location.reload(); 
      },
      onOfflineReady() { console.log('App siap offline.'); },
    });
  </script>
  
  <meta name="theme-color" content="#0f172a" />
  <link rel="apple-touch-icon" href="/pwa-192x192.png" />
  <link rel="mask-icon" href="/favicon.svg" color="#0f172a" />
</head>

<body class="antialiased bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-200 transition-colors duration-300 min-h-screen flex flex-col font-sans selection:bg-indigo-500 selection:text-white">
  
  <div id="toast-container" class="fixed top-24 right-5 z-[100] flex flex-col gap-3 pointer-events-none"></div>

  <div id="offline-indicator" class="hidden fixed bottom-0 left-0 w-full bg-rose-600 text-white text-center py-2 text-sm font-bold z-[100] shadow-lg animate-slide-up">
      ⚠️ Koneksi terputus. Anda sedang offline.
  </div>

  <header class="sticky top-0 z-50 w-full border-b border-slate-200 dark:border-slate-800 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
      <a href="/" class="group flex items-center gap-2.5 font-bold text-xl tracking-tight z-50 focus:outline-none">
        <div class="relative w-8 h-8 rounded-lg bg-gradient-to-tr from-sky-500 to-violet-500 flex items-center justify-center text-white shadow-lg shadow-sky-500/20 group-hover:rotate-12 transition-transform duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
        </div>
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-slate-800 to-slate-600 dark:from-white dark:to-slate-300">
          Tools<span class="text-sky-500">Aulia</span>
        </span>
      </a>
      
      <nav class="hidden md:flex items-center gap-1">
        <a href="/" class={`px-4 py-2 rounded-full text-sm font-medium transition-all ${isHome ? 'bg-slate-100 dark:bg-slate-800 text-sky-600 dark:text-sky-400' : 'text-slate-600 dark:text-slate-400 hover:text-sky-600 dark:hover:text-sky-400 hover:bg-slate-50 dark:hover:bg-slate-800/50'}`}>Home</a>
        <a href="/pdf" class={`px-4 py-2 rounded-full text-sm font-medium transition-all ${isPdfRoot || isPdfTool ? 'bg-slate-100 dark:bg-slate-800 text-sky-600 dark:text-sky-400' : 'text-slate-600 dark:text-slate-400 hover:text-sky-600 dark:hover:text-sky-400 hover:bg-slate-50 dark:hover:bg-slate-800/50'}`}>PDF Tools</a>
        <div class="w-px h-6 bg-slate-200 dark:bg-slate-700 mx-2"></div>
        <button id="theme-toggle-desktop" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 transition-colors focus:outline-none">
          <svg id="sun-icon" class="hidden dark:block w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
          <svg id="moon-icon" class="block dark:hidden w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </button>
      </nav>

      <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 dark:text-slate-300 focus:outline-none z-50 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden absolute top-16 left-0 w-full bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 shadow-xl md:hidden flex-col p-2 gap-1 transition-all z-40 origin-top animate-fade-in-down">
      <a href="/" class="block p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 font-medium text-slate-700 dark:text-slate-200 mobile-link">Dashboard</a>
      <a href="/pdf" class="block p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 font-medium text-slate-700 dark:text-slate-200 mobile-link">PDF Tools</a>
      <a href="https://paklubis.my.id" target="_blank" class="block p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 font-medium text-slate-700 dark:text-slate-200 mobile-link">Portfolio</a>
      <div class="border-t border-slate-100 dark:border-slate-800 pt-2 mt-2 px-3 pb-2 flex items-center justify-between">
        <span class="text-sm text-slate-500 font-medium">Tema Tampilan</span>
        <button id="theme-toggle-mobile" class="p-2 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:scale-105 transition-transform">
          <span class="dark:hidden flex items-center gap-2 text-xs font-bold uppercase">Gelap 🌙</span>
          <span class="hidden dark:flex items-center gap-2 text-xs font-bold uppercase">Terang ☀️</span>
        </button>
      </div>
    </div>
  </header>

  <main class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 py-8 md:py-12">
    { showBackBtn && (
      <div class="mb-8 animate-fade-in-down">
        <a id="back-btn" href={backLink} class="inline-flex items-center gap-3 text-sm font-semibold text-slate-500 hover:text-sky-600 dark:text-slate-400 dark:hover:text-sky-400 transition-colors group px-4 py-2.5 rounded-xl hover:bg-white dark:hover:bg-slate-800 border border-transparent hover:border-slate-200 dark:hover:border-slate-700 hover:shadow-sm">
          <div class="bg-slate-200 dark:bg-slate-800 p-1 rounded-md group-hover:bg-sky-100 dark:group-hover:bg-sky-900/30 group-hover:text-sky-600 transition-colors">
             <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
          </div>
          <span id="back-btn-text">{backLabel}</span>
        </a>
      </div>
    )}
    <slot />
  </main>

  <footer class="border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-slate-500">
      <p>&copy; {new Date().getFullYear()} <span class="font-bold text-slate-700 dark:text-slate-300">Aulia Iskandar Lubis</span>. Built with Astro & Tailwind.</p>
      <div class="flex gap-4">
         <a href="https://github.com/kandarlubis31" target="_blank" class="hover:text-slate-800 dark:hover:text-white transition-colors">GitHub</a>
         <a href="https://paklubis.my.id" target="_blank" class="hover:text-slate-800 dark:hover:text-white transition-colors">Website</a>
      </div>
    </div>
  </footer>

  <script is:inline>
    // --- 1. TOAST SYSTEM ---
    window.showToast = (message, type = 'success') => {
      const container = document.getElementById('toast-container');
      if (!container) return;
      const toast = document.createElement('div');
      const colors = { success: 'bg-emerald-500 text-white', error: 'bg-rose-500 text-white', info: 'bg-sky-500 text-white' };
      const icons = {
        success: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>',
        error: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>',
        info: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>'
      };
      toast.className = `flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg transform transition-all duration-300 translate-x-10 opacity-0 pointer-events-auto min-w-[300px] backdrop-blur-sm ${colors[type] || colors.info}`;
      toast.innerHTML = `${icons[type] || icons.info} <span class="font-bold text-sm">${message}</span>`;
      container.appendChild(toast);
      requestAnimationFrame(() => toast.classList.remove('translate-x-10', 'opacity-0'));
      setTimeout(() => { toast.classList.add('translate-x-10', 'opacity-0'); setTimeout(() => toast.remove(), 300); }, 3000);
    };

    // --- 2. GLOBAL HANDLERS ---
    document.addEventListener('astro:page-load', () => {
      
      // --- LOGIC TOMBOL BACK DINAMIS (Client-Side Fix) ---
      const backBtn = document.getElementById('back-btn');
      const backBtnText = document.getElementById('back-btn-text');
      const urlParams = new URLSearchParams(window.location.search);
      const fromCat = urlParams.get('from_cat');

      if (backBtn && fromCat && fromCat !== 'popular' && fromCat !== 'all') {
         // Update URL agar balik ke kategori yg benar
         backBtn.href = `/?cat=${fromCat}`;
         
         // Update Teks Label
         const catNames = {
            'dev': 'Developer Tools',
            'image': 'Image Tools',
            'security': 'Security Tools',
            'calc': 'Kalkulator',
            'utils': 'Productivity',
            'file': 'File Tools'
         };
         if (backBtnText) {
            backBtnText.innerText = `Kembali ke ${catNames[fromCat] || 'Kategori'}`;
         }
      }

      // Offline Checker
      const updateOnlineStatus = () => {
        const indicator = document.getElementById('offline-indicator');
        if (!navigator.onLine) {
            indicator?.classList.remove('hidden');
            window.showToast('Koneksi terputus.', 'error');
        } else {
            if(!indicator?.classList.contains('hidden')) {
                indicator?.classList.add('hidden');
                window.showToast('Kembali Online!', 'success');
            }
        }
      };
      window.addEventListener('online', updateOnlineStatus);
      window.addEventListener('offline', updateOnlineStatus);
      if(!navigator.onLine) document.getElementById('offline-indicator')?.classList.remove('hidden');

      // Mobile Menu
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const mobileLinks = document.querySelectorAll('.mobile-link');

      if (mobileMenu) { mobileMenu.classList.add('hidden'); mobileMenu.classList.remove('flex'); }

      if (menuBtn && mobileMenu) {
        const newMenuBtn = menuBtn.cloneNode(true);
        if(menuBtn.parentNode) menuBtn.parentNode.replaceChild(newMenuBtn, menuBtn);

        newMenuBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          mobileMenu.classList.toggle('hidden');
          mobileMenu.classList.toggle('flex');
        });

        document.addEventListener('click', (e) => {
          if (!newMenuBtn.contains(e.target) && !mobileMenu.contains(e.target)) {
            mobileMenu.classList.add('hidden');
            mobileMenu.classList.remove('flex');
          }
        });

        mobileLinks.forEach(link => {
            link.addEventListener('click', () => { mobileMenu.classList.add('hidden'); mobileMenu.classList.remove('flex'); });
        });
      }

      // Theme Toggle
      const handleThemeToggle = () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      };
      
      const desktopToggle = document.getElementById('theme-toggle-desktop');
      const mobileToggle = document.getElementById('theme-toggle-mobile');

      if(desktopToggle) {
          const newToggle = desktopToggle.cloneNode(true);
          desktopToggle.parentNode.replaceChild(newToggle, desktopToggle);
          newToggle.addEventListener('click', handleThemeToggle);
      }
      if(mobileToggle) {
          const newToggle = mobileToggle.cloneNode(true);
          mobileToggle.parentNode.replaceChild(newToggle, mobileToggle);
          newToggle.addEventListener('click', handleThemeToggle);
      }
    });
  </script>
</body>
</html>

<style is:global>
  html { font-family: 'Inter', system-ui, sans-serif; }
  ::-webkit-scrollbar { width: 8px; height: 8px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 99px; }
  ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
  .dark ::-webkit-scrollbar-thumb { background: #334155; }
  .dark ::-webkit-scrollbar-thumb:hover { background: #475569; }
  .animate-fade-in-down { animation: fadeInDown 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  @keyframes fadeInDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
  .animate-slide-up { animation: slideUp 0.5s ease-out; }
  @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
</style>