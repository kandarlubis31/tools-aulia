---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Stopwatch">
  <div class="max-w-2xl mx-auto px-4 min-h-[60vh] flex flex-col items-center">
    
    <div class="text-center mb-8 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-matte-900 dark:text-white" data-i18n="header.stopwatch">
        Stopwatch
      </h1>
      <p class="text-matte-400 dark:text-matte-300">
        Pencatat waktu presisi dengan fitur putaran (Lap).
      </p>
    </div>

    <div class="relative w-72 h-72 md:w-80 md:h-80 card-base rounded-full shadow-2xl border-8 border-matte-100 dark:border-surface-border flex items-center justify-center mb-10 animate-fade-in">
        <div class="absolute inset-0 rounded-full border-4 border-cyan-500/20 m-2"></div>
        
        <div class="text-center z-10">
            <div id="display-time" class="text-5xl md:text-6xl font-mono font-bold text-matte-800 dark:text-white tracking-wider">
                00:00:00
            </div>
            <div id="display-ms" class="text-2xl md:text-3xl font-mono font-bold text-cyan-500 mt-2">
                .00
            </div>
        </div>
    </div>

    <div class="flex gap-4 mb-10 animate-fade-in">
        <button id="btn-reset" class="w-16 h-16 rounded-full bg-matte-100 dark:bg-surface-elevated text-matte-500 dark:text-matte-300 font-bold hover:bg-matte-200 dark:hover:bg-surface-hover transition shadow-lg flex items-center justify-center" title="Reset">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
        </button>

        <button id="btn-start-stop" class="w-24 h-24 -mt-4 rounded-full bg-cyan-500 text-white font-bold text-xl hover:bg-cyan-600 hover:scale-105 transition shadow-xl shadow-cyan-500/30 flex items-center justify-center" data-i18n="btn.start">
            Start
        </button>

        <button id="btn-lap" class="w-16 h-16 rounded-full bg-matte-100 dark:bg-surface-elevated text-matte-500 dark:text-matte-300 font-bold hover:bg-matte-200 dark:hover:bg-surface-hover transition shadow-lg flex items-center justify-center" title="Lap" disabled>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
        </button>
    </div>

    <div id="laps-container" class="w-full max-w-md card-base overflow-hidden hidden animate-fade-in">
        <div class="px-6 py-3 bg-matte-100 dark:bg-surface-hover border-b border-matte-200 dark:border-surface-border flex justify-between font-bold text-matte-400 text-sm uppercase">
            <span>Lap #</span>
            <span data-i18n="label.time">Waktu</span>
        </div>
        <div id="laps-list" class="max-h-48 overflow-y-auto p-0">
            </div>
    </div>

  </div>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
  let startTime = 0;
  let elapsedTime = 0;
  let timerInterval: any = null;
  let isRunning = false;
  let lapCounter = 1;

  const displayTime = document.getElementById('display-time');
  const displayMs = document.getElementById('display-ms');
  const btnStartStop = document.getElementById('btn-start-stop');
  const btnReset = document.getElementById('btn-reset');
  const btnLap = document.getElementById('btn-lap') as HTMLButtonElement;
  const lapsContainer = document.getElementById('laps-container');
  const lapsList = document.getElementById('laps-list');

  function formatTime(ms: number) {
    const date = new Date(ms);
    const m = date.getUTCMinutes().toString().padStart(2, '0');
    const s = date.getUTCSeconds().toString().padStart(2, '0');
    const cs = Math.floor(date.getUTCMilliseconds() / 10).toString().padStart(2, '0');
    
    // Jam logic manual karena getUTCHours cuma sampai 24
    const h = Math.floor(ms / 3600000).toString().padStart(2, '0');
    
    return {
        main: `${h}:${m}:${s}`,
        ms: `.${cs}`
    };
  }

  function updateDisplay() {
    const time = Date.now() - startTime + elapsedTime;
    const formatted = formatTime(time);
    if(displayTime) displayTime.innerText = formatted.main;
    if(displayMs) displayMs.innerText = formatted.ms;
  }

  function start() {
    startTime = Date.now();
    timerInterval = setInterval(updateDisplay, 10); // Update tiap 10ms
    isRunning = true;
    
    if(btnStartStop) {
        btnStartStop.innerText = window._tToast ? window._tToast("Stop") : "Stop";
        btnStartStop.classList.replace('bg-cyan-500', 'bg-red-500');
        btnStartStop.classList.replace('hover:bg-cyan-600', 'hover:bg-red-600');
        btnStartStop.classList.replace('shadow-cyan-500/30', 'shadow-red-500/30');
    }
    if(btnLap) {
        btnLap.disabled = false;
        btnLap.classList.remove('opacity-50', 'cursor-not-allowed');
    }
  }

  function stop() {
    clearInterval(timerInterval);
    elapsedTime += Date.now() - startTime;
    isRunning = false;

    if(btnStartStop) {
        btnStartStop.innerText = window._tToast ? window._tToast("Start") : "Start";
        btnStartStop.classList.replace('bg-red-500', 'bg-cyan-500');
        btnStartStop.classList.replace('hover:bg-red-600', 'hover:bg-cyan-600');
        btnStartStop.classList.replace('shadow-red-500/30', 'shadow-cyan-500/30');
    }
    if(btnLap) {
        btnLap.disabled = true;
        btnLap.classList.add('opacity-50', 'cursor-not-allowed');
    }
  }

  function reset() {
    stop();
    elapsedTime = 0;
    if(displayTime) displayTime.innerText = window._tToast ? window._tToast("00:00:00") : "00:00:00";
    if(displayMs) displayMs.innerText = window._tToast ? window._tToast(".00") : ".00";
    if(lapsList) lapsList.innerHTML = '';
    lapsContainer?.classList.add('hidden');
    lapCounter = 1;
  }

  function logLap() {
    const time = Date.now() - startTime + elapsedTime;
    const formatted = formatTime(time);
    const fullTime = `${formatted.main}${formatted.ms}`;
    
    const div = document.createElement('div');
    div.className = "px-6 py-3 border-b border-matte-100 dark:border-matte-700 flex justify-between text-matte-700 dark:text-matte-300 font-mono animate-fade-in";
    div.innerHTML = `<span>Lap ${lapCounter}</span> <span class="font-bold">${fullTime}</span>`;
    
    lapsList?.prepend(div); // Add to top
    lapsContainer?.classList.remove('hidden');
    lapCounter++;
  }

  btnStartStop?.addEventListener('click', () => {
    if (isRunning) stop();
    else start();
  });

  btnReset?.addEventListener('click', reset);
  btnLap?.addEventListener('click', logLap);

  // Cleanup interval on SPA navigation
  document.addEventListener('astro:page-leave', () => {
    clearInterval(timerInterval);
    isRunning = false;
  });
  });
</script>
