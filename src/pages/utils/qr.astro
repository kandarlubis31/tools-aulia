---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="QR Code Generator">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/qrious/4.0.2/qrious.min.js"></script>
  
  <div class="max-w-6xl mx-auto px-4 min-h-[60vh]">
    <div class="text-center mb-10 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-matte-900 dark:text-white">
        QR Code Generator
      </h1>
      <p class="text-matte-400 dark:text-matte-300">
        Ubah teks, link, atau data lainnya menjadi kode QR kustom dengan berbagai opsi.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 animate-fade-in pb-20">
      
      <div class="lg:col-span-2 space-y-6">
        <div class="card-base p-6">
          <div class="mb-4">
            <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.qr_type">Tipe QR Code</label>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
              <button class="qr-type-btn active" data-type="text" data-i18n="label.text_url">Teks/URL</button>
              <button class="qr-type-btn" data-type="wifi" data-i18n="label.wifi">WiFi</button>
              <button class="qr-type-btn" data-type="email" data-i18n="label.email">Email</button>
              <button class="qr-type-btn" data-type="sms" data-i18n="label.sms">SMS</button>
              <button class="qr-type-btn" data-type="phone" data-i18n="label.phone">Telepon</button>
              <button class="qr-type-btn" data-type="vcard" data-i18n="label.contact">Kontak</button>
              <button class="qr-type-btn" data-type="location" data-i18n="label.location">Lokasi</button>
              <button class="qr-type-btn" data-type="event" data-i18n="label.event">Acara</button>
            </div>
          </div>
          
          <div id="qr-input-fields">
            <div id="text-input" class="qr-input-container">
              <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.content">Isi Konten</label>
              <textarea id="qr-text" placeholder="https://example.com atau teks apa pun" rows="3" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all resize-none" data-i18n-attr="placeholder" data-i18n="ph.qr_content"></textarea>
            </div>
            
            <div id="wifi-input" class="qr-input-container hidden">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                <div>
                  <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.wifi_name">Nama Jaringan (SSID)</label>
                  <input type="text" id="wifi-ssid" placeholder="Nama WiFi" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.wifi_name" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.password">Kata Sandi</label>
                  <input type="text" id="wifi-password" placeholder="Kata sandi WiFi" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.wifi_password" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.encryption">Enkripsi</label>
                <label for="wifi-encryption" class="block text-xs font-semibold text-matte-400 uppercase mb-1">Enkripsi WiFi</label>
                <select id="wifi-encryption" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all">
                  <option value="WPA">WPA/WPA2</option>
                  <option value="WEP">WEP</option>
                  <option value="nopass">Tanpa Kata Sandi</option>
                </select>
              </div>
            </div>
            
            <div id="email-input" class="qr-input-container hidden">
              <div class="mb-4">
                <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.email_address">Alamat Email</label>
                <input type="email" id="email-address" placeholder="email@example.com" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.email" />
              </div>
              <div class="mb-4">
                <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.email_subject">Subjek</label>
                <input type="text" id="email-subject" placeholder="Subjek email" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.email_subject" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.email_message">Pesan</label>
                <textarea id="email-message" placeholder="Isi pesan email" rows="3" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all resize-none" data-i18n-attr="placeholder" data-i18n="ph.email_content"></textarea>
              </div>
            </div>
            
            <div id="sms-input" class="qr-input-container hidden">
              <div class="mb-4">
                <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.phone_number">Nomor Telepon</label>
                <input type="tel" id="sms-number" placeholder="+628123456789" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.sms_number" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.sms_message">Pesan</label>
                <textarea id="sms-message" placeholder="Isi pesan SMS" rows="3" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all resize-none" data-i18n-attr="placeholder" data-i18n="ph.sms_content"></textarea>
              </div>
            </div>
            
            <div id="phone-input" class="qr-input-container hidden">
              <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.phone_number">Nomor Telepon</label>
              <input type="tel" id="phone-number" placeholder="+628123456789" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.phone_number" />
            </div>
            
            <div id="vcard-input" class="qr-input-container hidden">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                <div>
                  <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.first_name">Nama Depan</label>
                  <input type="text" id="vcard-firstname" placeholder="John" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.first_name" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.last_name">Nama Belakang</label>
                  <input type="text" id="vcard-lastname" placeholder="Doe" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.last_name" />
                </div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                <div>
                  <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.organization">Organisasi</label>
                  <input type="text" id="vcard-org" placeholder="Perusahaan" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.company" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.title">Judul</label>
                  <input type="text" id="vcard-title" placeholder="Manajer" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.manager" />
                </div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                <div>
                  <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.phone">Telepon</label>
                  <input type="tel" id="vcard-phone" placeholder="+628123456789" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.phone_number" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.email">Email</label>
                  <input type="email" id="vcard-email" placeholder="email@example.com" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.email" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.address">Alamat</label>
                <input type="text" id="vcard-address" placeholder="Jl. Contoh No. 123, Jakarta" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.address_example" />
              </div>
            </div>
            
            <div id="location-input" class="qr-input-container hidden">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                <div>
                  <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.latitude">Lintang (Latitude)</label>
                  <input type="text" id="location-lat" placeholder="-6.2088" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.latitude" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.longitude">Bujur (Longitude)</label>
                  <input type="text" id="location-lng" placeholder="106.8456" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.longitude" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.query">Query (Opsional)</label>
                <input type="text" id="location-query" placeholder="Monas, Jakarta" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.query" />
              </div>
            </div>
            
            <div id="event-input" class="qr-input-container hidden">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                <div>
                  <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.event_title">Judul Acara</label>
                  <input type="text" id="event-title" placeholder="Meeting Tim" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.meeting" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.location">Lokasi</label>
                  <input type="text" id="event-location" placeholder="Ruang Meeting 1" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" data-i18n-attr="placeholder" data-i18n="ph.room" />
                </div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                <div>
                  <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.start_date">Tanggal Mulai</label>
                  <input type="datetime-local" id="event-start" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.end_date">Tanggal Selesai</label>
                  <input type="datetime-local" id="event-end" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.description">Deskripsi</label>
                <textarea id="event-description" placeholder="Deskripsi acara" rows="3" class="w-full p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all resize-none" data-i18n-attr="placeholder" data-i18n="ph.event_desc"></textarea>
              </div>
            </div>
          </div>
        </div>
        
        <div class="card-base p-6">
          <h3 class="text-sm font-semibold text-matte-700 dark:text-white mb-4" data-i18n="label.customization">Kustomisasi</h3>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.qr_color">Warna QR</label>
              <div class="flex items-center gap-2">
                <input type="color" id="qr-color" value="#000000"class="w-full h-10 rounded cursor-pointer border border-matte-200 dark:border-surface-border" /><input type="text" id="qr-color-hex" value="#000000" class="w-24 p-2 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border text-sm focus:border-accent-blue outline-none font-mono" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.bg_color">Warna Background</label>
              <div class="flex items-center gap-2">
                <input type="color" id="bg-color" value="#ffffff" class="w-full h-10 rounded cursor-pointer border border-matte-200 dark:border-surface-border" />
                <input type="text" id="bg-color-hex" value="#ffffff" class="w-24 p-2 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border text-sm focus:border-accent-blue outline-none font-mono" />
              </div>
            </div>
          </div>
          
          <div class="mt-6">
            <label class="flex justify-between text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.qr_size">
              <span>Ukuran</span>
              <span id="size-val">250px</span>
            </label>
            <input type="range" id="qr-size" min="100" max="500" value="250" class="w-full h-2 bg-matte-200 dark:bg-surface-border rounded-lg appearance-none cursor-pointer accent-matte-500" />
          </div>
          
          <div class="mt-6">
            <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.error_correction">Tingkat Koreksi Error</label>
            <div class="grid grid-cols-4 gap-2">
              <button class="error-level-btn" data-level="L" data-i18n="label.low">Rendah (7%)</button>
              <button class="error-level-btn active" data-level="M" data-i18n="label.medium">Sedang (15%)</button>
              <button class="error-level-btn" data-level="Q" data-i18n="label.high">Tinggi (25%)</button>
              <button class="error-level-btn" data-level="H" data-i18n="label.highest">Tertinggi (30%)</button>
            </div>
          </div>
        </div>
      </div>
      
      <div class="space-y-6">
        <div class="card-base p-6">
          <h3 class="text-sm font-semibold text-matte-700 dark:text-white mb-4" data-i18n="label.preview">Preview</h3>
          <div class="flex flex-col items-center justify-center bg-matte-100 dark:bg-surface-hover p-6 rounded-xl">
            <div class="bg-white p-4 rounded-xl shadow-lg transition-transform hover:scale-105 duration-300">
              <canvas id="qr-code"></canvas>
            </div>
            <p class="mt-4 text-sm text-matte-400 font-medium" data-i18n="text.preview_live">Preview Live</p>
          </div>
        </div>
        
        <div class="card-base p-6">
          <h3 class="text-sm font-semibold text-matte-700 dark:text-white mb-4" data-i18n="label.actions">Aksi</h3>
          
          <div class="space-y-3">
            <div class="grid grid-cols-2 gap-3">
              <button id="download-png-btn" class="action-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                <span data-i18n="btn.png">PNG</span>
              </button>
              <button id="download-jpg-btn" class="action-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                <span data-i18n="btn.jpg">JPG</span>
              </button>
            </div>
            
            <button id="copy-btn" class="action-btn w-full">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
              <span data-i18n="btn.copy_clipboard">Salin ke Clipboard</span>
            </button>
            
            <button id="share-btn" class="action-btn w-full">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
              <span data-i18n="btn.share">Bagikan</span>
            </button>
            
            <button id="reset-btn" class="action-btn w-full bg-matte-100 dark:bg-surface-elevated text-matte-500 dark:text-matte-300 hover:bg-matte-200 dark:hover:bg-surface-hover">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
              <span data-i18n="btn.reset">Reset</span>
            </button>
          </div>
        </div>
        
        <div class="card-base p-6">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-sm font-semibold text-matte-700 dark:text-white" data-i18n="label.history">Riwayat</h3>
            <button id="clear-history-btn" class="text-xs text-matte-400 hover:text-red-500 transition-colors font-medium" data-i18n="btn.clear_all">Hapus Semua</button>
          </div>
          <div id="history-container" class="space-y-2 max-h-60 overflow-y-auto pr-2 custom-scrollbar">
            <p class="text-sm text-matte-400 text-center py-4" data-i18n="text.no_history">Belum ada riwayat</p>
          </div>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

<style>
  .qr-type-btn, .error-level-btn, .action-btn {
    @apply px-4 py-2 rounded-lg font-medium text-sm transition-all;
  }
  
  .qr-type-btn {
    @apply bg-matte-100 dark:bg-surface-elevated text-matte-500 dark:text-matte-300 hover:bg-matte-200 dark:hover:bg-surface-hover border border-transparent;
  }
  
  .qr-type-btn.active {
    @apply bg-matte-900 dark:bg-white text-white dark:text-matte-900 shadow-md;
  }
  
  .error-level-btn {
    @apply bg-matte-100 dark:bg-surface-elevated text-matte-500 dark:text-matte-300 hover:bg-matte-200 dark:hover:bg-surface-hover border border-transparent;
  }
  
  .error-level-btn.active {
    @apply bg-matte-900 dark:bg-white text-white dark:text-matte-900 shadow-md;
  }
  
  .action-btn {
    @apply bg-matte-900 dark:bg-white text-white dark:text-matte-900 font-semibold py-2.5 px-4 rounded-lg hover:opacity-90 transition-all active:scale-95 flex items-center justify-center gap-2;
  }
  
  .history-item {
    @apply flex items-center justify-between p-3 rounded-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border hover:bg-matte-200 dark:hover:bg-surface-elevated transition-colors cursor-pointer;
  }
</style>

<script>
  import { debounce } from '../../composables/useDebounce';
  import { useLocalHistory } from '../../composables/useLocalHistory';
  import { copyImageToClipboard } from '../../composables/useClipboard';

  // Elements
  const canvas = document.getElementById('qr-code');
  const qrTypeButtons = document.querySelectorAll('.qr-type-btn');
  const errorLevelButtons = document.querySelectorAll('.error-level-btn');
  const qrInputContainers = document.querySelectorAll('.qr-input-container');
  const qrColor = document.getElementById('qr-color');
  const qrColorHex = document.getElementById('qr-color-hex');
  const bgColor = document.getElementById('bg-color');
  const bgColorHex = document.getElementById('bg-color-hex');
  const qrSize = document.getElementById('qr-size');
  const sizeVal = document.getElementById('size-val');
  const downloadPngBtn = document.getElementById('download-png-btn');
  const downloadJpgBtn = document.getElementById('download-jpg-btn');
  const copyBtn = document.getElementById('copy-btn');
  const shareBtn = document.getElementById('share-btn');
  const resetBtn = document.getElementById('reset-btn');
  const clearHistoryBtn = document.getElementById('clear-history-btn');
  const historyContainer = document.getElementById('history-container');
  
  // QR Code instance
  let qr = new QRious({
    element: canvas,
    value: 'https://paklubis.my.id',
    size: 250,
    foreground: '#000000',
    background: '#ffffff',
    level: 'M'
  });
  
  // Current QR type
  let currentQRType = 'text';
  
  // History (using composable)
  const qrHistoryManager = useLocalHistory('qrHistory', 10);
  let qrHistory = qrHistoryManager.getAll();
  
  // Initialize
  document.addEventListener('astro:page-load', () => {
    renderHistory();
    updateQR();
  });
  
  // QR Type Selection
  qrTypeButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Update active state
      qrTypeButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      // Show/hide input containers
      const type = btn.dataset.type;
      currentQRType = type;
      
      qrInputContainers.forEach(container => {
        container.classList.add('hidden');
      });
      
      document.getElementById(`${type}-input`).classList.remove('hidden');
      
      // Update QR
      updateQR();
    });
  });
  
  // Error Level Selection
  errorLevelButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Update active state
      errorLevelButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      // Update QR
      updateQR();
    });
  });
  
  // Color Sync
  qrColor.addEventListener('input', (e) => {
    qrColorHex.value = e.target.value;
    updateQR();
  });
  
  qrColorHex.addEventListener('input', (e) => {
    if (/^#[0-9A-F]{6}$/i.test(e.target.value)) {
      qrColor.value = e.target.value;
      updateQR();
    }
  });
  
  bgColor.addEventListener('input', (e) => {
    bgColorHex.value = e.target.value;
    updateQR();
  });
  
  bgColorHex.addEventListener('input', (e) => {
    if (/^#[0-9A-F]{6}$/i.test(e.target.value)) {
      bgColor.value = e.target.value;
      updateQR();
    }
  });
  
  // Size Slider
  qrSize.addEventListener('input', (e) => {
    sizeVal.innerText = `${e.target.value}px`;
    updateQR();
  });
  
  // Add input event listeners to all input fields (with debounce from composables)
  const debouncedUpdate = debounce(updateQR, 300);
  document.querySelectorAll('input, textarea, select').forEach(el => {
    el.addEventListener('input', debouncedUpdate);
  });
  
  // Update QR Code
  function updateQR() {
    let qrValue = '';
    
    // Generate QR value based on type
    switch (currentQRType) {
      case 'text':
        qrValue = document.getElementById('qr-text').value || 'https://paklubis.my.id';
        break;
        
      case 'wifi':
        const ssid = document.getElementById('wifi-ssid').value || 'NetworkName';
        const password = document.getElementById('wifi-password').value || '';
        const encryption = document.getElementById('wifi-encryption').value || 'WPA';
        qrValue = `WIFI:T:${encryption};S:${ssid};P:${password};;`;
        break;
        
      case 'email':
        const email = document.getElementById('email-address').value || 'email@example.com';
        const subject = document.getElementById('email-subject').value || '';
        const message = document.getElementById('email-message').value || '';
        qrValue = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(message)}`;
        break;
        
      case 'sms':
        const number = document.getElementById('sms-number').value || '';
        const smsMessage = document.getElementById('sms-message').value || '';
        qrValue = `sms:${number}?body=${encodeURIComponent(smsMessage)}`;
        break;
        
      case 'phone':
        const phoneNumber = document.getElementById('phone-number').value || '';
        qrValue = `tel:${phoneNumber}`;
        break;
        
      case 'vcard':
        const firstName = document.getElementById('vcard-firstname').value || '';
        const lastName = document.getElementById('vcard-lastname').value || '';
        const org = document.getElementById('vcard-org').value || '';
        const title = document.getElementById('vcard-title').value || '';
        const vcardPhone = document.getElementById('vcard-phone').value || '';
        const vcardEmail = document.getElementById('vcard-email').value || '';
        const address = document.getElementById('vcard-address').value || '';
        
        qrValue = `BEGIN:VCARD
VERSION:3.0
FN:${firstName} ${lastName}
ORG:${org}
TITLE:${title}
TEL:${vcardPhone}
EMAIL:${vcardEmail}
ADR:;;${address};;;;
END:VCARD`;
        break;
        
      case 'location':
        const lat = document.getElementById('location-lat').value || '';
        const lng = document.getElementById('location-lng').value || '';
        const query = document.getElementById('location-query').value || '';
        
        if (lat && lng) {
          qrValue = `geo:${lat},${lng}${query ? '?q=' + encodeURIComponent(query) : ''}`;
        } else if (query) {
          qrValue = `http://maps.google.com/maps?q=${encodeURIComponent(query)}`;
        }
        break;
        
      case 'event':
        const eventTitle = document.getElementById('event-title').value || '';
        const eventLocation = document.getElementById('event-location').value || '';
        const eventStart = document.getElementById('event-start').value || '';
        const eventEnd = document.getElementById('event-end').value || '';
        const eventDescription = document.getElementById('event-description').value || '';
        
        // Format dates for iCal
        const formatDateTime = (dateTime) => {
          if (!dateTime) return '';
          const date = new Date(dateTime);
          return date.toISOString().replace(/[-:]/g, '').replace(/\.\d{3}/, '');
        };
        
        qrValue = `BEGIN:VEVENT
SUMMARY:${eventTitle}
LOCATION:${eventLocation}
DTSTART:${formatDateTime(eventStart)}
DTEND:${formatDateTime(eventEnd)}
DESCRIPTION:${eventDescription}
END:VEVENT`;
        break;
    }
    
    // Get active error level
    const activeErrorLevel = document.querySelector('.error-level-btn.active').dataset.level;
    
    // Update QR
    qr.set({
      value: qrValue,
      foreground: qrColor.value,
      background: bgColor.value,
      size: parseInt(qrSize.value),
      level: activeErrorLevel
    });
  }
  
  // Download PNG
  downloadPngBtn.addEventListener('click', () => {
    const link = document.createElement('a');
    link.download = 'qrcode.png';
    link.href = canvas.toDataURL();
    link.click();
    
    // Add to history
    addToHistory('PNG');
    
    window.showToast(window._tToast ? window._tToast('QR Code diunduh sebagai PNG!') : 'QR Code diunduh sebagai PNG!', 'success');
  });
  
  // Download JPG
  downloadJpgBtn.addEventListener('click', () => {
    // Create a temporary canvas with white background
    const tempCanvas = document.createElement('canvas');
    const tempCtx = tempCanvas.getContext('2d');
    tempCanvas.width = canvas.width;
    tempCanvas.height = canvas.height;
    
    // Fill white background
    tempCtx.fillStyle = '#ffffff';
    tempCtx.fillRect(0, 0, tempCanvas.width, tempCanvas.height);
    
    // Draw the QR code on top
    tempCtx.drawImage(canvas, 0, 0);
    
    // Download as JPG
    const link = document.createElement('a');
    link.download = 'qrcode.jpg';
    link.href = tempCanvas.toDataURL('image/jpeg', 0.9);
    link.click();
    
    // Add to history
    addToHistory('JPG');
    
    window.showToast(window._tToast ? window._tToast('QR Code diunduh sebagai JPG!') : 'QR Code diunduh sebagai JPG!', 'success');
  });
  
  // Copy to Clipboard (via composable)
  copyBtn.addEventListener('click', async () => {
    const ok = await copyImageToClipboard(canvas);
    if (ok) {
      window.showToast(window._tToast ? window._tToast('QR Code disalin ke clipboard!') : 'QR Code disalin ke clipboard!', 'success');
    } else {
      window.showToast(window._tToast ? window._tToast('Gagal menyalin ke clipboard') : 'Gagal menyalin ke clipboard', 'error');
    }
  });
  
  // Share
  shareBtn.addEventListener('click', async () => {
    if (navigator.share) {
      try {
        canvas.toBlob(async (blob) => {
          const file = new File([blob], 'qrcode.png', { type: 'image/png' });
          await navigator.share({
            title: 'QR Code',
            text: 'Lihat QR Code yang saya buat',
            files: [file]
          });
        });
      } catch (err) {
        window.showToast(window._tToast ? window._tToast('Gagal membagikan QR Code') : 'Gagal membagikan QR Code', 'error');
      }
    } else {
      window.showToast(window._tToast ? window._tToast('Browser Anda tidak mendukung fitur berbagi') : 'Browser Anda tidak mendukung fitur berbagi', 'error');
    }
  });
  
  // Reset
  resetBtn.addEventListener('click', () => {
    // Reset all inputs
    document.querySelectorAll('input, textarea, select').forEach(el => {
      if (el.type === 'color') {
        if (el.id === 'qr-color') {
            el.value = '#000000'; 
        }
        if (el.id === 'bg-color') {
            el.value = '#ffffff'; 
        }
      } else if (el.id === 'qr-size') {
        el.value = '250';
        sizeVal.innerText = window._tToast ? window._tToast('250px') : '250px';
      } else if (el.id === 'qr-color-hex') {
        el.value = '#000000';
      } else if (el.id === 'bg-color-hex') {
        el.value = '#ffffff';
      } else {
        el.value = '';
      }
    });
    
    // Reset QR type
    qrTypeButtons.forEach(btn => {
      btn.classList.remove('active');
      if (btn.dataset.type === 'text') {
        btn.classList.add('active');
      }
    });
    
    // Reset error level
    errorLevelButtons.forEach(btn => {
      btn.classList.remove('active');
      if (btn.dataset.level === 'M') {
        btn.classList.add('active');
      }
    });
    
    // Show text input
    qrInputContainers.forEach(container => {
      container.classList.add('hidden');
    });
    document.getElementById('text-input').classList.remove('hidden');
    
    // Reset current QR type
    currentQRType = 'text';
    
    // Update QR
    updateQR();
    
    window.showToast(window._tToast ? window._tToast('Form berhasil direset!') : 'Form berhasil direset!', 'success');
  });
  
  // Clear History
  clearHistoryBtn.addEventListener('click', () => {
    qrHistory = [];
    qrHistoryManager.clear();
    renderHistory();
    window.showToast(window._tToast ? window._tToast('Riwayat dihapus!') : 'Riwayat dihapus!', 'success');
  });
  
  // Add to History (via composable)
  function addToHistory(format) {
    const now = new Date();
    const historyItem = {
      id: Date.now(),
      type: currentQRType,
      format: format,
      date: now.toLocaleString('id-ID'),
      dataUrl: canvas.toDataURL()
    };
    
    const updated = qrHistoryManager.add(historyItem);
    qrHistory = updated;
    renderHistory();
  }
  
  // Render History
  function renderHistory() {
    if (qrHistory.length === 0) {
      historyContainer.innerHTML = '<p class="text-sm text-matte-400 text-center py-4" data-i18n="text.no_history">Belum ada riwayat</p>';
      return;
    }
    
    historyContainer.innerHTML = qrHistory.map(item => `
      <div class="history-item" data-id="${item.id}">
        <div class="flex items-center gap-3">
          <img src="${item.dataUrl}" alt="QR Code" class="w-10 h-10 rounded border border-matte-200 dark:border-surface-border bg-white">
          <div>
            <p class="text-sm font-medium text-matte-700 dark:text-white uppercase">${item.type} - ${item.format}</p>
            <p class="text-[10px] text-matte-400">${item.date}</p>
          </div>
        </div>
        <button class="text-matte-400 hover:text-accent-blue transition-colors p-1" title="Unduh">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        </button>
      </div>
    `).join('');
    
    // Add click event to history items
    document.querySelectorAll('.history-item button').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = parseInt(btn.closest('.history-item').dataset.id);
        const item = qrHistory.find(h => h.id === id);
        if (item) {
          const link = document.createElement('a');
          link.download = `qrcode-${item.type}-${item.id}.${item.format.toLowerCase()}`;
          link.href = item.dataUrl;
          link.click();
          window.showToast(window._tToast ? window._tToast('QR Code dari riwayat diunduh!') : 'QR Code dari riwayat diunduh!', 'success');
        }
      });
    });
  }
  
  // Debounce function (imported from composables)
</script>