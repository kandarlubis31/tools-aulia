---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Word Counter">
  <div class="max-w-4xl mx-auto px-4 min-h-[80vh] flex flex-col">
    <div class="text-center mb-8 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-matte-900 dark:text-white" data-i18n="header.word_counter">
        Word Counter
      </h1>
      <p class="text-matte-400 dark:text-matte-300">
        Analisis teks secara real-time: jumlah kata, karakter, dan waktu baca.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6 animate-fade-in">
      <div class="card-base p-4 text-center">
         <div id="stat-words" class="text-3xl font-bold text-pink-600 dark:text-pink-400">0</div>
         <div class="text-xs font-bold text-slate-500 uppercase mt-1" data-i18n="label.words">Kata</div>
      </div>
      <div class="card-base p-4 text-center">
         <div id="stat-chars" class="text-3xl font-bold text-pink-600 dark:text-pink-400">0</div>
         <div class="text-xs font-bold text-slate-500 uppercase mt-1" data-i18n="label.characters">Karakter</div>
      </div>
      <div class="card-base p-4 text-center">
         <div id="stat-paragraphs" class="text-3xl font-bold text-pink-600 dark:text-pink-400">0</div>
         <div class="text-xs font-bold text-slate-500 uppercase mt-1" data-i18n="label.paragraphs">Paragraf</div>
      </div>
      <div class="card-base p-4 text-center">
         <div id="stat-time" class="text-3xl font-bold text-pink-600 dark:text-pink-400">0s</div>
         <div class="text-xs font-bold text-slate-500 uppercase mt-1">Waktu Baca</div>
      </div>
    </div>

    <div class="flex-1 flex flex-col card-base overflow-hidden mb-12 animate-fade-in">
       <div class="bg-matte-100 dark:bg-surface-hover px-4 py-2 border-b border-matte-200 dark:border-surface-border flex justify-between items-center">
          <span class="section-title">Input Teks</span>
          <button id="clear-btn" class="text-xs font-bold text-rose-500 hover:text-rose-600 px-2 py-1 rounded hover:bg-matte-100 dark:hover:bg-surface-hover transition" data-i18n="btn.clear_text">
             Clear Text
          </button>
       </div>
       <textarea id="text-input" class="flex-1 w-full p-6 font-sans text-base leading-relaxed bg-matte-100 dark:bg-surface-hover text-matte-800 dark:text-white outline-none resize-none" placeholder="Ketik atau tempel teks di sini..." spellcheck="false"></textarea>
       
       <div class="bg-matte-100 dark:bg-surface-hover px-4 py-2 border-t border-matte-200 dark:border-surface-border text-xs text-matte-400 flex justify-between">
          <span id="stat-sentences" data-i18n="label.sentences">0 Kalimat</span>
          <span id="stat-chars-no-space">0 Karakter (no space)</span>
       </div>
    </div>

  </div>
</BaseLayout>

<script>
  const input = document.getElementById('text-input') as HTMLTextAreaElement;
  const clearBtn = document.getElementById('clear-btn');
  
  // Stats Elements
  const elWords = document.getElementById('stat-words');
  const elChars = document.getElementById('stat-chars');
  const elParagraphs = document.getElementById('stat-paragraphs');
  const elTime = document.getElementById('stat-time');
  const elSentences = document.getElementById('stat-sentences');
  const elCharsNoSpace = document.getElementById('stat-chars-no-space');

  function analyze() {
    const text = input.value;
    
    // 1. Karakter
    const chars = text.length;
    const charsNoSpace = text.replace(/\s/g, '').length;

    // 2. Kata (Hanya hitung yg bukan spasi kosong)
    // Regex: Pisahkan berdasarkan spasi/newline, filter yg kosong
    const wordsArr = text.trim().split(/\s+/).filter(w => w.length > 0);
    const words = text.trim() === '' ? 0 : wordsArr.length;

    // 3. Paragraf (Pisahkan double newline)
    const paragraphs = text.split(/\n\n+/).filter(p => p.trim().length > 0).length;

    // 4. Kalimat (Pisahkan . ! ?)
    const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0).length;

    // 5. Reading Time (Avg: 200 kata/menit)
    const totalSeconds = Math.ceil(words / 3.33); // 200 words / 60 sec = 3.33 words/sec
    let timeStr = `${totalSeconds}s`;
    if (totalSeconds > 60) {
        timeStr = `${Math.floor(totalSeconds / 60)}m ${totalSeconds % 60}s`;
    }

    // Update DOM
    if(elChars) elChars.innerText = chars.toLocaleString();
    if(elWords) elWords.innerText = words.toLocaleString();
    if(elParagraphs) elParagraphs.innerText = paragraphs.toLocaleString();
    if(elTime) elTime.innerText = timeStr;
    
    if(elSentences) elSentences.innerText = `${sentences} Kalimat`;
    if(elCharsNoSpace) elCharsNoSpace.innerText = `${charsNoSpace.toLocaleString()} Karakter (tanpa spasi)`;
  }

  input?.addEventListener('input', analyze);
  
  clearBtn?.addEventListener('click', () => {
    input.value = '';
    analyze();
    input.focus();
  });
</script>
