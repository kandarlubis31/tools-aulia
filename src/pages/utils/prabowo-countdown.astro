---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Countdown Presiden Baru 2029">
  <div class="max-w-4xl mx-auto px-2 sm:px-4 min-h-[85vh] flex flex-col justify-center items-center py-6 sm:py-10 pb-32 relative">

    <div class="fixed inset-0 pointer-events-none -z-10 overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(#e0e7ff_1px,transparent_1px)] dark:bg-[radial-gradient(#1e293b_1px,transparent_1px)] bg-[length:24px_24px] opacity-40 dark:opacity-30"></div>
      <div class="absolute top-0 -left-40 w-80 h-80 bg-red-500/5 dark:bg-red-500/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 -right-40 w-80 h-80 bg-amber-500/5 dark:bg-amber-500/10 rounded-full blur-3xl"></div>
    </div>

    <div class="text-center mb-6 sm:mb-8 animate-on-scroll px-2 relative">
      <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-extrabold mb-3 sm:mb-4 tracking-tight leading-tight" data-i18n="header.prabowo_countdown">
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-red-700 dark:from-red-400 dark:to-red-600">Countdown</span> 
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-matte-200 dark:from-matte-100 dark:to-matte-300">Presiden</span>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-red-700 dark:from-red-400 dark:to-red-600">Baru</span>
      </h1>
      <p class="text-matte-600 dark:text-matte-400 text-xs sm:text-sm md:text-lg max-w-xl mx-auto" data-i18n="prabowo.subtitle">
        Menuju <strong class="text-red-600 dark:text-red-400">Indonesia Baru</strong> — versi yang katanya lebih baik dari ini.
      </p>
    </div>

    <div class="w-full max-w-2xl mb-4 sm:mb-6">
      <div id="mascot-container" role="button" tabindex="0" class="relative bg-white/80 dark:bg-surface/80 backdrop-blur-sm rounded-3xl border-2 border-red-200 dark:border-red-900/50 shadow-xl cursor-pointer group transition-all duration-300 hover:shadow-red-500/20 hover:border-red-400 dark:hover:border-red-700 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-red-500/50">
        
        <div class="flex items-start gap-2 sm:gap-4 md:gap-6 p-3 sm:p-4 md:p-6 lg:p-8 pb-1">
          <div class="flex flex-col items-center shrink-0">
            <div id="mascot" class="w-16 h-16 sm:w-20 sm:h-20 md:w-28 md:h-28 lg:w-32 lg:h-32 bg-gradient-to-br from-red-100 to-red-200 dark:from-red-950 dark:to-red-900 rounded-xl sm:rounded-2xl flex items-center justify-center select-none transition-transform duration-300 group-hover:scale-110 relative overflow-hidden shadow-inner">
              <img id="mascot-face" class="relative z-10 w-full h-full object-cover rounded-xl sm:rounded-2xl transition-all duration-300" src="https://media.giphy.com/media/Y39pGbofrbvN9TzcDC/giphy.gif" alt="Prabowo Joget" loading="lazy" onerror="this.onerror=null;this.style.display='none';document.getElementById('mascot-face-fallback').classList.remove('opacity-0','pointer-events-none');document.getElementById('mascot-face-fallback').classList.add('opacity-100','z-10')" />
              <span id="mascot-face-fallback" class="absolute inset-0 z-0 flex items-center justify-center text-3xl sm:text-4xl md:text-5xl lg:text-6xl opacity-0 pointer-events-none transition-all duration-300">👨‍💼</span>
              <div id="mascot-blink" class="absolute inset-0 z-10 rounded-2xl pointer-events-none" style="background: transparent;"></div>
              <div id="mascot-sparkle" class="absolute inset-0 bg-gradient-to-t from-yellow-400/0 to-yellow-400/0 transition-all duration-500 rounded-2xl"></div>
              <div id="fire-particles" class="absolute inset-0 pointer-events-none z-20 overflow-visible"></div>
              <div id="status-ring" class="absolute inset-0 rounded-xl sm:rounded-2xl ring-2 ring-transparent transition-all duration-500"></div>
              <div class="absolute -top-1 -right-1 w-6 h-6 md:w-7 md:h-7 rounded-full bg-white dark:bg-surface-hover shadow-md flex items-center justify-center text-xs z-20 animate-bounce-subtle">
                🇮🇩
              </div>
            </div>
            
            <div id="speech-wrapper" class="flex flex-col items-center -mt-0.5 z-20 animate-float-y">
              <div class="w-2.5 h-2.5 bg-red-500 rotate-45 mb-[-5px]"></div>
              <div id="speech-bubble" class="px-3 sm:px-4 py-1 bg-gradient-to-r from-red-500 to-red-600 text-white text-[10px] sm:text-xs md:text-sm font-black rounded-full shadow-lg shadow-red-500/30 max-w-[60vw] sm:max-w-none text-center leading-tight animate-bubble-enter">
                <span id="speech-text">Oke Gas!</span>
              </div>
            </div>
          </div>

          <div class="flex-1 min-w-0">
            <h3 class="text-lg md:text-xl font-black text-matte-800 dark:text-white" data-i18n="prabowo.mascot_name">Pak Prabowo 2029</h3>
            <p id="mascot-status" class="text-sm text-matte-500 dark:text-matte-400 mt-1 flex items-center gap-1.5" data-i18n="prabowo.mascot_status">
              <span>🕐</span> Siap-siap... tinggal nunggu waktu!
            </p>
            
            <div class="flex items-center gap-2 mt-2 flex-wrap">
              <span class="flex items-center gap-1">
                <kbd class="inline-flex items-center justify-center px-1.5 py-0.5 text-[9px] font-bold bg-surface-hover dark:bg-surface-hover text-matte-500 dark:text-matte-400 rounded border border-matte-300 dark:border-surface-border shadow-sm">Space</kbd>
                <span class="text-[10px] text-matte-400 dark:text-matte-500 animate-pulse" data-i18n="prabowo.click_hint">atau klik</span>
              </span>
              <span id="click-count" class="text-sm sm:text-base font-black text-red-600 dark:text-red-400 bg-red-100 dark:bg-red-950/50 px-3 py-1.5 rounded-md border-2 border-red-300 dark:border-red-700 transition-all duration-300 shadow-sm whitespace-nowrap min-w-[60px] text-center inline-block">0 klik</span>
            </div>
            <p class="text-[9px] text-red-400 dark:text-red-500 mt-1.5 flex items-center gap-1">
              <span>👆</span> Pencet maskotnya! Dijamin gak ada efek samping (kecuali ketagihan)
            </p>
          </div>
        </div>

        <div class="bg-gradient-to-r from-red-50 via-red-100 to-red-50 dark:from-red-950/50 dark:via-red-900/30 dark:to-red-950/50 px-3 sm:px-6 py-1.5 sm:py-2 border-t border-red-100 dark:border-red-900/30">
          <div class="flex items-center gap-1.5 sm:gap-2 text-[10px] sm:text-xs text-red-700 dark:text-red-300 font-medium">
            <span class="animate-pulse shrink-0">🔥</span>
            <span data-i18n="prabowo.famous_quote">"GAS! GAS! GAS! Kita kejar!"</span>
          </div>
        </div>
      </div>
    </div>

    <div id="rage-meter" class="w-full max-w-2xl mb-6 hidden transition-all duration-500">
      <div class="bg-white/80 dark:bg-surface/80 backdrop-blur-sm p-4 rounded-2xl border border-matte-200 dark:border-surface-border shadow-sm">
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-2">
            <span id="rage-emoji" class="text-xl">😎</span>
            <span class="text-xs font-bold text-matte-500 dark:text-matte-400 uppercase tracking-wider" data-i18n="prabowo.rage_meter">🔥 Rage Meter</span>
          </div>
          <span id="rage-level-text" class="text-xs font-black text-red-600 dark:text-red-400">LVL 0</span>
        </div>
        <div class="w-full h-3 bg-matte-200 dark:bg-surface-hover rounded-full overflow-hidden relative shadow-inner">
          <div id="rage-fill" class="h-full rounded-full transition-all duration-300 ease-out" style="width: 0%; background: linear-gradient(to right, #22c55e, #eab308, #f97316, #dc2626, #991b1b);"></div>
        </div>
        <div class="flex justify-between mt-1.5 px-0.5">
          <span class="text-[7px] md:text-[8px] text-green-500 font-bold opacity-60">😎 Santuy</span>
          <span class="text-[7px] md:text-[8px] text-amber-500 font-bold opacity-40">😤 Panas</span>
          <span class="text-[7px] md:text-[8px] text-orange-600 font-bold opacity-30">🤬 BAH!</span>
          <span class="text-[7px] md:text-[8px] text-red-700 font-bold opacity-30">💀 MAX</span>
        </div>
      </div>
    </div>

    <div class="w-full max-w-2xl mb-6 animate-on-scroll">
      <div class="bg-gradient-to-r from-red-600 via-red-500 to-orange-500 p-[2px] rounded-2xl shadow-lg shadow-red-500/20">
        <div class="bg-white dark:bg-matte-900 rounded-2xl p-4 sm:p-5">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2 sm:gap-3">
              <span class="text-2xl sm:text-3xl">⏳</span>
              <div>
                <p class="text-[10px] sm:text-xs font-bold text-matte-500 dark:text-matte-400 uppercase tracking-wider" data-i18n="prabowo.term_remaining_label">Sisa Masa Jabatan</p>
                <p class="text-lg sm:text-xl md:text-2xl font-black text-red-600 dark:text-red-400">
                  <span id="remaining-days-big" class="tabular-nums">0000</span>
                  <span class="text-sm md:text-base text-red-400 dark:text-red-500 ml-1">hari</span>
                </p>
              </div>
            </div>
            <div class="text-right">
              <p class="text-[9px] sm:text-[10px] font-bold text-matte-400 dark:text-matte-500 uppercase tracking-wider" data-i18n="prabowo.term_passed_label">Terlewati</p>
              <p class="text-lg sm:text-xl font-black text-amber-500 dark:text-amber-400">
                <span id="remaining-pct-big" class="tabular-nums">0.00</span><span class="text-sm ml-0.5">%</span>
              </p>
            </div>
          </div>
          <div class="mt-3 w-full h-2 bg-matte-200 dark:bg-surface-hover rounded-full overflow-hidden">
            <div id="mini-progress-bar" class="h-full rounded-full transition-all duration-1000 ease-linear" style="width: 0%; background: linear-gradient(to right, #ef4444, #f97316);"></div>
          </div>
          <p class="text-[10px] text-matte-400 dark:text-matte-500 mt-2 text-center" data-i18n="prabowo.progress_hint">
            🐌 Secepat ini kah? Cepetan 2029!
          </p>
        </div>
      </div>
    </div>

    <div class="w-full max-w-2xl bg-white/80 dark:bg-surface/80 backdrop-blur-sm p-4 sm:p-6 md:p-8 lg:p-12 rounded-2xl sm:rounded-3xl shadow-2xl border border-matte-200 dark:border-surface-border relative overflow-hidden">
      <div class="absolute -top-10 -right-10 text-[80px] sm:text-[120px] opacity-5 dark:opacity-10 select-none pointer-events-none rotate-12 animate-float-flag">🇮🇩</div>
      <div class="absolute -bottom-10 -left-10 text-[80px] sm:text-[120px] opacity-5 dark:opacity-10 select-none pointer-events-none -rotate-12 animate-float-flag-delayed">🇮🇩</div>
      <div class="absolute inset-0 bg-gradient-to-br from-transparent via-white/5 to-transparent pointer-events-none"></div>

      <div class="absolute top-3 sm:top-6 left-3 sm:left-6 flex items-center gap-1.5 sm:gap-2 px-2 sm:px-3 py-0.5 sm:py-1 rounded-full bg-red-50 dark:bg-red-900/30 text-[8px] sm:text-[10px] font-bold uppercase tracking-widest text-red-600 dark:text-red-400 border border-red-200 dark:border-red-800">
        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
        <span id="live-badge" data-i18n="prabowo.live_badge">LIVE COUNTDOWN</span>
      </div>

      <div class="relative z-10 text-center mt-3 sm:mt-4">
        <p class="text-[10px] sm:text-xs md:text-sm font-bold text-matte-500 dark:text-matte-400 mb-2 uppercase tracking-wider">
          ⏳ <span data-i18n="prabowo.remaining_detail_label">Detail Hitung Mundur</span>
        </p>
        
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-1.5 sm:gap-3 md:gap-6 mb-6">
          <div class="flex flex-col items-center group/timer">
            <div class="w-full bg-red-50 dark:bg-red-950/50 rounded-xl sm:rounded-2xl p-2 sm:p-3 md:p-5 border border-red-100 dark:border-red-900/50 shadow-inner flex justify-center items-center transition-all duration-300 group-hover/timer:scale-105 group-hover/timer:shadow-md group-hover/timer:border-red-300 dark:group-hover/timer:border-red-700">
              <span id="days" class="block text-[clamp(1.5rem,5vw,3rem)] font-black text-red-600 dark:text-red-400 tabular-nums leading-none overflow-visible">00</span>
            </div>
            <span class="text-[9px] sm:text-[10px] md:text-xs font-bold text-matte-500 dark:text-matte-400 uppercase mt-1.5 sm:mt-2 tracking-widest" data-i18n="time.days">Hari</span>
          </div>
          <div class="flex flex-col items-center group/timer">
            <div class="w-full bg-matte-50 dark:bg-matte-900/50 rounded-xl sm:rounded-2xl p-2 sm:p-3 md:p-5 border border-matte-200 dark:border-surface-border shadow-inner min-w-[80px] sm:min-w-[100px] md:min-w-[120px] transition-all duration-300 group-hover/timer:scale-105 group-hover/timer:shadow-md">
              <span id="hours" class="block text-3xl sm:text-4xl md:text-6xl font-black text-matte-700 dark:text-matte-200 tabular-nums leading-none overflow-visible whitespace-nowrap">00</span>
            </div>
            <span class="text-[9px] sm:text-[10px] md:text-xs font-bold text-matte-500 dark:text-matte-400 uppercase mt-1.5 sm:mt-2 tracking-widest" data-i18n="time.hours">Jam</span>
          </div>
          <div class="flex flex-col items-center group/timer">
            <div class="w-full bg-red-50 dark:bg-red-950/50 rounded-xl sm:rounded-2xl p-2 sm:p-3 md:p-5 border border-red-100 dark:border-red-900/50 shadow-inner min-w-[80px] sm:min-w-[100px] md:min-w-[120px] transition-all duration-300 group-hover/timer:scale-105 group-hover/timer:shadow-md group-hover/timer:border-red-300 dark:group-hover/timer:border-red-700">
              <span id="minutes" class="block text-3xl sm:text-4xl md:text-6xl font-black text-red-600 dark:text-red-400 tabular-nums leading-none overflow-visible whitespace-nowrap">00</span>
            </div>
            <span class="text-[9px] sm:text-[10px] md:text-xs font-bold text-matte-500 dark:text-matte-400 uppercase mt-1.5 sm:mt-2 tracking-widest" data-i18n="time.minutes">Menit</span>
          </div>
          <div class="flex flex-col items-center group/timer">
            <div class="w-full bg-matte-50 dark:bg-matte-900/50 rounded-xl sm:rounded-2xl p-2 sm:p-3 md:p-5 border border-matte-200 dark:border-surface-border shadow-inner min-w-[80px] sm:min-w-[100px] md:min-w-[120px] transition-all duration-300 group-hover/timer:scale-105 group-hover/timer:shadow-md">
              <span id="seconds" class="block text-3xl sm:text-4xl md:text-6xl font-black text-matte-700 dark:text-matte-200 tabular-nums leading-none overflow-visible whitespace-nowrap">00</span>
            </div>
            <span class="text-[9px] sm:text-[10px] md:text-xs font-bold text-matte-500 dark:text-matte-400 uppercase mt-1.5 sm:mt-2 tracking-widest" data-i18n="time.seconds">Detik</span>
          </div>
        </div>

        <div class="flex justify-center my-4 sm:my-5">
          <div id="center-gif-wrapper" class="relative">
            <!-- Placeholder: shown while countdown runs -->
            <div id="gif-placeholder" class="flex flex-col items-center gap-1.5">
              <div class="w-24 h-24 sm:w-28 sm:h-28 md:w-36 md:h-36 bg-matte-100 dark:bg-matte-800/80 rounded-2xl border-2 border-dashed border-matte-300 dark:border-surface-border flex items-center justify-center transition-all duration-300 hover:border-red-300 dark:hover:border-red-700">
                <span class="text-3xl sm:text-4xl md:text-5xl animate-bounce-subtle">🎁</span>
              </div>
              <span class="text-[9px] sm:text-[10px] text-matte-400 dark:text-matte-500 font-medium text-center px-2">
                ⏳ Nanti nongol pas countdown abis!
              </span>
            </div>
            <!-- Actual GIF content: hidden until countdown ends -->
            <div id="gif-content" class="hidden relative group/gif">
              <img 
                src="https://media.giphy.com/media/siFflmcfRp5sb0avf6/giphy.gif" 
                alt="Nunggu 2029" 
                loading="lazy"
                class="w-24 h-24 sm:w-28 sm:h-28 md:w-36 md:h-36 object-cover rounded-2xl shadow-lg border-2 border-red-200 dark:border-red-800 transition-all duration-300 group-hover/gif:scale-110 group-hover/gif:shadow-red-500/30 group-hover/gif:border-red-400"
                onerror="this.onerror=null;this.style.display='none';this.nextElementSibling.style.display='flex'"
              />
              <span class="hidden w-24 h-24 sm:w-28 sm:h-28 md:w-36 md:h-36 items-center justify-center text-4xl sm:text-5xl md:text-6xl bg-red-50 dark:bg-red-950/50 rounded-2xl border-2 border-red-200 dark:border-red-800">🕐</span>
              <div id="gif-badge" class="absolute -bottom-2 left-1/2 -tranmatte-x-1/2 bg-red-500 text-white text-[8px] sm:text-[9px] font-black px-2 sm:px-3 py-0.5 rounded-full whitespace-nowrap shadow-md">
                🎉 AKHIRNYA!
              </div>
            </div>
          </div>
        </div>

        <p class="text-[10px] sm:text-xs text-matte-400 dark:text-matte-500 font-medium" data-i18n="prabowo.target_label">
          Target: <span class="font-bold text-red-600 dark:text-red-400 whitespace-nowrap">20 Oktober 2029</span> <span id="target-end-text">— Akhir masa bakti</span>
        </p>
      </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 sm:gap-3 w-full max-w-2xl mt-6 sm:mt-8">
      <div class="bg-white/80 dark:bg-surface/80 backdrop-blur-sm p-4 rounded-xl sm:rounded-2xl border border-matte-200 dark:border-surface-border shadow-sm hover:shadow-md transition-all hover:-tranmatte-y-1 flex flex-col justify-between h-full hover:border-orange-200 dark:hover:border-orange-800">
        <div class="text-lg sm:text-xl mb-1">🍜</div>
        <div id="stat-mie" class="text-lg sm:text-xl md:text-2xl font-black text-orange-600 dark:text-orange-400">0</div>
        <div class="text-[7px] sm:text-[9px] uppercase font-bold text-matte-400 mt-0.5 leading-tight" data-i18n="prabowo.stat_mie">Mie Instan Dikonsumsi (Miliar)</div>
      </div>
      <div class="bg-white/80 dark:bg-matte-800/80 backdrop-blur-sm p-4 rounded-xl sm:rounded-2xl border border-matte-200 dark:border-matte-700 shadow-sm hover:shadow-md transition-all hover:-tranmatte-y-1 flex flex-col justify-between h-full hover:border-amber-200 dark:hover:border-amber-800">
        <div class="text-lg sm:text-xl mb-1">🥚</div>
        <div id="percent-done" class="text-lg sm:text-xl md:text-2xl font-black text-matte-800 dark:text-white">0%</div>
        <div class="text-[7px] sm:text-[9px] uppercase font-bold text-matte-400 mt-0.5 leading-tight" data-i18n="prabowo.stat_term">Masa Jabatan Terlewati</div>
      </div>
      <div class="bg-white/80 dark:bg-matte-800/80 backdrop-blur-sm p-4 rounded-xl sm:rounded-2xl border border-matte-200 dark:border-matte-700 shadow-sm hover:shadow-md transition-all hover:-tranmatte-y-1 flex flex-col justify-between h-full hover:border-pink-200 dark:hover:border-pink-800">
        <div class="text-lg sm:text-xl mb-1">🏃</div>
        <div id="stat-kabur" class="text-lg sm:text-xl md:text-2xl font-black text-pink-600 dark:text-pink-400">0</div>
        <div class="text-[7px] sm:text-[9px] uppercase font-bold text-matte-400 mt-0.5 leading-tight" data-i18n="prabowo.stat_kabur">Alasan Kabur Meeting</div>
      </div>
      <div class="bg-white/80 dark:bg-matte-800/80 backdrop-blur-sm p-4 rounded-xl sm:rounded-2xl border border-matte-200 dark:border-matte-700 shadow-sm hover:shadow-md transition-all hover:-tranmatte-y-1 flex flex-col justify-between h-full hover:border-purple-200 dark:hover:border-purple-800">
        <div class="text-lg sm:text-xl mb-1">🎭</div>
        <div id="stat-gimmick" class="text-lg sm:text-xl md:text-2xl font-black text-purple-600 dark:text-purple-400">0</div>
        <div class="text-[7px] sm:text-[9px] uppercase font-bold text-matte-400 mt-0.5 leading-tight" data-i18n="prabowo.stat_gimmick">Gimmick Gagal Viral</div>
      </div>
      <div class="bg-white/80 dark:bg-matte-800/80 backdrop-blur-sm p-4 rounded-xl sm:rounded-2xl border border-matte-200 dark:border-matte-700 shadow-sm hover:shadow-md transition-all hover:-tranmatte-y-1 flex flex-col justify-between h-full hover:border-blue-200 dark:hover:border-blue-800">
        <div class="text-lg sm:text-xl mb-1">🌧️</div>
        <div id="stat-hujan" class="text-lg sm:text-xl md:text-2xl font-black text-blue-600 dark:text-blue-400">0</div>
        <div class="text-[7px] sm:text-[9px] uppercase font-bold text-matte-400 mt-0.5 leading-tight" data-i18n="prabowo.stat_hujan">Hujan Pas Ada Acara</div>
      </div>
      <div class="bg-white/80 dark:bg-matte-800/80 backdrop-blur-sm p-4 rounded-xl sm:rounded-2xl border border-matte-200 dark:border-matte-700 shadow-sm hover:shadow-md transition-all hover:-tranmatte-y-1 flex flex-col justify-between h-full hover:border-emerald-200 dark:hover:border-emerald-800">
        <div class="text-lg sm:text-xl mb-1">🤳</div>
        <div id="stat-selfie" class="text-lg sm:text-xl md:text-2xl font-black text-emerald-600 dark:text-emerald-400">0</div>
        <div class="text-[7px] sm:text-[9px] uppercase font-bold text-matte-400 mt-0.5 leading-tight" data-i18n="prabowo.stat_selfie">Selfie Gak Jelas (kali)</div>
      </div>
    </div>

    <div class="w-full max-w-2xl mt-6 sm:mt-8">
      <div class="bg-white/80 dark:bg-surface/80 backdrop-blur-sm p-4 sm:p-5 md:p-6 rounded-xl sm:rounded-2xl border border-matte-200 dark:border-surface-border shadow-sm hover:shadow-md transition-all duration-300 relative overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-red-500 via-amber-500 to-red-500"></div>
        
        <div class="flex items-center gap-2 mb-3 sm:mb-4">
