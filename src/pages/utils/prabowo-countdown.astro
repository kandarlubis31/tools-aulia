  let backsoundAudio = null;
  let backsoundStarted = false;
  let currentBacksoundIndex = parseInt(localStorage.getItem('prabowoBacksoundIndex') || '1');
  let backsoundMuted = localStorage.getItem('prabowoBacksoundMuted') === 'true';
  if (localStorage.getItem('prabowoBacksoundMuted') === null) {
    backsoundMuted = false;
    localStorage.setItem('prabowoBacksoundMuted', 'false');
  }
  let currentClickAudio = null;
  let resumeSafetyTimer = null;

  function preloadAudios() {
    soundAudios = SOUND_FILES.map(url => {
      const a = new Audio(url);
      a.preload = 'auto';
      a.volume = 1.0;
      return a;
    });
    backsoundAudios = BACKSOUND_FILES.map(bs => {
      const a = new Audio(bs.path);
      a.preload = 'auto';
      a.loop = true;
      a.volume = 0.45;
      return a;
    });
    backsoundAudio = backsoundAudios[currentBacksoundIndex] || backsoundAudios[0];
  }

  function playNextSound() {
    soundQueueIndex = Math.floor(Math.random() * soundAudios.length);
    const audio = soundAudios[soundQueueIndex];
    if (!audio) return;

    if (currentClickAudio) {
      currentClickAudio.onended = null;
      currentClickAudio.pause();
    }
    if (resumeSafetyTimer) { clearTimeout(resumeSafetyTimer); resumeSafetyTimer = null; }
    currentClickAudio = audio;

    audio.currentTime = 0;
    const wasPlayingBacksound = backsoundAudio && !backsoundMuted && backsoundStarted && !backsoundAudio.paused;
    if (wasPlayingBacksound) backsoundAudio.pause();
    audio.play().catch(() => {});

    audio.onended = () => {
      if (resumeSafetyTimer) { clearTimeout(resumeSafetyTimer); resumeSafetyTimer = null; }
      if (backsoundAudio && !backsoundMuted && backsoundStarted && wasPlayingBacksound) {
        backsoundAudio.play().catch(() => {});
      }
      if (currentClickAudio === audio) currentClickAudio = null;
    };

    resumeSafetyTimer = setTimeout(() => {
      if (backsoundAudio && !backsoundMuted && backsoundStarted && wasPlayingBacksound) {
        backsoundAudio.play().catch(() => {});
      }
      if (currentClickAudio === audio) currentClickAudio = null;
      resumeSafetyTimer = null;
    }, 8000);
  }

  function initBacksound() {
    if (backsoundStarted) return;
    backsoundStarted = true;
    if (backsoundAudio && !backsoundMuted) {
      backsoundAudio.play().catch(() => {});
    }
  }

  function toggleBacksoundMute() {
    backsoundMuted = !backsoundMuted;
    localStorage.setItem('prabowoBacksoundMuted', backsoundMuted);
    updateMuteButton();
    if (backsoundMuted) {
      if (backsoundAudio) backsoundAudio.pause();
    } else {
      if (backsoundAudio && backsoundStarted) backsoundAudio.play().catch(() => {});
    }
  }

  function switchBacksound() {
    const wasPlaying = backsoundStarted && !backsoundMuted && backsoundAudio && !backsoundAudio.paused;
    if (backsoundAudio) {
      backsoundAudio.pause();
      backsoundAudio.currentTime = 0;
    }
    currentBacksoundIndex = (currentBacksoundIndex + 1) % BACKSOUND_FILES.length;
    localStorage.setItem('prabowoBacksoundIndex', currentBacksoundIndex);
    backsoundAudio = backsoundAudios[currentBacksoundIndex];
    if (wasPlaying && backsoundStarted) {
      backsoundAudio.currentTime = 0;
      backsoundAudio.play().catch(() => {});
    }
    updateMuteButton();
  }

  function updateMuteButton() {
    const muteBtn = document.getElementById('mute-backsound-btn');
    if (muteBtn) {
      muteBtn.textContent = backsoundMuted ? '🔇' : '🔊';
      muteBtn.title = backsoundMuted ? 'Unmute backsound' : 'Mute backsound';
    }
    const label = document.getElementById('bs-label');
    if (label) label.textContent = BACKSOUND_FILES[currentBacksoundIndex].label;
  }

  function generateUsername() {
    const prefixes = ['Rakyat', 'Warga', 'Bang', 'Mbak', 'Mas', 'Pak', 'Bu', 'Kang', 'Ayang', 'Bestie', 'Bro', 'Sis', 'Om', 'Tante', 'Adek', 'Kakak', 'Sultan', 'Mister', 'Neng', 'A'];
    const suffixes = ['Gaspol', 'AntiGaspol', 'KlikTerus', 'PemilihPemula', 'Sarjana', 'Buruh', 'Mahasiswa', 'Driver', 'IbuKos', 'PecintaGas', 'Santuy', 'Baper', 'Receh', 'Woles', 'Gercep', 'Capek', 'Legend', 'Brok', 'Betah'];
    const p = prefixes[Math.floor(Math.random() * prefixes.length)];
    const s = suffixes[Math.floor(Math.random() * suffixes.length)];
    const num = Math.floor(Math.random() * 999);
    return `${p}${s}${num}`;
  }

  function getOrCreateUsername() {
    if (!currentUsername) {
      currentUsername = generateUsername();
      localStorage.setItem('prabowoUsername', currentUsername);
    }
    return currentUsername;
  }

  function updateLeaderboard() {
    const username = getOrCreateUsername();
    let userEntry = leaderboardData.find(e => e.username === username);
    if (userEntry) {
      userEntry.score = Math.max(userEntry.score || 0, clickCount);
      userEntry.lastClick = Date.now();
    } else {
      leaderboardData.push({ username, score: clickCount, lastClick: Date.now() });
    }

    leaderboardData.sort((a, b) => b.score - a.score);
    if (leaderboardData.length > 50) leaderboardData = leaderboardData.slice(0, 50);

    localStorage.setItem('prabowoLeaderboard', JSON.stringify(leaderboardData));
    renderLeaderboard();
  }

  function renderLeaderboard() {
    const listEl = document.getElementById('leaderboard-list');
    const sectionEl = document.getElementById('leaderboard-section');
    if (!listEl || !sectionEl) return;

    if (leaderboardData.length === 0) {
      sectionEl.classList.add('hidden');
      return;
    }

    sectionEl.classList.remove('hidden');
    const username = getOrCreateUsername();
    const medalEmojis = ['🥇', '🥈', '🥉'];

    listEl.innerHTML = leaderboardData.slice(0, 10).map((entry, index) => {
      const isMe = entry.username === username;
      const medal = medalEmojis[index] || `#${index + 1}`;
      const timeAgo = entry.lastClick ? getTimeAgo(entry.lastClick) : 'baru';
      const safeUsername = entry.username.replace(/[<>"']/g, '');
      return `
        <div class="flex items-center gap-3 p-2 rounded-xl ${isMe ? 'bg-red-50 dark:bg-red-950/40 border border-red-200 dark:border-red-800' : 'bg-matte-50 dark:bg-matte-900/50'} transition-all hover:scale-[1.01]">
          <span class="w-8 text-center text-sm font-bold ${index < 3 ? 'text-lg' : 'text-matte-400'}">${medal}</span>
          <div class="flex-1 min-w-0">
            <span class="text-sm font-bold ${isMe ? 'text-red-600 dark:text-red-400' : 'text-matte-700 dark:text-matte-300'} truncate block">
              ${entry.legend ? '⭐ ' : ''}${safeUsername} ${isMe ? '👈' : ''}
            </span>
            <span class="text-[10px] text-matte-400">${timeAgo}</span>
          </div>
          <div class="flex items-center gap-1">
            <span class="text-lg font-black ${isMe ? 'text-red-600 dark:text-red-400' : 'text-matte-800 dark:text-white'}">${entry.score}</span>
            <span class="text-[10px] text-matte-400">x</span>
          </div>
        </div>
      `;
    }).join('');
  }

  function getTimeAgo(timestamp) {
    const diff = Date.now() - timestamp;
    if (diff < 60000) return 'baru aja';
    if (diff < 3600000) return `${Math.floor(diff / 60000)}m lalu`;
    if (diff < 86400000) return `${Math.floor(diff / 3600000)}j lalu`;
    return `${Math.floor(diff / 86400000)}h lalu`;
  }

  function scheduleBlink() {
    const delay = 3000 + Math.random() * 5000;
    idleBlinkTimer = setTimeout(() => {
      const faceEl = document.getElementById('mascot-face');
      const mascotEl = document.getElementById('mascot');
      if (!faceEl || !mascotEl) { scheduleBlink(); return; }

      const blinkEl = document.getElementById('mascot-blink');
      if (blinkEl) {
        faceEl.style.transform = 'scaleY(0.15)';
        blinkEl.style.background = 'rgba(0,0,0,0.25)';
        blinkEl.style.transition = 'background 0.08s, transform 0.08s';
        setTimeout(() => {
          faceEl.style.transform = 'scaleY(1)';
          blinkEl.style.background = 'transparent';
        }, 100);
      }
      scheduleBlink();
    }, delay);
  }

  function resetIdle() {
    if (idleBlinkTimer) { clearTimeout(idleBlinkTimer); idleBlinkTimer = null; }
    if (idleBoredTimer) { clearTimeout(idleBoredTimer); idleBoredTimer = null; }

    const mascotEl = document.getElementById('mascot');
    if (mascotEl) {
      mascotEl.classList.remove('animate-idle-bored', 'animate-idle-breathe');
      void mascotEl.offsetWidth;
      mascotEl.classList.add('animate-idle-breathe');
    }

    isBored = false;
    scheduleBlink();

    idleBoredTimer = setTimeout(() => {
      isBored = true;
      const el = document.getElementById('mascot');
      if (el) {
        el.classList.remove('animate-idle-breathe');
        el.classList.add('animate-idle-bored');
      }
      setMascotFace('selfie');
      const statusEl = document.getElementById('mascot-status');
      if (statusEl) statusEl.textContent = 'Zzz... gaskah?';
      const speechEl = document.getElementById('speech-text');
      if (speechEl) {
        const boredTexts = ['Kapan diklik?', 'Bosen nih...', 'Halo?', 'Tidur dulu ah', 'Gasken lahh!'];
        speechEl.textContent = boredTexts[Math.floor(Math.random() * boredTexts.length)];
      }
    }, 25000);
  }

  function getRandomItem(arr, prevIndex) {
    let index;
    do {
      index = Math.floor(Math.random() * arr.length);
    } while (index === prevIndex && arr.length > 1);
    return { index, item: arr[index] };
  }

  function updateQuote() {
    const { item } = getRandomItem(realityQuotes, previousQuoteIndex);
    previousQuoteIndex = realityQuotes.indexOf(item);
    const quoteEl = document.getElementById('reality-quote');
    const sourceEl = document.getElementById('reality-source');
    const categoryEl = document.getElementById('quote-category');
    if (quoteEl && sourceEl) {
      quoteEl.style.opacity = '0';
      setTimeout(() => {
        quoteEl.textContent = `"${item.text}"`;
        sourceEl.innerHTML = `<span>✍️</span> — ${item.source}`;
        if (categoryEl && item.category) categoryEl.textContent = item.category;
        quoteEl.style.opacity = '1';
      }, 200);
    }
  }

  function showCatchphrase(fromClick = true) {
    const { item } = getRandomItem(catchphrases, previousCatchphraseIndex);
    previousCatchphraseIndex = catchphrases.indexOf(item);
    
    const speechEl = document.getElementById('speech-text');
    const statusEl = document.getElementById('mascot-status');
    const sparkleEl = document.getElementById('mascot-sparkle');
    const bubbleEl = document.getElementById('speech-bubble');
    const containerEl = document.getElementById('mascot-container');

    if (speechEl) {
      speechEl.style.transform = 'scale(0.4)';
      speechEl.style.opacity = '0';
      setTimeout(() => {
        speechEl.textContent = item.text;
        requestAnimationFrame(() => {
          speechEl.style.transform = 'scale(1)';
          speechEl.style.opacity = '1';
        });
      }, 120);
    }
    
    const gifMood = item.text.includes('marah') || item.text.includes('AMARAH') ? 'marah'
      : item.text.includes('lama') || item.text.includes('bodo') || item.text.includes('Santuy') ? 'selfie'
      : 'joget';
    setMascotFace(gifMood);
    if (statusEl) statusEl.textContent = item.status;

    if (sparkleEl) {
      sparkleEl.classList.add('animate-sparkle');
      setTimeout(() => sparkleEl.classList.remove('animate-sparkle'), 600);
    }

    if (bubbleEl) {
      bubbleEl.classList.remove('animate-pop');
      const oldHandler = bubbleEl._popEndHandler;
      if (oldHandler) bubbleEl.removeEventListener('animationend', oldHandler);
      void bubbleEl.offsetWidth;
      bubbleEl.classList.add('animate-pop');
      const handler = () => {
        bubbleEl.classList.remove('animate-pop');
        bubbleEl._popEndHandler = null;
      };
      bubbleEl._popEndHandler = handler;
      bubbleEl.addEventListener('animationend', handler, { once: true });
    }

    if (fromClick) {
      clickCount++;
      const countEl = document.getElementById('click-count');
      if (countEl) countEl.textContent = `${clickCount} klik`;
      resetIdle();
      const now = Date.now();
      const timeSinceLast = now - lastClickTime;
      lastClickTime = now;

      if (timeSinceLast < 800 && timeSinceLast > 20) {
        rageLevel = Math.min(rageLevel + 1, MAX_RAGE);
      } else if (timeSinceLast > 2000) {
        rageLevel = Math.max(0, rageLevel - 2);
      }

      updateRageVisuals();
      if (!backsoundStarted) initBacksound();
      playNextSound();

      if (rageLevel >= 7) {
        containerEl?.classList.add('animate-shake');
        setTimeout(() => containerEl?.classList.remove('animate-shake'), 300);
      }

      updateLeaderboard();

      if (rageDecayTimer) clearTimeout(rageDecayTimer);
      (function startDecay() {
        rageDecayTimer = setTimeout(() => {
          if (rageLevel > 0) {
            rageLevel = Math.max(0, rageLevel - 2);
            updateRageVisuals();
            if (rageLevel > 0) startDecay();
          }
        }, 2000);
      })();

      if (clickCount === 100 && !easterEggUnlocked) {
        easterEggUnlocked = true;
        localStorage.setItem('prabowoEasterEgg', 'true');
        triggerEasterEgg();
      }
    }

    if (mascotTimer) clearTimeout(mascotTimer);
    mascotTimer = setTimeout(() => showCatchphrase(false), 4000);
  }

  let fireInterval = null;
  const fireColors = ['#ef4444', '#f97316', '#eab308', '#dc2626', '#ff6b35', '#ff4500'];

  function startFireParticles() {
    if (fireInterval) return;
    if (window.matchMedia?.('(prefers-reduced-motion: reduce)').matches) return;
    fireInterval = setInterval(() => { spawnFireParticle(); }, 150);
  }

  function stopFireParticles() {
    if (fireInterval) { clearInterval(fireInterval); fireInterval = null; }
  }

  function spawnFireParticle() {
    const container = document.getElementById('fire-particles');
    if (!container) return;
    const particle = document.createElement('div');
    const color = fireColors[Math.floor(Math.random() * fireColors.length)];
    const size = 3 + Math.random() * 7;
    const left = 15 + Math.random() * 70;
    const delay = Math.random() * 0.15;
    const duration = 0.6 + Math.random() * 1.0;
    
    // Perbaikan: gunakan style inline khusus untuk keyframe riseparticle agar tidak menabrak Astro CSS-Scope
    particle.style.cssText = `position:absolute;bottom:0;left:${left}%;width:${size}px;height:${size}px;background:${color};border-radius:${Math.random() > 0.5 ? '50%' : '1px'};animation:pwFireRise ${duration}s ease-out ${delay}s forwards;box-shadow:0 0 ${size * 2}px ${color}60;`;
    container.appendChild(particle);
    setTimeout(() => { if (particle.parentNode) particle.remove(); }, (duration + delay) * 1000 + 200);
  }

  function updateRageMeter() {
    const meterEl = document.getElementById('rage-meter');
    const fillEl = document.getElementById('rage-fill');
    const emojiEl = document.getElementById('rage-emoji');
    const labelEl = document.getElementById('rage-level-text');
    if (!meterEl || !fillEl) return;
    if (rageLevel === 0) {
      meterEl.classList.add('hidden');
      meterEl.style.opacity = '0';
      stopFireParticles();
      return;
    }
    meterEl.classList.remove('hidden');
    meterEl.style.opacity = '0';
    void meterEl.offsetHeight;
    meterEl.style.opacity = '1';
    const percent = (rageLevel / MAX_RAGE) * 100;
    fillEl.style.width = `${percent}%`;
    let emoji, levelLabel;
    if (rageLevel <= 2) { emoji = '😎'; levelLabel = 'LVL ' + rageLevel + ' — Santuy'; }
    else if (rageLevel <= 4) { emoji = '😤'; levelLabel = 'LVL ' + rageLevel + ' — Mulai Panas'; }
    else if (rageLevel <= 6) { emoji = '😡'; levelLabel = 'LVL ' + rageLevel + ' — NAIK DARAH!'; }
    else if (rageLevel <= 8) { emoji = '🤬'; levelLabel = 'LVL ' + rageLevel + ' — BAH! AMARAH!'; }
    else { emoji = '💀'; levelLabel = 'LVL ' + rageLevel + ' — MAX RAGE!!'; }
    if (emojiEl) emojiEl.textContent = emoji;
    if (labelEl) labelEl.textContent = levelLabel;
    if (rageLevel >= 5) startFireParticles(); else stopFireParticles();
  }

  function updateRageVisuals() {
    const mascotEl = document.getElementById('mascot');
    const containerEl = document.getElementById('mascot-container');
    const speechBubble = document.getElementById('speech-bubble');
    const statusRing = document.getElementById('status-ring');
    if (!mascotEl) return;

    mascotEl.classList.remove('rage-1','rage-2','rage-3','rage-4','rage-5','rage-6','rage-7','rage-8','rage-9','rage-10');
    containerEl?.classList.remove('rage-border');
    
    if (speechBubble) speechBubble.style.background = '';
    if (statusRing) statusRing.className = 'absolute inset-0 rounded-xl sm:rounded-2xl ring-2 transition-all duration-500';

    if (rageLevel === 0) {
      setMascotFace('joget');
      return;
    }

    const rageClass = `rage-${rageLevel}`;
    mascotEl.classList.add(rageClass);
    if (rageLevel >= 5) containerEl?.classList.add('rage-border');

    if (rageLevel >= 7) setMascotFace('marah');
    else if (rageLevel >= 4) setMascotFace('selfie');
    else setMascotFace('joget');

    if (speechBubble) {
      if (rageLevel >= 8) speechBubble.style.background = 'linear-gradient(to right, #dc2626, #991b1b)';
      else if (rageLevel >= 5) speechBubble.style.background = 'linear-gradient(to right, #f97316, #dc2626)';
      else speechBubble.style.background = 'linear-gradient(to right, #ef4444, #dc2626)';
    }

    if (statusRing) {
      const colors = ['', 'ring-green-400', 'ring-green-500', 'ring-yellow-400', 'ring-yellow-500', 'ring-orange-400', 'ring-orange-500', 'ring-red-400', 'ring-red-500', 'ring-red-600', 'ring-red-700'];
      statusRing.classList.add(colors[Math.min(rageLevel, 10)] || '');
    }

    updateRageMeter();
  }

  function triggerEasterEgg() {
    const mascotEl = document.getElementById('mascot');
    const containerEl = document.getElementById('mascot-container');
    const countEl = document.getElementById('click-count');

    containerEl?.classList.add('animate-easter-egg');
    
    const statusEl = document.getElementById('mascot-status');
    if (statusEl) statusEl.textContent = '✨ LEGEND! ✨';
    if (countEl) countEl.textContent = '🔥 100 klik!';
    setMascotFace('kabur');

    createConfetti();

    setTimeout(() => {
      // @ts-ignore
      if (window.showToast) window.showToast('🏆 EASTER EGG: 100 CLICKS! Lu legend!', 'success');
    }, 300);

    if (!document.getElementById('easter-egg-badge')) {
      const badge = document.createElement('div');
      badge.id = 'easter-egg-badge';
      badge.className = 'absolute -bottom-1 -left-1 w-7 h-7 bg-gradient-to-br from-yellow-400 to-orange-500 rounded-full flex items-center justify-center text-xs shadow-lg z-30 animate-pulse';
      badge.textContent = '⭐';
      mascotEl?.appendChild(badge);
    }

    setTimeout(() => { containerEl?.classList.remove('animate-easter-egg'); }, 3000);

    const username = getOrCreateUsername();
    const entry = leaderboardData.find(e => e.username === username);
    if (entry) {
      entry.legend = true;
      localStorage.setItem('prabowoLeaderboard', JSON.stringify(leaderboardData));
      renderLeaderboard();
    }
  }

  function createConfetti() {
    const container = document.getElementById('confetti-container');
    if (!container) return;
    container.innerHTML = '';
    const colors = ['#ef4444', '#f97316', '#eab308', '#22c55e', '#3b82f6', '#8b5cf6', '#ec4899', '#ffffff'];
    
    for (let i = 0; i < 60; i++) {
      const confetti = document.createElement('div');
      const color = colors[Math.floor(Math.random() * colors.length)];
      const left = Math.random() * 100;
      const delay = Math.random() * 0.5;
      const duration = 1 + Math.random() * 2;
      const size = 6 + Math.random() * 8;
      
      confetti.style.cssText = `position: absolute;top: -10px;left: ${left}%;width: ${size}px;height: ${size * 0.6}px;background: ${color};border-radius: 2px;animation: pwConfettiFall ${duration}s ease-out ${delay}s forwards;transform: rotate(${Math.random() * 360}deg);`;
      container.appendChild(confetti);
    }
    setTimeout(() => { if (container) container.innerHTML = ''; }, 4000);
  }

  function updateCountdown() {
    const now = Date.now();
    const diff = TARGET_DATE - now;
    
    if (diff <= 0) {
      document.getElementById('days').textContent = '00';
      document.getElementById('hours').textContent = '00';
      document.getElementById('minutes').textContent = '00';
      document.getElementById('seconds').textContent = '00';
      document.getElementById('progress-bar').style.width = '100%';
      document.getElementById('progress-label').textContent = '100%';
      document.getElementById('percent-done').textContent = '100%';
      document.getElementById('live-badge').textContent = '🎉 SUDAH SAMPAI!';
      const remainingEl = document.getElementById('remaining-days-big');
      if (remainingEl) remainingEl.textContent = '0000';
      const pctEl = document.getElementById('remaining-pct-big');
      if (pctEl) pctEl.textContent = '100.00';
      const miniBar = document.getElementById('mini-progress-bar');
      if (miniBar) miniBar.style.width = '100%';
      const gifPlaceholder = document.getElementById('gif-placeholder');
      const gifContent = document.getElementById('gif-content');
      if (gifPlaceholder) gifPlaceholder.classList.add('hidden');
      if (gifContent) gifContent.classList.remove('hidden');
      const gifBadge = document.getElementById('gif-badge');
      if (gifBadge) gifBadge.textContent = '🎉 AKHIRNYA!';
      const targetEnd = document.getElementById('target-end-text');
      if (targetEnd) targetEnd.textContent = '— SUDAH SAMPAI! 🎉';
      return;
    }

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((diff % (1000 * 60)) / 1000);

    document.getElementById('days').textContent = String(days).padStart(2, '0');
    document.getElementById('hours').textContent = String(hours).padStart(2, '0');
    document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
    document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');

    const elapsed = now - START_DATE;
    const percentDone = Math.min(100, Math.max(0, (elapsed / TOTAL_TERM_MS) * 100));
    const percentDisplay = Math.min(100, percentDone);
    
    document.getElementById('progress-bar').style.width = `${percentDisplay}%`;
    document.getElementById('progress-label').textContent = `${percentDisplay.toFixed(4)}%`;
    document.getElementById('percent-done').textContent = `${percentDisplay.toFixed(2)}%`;

    const remainingDaysEl = document.getElementById('remaining-days-big');
    if (remainingDaysEl) remainingDaysEl.textContent = String(days);
    const remainingPctEl = document.getElementById('remaining-pct-big');
    if (remainingPctEl) remainingPctEl.textContent = percentDisplay.toFixed(2);
    const miniProgressBar = document.getElementById('mini-progress-bar');
    if (miniProgressBar) miniProgressBar.style.width = `${percentDisplay}%`;
    
    const mieValue = Math.floor(days * 7.2 + Math.sin(percentDone * 10) * 150);
    const kaburValue = Math.max(0, Math.floor(percentDone * 0.1 + Math.abs(Math.cos(percentDone * 18)) * 2 + days * 0.015));
    const gimmickValue = Math.max(0, Math.floor(percentDone * 0.04 + Math.sin(percentDone * 22) * 1.5 + days * 0.008));
    const hujanValue = Math.max(1, Math.floor(percentDone * 0.03 + Math.abs(Math.sin(percentDone * 25)) * 2 + 1));
    const selfieValue = Math.max(0, Math.floor(percentDone * 0.2 + Math.abs(Math.cos(percentDone * 15)) * 3 + days * 0.025));

    document.getElementById('stat-mie').textContent = String(mieValue);
    document.getElementById('stat-kabur').textContent = String(kaburValue);
    document.getElementById('stat-gimmick').textContent = String(gimmickValue);
    document.getElementById('stat-hujan').textContent = String(hujanValue);
    document.getElementById('stat-selfie').textContent = String(selfieValue);
  }

  function navigateFact(direction) {
    currentFactIndex = (currentFactIndex + direction + funFacts.length) % funFacts.length;
    renderFact();
  }

  function renderFact() {
    const fact = funFacts[currentFactIndex];
    const factEl = document.getElementById('fun-fact');
    const iconEl = document.getElementById('fun-fact-icon');
    const counterEl = document.getElementById('fun-fact-counter');
    if (factEl) {
      factEl.style.opacity = '0';
      setTimeout(() => {
        factEl.textContent = fact.text;
        factEl.style.opacity = '1';
      }, 200);
    }
    if (iconEl) iconEl.textContent = fact.icon;
    if (counterEl) counterEl.textContent = `${currentFactIndex + 1}/${funFacts.length}`;
    document.querySelectorAll('.fact-dot').forEach((dot, i) => {
      dot.className = `w-2 h-2 rounded-full fact-dot fact-dot-${i} ${i === currentFactIndex ? 'bg-amber-400 dark:bg-amber-500' : 'bg-matte-300 dark:bg-matte-600'}`;
    });
  }

  // Definisikan handler keyboard global secara terisolasi agar aman saat astro swapping
  const globalKeydownHandler = (e) => {
    const tag = document.activeElement?.tagName?.toLowerCase();
    const isInput = tag === 'input' || tag === 'textarea' || tag === 'select' || document.activeElement?.isContentEditable;
    if (e.code === 'Space' && !isInput && !e.ctrlKey && !e.metaKey && !e.altKey && !e.repeat && !e.target.closest('#mascot-container')) {
      e.preventDefault();
      showCatchphrase(true);
      const container = document.getElementById('mascot-container');
      if (container) {
        container.style.boxShadow = '0 0 40px rgba(239,68,68,0.5)';
        setTimeout(() => { container.style.boxShadow = ''; }, 300);
      }
    }
    if (e.code === 'ArrowRight' && !isInput) { e.preventDefault(); navigateFact(1); }
    if (e.code === 'ArrowLeft' && !isInput) { e.preventDefault(); navigateFact(-1); }
  };

  document.addEventListener('astro:page-load', () => {
    preloadAudios();
    initBacksound();
    updateCountdown();
    const countdownInterval = setInterval(updateCountdown, 1000);
    
    updateQuote();
    document.getElementById('refresh-quote')?.addEventListener('click', updateQuote);
    const quoteInterval = setInterval(updateQuote, 15000);

    const mascotContainer = document.getElementById('mascot-container');
    mascotContainer?.addEventListener('click', () => showCatchphrase(true));
    mascotContainer?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        showCatchphrase(true);
      }
    });
    
    setTimeout(() => showCatchphrase(false), 1000);
    mascotTimer = setTimeout(() => showCatchphrase(false), 4000);

    resetIdle();
    renderLeaderboard();

    if (easterEggUnlocked) {
      clickCount = 100;
      const mascotEl = document.getElementById('mascot');
      if (mascotEl && !document.getElementById('easter-egg-badge')) {
        const badge = document.createElement('div');
        badge.id = 'easter-egg-badge';
        badge.className = 'absolute -bottom-1 -left-1 w-7 h-7 bg-gradient-to-br from-yellow-400 to-orange-500 rounded-full flex items-center justify-center text-xs shadow-lg z-30 animate-pulse';
        badge.textContent = '⭐';
        mascotEl.appendChild(badge);
      }
      const countEl = document.getElementById('click-count');
      if (countEl) countEl.textContent = '🔥 100 klik!';
    }

    document.getElementById('reset-leaderboard')?.addEventListener('click', () => {
      if (confirm('Reset semua leaderboard?')) {
        leaderboardData = [];
        localStorage.removeItem('prabowoLeaderboard');
        renderLeaderboard();
        // @ts-ignore
        if (window.showToast) window.showToast('Leaderboard direset!', 'info');
      }
    });

    document.getElementById('mute-backsound-btn')?.addEventListener('click', toggleBacksoundMute);
    document.getElementById('switch-backsound-btn')?.addEventListener('click', switchBacksound);
    updateMuteButton();

    document.getElementById('share-btn')?.addEventListener('click', async () => {
      const remainingDays = document.getElementById('days')?.textContent || '??';
      const shareText = `🇮🇩 Sisa ${remainingDays} hari lagi menuju Presiden Indonesia baru! Yuk kita tunggu 2029 bareng-bareng 😂\n\nCek countdown-nya di sini: ${window.location.href}`;
      
      if (navigator.share) {
        try {
          await navigator.share({ title: 'Countdown Presiden Baru 2029', text: shareText });
        } catch (err) {
          // @ts-ignore
          if (err.name !== 'AbortError') {
            navigator.clipboard.writeText(shareText);
            // @ts-ignore
            if (window.showToast) window.showToast('Link disalin! Share ke teman-teman', 'success');
          }
        }
      } else {
        navigator.clipboard.writeText(shareText);
        // @ts-ignore
        if (window.showToast) window.showToast('Link disalin! Share ke teman-teman', 'success');
      }
    });

    document.addEventListener('keydown', globalKeydownHandler);

    function startFactRotation() {
      if (factRotationTimer) clearInterval(factRotationTimer);
      factRotationTimer = setInterval(() => {
        currentFactIndex = (currentFactIndex + 1) % funFacts.length;
        renderFact();
      }, 8000);
    }
    document.getElementById('prev-fact')?.addEventListener('click', () => navigateFact(-1));
    document.getElementById('next-fact')?.addEventListener('click', () => navigateFact(1));
    renderFact();
    startFactRotation();

    // Store references for accurate teardown on swap
    // @ts-ignore
    window._staleIntervals = [countdownInterval, quoteInterval];
  });
  
  document.addEventListener('astro:before-swap', () => {
    // @ts-ignore
    if (window._staleIntervals) window._staleIntervals.forEach(clearInterval);
    document.removeEventListener('keydown', globalKeydownHandler);
    if (factRotationTimer) { clearInterval(factRotationTimer); factRotationTimer = null; }
    if (fireInterval) { clearInterval(fireInterval); fireInterval = null; }
    if (mascotTimer) { clearTimeout(mascotTimer); mascotTimer = null; }
    if (idleBlinkTimer) { clearTimeout(idleBlinkTimer); idleBlinkTimer = null; }
    if (idleBoredTimer) { clearTimeout(idleBoredTimer); idleBoredTimer = null; }
    if (rageDecayTimer) { clearTimeout(rageDecayTimer); rageDecayTimer = null; }
    soundAudios.forEach(a => { a.pause(); a.currentTime = 0; });
    backsoundAudios.forEach(a => { a.pause(); a.currentTime = 0; });
    if (backsoundAudio) { backsoundAudio.pause(); backsoundAudio.currentTime = 0; }
    if (currentClickAudio) { currentClickAudio.pause(); currentClickAudio.currentTime = 0; currentClickAudio.onended = null; currentClickAudio = null; }
    if (resumeSafetyTimer) { clearTimeout(resumeSafetyTimer); resumeSafetyTimer = null; }
  });
</script>

