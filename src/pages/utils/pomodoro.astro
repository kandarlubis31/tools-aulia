---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Pomodoro Timer">
  <div class="max-w-2xl mx-auto px-4 min-h-[70vh] flex flex-col items-center">
    
    <div class="text-center mb-8 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-rose-500 to-orange-500">
        Pomodoro Focus
      </h1>
      <p class="text-slate-600 dark:text-slate-400">
        Tingkatkan produktivitas dengan teknik interval waktu.
      </p>
    </div>

    <div class="bg-white dark:bg-slate-800 p-8 rounded-3xl border border-slate-200 dark:border-slate-700 shadow-2xl w-full max-w-md text-center animate-fade-in">
       
       <div class="flex p-1 bg-slate-100 dark:bg-slate-700 rounded-xl mb-8">
          <button class="mode-btn flex-1 py-2 text-sm font-bold bg-white dark:bg-slate-600 shadow text-rose-500 rounded-lg transition-all" data-time="25" data-color="rose">Fokus</button>
          <button class="mode-btn flex-1 py-2 text-sm font-medium text-slate-500 hover:text-slate-700 dark:text-slate-400 transition-all" data-time="5" data-color="teal">Short Break</button>
          <button class="mode-btn flex-1 py-2 text-sm font-medium text-slate-500 hover:text-slate-700 dark:text-slate-400 transition-all" data-time="15" data-color="blue">Long Break</button>
       </div>

       <div class="relative mb-10">
          <div id="timer-display" class="text-8xl font-mono font-bold text-rose-500 tracking-tighter transition-colors duration-500">
             25:00
          </div>
          <p id="status-text" class="text-slate-400 font-medium mt-2 uppercase tracking-widest text-sm">Waktunya Fokus</p>
       </div>

       <div class="flex justify-center gap-4">
          <button id="toggle-btn" class="w-20 h-20 rounded-full bg-rose-500 hover:bg-rose-600 text-white shadow-lg shadow-rose-500/30 flex items-center justify-center transition-all hover:scale-105 active:scale-95">
             <svg id="icon-play" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
             <svg id="icon-pause" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="hidden"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
          </button>
          <button id="reset-btn" class="w-16 h-16 rounded-full bg-slate-200 dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-300 dark:hover:bg-slate-600 flex items-center justify-center transition-all">
             <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
          </button>
       </div>

    </div>
  </div>
</BaseLayout>

<script>
  let timer: any = null;
  let timeLeft = 25 * 60; // seconds
  let isRunning = false;
  let currentColor = 'rose';

  const display = document.getElementById('timer-display');
  const statusText = document.getElementById('status-text');
  const toggleBtn = document.getElementById('toggle-btn');
  const resetBtn = document.getElementById('reset-btn');
  const iconPlay = document.getElementById('icon-play');
  const iconPause = document.getElementById('icon-pause');
  const modeBtns = document.querySelectorAll('.mode-btn');

  // Audio Beep Sederhana
  const audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
  function playBeep() {
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.connect(gain);
    gain.connect(audioCtx.destination);
    osc.frequency.value = 880; 
    gain.gain.value = 0.1;
    osc.start();
    setTimeout(() => osc.stop(), 500);
  }

  function updateDisplay() {
    const m = Math.floor(timeLeft / 60).toString().padStart(2, '0');
    const s = (timeLeft % 60).toString().padStart(2, '0');
    if(display) display.innerText = `${m}:${s}`;
    document.title = `${m}:${s} - Pomodoro`;
  }

  function toggleTimer() {
    if (isRunning) {
      clearInterval(timer);
      isRunning = false;
      iconPlay?.classList.remove('hidden');
      iconPause?.classList.add('hidden');
    } else {
      isRunning = true;
      iconPlay?.classList.add('hidden');
      iconPause?.classList.remove('hidden');
      
      timer = setInterval(() => {
        if (timeLeft > 0) {
          timeLeft--;
          updateDisplay();
        } else {
          clearInterval(timer);
          isRunning = false;
          playBeep();
          alert("Waktu Habis!");
          iconPlay?.classList.remove('hidden');
          iconPause?.classList.add('hidden');
        }
      }, 1000);
    }
  }

  function setMode(mins: number, color: string, label: string) {
    clearInterval(timer);
    isRunning = false;
    timeLeft = mins * 60;
    currentColor = color;
    
    updateDisplay();
    
    // Update UI Colors
    if(display) {
        display.className = `text-8xl font-mono font-bold text-${color}-500 tracking-tighter transition-colors duration-500`;
    }
    if(toggleBtn) {
        toggleBtn.className = `w-20 h-20 rounded-full bg-${color}-500 hover:bg-${color}-600 text-white shadow-lg shadow-${color}-500/30 flex items-center justify-center transition-all hover:scale-105 active:scale-95`;
    }
    if(statusText) statusText.innerText = label;
    
    iconPlay?.classList.remove('hidden');
    iconPause?.classList.add('hidden');
  }

  // Events
  toggleBtn?.addEventListener('click', toggleTimer);
  
  resetBtn?.addEventListener('click', () => {
    // Reset based on current active tab logic needed, but simple reset:
    const activeBtn = document.querySelector('.mode-btn[class*="bg-white"]');
    // @ts-ignore
    const mins = parseInt(activeBtn?.dataset.time || 25);
    timeLeft = mins * 60;
    clearInterval(timer);
    isRunning = false;
    updateDisplay();
    iconPlay?.classList.remove('hidden');
    iconPause?.classList.add('hidden');
  });

  modeBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      // Styles Reset
      modeBtns.forEach(b => b.className = "mode-btn flex-1 py-2 text-sm font-medium text-slate-500 hover:text-slate-700 dark:text-slate-400 transition-all");
      
      // Active Style
      // @ts-ignore
      const color = e.target.dataset.color;
      // @ts-ignore
      e.target.className = `mode-btn flex-1 py-2 text-sm font-bold bg-white dark:bg-slate-600 shadow text-${color}-500 rounded-lg transition-all`;

      // Logic
      // @ts-ignore
      const mins = parseInt(e.target.dataset.time);
      // @ts-ignore
      const label = e.target.innerText;
      setMode(mins, color, label);
    });
  });
</script>
