---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Pomodoro Timer">
  <div class="max-w-2xl mx-auto px-4 min-h-[70vh] flex flex-col items-center">
    
    <div class="text-center mb-8 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-rose-500 to-orange-500" data-i18n="header.pomodoro">
        Pomodoro Focus
      </h1>
      <p class="text-matte-600 dark:text-matte-400" data-i18n="header.pomodoro_desc">
        Tingkatkan produktivitas dengan teknik interval waktu.
      </p>
    </div>

    <div class="bg-white dark:bg-matte-800 p-8 rounded-3xl border border-matte-200 dark:border-matte-700 shadow-2xl w-full max-w-md text-center animate-fade-in">
       
       <div class="flex p-1 bg-matte-100 dark:bg-matte-700 rounded-xl mb-8">
          <button class="mode-btn flex-1 py-2 text-sm font-bold bg-white dark:bg-matte-600 shadow text-rose-500 rounded-lg transition-all" data-time="25" data-color="rose" data-i18n="text.focus_mode">Fokus</button>
          <button class="mode-btn flex-1 py-2 text-sm font-medium text-matte-500 hover:text-matte-700 dark:text-matte-400 transition-all" data-time="5" data-color="teal" data-i18n="text.short_break">Short Break</button>
          <button class="mode-btn flex-1 py-2 text-sm font-medium text-matte-500 hover:text-matte-700 dark:text-matte-400 transition-all" data-time="15" data-color="blue" data-i18n="text.long_break">Long Break</button>
       </div>

       <div class="relative mb-10">
          <div id="timer-display" class="text-8xl font-mono font-bold text-rose-500 tracking-tighter transition-colors duration-500">
             25:00
          </div>
          <p id="status-text" class="text-matte-400 font-medium mt-2 uppercase tracking-widest text-sm" data-i18n="text.time_to_focus">Waktunya Fokus</p>
       </div>

       <div class="flex justify-center gap-4">
          <button id="toggle-btn" class="w-20 h-20 rounded-full bg-rose-500 hover:bg-rose-600 text-white shadow-lg shadow-rose-500/30 flex items-center justify-center transition-all hover:scale-105 active:scale-95">
             <svg id="icon-play" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
             <svg id="icon-pause" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="hidden"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
          </button>
          <button id="reset-btn" class="w-16 h-16 rounded-full bg-matte-200 dark:bg-matte-700 text-matte-600 dark:text-matte-300 hover:bg-matte-300 dark:hover:bg-matte-600 flex items-center justify-center transition-all">
             <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
          </button>
       </div>

       <div id="session-count" class="mt-4 text-xs font-medium text-matte-400 dark:text-matte-500 hidden"></div>

       <div class="mt-4 flex items-center justify-center gap-2">
          <button id="notif-btn" class="flex items-center gap-1.5 text-xs font-medium text-matte-500 dark:text-matte-400 hover:text-rose-500 dark:hover:text-rose-400 transition-colors px-3 py-1.5 rounded-lg hover:bg-rose-50 dark:hover:bg-rose-950/30" title="Notifikasi browser saat sesi selesai">
             <svg id="notif-icon-off" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/><line x1="2" y1="2" x2="22" y2="22"/></svg>
             <svg id="notif-icon-on" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
             <span id="notif-label">Notifikasi</span>
          </button>
       </div>

    </div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
  // --- Color theme mapping (complete strings so Tailwind JIT can see them) ---
  const THEMES = {
    rose: {
      display: 'text-8xl font-mono font-bold text-rose-500 tracking-tighter transition-colors duration-500',
      toggle: 'w-20 h-20 rounded-full bg-rose-500 hover:bg-rose-600 text-white shadow-lg shadow-rose-500/30 flex items-center justify-center transition-all hover:scale-105 active:scale-95',
      modeActive: 'mode-btn flex-1 py-2 text-sm font-bold bg-white dark:bg-matte-600 shadow text-rose-500 rounded-lg transition-all',
    },
    teal: {
      display: 'text-8xl font-mono font-bold text-teal-500 tracking-tighter transition-colors duration-500',
      toggle: 'w-20 h-20 rounded-full bg-teal-500 hover:bg-teal-600 text-white shadow-lg shadow-teal-500/30 flex items-center justify-center transition-all hover:scale-105 active:scale-95',
      modeActive: 'mode-btn flex-1 py-2 text-sm font-bold bg-white dark:bg-matte-600 shadow text-teal-500 rounded-lg transition-all',
    },
    blue: {
      display: 'text-8xl font-mono font-bold text-blue-500 tracking-tighter transition-colors duration-500',
      toggle: 'w-20 h-20 rounded-full bg-blue-500 hover:bg-blue-600 text-white shadow-lg shadow-blue-500/30 flex items-center justify-center transition-all hover:scale-105 active:scale-95',
      modeActive: 'mode-btn flex-1 py-2 text-sm font-bold bg-white dark:bg-matte-600 shadow text-blue-500 rounded-lg transition-all',
    },
  };

  var timer = null;
  var timeLeft = 25 * 60; // seconds
  var isRunning = false;
  var sessionCount = parseInt(localStorage.getItem('pomodoroSessions') || '0');
  const display = document.getElementById('timer-display');
  const statusText = document.getElementById('status-text');
  const toggleBtn = document.getElementById('toggle-btn');
  const resetBtn = document.getElementById('reset-btn');
  const iconPlay = document.getElementById('icon-play');
  const iconPause = document.getElementById('icon-pause');
  const modeBtns = document.querySelectorAll('.mode-btn');

  // --- Notification System ---
  var notifEnabled = localStorage.getItem('pomodoroNotif') === 'true';
  var notifPermission = 'default';
  if ('Notification' in window) {
    notifPermission = Notification.permission;
  }

  function updateNotifUI() {
    const iconOff = document.getElementById('notif-icon-off');
    const iconOn = document.getElementById('notif-icon-on');
    const label = document.getElementById('notif-label');
    const t = window._tToast;

    if (notifPermission === 'granted' && notifEnabled) {
      if (iconOff) iconOff.classList.add('hidden');
      if (iconOn) iconOn.classList.remove('hidden');
      if (label) label.textContent = t ? t('Notifikasi Aktif') : 'Notifikasi Aktif';
    } else if (notifPermission === 'granted' && !notifEnabled) {
      if (iconOff) iconOff.classList.remove('hidden');
      if (iconOn) iconOn.classList.add('hidden');
      if (label) label.textContent = t ? t('Notifikasi (Mati)') : 'Notifikasi (Mati)';
    } else if (notifPermission === 'denied') {
      if (iconOff) iconOff.classList.remove('hidden');
      if (iconOn) iconOn.classList.add('hidden');
      if (label) label.textContent = t ? t('Notifikasi Diblokir') : 'Notifikasi Diblokir';
      notifEnabled = false;
      localStorage.setItem('pomodoroNotif', 'false');
    } else {
      if (iconOff) iconOff.classList.remove('hidden');
      if (iconOn) iconOn.classList.add('hidden');
      if (label) label.textContent = t ? t('Notifikasi') : 'Notifikasi';
    }
  }

  async function requestNotifPermission() {
    if (!('Notification' in window)) {
      window.showToast?.((window._tToast ? window._tToast('Browser tidak mendukung notifikasi.') : 'Browser tidak mendukung notifikasi.'), 'info');
      return;
    }
    if (notifPermission === 'granted') {
      notifEnabled = !notifEnabled;
      localStorage.setItem('pomodoroNotif', notifEnabled);
      updateNotifUI();
      window.showToast?.((window._tToast ? window._tToast(notifEnabled ? 'Notifikasi diaktifkan! 🔔' : 'Notifikasi dimatikan.') : (notifEnabled ? 'Notifikasi diaktifkan! 🔔' : 'Notifikasi dimatikan.')), 'info');
      return;
    }
    if (notifPermission === 'denied') {
      window.showToast?.((window._tToast ? window._tToast('Notifikasi diblokir. Buka pengaturan browser untuk mengizinkan.') : 'Notifikasi diblokir. Buka pengaturan browser untuk mengizinkan.'), 'error');
      return;
    }
    // Request permission
    try {
      var result = await Notification.requestPermission();
      notifPermission = result;
      if (result === 'granted') {
        notifEnabled = true;
        localStorage.setItem('pomodoroNotif', 'true');
        updateNotifUI();
        window.showToast?.((window._tToast ? window._tToast('Notifikasi diaktifkan! 🔔') : 'Notifikasi diaktifkan! 🔔'), 'success');
      } else {
        updateNotifUI();
        window.showToast?.((window._tToast ? window._tToast('Notifikasi ditolak. Kamu bisa mengaktifkannya nanti.') : 'Notifikasi ditolak. Kamu bisa mengaktifkannya nanti.'), 'info');
      }
    } catch (e) {
      // Fallback for older browsers
    }
  }

  function showEndNotification(label) {
    // Always play sound first
    playEndSound();
    // Try browser notification
    if (notifEnabled && notifPermission === 'granted' && 'Notification' in window) {
      try {
        new Notification('⏰ Pomodoro Selesai!', {
          body: label + ' — Waktunya istirahat! ☕',
          icon: '/favicon.svg',
          tag: 'pomodoro-end',
          silent: true, // We already play our own sound
        });
      } catch (e) { /* ignore */ }
    }
    // Show toast as fallback / complement
    window.showToast?.((window._tToast ? window._tToast('⏰ Waktu Habis! Saatnya istirahat ☕') : '⏰ Waktu Habis! Saatnya istirahat ☕'), 'success');
  }

  // Audio Beep — melodic end-of-session chime via Web Audio API
  var AudioContextCtor = window.AudioContext || window['webkitAudioContext'];
  var audioCtx = AudioContextCtor ? new AudioContextCtor() : null;
  function playEndSound() {
    if (!audioCtx) return;
    // Resume context if suspended (browser autoplay policy)
    if (audioCtx.state === 'suspended') audioCtx.resume();
    // Play a pleasant 3-note ascending chime
    var notes = [523.25, 659.25, 783.99]; // C5, E5, G5
    notes.forEach(function(freq, i) {
      var osc = audioCtx.createOscillator();
      var gain = audioCtx.createGain();
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.type = 'sine';
      osc.frequency.value = freq;
      gain.gain.setValueAtTime(0, audioCtx.currentTime + i * 0.2);
      gain.gain.linearRampToValueAtTime(0.15, audioCtx.currentTime + i * 0.2 + 0.05);
      gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + i * 0.2 + 0.5);
      osc.start(audioCtx.currentTime + i * 0.2);
      osc.stop(audioCtx.currentTime + i * 0.2 + 0.5);
    });
  }

  function updateDisplay() {
    const m = Math.floor(timeLeft / 60).toString().padStart(2, '0');
    const s = (timeLeft % 60).toString().padStart(2, '0');
    if(display) display.innerText = m + ':' + s;
    document.title = `${m}:${s} - Pomodoro`;
  }

  function toggleTimer() {
    if (isRunning) {
      clearInterval(timer);
      isRunning = false;
      if (iconPlay) iconPlay.classList.remove('hidden');
      if (iconPause) iconPause.classList.add('hidden');
    } else {
      isRunning = true;
      if (iconPlay) iconPlay.classList.add('hidden');
      if (iconPause) iconPause.classList.remove('hidden');
      
      timer = setInterval(() => {
        if (timeLeft > 0) {
          timeLeft--;
          updateDisplay();
        } else {
          clearInterval(timer);
          isRunning = false;
          var activeBtn = document.querySelector('.mode-btn[class*="bg-white"]');
          var label = activeBtn ? activeBtn.innerText : 'Fokus';
          sessionCount++;
          localStorage.setItem('pomodoroSessions', sessionCount);
          showEndNotification(label);
          if (iconPlay) iconPlay.classList.remove('hidden');
          if (iconPause) iconPause.classList.add('hidden');
        }
      }, 1000);
    }
  }

  function setMode(mins, color, label) {
    clearInterval(timer);
    isRunning = false;
    timeLeft = mins * 60;
    updateDisplay();
    
    // Update UI Colors (via THEMES mapping — NOT template strings)
    const theme = THEMES[color] || THEMES.rose;
    if(display) display.className = theme.display;
    if(toggleBtn) toggleBtn.className = theme.toggle;      if (statusText) statusText.innerText = label;
    
    // Update session count display (only show after first session)
    var sessionDisplay = document.getElementById('session-count');
    if (sessionDisplay) {
      if (sessionCount > 0) {
        sessionDisplay.classList.remove('hidden');
        sessionDisplay.textContent = (window._tToast ? window._tToast('Sesi Selesai: ') + sessionCount : 'Selesai: ' + sessionCount);
      }
    }
    
    if (iconPlay) iconPlay.classList.remove('hidden');
    if (iconPause) iconPause.classList.add('hidden');
  }

  // Events
  if (toggleBtn) toggleBtn.addEventListener('click', toggleTimer);
  
  if (resetBtn) resetBtn.addEventListener('click', function() {
    var activeBtn = document.querySelector('.mode-btn[class*="bg-white"]');
    var mins = 25;
    if (activeBtn && activeBtn.dataset && activeBtn.dataset.time) {
      mins = parseInt(activeBtn.dataset.time);
    }
    timeLeft = mins * 60;
    clearInterval(timer);
    isRunning = false;
    updateDisplay();
    if (iconPlay) iconPlay.classList.remove('hidden');
    if (iconPause) iconPause.classList.add('hidden');
  });

  modeBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      // Styles Reset
      modeBtns.forEach(b => b.className = "mode-btn flex-1 py-2 text-sm font-medium text-matte-500 hover:text-matte-700 dark:text-matte-400 transition-all");
      
      // Active Style (via THEMES mapping — NOT template strings)
      var color = e.target.dataset.color;
      var theme = THEMES[color] || THEMES.rose;
      e.target.className = theme.modeActive;

      // Logic
      var mins = parseInt(e.target.dataset.time);
      var label = e.target.innerText;
      setMode(mins, color, label);
    });
  });

  // Notification toggle button
  var notifBtn = document.getElementById('notif-btn');
  if (notifBtn) notifBtn.addEventListener('click', requestNotifPermission);
  updateNotifUI();

  // Cleanup timer on SPA navigation
  document.addEventListener('astro:page-leave', () => {
    clearInterval(timer);
    isRunning = false;
  });
  });
</script>
