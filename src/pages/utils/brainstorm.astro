---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Ultimate Brainstorm & Facts">
  <div class="max-w-4xl mx-auto px-4 min-h-[85vh] flex flex-col justify-center items-center py-10">
    
    <div class="text-center mb-8 animate-on-scroll">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-matte-900 dark:text-white tracking-tight" data-i18n="header.brainstorm">
        Infinite Spark
      </h1>
      <p class="text-matte-400 dark:text-matte-300 text-lg max-w-lg mx-auto" data-i18n="header.brainstorm_desc">
        Generator ide proyek, fakta unik, dan trivia teknologi. Dilengkapi fitur translate dan statistik.
      </p>
    </div>

    <div class="w-full max-w-3xl mb-8 flex flex-col gap-4">
        
        <div class="card-base p-2 flex flex-wrap justify-center gap-2">
            <button class="tab-btn px-4 py-2 rounded-xl text-sm font-bold transition-all duration-200 bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400 shadow-sm" data-type="facts" data-i18n="tab.facts">
                🌍 Random Facts
            </button>
            <button class="tab-btn px-4 py-2 rounded-xl text-sm font-bold transition-all duration-200 text-matte-500 hover:bg-surface-hover dark:hover:bg-surface-hover" data-type="ideas" data-i18n="tab.ideas">
                🚀 App Ideas
            </button>
            <button class="tab-btn px-4 py-2 rounded-xl text-sm font-bold transition-all duration-200 text-matte-500 hover:bg-surface-hover dark:hover:bg-surface-hover" data-type="trivia" data-i18n="tab.trivia">
                💾 Tech Trivia
            </button>
            <button class="tab-btn px-4 py-2 rounded-xl text-sm font-bold transition-all duration-200 text-matte-500 hover:bg-surface-hover dark:hover:bg-surface-hover" data-type="hacks" data-i18n="tab.hacks">
                ⚡ Life Hacks
            </button>
        </div>

        <div class="flex justify-between items-center px-2">
            <div class="card-base p-2 flex items-center gap-3">
                <span class="text-xs font-bold text-matte-400 uppercase tracking-wider pl-2" data-i18n="label.mode">Mode:</span>
                <button id="mode-toggle" class="relative inline-flex h-8 w-32 items-center rounded-lg transition-colors duration-300 focus:outline-none bg-matte-200 dark:bg-surface-hover">
                    <span id="mode-indicator" class="inline-block h-6 w-14 transform rounded-md bg-white shadow-md transition duration-300 ease-in-out translate-x-1"></span>
                    <span class="absolute left-0 w-1/2 text-[10px] font-bold text-center text-matte-600 dark:text-matte-300 z-10 pointer-events-none">OFFLINE</span>
                    <span class="absolute right-0 w-1/2 text-[10px] font-bold text-center text-slate-600 dark:text-slate-300 z-10 pointer-events-none">ONLINE</span>
                </button>
            </div>
            
            <div id="status-badge" class="hidden md:flex items-center gap-2 px-3 py-1 rounded-full bg-surface-hover dark:bg-surface-hover text-[10px] font-bold uppercase tracking-widest text-matte-500">
                <span class="w-2 h-2 rounded-full bg-matte-400"></span>
                <span>Local DB</span>
            </div>
        </div>
    </div>

    <div class="card-base p-8 md:p-12 w-full max-w-2xl relative overflow-hidden group transition-all hover:shadow-amber-500/10 min-h-[300px] flex flex-col justify-between">
      
      <div class="absolute -top-6 -right-6 text-9xl opacity-5 dark:opacity-10 pointer-events-none select-none transition-transform group-hover:rotate-12">
          💡
      </div>

      <div class="relative z-10 text-center flex-1 flex flex-col justify-center">
          <span id="category-badge" class="inline-block mx-auto px-3 py-1 mb-6 text-[10px] font-bold tracking-widest uppercase rounded-full bg-amber-50 text-amber-600 dark:bg-amber-900/20 dark:text-amber-400 border border-amber-100 dark:border-amber-800 transition-all">
              DID YOU KNOW?
          </span>
          
          <h2 id="content-text" class="text-2xl md:text-3xl font-bold text-matte-800 dark:text-white leading-relaxed animate-fade-in transition-opacity duration-300">
            Tekan tombol di bawah untuk mulai mencari inspirasi...
          </h2>
      </div>

      <div class="relative z-10 flex justify-center gap-3 mt-8 pt-6 border-t border-matte-200 dark:border-surface-border">
          <button id="translate-btn" class="p-3 rounded-xl bg-surface-hover dark:bg-surface-hover text-matte-500 hover:text-blue-500 transition-colors tooltip-trigger" title="Terjemahkan">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/></svg>
          </button>
          <button id="copy-btn" class="p-3 rounded-xl bg-surface-hover dark:bg-surface-hover text-matte-500 hover:text-amber-500 transition-colors" title="Copy">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          </button>
          <button id="favorite-btn" class="p-3 rounded-xl bg-surface-hover dark:bg-surface-hover text-matte-500 hover:text-red-500 transition-colors" title="Save">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
          </button>
          <button id="share-btn" class="p-3 rounded-xl bg-surface-hover dark:bg-surface-hover text-matte-500 hover:text-blue-500 transition-colors" title="Share">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
          </button>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center gap-4">            <button id="generate-btn" class="group relative inline-flex items-center justify-center gap-3 px-12 py-4 font-bold text-white transition-all duration-200 bg-matte-900 dark:bg-white dark:text-matte-900 text-lg rounded-full focus:outline-none hover:scale-105 active:scale-95 shadow-xl shadow-amber-500/20">
            <span data-i18n="btn.generate_spark">Generate Spark</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-12 transition-transform duration-500"><path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"/><path d="M8.5 8.5v.01"/><path d="M15.5 8.5v.01"/><path d="M9 14a6 6 0 0 0 6 0"/></svg>
        </button>
        <div class="flex items-center gap-4">
            <p class="text-xs text-center text-matte-400" data-i18n="msg.press_space">Tekan Spasi untuk acak</p>
            <button id="settings-btn" class="text-xs text-matte-400 hover:text-matte-600 dark:hover:text-matte-300 transition-colors underline decoration-dotted" data-i18n="btn.settings">Pengaturan</button>
        </div>
    </div>

    <div class="mt-16 grid grid-cols-3 gap-4 w-full max-w-2xl text-center">
        <div class="card-base p-4">
            <div id="total-view" class="text-2xl font-black text-matte-800 dark:text-white">0</div>
            <div class="text-[10px] uppercase font-bold text-matte-400 mt-1" data-i18n="stat.ideas_found">Ide Ditemukan</div>
        </div>
        <div class="card-base p-4">
            <div id="fav-cat" class="text-lg font-bold text-amber-500 truncate px-2">-</div>
            <div class="text-[10px] uppercase font-bold text-matte-400 mt-1" data-i18n="stat.top_category">Top Kategori</div>
        </div>
        <div class="card-base p-4">
            <div id="daily-streak" class="text-2xl font-black text-matte-800 dark:text-white">0</div>
            <div class="text-[10px] uppercase font-bold text-matte-400 mt-1" data-i18n="stat.daily_streak">Streak Harian</div>
        </div>
    </div>

    <div id="settings-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4 backdrop-blur-sm transition-opacity animate-fade-in">
        <div class="card-base p-6 max-w-sm w-full transform scale-100 transition-transform">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-bold text-matte-800 dark:text-white" data-i18n="modal.settings_title">Pengaturan</h3>
                <button id="close-settings" class="text-matte-400 hover:text-matte-600 dark:hover:text-matte-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            
            <div class="space-y-6">
                <div>
                    <label class="block text-sm font-bold text-matte-700 dark:text-matte-300 mb-2" data-i18n="label.target_translate">Target Translate</label>
                    <label for="target-lang" class="block text-xs font-bold text-matte-500 uppercase mb-1">Bahasa Target</label>
                     <select id="target-lang" class="w-full p-3 rounded-xl bg-surface-hover dark:bg-matte-900 border border-matte-200 dark:border-surface-border focus:border-amber-500 outline-none text-matte-700 dark:text-matte-200 font-medium">
                        <option value="id" selected>🇮🇩 Indonesia</option>
                        <option value="es">🇪🇸 Spanish</option>
                        <option value="ja">🇯🇵 Japanese</option>
                        <option value="ko">🇰🇷 Korean</option>
                        <option value="fr">🇫🇷 French</option>
                        <option value="de">🇩🇪 German</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-bold text-matte-700 dark:text-matte-300 mb-2" data-i18n="label.auto_refresh">Auto-refresh (detik)</label>
                    <input type="number" id="auto-refresh" min="0" max="60" value="0" class="w-full p-3 rounded-xl bg-surface-hover dark:bg-matte-900 border border-matte-200 dark:border-surface-border focus:border-amber-500 outline-none text-matte-700 dark:text-matte-200 font-medium">
                    <p class="text-[10px] text-matte-400 mt-1" data-i18n="msg.fill_zero_disable">Isi 0 untuk mematikan.</p>
                </div>
                
                <div>
                    <label class="block text-sm font-bold text-matte-700 dark:text-matte-300 mb-2" data-i18n="label.font_size">Ukuran Font</label>
                    <label for="text-size" class="block text-xs font-bold text-matte-500 uppercase mb-1">Ukuran Teks</label>
                     <select id="text-size" class="w-full p-3 rounded-xl bg-surface-hover dark:bg-matte-900 border border-matte-200 dark:border-surface-border focus:border-amber-500 outline-none text-matte-700 dark:text-matte-200 font-medium">
                        <option value="text-xl" data-i18n="size.small">Kecil</option>
                        <option value="text-2xl" selected data-i18n="size.medium">Sedang</option>
                        <option value="text-3xl" data-i18n="size.large">Besar</option>
                        <option value="text-4xl" data-i18n="size.giant">Raksasa</option>
                    </select>
                </div>
            </div>
            
            <div class="mt-8">
                <button id="save-settings" class="w-full py-3 bg-amber-500 hover:bg-amber-600 text-white font-bold rounded-xl transition-colors shadow-lg shadow-amber-500/30" data-i18n="btn.save_changes">Simpan Perubahan</button>
            </div>
        </div>
    </div>

    <div id="favorites-section" class="hidden mt-16 w-full max-w-2xl animate-fade-in-up">
        <div class="card-base p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-bold text-matte-800 dark:text-white flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-red-500"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                    <span data-i18n="title.saved_sparks">Saved Sparks</span>
                    <span id="fav-count" class="text-xs font-bold bg-surface-hover dark:bg-surface-hover text-matte-500 px-2 py-0.5 rounded-full">0</span>
                </h3>
                <div class="flex gap-2">
                    <button id="export-favorites" class="text-xs text-slate-400 hover:text-emerald-500 transition-colors" title="Export">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    </button>
                    <button id="import-favorites" class="text-xs text-slate-400 hover:text-amber-500 transition-colors" title="Import">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    </button>
                    <button id="clear-favorites" class="text-xs font-bold text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 px-2 py-1 rounded transition-colors" data-i18n="btn.clear_all">Hapus Semua</button>
                </div>
            </div>
            <div class="mb-3">
                <input id="fav-search" type="text" placeholder="Cari favorit..." class="w-full p-2.5 text-sm rounded-xl bg-surface-hover dark:bg-matte-900 border border-matte-200 dark:border-surface-border focus:border-amber-500 outline-none text-matte-700 dark:text-matte-200">
            </div>
            <div id="favorites-list" class="space-y-3 max-h-72 overflow-y-auto custom-scrollbar pr-2" data-fav-list></div>
            <div id="fav-empty-search" class="hidden text-center py-6 text-sm text-slate-400">Tidak ada hasil yang cocok.</div>
        </div>
    </div>

  </div>
</BaseLayout>

<style is:global>
  .skeleton-shimmer {
      background: linear-gradient(90deg, transparent 0%, rgba(150,150,150,0.15) 50%, transparent 100%);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
      border-radius: 8px;
      color: transparent !important;
      min-height: 1.2em;
      user-select: none;
      pointer-events: none;
  }
  @keyframes shimmer {
      0% { background-position: -200% 0; }
      100% { background-position: 200% 0; }
  }
</style>

<script>
  // --- 1. DATABASES (Expanded) ---
  
  // App Ideas (Expanded)
  const appIdeas = [
    "Expense Tracker dengan fitur scan struk belanja (OCR).",
    "Aplikasi pencari resep berdasarkan bahan sisa di kulkas.",
    "Portfolio Generator statis berbasis Markdown untuk desainer.",
    "Ekstensi browser pemblokir spoiler film/series populer.",
    "Water Reminder dengan notifikasi suara karakter lucu.",
    "Sistem Absensi Pintar menggunakan QR Code & Geolocation.",
    "Bot Telegram pengirim ringkasan berita teknologi harian.",
    "Platform donasi barang bekas berbasis lokasi terdekat.",
    "Markdown Editor real-time dengan fitur kolaborasi tim.",
    "Clone Trello sederhana (Kanban) menggunakan React/Vue.",
    "API Generator Data Dummy (Nama Indonesia) untuk testing.",
    "Dashboard Crypto dengan alert harga real-time via WA.",
    "Manajemen Tugas Kuliah dengan matriks prioritas Eisenhower.",
    "Game Typing Speed multiplayer real-time via WebSocket.",
    "Kompresor Gambar Lokal (WebAssembly) tanpa upload server.",
    "Aplikasi Jurnal Harian dengan analisis mood AI sederhana.",
    "Sistem Booking Lapangan Futsal online.",
    "Kalkulator Gizi Harian berdasarkan foto makanan.",
    "Platform Crowdfunding khusus proyek mahasiswa.",
    "Aplikasi Manajemen Kost (Tagihan, Laporan Kerusakan).",
