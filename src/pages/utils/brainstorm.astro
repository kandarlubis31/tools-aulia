    "Game 'Tetris' terinspirasi dari permainan puzzle pentomino.",
    "Token ring adalah protokol jaringan yang menggunakan topologi ring."
  ];

  // Life Hacks (Expanded)
  const lifeHacks = [
    "Coding stuck? Coba 'Rubber Duck Debugging' (curhat ke bebek karet).",
    "Pakai Teknik Pomodoro (25 menit kerja, 5 menit istirahat) biar fokus.",
    "Tekan Win + V di Windows untuk melihat history clipboard.",
    "Di Chrome, tekan Ctrl + Shift + T untuk buka tab yang baru ditutup.",
    "Tambahkan 'ss' sebelum 'youtube.com' di URL untuk download video.",
    "Gunakan atribut 'alt' pada gambar agar SEO website naik.",
    "Jangan hafal syntax, hafalkan konsep. Syntax bisa di-Google.",
    "Minum air putih! Otak butuh hidrasi untuk logika kompleks.",
    "Tekan Ctrl + K di banyak aplikasi (Discord/Slack/VSCode) untuk search cepat.",
    "Gunakan mode 'Incognito' untuk cek harga tiket pesawat (biar murah).",
    "Matikan notifikasi HP saat deep work coding.",
    "Gunakan Password Manager, jangan pakai password yang sama di semua akun.",
    "Belajar shortcut keyboard VS Code biar coding secepat kilat.",
    "Olahraga mata 20-20-20: Tiap 20 menit, lihat objek 20 kaki, selama 20 detik.",
    "Gunakan GitHub Copilot atau ChatGPT sebagai asisten, bukan pengganti otak.",
    "Sleep coding dulu, lalu review code pagi harinya dengan pikiran segar.",
    "Gunakan Cmd/Ctrl + Shift + F di VS Code untuk search seluruh project.",
    "Aktifkan 'Wrap Guide' di editor biar baris code gak kepanjangan.",
    "Biasakan nulis commit message yang jelas: 'feat:', 'fix:', 'chore:'.",
    "Gunakan 'git stash' buat simpan sementara pekerjaan yang belum selesai.",
    "Baca error message dengan saksama — biasanya sudah ada petunjuk di situ.",
    "Jangan multitasking saat coding: satu task sampai selesai.",
    "Gunakan console.table() buat debugging array of objects di browser.",
    "Buat snippet biar coding repetitive lebih cepat.",
    "Debug dengan console.log() → kalau mentok, pakai debugger.",
    "Pelajari regex dasar: bakal berguna seumur hidup.",
    "Prioritaskan code yang mudah dibaca daripada code yang pintar tapi susah dipahami.",
    "Gunakan service worker buat caching biar web bisa akses offline.",
    "Biasakan nulis unit test: mencegah bug sebelum terjadi.",
    "Jangan lupa stretch setiap 1 jam: leher dan punggung yang sehat bikin koding makin produktif."
  ];

  // Random Facts (Expanded)
  const offlineFacts = [
    "Madu tidak pernah basi. Ditemukan di makam Mesir kuno masih bisa dimakan.",
    "Gurita punya tiga jantung dan darahnya biru.",
    "Pisang secara botani adalah buah beri, tapi stroberi bukan.",
    "Rata-rata orang menghabiskan 6 bulan hidupnya menunggu lampu merah.",
    "Semut tidak pernah tidur.",
    "Kertas tidak bisa dilipat dua lebih dari 7 kali (secara umum).",
    "Venus adalah satu-satunya planet yang berputar searah jarum jam.",
    "Siput bisa tidur selama 3 tahun.",
    "Nama asli boneka Barbie adalah Barbara Millicent Roberts.",
    "Kudanil susu-nya berwarna merah muda.",
    "Manusia berbagi 50% DNA dengan pisang.",
    "Di Jepang, ada lebih banyak hewan peliharaan daripada anak-anak.",
    "Lumba-lumba tidur dengan satu mata terbuka.",
    "Cokelat pernah digunakan sebagai mata uang oleh suku Aztec.",
    "Jerapah tidak memiliki pita suara.",
    "Hari Sabtu adalah satu-satunya hari dalam seminggu yang tidak berubah nama dari bahasa Romawi.",
    "Pelangi sebenarnya berbentuk lingkaran penuh, bukan setengah lingkaran.",
    "Suhu di permukaan Venus lebih panas dari Merkurius meski lebih jauh dari matahari.",
    "Flamingo lahir dengan warna abu-abu, baru berubah merah muda karena makan udang.",
    "Gajah adalah satu-satunya mamalia yang tidak bisa melompat.",
    "Mata burung unta lebih besar dari otaknya.",
    "Ilmuwan telah menemukan bakteri yang bisa hidup di luar angkasa selama 3 tahun.",
    "DNA manusia 99,9% identik satu sama lain.",
    "Suara kentut dari dubur bergerak dengan kecepatan sekitar 3 meter per detik.",
    "Nama panjang ibu kota Thailand, Bangkok, adalah 'Krung Thep Mahanakhon Amon Rattanakosin Mahinthara Ayuthaya Mahadilok Phop Noppharat Ratchathani Burirom Udomratchaniwet Mahasathan Amon Piman Awatan Sathit Sakkathattiya Witsanukam Prasit'.",
    "Sekitar 70% dari seluruh kucing di dunia adalah kucing liar (stray/feral).",
    "Ada lebih banyak pohon di bumi daripada bintang di galaksi Bima Sakti.",
    "Satu sendok teh bintang neutron beratnya sekitar 6 miliar ton.",
    "Bumi berputar dengan kecepatan sekitar 1.670 km/jam di khatulistiwa.",
    "Rata-rata orang menghasilkan 25.000 liter air liur seumur hidupnya.",
    "Awan rata-rata beratnya sekitar 500 ton (setara 100 gajah).",
    "Tulang femur (paha) manusia lebih kuat dari beton.",
    "Bulan menjauh dari Bumi sekitar 3,8 cm setiap tahun.",
    "Total energi yang sampai ke Bumi dari Matahari dalam 1 jam bisa memenuhi kebutuhan energi dunia selama 1 tahun.",
    "Lidah bunglon dua kali lebih panjang dari tubuhnya."
  ];

  // --- 2. STATE ---
  let currentType = 'facts'; 
  let currentContent = "";
  let originalContent = ""; // Backup for translation
  let isTranslated = false;
  let isOnline = localStorage.getItem('brainMode') === 'online';
  let favorites = JSON.parse(localStorage.getItem('brainstormFavs') || '[]');
  let userStats = JSON.parse(localStorage.getItem('brainStats') || '{"total": 0, "catCounts": {}, "lastDate": null, "streak": 0}');
  let settings = JSON.parse(localStorage.getItem('brainSettings') || '{"autoRefresh": 0, "textSize": "text-2xl", "targetLang": "id"}');
  let autoRefreshInterval = null;

  // --- 3. ELEMENTS ---
  const contentText = document.getElementById('content-text');
  const categoryBadge = document.getElementById('category-badge');
  const generateBtn = document.getElementById('generate-btn');
  const copyBtn = document.getElementById('copy-btn');
  const shareBtn = document.getElementById('share-btn');
  const favoriteBtn = document.getElementById('favorite-btn');
  const translateBtn = document.getElementById('translate-btn');
  const tabBtns = document.querySelectorAll('.tab-btn');
  const favoritesSection = document.getElementById('favorites-section');
  const favoritesList = document.getElementById('favorites-list');
  const clearFavoritesBtn = document.getElementById('clear-favorites');
  const modeToggle = document.getElementById('mode-toggle');
  const modeIndicator = document.getElementById('mode-indicator');
  const statusBadge = document.getElementById('status-badge');
  const settingsBtn = document.getElementById('settings-btn');
  const settingsModal = document.getElementById('settings-modal');
  const closeSettingsBtn = document.getElementById('close-settings');
  const saveSettingsBtn = document.getElementById('save-settings');
  const autoRefreshInput = document.getElementById('auto-refresh');
  const textSizeSelect = document.getElementById('text-size');
  const targetLangSelect = document.getElementById('target-lang');
  const totalViewEl = document.getElementById('total-view');
  const favCatEl = document.getElementById('fav-cat');
  const dailyStreakEl = document.getElementById('daily-streak');
  const favSearchInput = document.getElementById('fav-search');

  // --- 4. CORE FUNCTIONS ---

  // Update Mode UI
  function updateModeUI() {
      if (isOnline) {
          modeIndicator.style.transform = 'translateX(100%) translateX(4px)'; 
          modeIndicator.classList.add('bg-amber-400');
          modeIndicator.classList.remove('bg-white');
          
          statusBadge.innerHTML = '<span class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span><span class="text-amber-600 dark:text-amber-400">Online API</span>';
      } else {
          modeIndicator.style.transform = 'translateX(4px)';
          modeIndicator.classList.remove('bg-amber-400');
          modeIndicator.classList.add('bg-white');

          statusBadge.innerHTML = '<span class="w-2 h-2 rounded-full bg-slate-400"></span><span class="text-slate-500 dark:text-slate-400">Local DB</span>';
      }
  }

  // Stats Logic
  function trackStat(type) {
      userStats.total++;
      userStats.catCounts[type] = (userStats.catCounts[type] || 0) + 1;
      
      const today = new Date().toDateString();
      if(userStats.lastDate !== today) {
          userStats.streak = (userStats.lastDate === new Date(Date.now() - 86400000).toDateString()) 
              ? userStats.streak + 1 
              : 1;
          userStats.lastDate = today;
      }
      
      localStorage.setItem('brainStats', JSON.stringify(userStats));
      updateStatsDisplay();
  }

  function updateStatsDisplay() {
      totalViewEl.innerText = userStats.total;
      dailyStreakEl.innerText = userStats.streak;
      
      let max = 0;
      let fav = '-';
      for(const [cat, count] of Object.entries(userStats.catCounts)) {
          if(count > max) { max = count; fav = cat; }
      }
      favCatEl.innerText = fav.charAt(0).toUpperCase() + fav.slice(1);
  }

  // Settings
  function applySettings() {
      contentText.className = `${settings.textSize} font-bold text-slate-800 dark:text-slate-100 leading-relaxed animate-fade-in transition-opacity duration-300`;
      
      if (autoRefreshInterval) clearInterval(autoRefreshInterval);
      if (settings.autoRefresh > 0) autoRefreshInterval = setInterval(generateContent, settings.autoRefresh * 1000);
  }

  function getRandomItem(arr) {
      return arr[Math.floor(Math.random() * arr.length)];
  }

  // Generate Content
  async function generateContent() {
      // Reset Translation
      isTranslated = false;
      translateBtn.classList.remove('text-blue-500', 'bg-blue-100', 'dark:bg-blue-900/30');
      translateBtn.classList.add('text-slate-500', 'bg-slate-100', 'dark:bg-slate-700');

      // UI Loading
      generateBtn.disabled = true;
      generateBtn.classList.add('opacity-75', 'scale-95');
      const originalText = generateBtn.innerHTML;
      generateBtn.innerHTML = '<span class="animate-pulse">🧠 Thinking...</span>';
      
      // Add shimmer skeleton
      contentText.classList.add('skeleton-shimmer');
      
      // Animasi Text Out
      contentText.style.opacity = '0';

      setTimeout(async () => {
          let result = "";
          
          try {
              if (currentType === 'facts') {
                  if (isOnline) {
                      const res = await fetch('https://uselessfacts.jsph.pl/api/v2/facts/random');
                      const data = await res.json();
                      result = data.text;
                  } else {
                      result = getRandomItem(offlineFacts);
                  }
              } else if (currentType === 'ideas') {
                  result = getRandomItem(appIdeas);
              } else if (currentType === 'trivia') {
                  result = getRandomItem(techTrivia);
              } else {
                  result = getRandomItem(lifeHacks);
              }
          } catch (e) {
              result = getRandomItem(offlineFacts); // Fallback
              if(isOnline) showToast('Koneksi lambat, menggunakan data lokal', 'info');
          }

          // Update Content
          currentContent = result;
          originalContent = result; // Backup original
          contentText.innerText = result;
          contentText.classList.remove('skeleton-shimmer');
          trackStat(currentType);
          
          // Animasi Text In
          contentText.style.opacity = '1';
          
          // Restore Button
          generateBtn.disabled = false;
          generateBtn.classList.remove('opacity-75', 'scale-95');
          generateBtn.innerHTML = originalText;
          
          updateFavoriteButton();
      }, 300);
  }

  // Translate
  async function toggleTranslation() {
      if (isTranslated) {
          contentText.innerText = originalContent;
          currentContent = originalContent;
          isTranslated = false;
          translateBtn.classList.remove('text-blue-500', 'bg-blue-100', 'dark:bg-blue-900/30');
          translateBtn.classList.add('text-slate-500', 'bg-slate-100', 'dark:bg-slate-700');
          showToast('Kembali ke asli');
      } else {
          if (!isOnline && !navigator.onLine) {
              showToast('Fitur translate butuh internet!', 'error');
              return;
          }

          const target = settings.targetLang || 'id';
          translateBtn.disabled = true;
          translateBtn.innerHTML = '<span class="animate-spin">⏳</span>';

          try {
              const res = await fetch(`https://api.mymemory.translated.net/get?q=${encodeURIComponent(currentContent)}&langpair=en|${target}`);
              const data = await res.json();
              
              if(data.responseStatus === 200) {
                  currentContent = data.responseData.translatedText;
                  contentText.innerText = currentContent;
                  isTranslated = true;
                  
                  translateBtn.classList.remove('text-slate-500', 'bg-slate-100', 'dark:bg-slate-700');
                  translateBtn.classList.add('text-blue-500', 'bg-blue-100', 'dark:bg-blue-900/30');
                  showToast('Berhasil diterjemahkan', 'success');
              } else {
                  throw new Error('Limit API');
              }
          } catch(e) {
              showToast('Gagal translate', 'error');
          } finally {
              translateBtn.disabled = false;
              translateBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/></svg>';
          }
      }
  }

  // Switch Tabs
  function switchTab(type) {
      currentType = type;
      
      // Update UI Tabs
      tabBtns.forEach(btn => {
          if (btn.dataset.type === type) {
              btn.className = "tab-btn px-4 py-2 rounded-xl text-sm font-bold transition-all duration-200 bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400 transform scale-105 shadow-sm";
          } else {
              btn.className = "tab-btn px-4 py-2 rounded-xl text-sm font-bold transition-all duration-200 text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-700";
          }
      });

      // Update Badge Text
      const badges = {
          facts: "DID YOU KNOW?",
          ideas: "PROJECT IDEA",
          trivia: "TECH TRIVIA",
          hacks: "LIFE HACK"
      };
      categoryBadge.innerText = badges[type];

      generateContent();
  }

  // Favorites
  function updateFavoriteButton() {
      const isFav = favorites.includes(originalContent); // Check original content
      if (isFav) {
          favoriteBtn.classList.add('text-red-500', 'bg-red-50', 'dark:bg-red-900/30');
          favoriteBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>';
      } else {
          favoriteBtn.classList.remove('text-red-500', 'bg-red-50', 'dark:bg-red-900/30');
          favoriteBtn.classList.add('text-slate-500');
          favoriteBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>';
      }
  }

  function toggleFavorite() {
      if (!originalContent) return;
      
      if (favorites.includes(originalContent)) {
          favorites = favorites.filter(f => f !== originalContent);
          showToast('Dihapus dari favorit');
      } else {
          favorites.push(originalContent);
          showToast('Disimpan ke favorit!', 'success');
      }
      localStorage.setItem('brainstormFavs', JSON.stringify(favorites));
      updateFavoriteButton();
      renderFavorites();
  }

  function renderFavorites() {
      const searchTerm = (favSearchInput.value || '').toLowerCase();
      const filtered = searchTerm ? favorites.filter(f => f.toLowerCase().includes(searchTerm)) : favorites;
      
      if (favorites.length === 0) {
          favoritesSection.classList.add('hidden');
          return;
      }
      favoritesSection.classList.remove('hidden');
      
      document.getElementById('fav-count').textContent = favorites.length;
      
      if (filtered.length === 0) {
          favoritesList.innerHTML = '';
          document.getElementById('fav-empty-search').classList.remove('hidden');
          return;
      }
      document.getElementById('fav-empty-search').classList.add('hidden');
      
      favoritesList.innerHTML = filtered.map((text, i) => `
          <div class="fav-item p-3 bg-slate-50 dark:bg-slate-700 rounded-lg flex justify-between items-start group hover:bg-slate-100 dark:hover:bg-slate-600 transition-colors mb-2" data-fav-index="${favorites.indexOf(text)}">
              <p class="text-sm text-slate-700 dark:text-slate-200 line-clamp-2 cursor-pointer flex-1 fav-text">${text}</p>
              <button class="fav-remove ml-2 text-slate-400 hover:text-red-500 transition-colors" data-fav-index="${favorites.indexOf(text)}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
              </button>
          </div>
      `).join('');
  }

  // Event delegation for favorites list
  favoritesList.addEventListener('click', (e) => {
      const item = e.target.closest('.fav-item');
      if (!item) return;
      
      const index = parseInt(item.dataset.favIndex);
      const text = favorites[index];
      if (!text) return;
      
      // Check if the click was on the remove button
      if (e.target.closest('.fav-remove')) {
          favorites.splice(index, 1);
          localStorage.setItem('brainstormFavs', JSON.stringify(favorites));
          renderFavorites();
          updateFavoriteButton();
          return;
      }
      
      // Otherwise load the favorite
      currentContent = text;
      originalContent = text;
      contentText.innerText = text;
      
      isTranslated = false;
      translateBtn.classList.remove('text-blue-500', 'bg-blue-100', 'dark:bg-blue-900/30');
      translateBtn.classList.add('text-slate-500', 'bg-slate-100', 'dark:bg-slate-700');
      
      updateFavoriteButton();
      window.scrollTo({top:0, behavior:'smooth'});
  });

  // --- ACTIONS ---
  
  modeToggle.addEventListener('click', () => {
      isOnline = !isOnline;
      localStorage.setItem('brainMode', isOnline ? 'online' : 'offline');
      updateModeUI();
      generateContent();
  });

  tabBtns.forEach(btn => {
      btn.addEventListener('click', () => switchTab(btn.dataset.type));
  });

  generateBtn.addEventListener('click', generateContent);
  favoriteBtn.addEventListener('click', toggleFavorite);
  translateBtn.addEventListener('click', toggleTranslation);

  copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(currentContent);
      showToast('Teks disalin!', 'success');
  });

  shareBtn.addEventListener('click', async () => {
      const fullMessage = `"${currentContent}"\n\n✨ Inspirasi via ToolsAulia:\n${window.location.href}`;
      
      if (navigator.share) {
          try {
              await navigator.share({ title: 'Spark Idea', text: fullMessage });
          } catch(e) {
              if(e.name !== 'AbortError') {
                  navigator.clipboard.writeText(fullMessage);
                  showToast('Link & Teks disalin!');
              }
          }
      } else {
          navigator.clipboard.writeText(fullMessage);
          showToast('Link & Teks disalin!');
      }
  });

  // Settings
  // Settings Modal Open/Close
  function closeSettingsModal() {
      settingsModal.classList.add('hidden');
  }

  settingsBtn.addEventListener('click', () => {
      settingsModal.classList.remove('hidden');
      autoRefreshInput.value = settings.autoRefresh;
      textSizeSelect.value = settings.textSize;
      targetLangSelect.value = settings.targetLang || 'id';
  });

  closeSettingsBtn.addEventListener('click', closeSettingsModal);

  // Backdrop click
  settingsModal.addEventListener('click', (e) => {
      if (e.target === settingsModal) closeSettingsModal();
  });

  // Escape key
  document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !settingsModal.classList.contains('hidden')) {
          closeSettingsModal();
      }
  });

  saveSettingsBtn.addEventListener('click', () => {
      settings = {
          autoRefresh: parseInt(autoRefreshInput.value),
          textSize: textSizeSelect.value,
          targetLang: targetLangSelect.value
      };
      localStorage.setItem('brainSettings', JSON.stringify(settings));
      applySettings();
      settingsModal.classList.add('hidden');
      showToast('Pengaturan disimpan!', 'success');
  });

  clearFavoritesBtn.addEventListener('click', () => {
      if(confirm('Hapus semua favorit?')) {
          favorites = [];
          localStorage.setItem('brainstormFavs', JSON.stringify(favorites));
          renderFavorites();
          updateFavoriteButton();
          showToast('Semua favorit dihapus!');
      }
  });

  // Favorites search with debounce
  let searchTimer;
  favSearchInput.addEventListener('input', () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(renderFavorites, 100);
  });

  // Export favorites
  document.getElementById('export-favorites').addEventListener('click', () => {
      if (favorites.length === 0) {
          showToast('Belum ada favorit untuk di-export', 'warning');
          return;
      }
      const blob = new Blob([JSON.stringify(favorites, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `brainstorm-favorites-${new Date().toISOString().slice(0,10)}.json`;
      a.click();
      URL.revokeObjectURL(url);
      showToast('Favorit di-export!', 'success');
  });

  // Import favorites
  document.getElementById('import-favorites').addEventListener('click', () => {
      const input = document.createElement('input');
      input.type = 'file';
      input.accept = '.json';
      input.onchange = (e) => {
          const file = e.target.files[0];
          if (!file) return;
          const reader = new FileReader();
          reader.onload = (ev) => {
              let imported;
              try {
                  imported = JSON.parse(ev.target.result);
                  if (!Array.isArray(imported)) throw new Error('not array');
              } catch (parseErr) {
                  showToast('File JSON tidak valid!', 'error');
                  return;
              }
              if (imported.length === 0) {
                  showToast('File kosong atau format salah', 'error');
                  return;
              }
              // Merge with existing, dedup
              imported.forEach(text => {
                  if (!favorites.includes(text)) favorites.push(text);
              });
              localStorage.setItem('brainstormFavs', JSON.stringify(favorites));
              renderFavorites();
              updateFavoriteButton();
              showToast(`${imported.length} favorit di-import!`, 'success');
          };
          reader.readAsText(file);
      };
      input.click();
  });

  document.addEventListener('keydown', (e) => {
      if (e.code === 'Space' && e.target.tagName !== 'BUTTON' && e.target.tagName !== 'SELECT' && e.target.tagName !== 'INPUT' && e.target.tagName !== 'TEXTAREA') {
          e.preventDefault();
          generateContent();
      }
      if ((e.ctrlKey || e.metaKey) && e.key === 's') {
        e.preventDefault();
        settingsBtn.click();
      }
  });

  // Init
  document.addEventListener('astro:page-load', () => {
      updateModeUI();
      renderFavorites();
      updateStatsDisplay();
      applySettings();
      generateContent(); 
  });

  // --- TOAST SYSTEM ---
  function showToast(message, type = 'info') {
      const existing = document.querySelector('.brain-toast');
      if (existing) existing.remove();
      
      const toast = document.createElement('div');
      toast.className = 'brain-toast fixed bottom-8 left-1/2 -translate-x-1/2 z-50 px-5 py-3 rounded-2xl shadow-2xl border text-sm font-bold transition-all duration-500 animate-fade-in-up';
      
      const colors = {
          success: 'bg-emerald-50 dark:bg-emerald-900/80 border-emerald-200 dark:border-emerald-700 text-emerald-700 dark:text-emerald-300',
          error: 'bg-red-50 dark:bg-red-900/80 border-red-200 dark:border-red-700 text-red-700 dark:text-red-300',
          info: 'bg-blue-50 dark:bg-blue-900/80 border-blue-200 dark:border-blue-700 text-blue-700 dark:text-blue-300',
          warning: 'bg-amber-50 dark:bg-amber-900/80 border-amber-200 dark:border-amber-700 text-amber-700 dark:text-amber-300'
      };
      
      toast.className = `brain-toast fixed bottom-8 left-1/2 -translate-x-1/2 z-50 px-5 py-3 rounded-2xl shadow-2xl border text-sm font-bold transition-all duration-500 animate-fade-in-up ${colors[type] || colors.info}`;
      toast.textContent = message;
      document.body.appendChild(toast);
      
      setTimeout(() => {
          toast.style.opacity = '0';
          toast.style.transform = 'translateX(-50%) translateY(20px)';
          setTimeout(() => toast.remove(), 400);
      }, 2500);
  }

  // Replace all window._tToast calls with local showToast
  // (Already replaced above)

</script>