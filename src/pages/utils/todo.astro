---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Todo List">
  <div class="max-w-2xl mx-auto px-4 min-h-[70vh]">
    <div class="text-center mb-8 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-matte-900 dark:text-white">
        Todo List
      </h1>
      <p class="text-matte-400 dark:text-matte-300" data-i18n="header.todo_desc">
        Catat tugas harian Anda. Tersimpan otomatis di browser.
      </p>
    </div>

    <div class="card-base overflow-hidden animate-fade-in">
      
      <div class="p-4 bg-matte-100 dark:bg-surface-hover border-b border-matte-200 dark:border-surface-border flex gap-2">
         <input type="text" id="todo-input" placeholder="Apa yang ingin dikerjakan?" data-i18n-attr="placeholder" data-i18n="ph.what_to_do" class="flex-1 p-3 rounded-lg bg-white dark:bg-surface-elevated border border-matte-200 dark:border-surface-border outline-none focus:border-accent-blue transition-colors" />
         <button id="add-btn" class="bg-matte-900 dark:bg-white text-white dark:text-matte-900 font-semibold py-2 px-6 rounded-lg transition-all active:scale-95" data-i18n="btn.add">
            Tambah
         </button>
      </div>

      <ul id="todo-list" class="divide-y divide-matte-100 dark:divide-surface-border max-h-[500px] overflow-y-auto">
         <li id="empty-state" class="p-8 text-center text-matte-400 flex flex-col items-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mb-2 opacity-50"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            <p data-i18n="text.no_tasks">Belum ada tugas. Yuk mulai produktif!</p>
         </li>
      </ul>

      <div class="p-3 bg-matte-100 dark:bg-surface-hover border-t border-matte-200 dark:border-surface-border text-xs text-matte-400 flex justify-between items-center">
         <span id="task-count" data-i18n="label.tasks_remaining">0 Tugas</span>
         <button id="clear-all" class="text-rose-500 hover:text-rose-600 font-bold hover:underline" data-i18n="btn.delete_all">Hapus Semua</button>
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  import { useLocalHistory } from '../../composables/useLocalHistory';

  const input = document.getElementById('todo-input') as HTMLInputElement;
  const addBtn = document.getElementById('add-btn');
  const list = document.getElementById('todo-list');
  const emptyState = document.getElementById('empty-state');
  const taskCount = document.getElementById('task-count');
  const clearAllBtn = document.getElementById('clear-all');

  interface Todo {
    id: number;
    text: string;
    completed: boolean;
  }

  const todoHistory = useLocalHistory<Todo>('my_todos');
  let todos: Todo[] = todoHistory.getAll();

  function saveAndRender() {
    todoHistory.update(todos);
    render();
  }

  function render() {
    if (!list) return;
    
    // Clear list but keep empty state ref
    list.innerHTML = ''; 

    if (todos.length === 0) {
        list.appendChild(emptyState as Node);
        emptyState.style.display = 'flex';
    } else {
        emptyState.style.display = 'none';
        
        todos.forEach(todo => {
            const li = document.createElement('li');
            li.className = `p-4 flex items-center justify-between group transition-colors hover:bg-matte-100 dark:hover:bg-surface-hover ${todo.completed ? 'bg-matte-100/50 dark:bg-surface-hover/50' : ''}`;
            
            li.innerHTML = `
                <div class="flex items-center gap-3 flex-1 cursor-pointer toggle-area">
                    <div class="w-6 h-6 rounded-full border-2 flex items-center justify-center transition-colors ${todo.completed ? 'border-accent-blue bg-accent-blue' : 'border-matte-300 dark:border-matte-500'}">
                        ${todo.completed ? '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="text-white"><polyline points="20 6 9 17 4 12"/></svg>' : ''}
                    </div>
                    <span class="text-sm font-medium ${todo.completed ? 'text-matte-400 line-through' : 'text-matte-700 dark:text-white'}">${todo.text}</span>
                </div>
                <button class="delete-btn p-2 text-matte-400 hover:text-red-500 transition-colors opacity-0 group-hover:opacity-100" aria-label="Delete">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                </button>
            `;

            // Event Listeners for Dynamic Items
            const toggleArea = li.querySelector('.toggle-area');
            const delBtn = li.querySelector('.delete-btn');

            toggleArea?.addEventListener('click', () => {
                todo.completed = !todo.completed;
                saveAndRender();
            });

            delBtn?.addEventListener('click', () => {
                todos = todos.filter(t => t.id !== todo.id);
                saveAndRender();
            });

            list.appendChild(li);
        });
    }

    var remaining = todos.filter(t => !t.completed).length;
    var taskLabel = (window._tToast) ? window._tToast('Tugas Tersisa') : 'Tugas Tersisa';
    if(taskCount) taskCount.innerText = remaining + ' ' + taskLabel;
  }

  function addTodo() {
    const text = input.value.trim();
    if (!text) return;

    todos.unshift({
        id: Date.now(),
        text: text,
        completed: false
    });

    input.value = '';
    saveAndRender();
  }

  addBtn?.addEventListener('click', addTodo);
  input?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') addTodo();
  });

  clearAllBtn?.addEventListener('click', () => {
    var confirmMsg = (window.i18n && window.i18n.t) ? window.i18n.t('confirm.delete_all', 'Hapus semua tugas?') : 'Hapus semua tugas?';
    if(confirm(confirmMsg)) {
        todos = [];
        saveAndRender();
    }
  });

  // Init
  render();
</script>
