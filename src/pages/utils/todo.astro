---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Todo List">
  <div class="max-w-2xl mx-auto px-4 min-h-[70vh]">
    <div class="text-center mb-8 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-violet-500 to-purple-500">
        Todo List
      </h1>
      <p class="text-slate-600 dark:text-slate-400">
        Catat tugas harian Anda. Tersimpan otomatis di browser.
      </p>
    </div>

    <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-xl overflow-hidden animate-fade-in">
      
      <div class="p-4 bg-slate-50 dark:bg-slate-900 border-b border-slate-200 dark:border-slate-700 flex gap-2">
         <input type="text" id="todo-input" placeholder="Apa yang ingin dikerjakan?" class="flex-1 p-3 rounded-lg bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-600 outline-none focus:border-violet-500 transition-colors" />
         <button id="add-btn" class="bg-violet-600 hover:bg-violet-700 text-white font-bold py-2 px-6 rounded-lg shadow-md transition-transform active:scale-95">
            Tambah
         </button>
      </div>

      <ul id="todo-list" class="divide-y divide-slate-100 dark:divide-slate-700 max-h-[500px] overflow-y-auto">
         <li id="empty-state" class="p-8 text-center text-slate-400 flex flex-col items-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mb-2 opacity-50"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            <p>Belum ada tugas. Yuk mulai produktif!</p>
         </li>
      </ul>

      <div class="p-3 bg-slate-50 dark:bg-slate-900 border-t border-slate-200 dark:border-slate-700 text-xs text-slate-500 flex justify-between items-center">
         <span id="task-count">0 Tugas</span>
         <button id="clear-all" class="text-red-500 hover:text-red-600 font-bold hover:underline">Hapus Semua</button>
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  const input = document.getElementById('todo-input') as HTMLInputElement;
  const addBtn = document.getElementById('add-btn');
  const list = document.getElementById('todo-list');
  const emptyState = document.getElementById('empty-state');
  const taskCount = document.getElementById('task-count');
  const clearAllBtn = document.getElementById('clear-all');

  interface Todo {
    id: number;
    text: string;
    completed: boolean;
  }

  let todos: Todo[] = JSON.parse(localStorage.getItem('my_todos') || '[]');

  function saveAndRender() {
    localStorage.setItem('my_todos', JSON.stringify(todos));
    render();
  }

  function render() {
    if (!list) return;
    
    // Clear list but keep empty state ref
    list.innerHTML = ''; 

    if (todos.length === 0) {
        list.appendChild(emptyState as Node);
        // @ts-ignore
        emptyState.style.display = 'flex';
    } else {
        // @ts-ignore
        emptyState.style.display = 'none';
        
        todos.forEach(todo => {
            const li = document.createElement('li');
            li.className = `p-4 flex items-center justify-between group transition-colors hover:bg-slate-50 dark:hover:bg-slate-700/50 ${todo.completed ? 'bg-slate-50 dark:bg-slate-900/50' : ''}`;
            
            li.innerHTML = `
                <div class="flex items-center gap-3 flex-1 cursor-pointer toggle-area">
                    <div class="w-6 h-6 rounded-full border-2 flex items-center justify-center transition-colors ${todo.completed ? 'border-violet-500 bg-violet-500' : 'border-slate-300 dark:border-slate-500'}">
                        ${todo.completed ? '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="text-white"><polyline points="20 6 9 17 4 12"/></svg>' : ''}
                    </div>
                    <span class="text-sm font-medium ${todo.completed ? 'text-slate-400 line-through' : 'text-slate-700 dark:text-slate-200'}">${todo.text}</span>
                </div>
                <button class="delete-btn p-2 text-slate-400 hover:text-red-500 transition-colors opacity-0 group-hover:opacity-100" aria-label="Delete">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                </button>
            `;

            // Event Listeners for Dynamic Items
            const toggleArea = li.querySelector('.toggle-area');
            const delBtn = li.querySelector('.delete-btn');

            toggleArea?.addEventListener('click', () => {
                todo.completed = !todo.completed;
                saveAndRender();
            });

            delBtn?.addEventListener('click', () => {
                todos = todos.filter(t => t.id !== todo.id);
                saveAndRender();
            });

            list.appendChild(li);
        });
    }

    if(taskCount) taskCount.innerText = `${todos.filter(t => !t.completed).length} Tugas Tersisa`;
  }

  function addTodo() {
    const text = input.value.trim();
    if (!text) return;

    todos.unshift({
        id: Date.now(),
        text: text,
        completed: false
    });

    input.value = '';
    saveAndRender();
  }

  addBtn?.addEventListener('click', addTodo);
  input?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') addTodo();
  });

  clearAllBtn?.addEventListener('click', () => {
    if(confirm('Hapus semua tugas?')) {
        todos = [];
        saveAndRender();
    }
  });

  // Init
  render();
</script>
