---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Rotate PDF Pages">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js" async></script>
  <script is:inline async>
    (function waitForPdfjs() {
      if (window.pdfjsLib) {
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
      } else {
        setTimeout(waitForPdfjs, 50);
      }
    })();
  </script>

  <div class="max-w-6xl mx-auto px-4 min-h-[60vh]">
    
    <div class="text-center mb-10 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600">
        Rotate PDF Pages
      </h1>
      <p class="text-slate-600 dark:text-slate-400" data-i18n="header.rotate_desc">
        Perbaiki orientasi halaman PDF yang terbalik. Kualitas render High-Definition.
      </p>
    </div>

    <div 
      id="drop-zone"
      class="max-w-2xl mx-auto border-3 border-dashed border-slate-300 dark:border-slate-600 rounded-3xl p-12 cursor-pointer hover:border-blue-500 hover:bg-blue-50 dark:hover:bg-slate-800/50 transition-all group text-center animate-on-scroll"
    >
      <div class="w-20 h-20 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
      </div>
      <h3 class="text-2xl font-bold text-slate-700 dark:text-slate-200 mb-2" data-i18n="upload.select_pdf">Pilih File PDF</h3>
      <p class="text-slate-500 dark:text-slate-400 font-medium" data-i18n="upload.drop_pdf">Klik atau tarik file ke area ini</p>
      <input type="file" id="file-input" accept="application/pdf" class="hidden" />
    </div>

    <div id="loading" class="hidden flex-col items-center justify-center py-20">
      <div class="animate-spin rounded-full h-12 w-12 border-4 border-slate-200 border-t-blue-600 mb-4"></div>
      <p class="text-slate-600 dark:text-slate-300 font-semibold animate-pulse" data-i18n="msg.rendering_pdf">Sedang merender halaman PDF...</p>
      <p class="text-xs text-slate-400 mt-2" data-i18n="msg.large_file_wait">Untuk file besar, proses ini memakan waktu beberapa detik.</p>
    </div>

    <div id="editor-area" class="hidden pb-20">
      
      <div class="sticky top-20 z-40 mx-auto max-w-4xl bg-slate-900/90 dark:bg-slate-800/90 backdrop-blur-md text-white p-4 rounded-xl shadow-2xl mb-8 flex flex-wrap gap-4 items-center justify-between border border-slate-700/50 ring-1 ring-white/10">
        
        <div class="flex items-center gap-3">
          <button id="rotate-all-btn" class="px-4 py-2 bg-slate-700 hover:bg-slate-600 rounded-lg text-sm font-semibold transition-colors flex items-center gap-2 border border-slate-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
            <span data-i18n="btn.rotate_all">Putar Semua</span>
          </button>
          <button id="reset-rotations-btn" class="px-4 py-2 hover:bg-red-500/20 hover:text-red-400 rounded-lg text-sm font-semibold transition-colors text-slate-300" data-i18n="btn.reset">
            Reset
          </button>
        </div>          <button id="save-btn" class="bg-blue-600 hover:bg-blue-500 text-white font-bold py-2.5 px-6 rounded-lg shadow-lg shadow-blue-500/30 transition-all active:scale-95 flex items-center gap-2 border border-blue-400/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            <span data-i18n="btn.save_pdf">Simpan PDF</span>
          </button>
      </div>

      <div id="pages-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
        </div>
    </div>

  </div>
</BaseLayout>

<script>
  let PDFDocument, degrees;

  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const loading = document.getElementById('loading');
  const editorArea = document.getElementById('editor-area');
  const pagesGrid = document.getElementById('pages-grid');
  const saveBtn = document.getElementById('save-btn');
  const rotateAllBtn = document.getElementById('rotate-all-btn');
  const resetRotationsBtn = document.getElementById('reset-rotations-btn');

  let currentFile: File | null = null;
  let pageRotations: number[] = []; 
  let totalPages = 0;

  // --- 1. HANDLE UPLOAD ---
  dropZone?.addEventListener('click', () => fileInput.click());

  fileInput?.addEventListener('change', async (e) => {
    if (fileInput.files && fileInput.files[0]) {
      const file = fileInput.files[0];
      if (file.type !== 'application/pdf') return alert(window._tToast ? window._tToast('Mohon upload file PDF!') : 'Mohon upload file PDF!');
      
      currentFile = file;
      await renderThumbnails(file);
    }
  });

  // --- 2. RENDER PAGES (VISUAL HIGH QUALITY) ---
  async function renderThumbnails(file: File) {
    if(!dropZone || !loading || !editorArea || !pagesGrid) return;

    dropZone.classList.add('hidden');
    loading.classList.remove('hidden');
    loading.classList.add('flex'); // Pastikan flex tampil
    editorArea.classList.add('hidden');
    pagesGrid.innerHTML = '';
    
    try {
      const arrayBuffer = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument(arrayBuffer).promise;
      totalPages = pdf.numPages;
      pageRotations = new Array(totalPages).fill(0); 

      loading.classList.add('hidden');
      loading.classList.remove('flex');
      editorArea.classList.remove('hidden');

      for (let i = 1; i <= totalPages; i++) {
        const page = await pdf.getPage(i);
        
        // --- PERBAIKAN KUALITAS DI SINI ---
        // Scale 1.5 biar tajam di layar modern (sebelumnya 0.5 bikin burik)
        const viewport = page.getViewport({ scale: 1.5 }); 

        const canvas = document.createElement('canvas');
        const context = canvas.getContext('2d');
        canvas.height = viewport.height;
        canvas.width = viewport.width;
        
        // CSS memaksa canvas fit ke container, tapi resolusi asli tetap tinggi
        canvas.className = "w-full h-auto rounded shadow-sm transition-transform duration-300 pointer-events-none bg-white";

        await page.render({ canvasContext: context, viewport: viewport }).promise;

        // UI Wrapper
        const wrapper = document.createElement('div');
        wrapper.className = "relative group flex flex-col gap-2";
        
        const imgContainer = document.createElement('div');
        imgContainer.className = "relative bg-slate-200 dark:bg-slate-700 rounded-lg overflow-hidden border-2 border-transparent hover:border-blue-500 cursor-pointer transition-all p-1 shadow-md";
        imgContainer.setAttribute('data-page', (i-1).toString());
        
        const badge = document.createElement('span');
        badge.className = "absolute top-2 left-2 bg-slate-900 text-white text-[10px] font-bold px-2 py-1 rounded z-10 shadow-sm";
        badge.innerText = `${i}`;

        const overlay = document.createElement('div');
        overlay.className = "absolute inset-0 bg-blue-900/20 dark:bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center z-20 backdrop-blur-[1px]";
        overlay.innerHTML = `<div class="bg-white text-blue-600 p-3 rounded-full shadow-xl transform scale-90 group-hover:scale-110 transition-transform"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg></div>`;

        imgContainer.appendChild(badge);
        imgContainer.appendChild(canvas);
        imgContainer.appendChild(overlay);

        imgContainer.addEventListener('click', () => {
          const idx = i - 1;
          pageRotations[idx] = (pageRotations[idx] + 90) % 360;
          canvas.style.transform = `rotate(${pageRotations[idx]}deg)`;
        });

        wrapper.appendChild(imgContainer);
        pagesGrid.appendChild(wrapper);
      }

    } catch (err) {
      // console.error(err);
      alert(window._tToast ? window._tToast('Gagal memuat PDF. File mungkin rusak.') : 'Gagal memuat PDF. File mungkin rusak.');
      loading.classList.add('hidden');
      dropZone.classList.remove('hidden');
    }
  }

  // --- 3. CONTROLS ---
  rotateAllBtn?.addEventListener('click', () => {
    const canvases = document.querySelectorAll('canvas');
    canvases.forEach((canvas, idx) => {
      pageRotations[idx] = (pageRotations[idx] + 90) % 360;
      canvas.style.transform = `rotate(${pageRotations[idx]}deg)`;
    });
  });

  resetRotationsBtn?.addEventListener('click', () => {
    const canvases = document.querySelectorAll('canvas');
    pageRotations.fill(0);
    canvases.forEach((canvas) => {
      (canvas as HTMLElement).style.transform = `rotate(0deg)`;
    });
  });

  // --- 4. SAVE ---
  saveBtn?.addEventListener('click', async () => {
    if (!currentFile) return;

    // Lazy load pdf-lib
    if (!PDFDocument) {
      const pdfLib = await import('pdf-lib');
      PDFDocument = pdfLib.PDFDocument;
      degrees = pdfLib.degrees;
    }

    const originalText = saveBtn.innerHTML;
    saveBtn.innerHTML = `
      <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
      Menyimpan...
    `;
    saveBtn.classList.add('opacity-75', 'cursor-not-allowed');

    try {
      const arrayBuffer = await currentFile.arrayBuffer();
      const pdfDoc = await PDFDocument.load(arrayBuffer);
      const pages = pdfDoc.getPages();

      pages.forEach((page, idx) => {
        const rotation = pageRotations[idx];
        if (rotation > 0) {
          const currentRotation = page.getRotation().angle;
          page.setRotation(degrees(currentRotation + rotation));
        }
      });

      const pdfBytes = await pdfDoc.save();
      const blob = new Blob([pdfBytes], { type: 'application/pdf' });
      const link = document.createElement('a');
      link.href = URL.createObjectURL(blob);
      link.download = `rotated-${currentFile.name}`;
      link.click();

    } catch (err) {
      // console.error(err);
      alert(window._tToast ? window._tToast("Gagal menyimpan PDF.") : "Gagal menyimpan PDF.");
    } finally {
      saveBtn.innerHTML = originalText;
      saveBtn.classList.remove('opacity-75', 'cursor-not-allowed');
    }
  });
</script>