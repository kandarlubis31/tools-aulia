---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Extract PDF Pages">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js" async></script>
  <script is:inline async>
    (function waitForPdfjs() {
      if (window.pdfjsLib) {
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
      } else {
        setTimeout(waitForPdfjs, 50);
      }
    })();
  </script>
  <script type="module" src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>

  <div class="max-w-6xl mx-auto px-4 min-h-[80vh]">
    <div class="text-center mb-8 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-emerald-500 to-teal-500">
        Extract Pages
      </h1>
      <p class="text-matte-600 dark:text-matte-400">
        Pilih halaman yang ingin Anda ambil dan simpan sebagai file terpisah.
      </p>
    </div>

    <div id="drop-zone" class="max-w-2xl mx-auto border-3 border-dashed border-matte-300 dark:border-matte-600 rounded-3xl p-12 cursor-pointer hover:border-emerald-500 hover:bg-emerald-50 dark:hover:bg-matte-800/50 transition-all group text-center animate-on-scroll">
      <div class="w-20 h-20 bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M16 22h2a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v4"/><path d="M14 22v-4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2Z"/></svg>
      </div>
      <h3 class="text-2xl font-bold text-matte-700 dark:text-matte-200 mb-2">Pilih PDF</h3>
      <input type="file" id="file-input" accept="application/pdf" class="hidden" />
    </div>

    <div id="workspace" class="hidden pb-20 animate-fade-in">
      <div class="sticky top-24 z-40 bg-white/90 dark:bg-matte-900/90 backdrop-blur-md p-4 rounded-xl border border-matte-200 dark:border-matte-700 shadow-lg mb-8 flex flex-wrap gap-4 justify-between items-center max-w-4xl mx-auto">
         <div class="flex gap-2">
            <button id="select-all" class="text-xs font-bold px-3 py-1.5 bg-matte-100 dark:bg-matte-700 rounded hover:bg-matte-200 transition">Pilih Semua</button>
            <button id="clear-all" class="text-xs font-bold px-3 py-1.5 bg-matte-100 dark:bg-matte-700 rounded hover:bg-matte-200 transition">Reset</button>
         </div>
         <button id="save-btn" disabled class="bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-2 px-6 rounded-lg shadow-lg transition-all active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download Terpilih
         </button>
      </div>

      <div id="pages-grid" class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4"></div>
    </div>
  </div>
</BaseLayout>

<script type="module">
  const { PDFDocument } = await import('https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.esm.js');

  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input');
  const workspace = document.getElementById('workspace');
  const pagesGrid = document.getElementById('pages-grid');
  const saveBtn = document.getElementById('save-btn');
  const selectAllBtn = document.getElementById('select-all');
  const clearAllBtn = document.getElementById('clear-all');

  let currentFile = null;
  let selectedPages = new Set();

  dropZone.addEventListener('click', () => fileInput.click());

  fileInput.addEventListener('change', async (e) => {
    if (fileInput.files[0]) {
      currentFile = fileInput.files[0];
      dropZone.classList.add('hidden');
      workspace.classList.remove('hidden');
      await renderThumbnails(currentFile);
    }
  });

  async function renderThumbnails(file) {
    const arrayBuffer = await file.arrayBuffer();
    const pdf = await pdfjsLib.getDocument(arrayBuffer).promise;
    const totalPages = pdf.numPages;

    pagesGrid.innerHTML = '';

    for (let i = 1; i <= totalPages; i++) {
      const page = await pdf.getPage(i);
      const viewport = page.getViewport({ scale: 0.5 });
      const canvas = document.createElement('canvas');
      const context = canvas.getContext('2d');
      canvas.width = viewport.width;
      canvas.height = viewport.height;
      canvas.className = "w-full h-auto rounded shadow-sm pointer-events-none";
      await page.render({ canvasContext: context, viewport: viewport }).promise;

      // Card
      const card = document.createElement('div');
      card.className = "relative bg-matte-200 dark:bg-matte-800 p-1 rounded-lg cursor-pointer hover:ring-2 hover:ring-emerald-500 transition-all border-4 border-transparent";
      card.dataset.index = i - 1;
      
      const badge = document.createElement('span');
      badge.className = "absolute top-2 left-2 bg-matte-900/80 text-white text-xs font-bold px-2 py-1 rounded shadow-sm z-10";
      badge.innerText = i;

      // Checkmark Overlay
      const checkmark = document.createElement('div');
      checkmark.className = "absolute inset-0 bg-emerald-500/20 hidden items-center justify-center z-20 rounded-lg check-overlay";
      checkmark.innerHTML = `<div class="bg-emerald-600 text-white p-2 rounded-full shadow-lg"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>`;

      card.appendChild(badge);
      card.appendChild(canvas);
      card.appendChild(checkmark);
      pagesGrid.appendChild(card);

      card.addEventListener('click', () => toggleSelection(i - 1, card));
    }
  }

  function toggleSelection(idx, card) {
    const check = card.querySelector('.check-overlay');
    if (selectedPages.has(idx)) {
        selectedPages.delete(idx);
        card.classList.remove('border-emerald-500');
        card.classList.add('border-transparent');
        check.classList.remove('flex');
        check.classList.add('hidden');
    } else {
        selectedPages.add(idx);
        card.classList.remove('border-transparent');
        card.classList.add('border-emerald-500');
        check.classList.remove('hidden');
        check.classList.add('flex');
    }
    saveBtn.disabled = selectedPages.size === 0;
  }

  selectAllBtn.addEventListener('click', () => {
    const cards = pagesGrid.children;
    for (let i = 0; i < cards.length; i++) {
        if (!selectedPages.has(i)) toggleSelection(i, cards[i]);
    }
  });

  clearAllBtn.addEventListener('click', () => {
    const cards = pagesGrid.children;
    for (let i = 0; i < cards.length; i++) {
        if (selectedPages.has(i)) toggleSelection(i, cards[i]);
    }
  });

  saveBtn.addEventListener('click', async () => {
    if (!currentFile || selectedPages.size === 0) return;
    saveBtn.innerText = window._tToast ? window._tToast("Memproses...") : "Memproses...";
    saveBtn.disabled = true;

    try {
      const arrayBuffer = await currentFile.arrayBuffer();
      const pdfDoc = await PDFDocument.load(arrayBuffer);
      const newPdf = await PDFDocument.create();

      const sortedIndices = Array.from(selectedPages).sort((a, b) => a - b);
      const copiedPages = await newPdf.copyPages(pdfDoc, sortedIndices);
      copiedPages.forEach(page => newPdf.addPage(page));

      const pdfBytes = await newPdf.save();
      const blob = new Blob([pdfBytes], { type: 'application/pdf' });
      const link = document.createElement('a');
      link.href = URL.createObjectURL(blob);
      link.download = `extracted-${currentFile.name}`;
      link.click();
      
      window.showToast(window._tToast ? window._tToast("Berhasil ekstrak halaman!") : "Berhasil ekstrak halaman!", "success");

    } catch (err) {
      window.showToast(window._tToast ? window._tToast("Gagal memproses PDF.") : "Gagal memproses PDF.", "error");
    } finally {
      saveBtn.innerText = window._tToast ? window._tToast("Download Terpilih") : "Download Terpilih";
      saveBtn.disabled = false;
    }
  });
</script>