---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Grayscale PDF (Photocopy Effect) with Preview">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js" async></script>
  <script is:inline async>
    (function waitForPdfjs() {
      if (window.pdfjsLib) {
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
      } else {
        setTimeout(waitForPdfjs, 50);
      }
    })();
  </script>
  <script type="module" src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>

  <div class="max-w-5xl mx-auto px-4 min-h-[70vh]">
    <div class="text-center mb-8 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-gray-600 to-matte-800 dark:from-gray-100 dark:to-gray-400">
        Grayscale PDF + Preview
      </h1>
      <p class="text-matte-600 dark:text-matte-400">
        Ubah PDF menjadi hitam putih (Efek Fotokopi). Atur kontras dan lihat hasilnya langsung.
      </p>
    </div>

    <div id="drop-zone" class="max-w-2xl mx-auto border-3 border-dashed border-matte-300 dark:border-matte-600 rounded-3xl p-12 cursor-pointer hover:border-gray-500 hover:bg-gray-100 dark:hover:bg-matte-800/50 transition-all group text-center animate-on-scroll">
      <div class="w-20 h-20 bg-gray-200 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 14h12v8H6z"/></svg>
      </div>
      <h3 class="text-2xl font-bold text-matte-700 dark:text-matte-200 mb-2">Pilih PDF Warna</h3>
      <input type="file" id="file-input" accept="application/pdf" class="hidden" />
    </div>

    <div id="workspace" class="hidden grid grid-cols-1 lg:grid-cols-5 gap-8 pb-20 animate-fade-in">
        
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white dark:bg-matte-800 p-6 rounded-2xl border border-matte-200 dark:border-matte-700 shadow-lg sticky top-24">
                <h3 id="filename" class="font-bold text-lg mb-4 truncate text-matte-700 dark:text-matte-200">filename.pdf</h3>
                
                <div class="space-y-5 mb-8">
                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <label class="text-sm font-bold text-matte-600 dark:text-matte-300">Kontras (Ketajaman)</label>
                            <span id="contrast-val" class="text-sm font-mono text-blue-600 dark:text-blue-400">150%</span>
                        </div>
                        <input type="range" id="contrast" min="100" max="250" value="150" class="w-full h-2 bg-matte-200 dark:bg-matte-700 rounded-lg appearance-none cursor-pointer accent-gray-600 dark:accent-gray-400">
                        <p class="text-xs text-matte-400 mt-1">Rekomendasi: 150% - 200% untuk teks yang jelas.</p>
                    </div>
                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <label class="text-sm font-bold text-matte-600 dark:text-matte-300">Kecerahan (Brightness)</label>
                            <span id="brightness-val" class="text-sm font-mono text-blue-600 dark:text-blue-400">110%</span>
                        </div>
                        <input type="range" id="brightness" min="80" max="150" value="110" class="w-full h-2 bg-matte-200 dark:bg-matte-700 rounded-lg appearance-none cursor-pointer accent-gray-600 dark:accent-gray-400">
                    </div>
                </div>

                <button id="convert-btn" class="w-full bg-gray-800 hover:bg-gray-900 dark:bg-gray-700 dark:hover:bg-gray-600 text-white font-bold py-3 px-6 rounded-xl shadow-lg transition-all active:scale-95 flex items-center justify-center gap-2">
                    Proses Semua Halaman
                </button>

                <div id="progress-container" class="hidden mt-4">
                    <div class="w-full bg-matte-200 dark:bg-matte-700 rounded-full h-3 mb-2 overflow-hidden">
                        <div id="progress-bar" class="bg-blue-600 h-3 rounded-full transition-all duration-200" style="width: 0%"></div>
                    </div>
                    <p id="status-text" class="text-center text-xs text-matte-500 animate-pulse">Memproses...</p>
                </div>
            </div>
        </div>

        <div class="lg:col-span-3 flex flex-col items-center">
            <div class="bg-matte-200 dark:bg-matte-900 p-4 rounded-xl border border-matte-300 dark:border-matte-700 shadow-inner w-full flex flex-col items-center min-h-[400px]">
               <p class="text-xs text-matte-500 font-mono mb-2 self-start">Live Preview (Halaman 1)</p>
               
               <div class="relative shadow-2xl bg-white rounded-sm overflow-hidden max-w-full">
                   <canvas id="preview-canvas" class="block max-w-full h-auto"></canvas>
               </div>
            </div>
        </div>

    </div>

  </div>
</BaseLayout>

<script type="module">
  const { PDFDocument } = await import('https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.esm.js');

  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input');
  const workspace = document.getElementById('workspace');
  const filenameDisplay = document.getElementById('filename');
  const convertBtn = document.getElementById('convert-btn');
  
  const progressBar = document.getElementById('progress-bar');
  const progressContainer = document.getElementById('progress-container');
  const statusText = document.getElementById('status-text');
  
  // Preview Elements
  const previewCanvas = document.getElementById('preview-canvas');
  const previewCtx = previewCanvas.getContext('2d');
  // Off-screen canvas untuk menyimpan gambar asli halaman 1
  const rawFirstPageCanvas = document.createElement('canvas');
  
  // Filters Inputs
  const contrastInp = document.getElementById('contrast');
  const brightInp = document.getElementById('brightness');
  const contrastVal = document.getElementById('contrast-val');
  const brightVal = document.getElementById('brightness-val');

  let currentFile = null;
  let pdfDocSource = null; // Menyimpan dokumen PDF.js yang sudah diload

  // --- EVENT LISTENERS ---
  dropZone.addEventListener('click', () => fileInput.click());

  fileInput.addEventListener('change', async (e) => {
    if (fileInput.files[0]) {
      currentFile = fileInput.files[0];
      filenameDisplay.innerText = currentFile.name;
      dropZone.classList.add('hidden');
      workspace.classList.remove('hidden');
      
      // Load PDF dan siapkan preview
      await loadAndPreviewFirstPage(currentFile);
    }
  });

  // Live Preview Update saat slider digeser
  contrastInp.addEventListener('input', (e) => {
      contrastVal.innerText = `${e.target.value}%`;
      updatePreview();
  });
  brightInp.addEventListener('input', (e) => {
      brightVal.innerText = `${e.target.value}%`;
      updatePreview();
  });

  // --- FUNGSI PREVIEW ---
  async function loadAndPreviewFirstPage(file) {
      const arrayBuffer = await file.arrayBuffer();
      pdfDocSource = await pdfjsLib.getDocument(arrayBuffer).promise;
      const page = await pdfDocSource.getPage(1);
      
      // Render dengan kualitas cukup untuk preview
      const viewport = page.getViewport({ scale: 1.0 });
      
      // Siapkan canvas raw (sumber asli)
      rawFirstPageCanvas.width = viewport.width;
      rawFirstPageCanvas.height = viewport.height;
      const rawCtx = rawFirstPageCanvas.getContext('2d');
      
      // Render halaman asli ke canvas raw
      await page.render({ canvasContext: rawCtx, viewport: viewport }).promise;

      // Siapkan canvas preview (yang terlihat)
      previewCanvas.width = viewport.width;
      previewCanvas.height = viewport.height;
      
      // Terapkan filter pertama kali
      updatePreview();
  }

  function updatePreview() {
      // 1. Bersihkan canvas preview
      previewCtx.clearRect(0, 0, previewCanvas.width, previewCanvas.height);
      
      // 2. Set filter CSS pada context
      const contrast = contrastInp.value;
      const brightness = brightInp.value;
      // Urutan filter penting: Grayscale dulu, baru Contrast/Brightness
      previewCtx.filter = `grayscale(100%) contrast(${contrast}%) brightness(${brightness}%)`;
      
      // 3. Gambar dari canvas raw ke canvas preview dengan filter aktif
      previewCtx.drawImage(rawFirstPageCanvas, 0, 0);
  }


  // --- FUNGSI PROSES SEMUA HALAMAN (CONVERT) ---
  convertBtn.addEventListener('click', async () => {
    if (!currentFile || !pdfDocSource) return;

    const restoreBtn = window.showButtonSpinner(convertBtn, 'Memproses...');
    progressContainer.classList.remove('hidden');

    try {
      const totalPages = pdfDocSource.numPages;
      const newPdf = await PDFDocument.create();

      // Canvas sementara untuk pemrosesan
      const tempCanvas = document.createElement('canvas');
      const tempCtx = tempCanvas.getContext('2d');

      for (let i = 1; i <= totalPages; i++) {
        // Update Progress UI
        const percent = Math.round((i / totalPages) * 100);
        progressBar.style.width = `${percent}%`;
        statusText.innerText = `Me-render halaman ${i} dari ${totalPages} (Menerapkan filter)...`;

        // 1. Render halaman asli dengan kualitas tinggi
        const page = await pdfDocSource.getPage(i);
        const viewport = page.getViewport({ scale: 1.5 }); // Scale 1.5 untuk hasil print bagus
        
        tempCanvas.width = viewport.width;
        tempCanvas.height = viewport.height;

        // Render ke temp canvas
        await page.render({ canvasContext: tempCtx, viewport: viewport }).promise;

        // 2. Terapkan Filter (Teknik Composite)
        // Kita gambar ulang canvas pada dirinya sendiri dengan filter aktif
        const contrast = contrastInp.value;
        const brightness = brightInp.value;
        tempCtx.globalCompositeOperation = 'copy'; // Timpa konten lama
        tempCtx.filter = `grayscale(100%) contrast(${contrast}%) brightness(${brightness}%)`;
        tempCtx.drawImage(tempCanvas, 0, 0);
        tempCtx.filter = 'none'; // Reset filter

        // 3. Embed ke PDF baru
        // Gunakan JPEG dengan kompresi 0.75 agar ukuran file tidak meledak
        const imgData = tempCanvas.toDataURL('image/jpeg', 0.75);
        const embeddedImage = await newPdf.embedJpg(imgData);
        
        const newPage = newPdf.addPage([embeddedImage.width, embeddedImage.height]);
        newPage.drawImage(embeddedImage, {
            x: 0,
            y: 0,
            width: embeddedImage.width,
            height: embeddedImage.height,
        });
      }

      statusText.innerText = window._tToast ? window._tToast("Menyusun file PDF akhir...") : "Menyusun file PDF akhir...";
      const pdfBytes = await newPdf.save();
      const blob = new Blob([pdfBytes], { type: 'application/pdf' });
      const link = document.createElement('a');
      link.href = URL.createObjectURL(blob);
      link.download = `grayscale-${currentFile.name}`;
      link.click();

      window.showToast?.(window._tToast ? window._tToast("Berhasil! PDF Hitam Putih siap.") : "Berhasil! PDF Hitam Putih siap.", "success");

    } catch (err) {
      window.showToast?.(window._tToast ? window._tToast("Gagal memproses PDF. Coba file yang lebih kecil.") : "Gagal memproses PDF. Coba file yang lebih kecil.", "error");
    } finally {
      restoreBtn();
      statusText.innerText = window._tToast ? window._tToast("Selesai!") : "Selesai!";
      setTimeout(() => {
          progressContainer.classList.add('hidden');
          progressBar.style.width = '0%';
      }, 2000);
    }
  });
</script>