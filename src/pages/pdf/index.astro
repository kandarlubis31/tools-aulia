---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="PDF Tools Suite">
  <div class="max-w-4xl mx-auto text-center mb-12 animate-on-scroll">
    <div class="inline-block p-4 rounded-full bg-red-100 dark:bg-red-900/30 mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-red-500"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="M9 15h6"/></svg>
    </div>
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-slate-800 dark:text-white">
      PDF <span class="text-red-500">Master Suite</span>
    </h1>
    <p class="text-lg text-slate-600 dark:text-slate-400">
      Suite lengkap manipulasi PDF: Kompres, Pisah, Putar, dan Edit.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
    
    <a href="/pdf/merge" class="tool-card group">
      <div class="tool-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg></div>
      <div><h3 class="tool-title">Merge PDF</h3><p class="tool-desc">Gabungkan banyak file PDF jadi satu.</p></div>
    </a>

    <a href="/pdf/split" class="tool-card group">
      <div class="tool-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><line x1="20" y1="4" x2="8.12" y2="15.88"></line><line x1="14.47" y1="14.48" x2="20" y2="20"></line><line x1="8.12" y1="8.12" x2="12" y2="12"></line></svg></div>
      <div><h3 class="tool-title">Split PDF</h3><p class="tool-desc">Pisahkan halaman PDF.</p></div>
    </a>

    <a href="/pdf/compress" class="tool-card group">
      <div class="tool-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3v3a2 2 0 0 1-2 2H3"></path><path d="M21 8h-3a2 2 0 0 1-2-2V3"></path><path d="M3 16h3a2 2 0 0 1 2 2v3"></path><path d="M16 21v-3a2 2 0 0 1 2-2h3"></path></svg></div>
      <div><h3 class="tool-title">Compress PDF</h3><p class="tool-desc">Kurangi ukuran file PDF.</p></div>
    </a>

    <a href="/pdf/rotate" class="tool-card group">
      <div class="tool-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg></div>
      <div><h3 class="tool-title">Rotate PDF</h3><p class="tool-desc">Putar orientasi halaman.</p></div>
    </a>

    <a href="/pdf/watermark" class="tool-card group">
      <div class="tool-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/><path d="M9 12l2 2l4 -4"/></svg>
      </div>
      <div><h3 class="tool-title">Watermark</h3><p class="tool-desc">Tambah teks cap air transparan.</p></div>
    </a>

    <a href="/pdf/page-numbers" class="tool-card group">
      <div class="tool-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
      </div>
      <div><h3 class="tool-title">Page Numbers</h3><p class="tool-desc">Nomor halaman otomatis.</p></div>
    </a>

    <a href="/pdf/delete" class="tool-card group">
      <div class="tool-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg></div>
      <div><h3 class="tool-title">Delete Pages</h3><p class="tool-desc">Hapus halaman yang tidak perlu.</p></div>
    </a>

    <a href="/pdf/to-jpg" class="tool-card group">
      <div class="tool-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
      <div><h3 class="tool-title">PDF to JPG</h3><p class="tool-desc">Ubah halaman PDF menjadi gambar.</p></div>
    </a>

    <a href="/pdf/jpg-to-pdf" class="tool-card group">
      <div class="tool-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg></div>
      <div><h3 class="tool-title">JPG to PDF</h3><p class="tool-desc">Ubah gambar menjadi file PDF.</p></div>
    </a>

    <a href="/pdf/sign" class="tool-card group">
      <div class="tool-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      </div>
      <div><h3 class="tool-title">Sign PDF</h3><p class="tool-desc">Tanda tangan digital via browser.</p></div>
    </a>

    <a href="/pdf/to-ppt" class="tool-card group">
      <div class="tool-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M8 13h2"/><path d="M8 17h2"/><path d="M14 13h2"/><path d="M14 17h2"/></svg>
      </div>
      <div><h3 class="tool-title">PDF to PowerPoint</h3><p class="tool-desc">Konversi slide PDF ke PPTX.</p></div>
    </a>

    <a href="/pdf/html-to-pdf" class="tool-card group">
      <div class="tool-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="M9 15h6"/></svg>
      </div>
      <div><h3 class="tool-title">HTML to PDF</h3><p class="tool-desc">Ubah kode HTML menjadi PDF.</p></div>
    </a>
     
    <a href="/pdf/reorder" class="tool-card group">
      <div class="tool-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/><rect x="8" y="8" width="8" height="8" rx="2" ry="2"/></svg>
      </div>
      <div><h3 class="tool-title">Reorder Pages</h3><p class="tool-desc">Atur ulang urutan halaman PDF.</p></div>
    </a>

    <a href="/pdf/extract" class="tool-card group">
      <div class="tool-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M16 22h2a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v4"/><path d="M14 22v-4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2Z"/></svg>
      </div>
      <div><h3 class="tool-title">Extract Pages</h3><p class="tool-desc">Ambil halaman tertentu saja.</p></div>
    </a>

    <a href="/pdf/metadata" class="tool-card group">
      <div class="tool-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
      </div>
      <div><h3 class="tool-title">Edit Metadata</h3><p class="tool-desc">Ubah Judul, Author, dan Keywords.</p></div>
    </a>

    <a href="/pdf/grayscale" class="tool-card group">
      <div class="tool-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 14h12v8H6z"/></svg>
      </div>
      <div><h3 class="tool-title">Grayscale PDF</h3><p class="tool-desc">Efek fotokopi hitam putih.</p></div>
    </a>

  </div>
</BaseLayout>

<style>
  .tool-card {
    @apply flex items-start gap-4 p-6 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 transition-all shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-red-500 dark:hover:border-red-500;
  }
  .tool-icon {
    @apply p-3 bg-red-100 dark:bg-red-900/30 rounded-lg text-red-600 dark:text-red-400 group-hover:scale-110 transition-transform flex-shrink-0;
  }
  .tool-title {
    @apply text-xl font-bold mb-1 text-slate-800 dark:text-slate-100 group-hover:text-red-500 transition-colors;
  }
  .tool-desc {
    @apply text-sm text-slate-500 dark:text-slate-400 leading-relaxed;
  }
</style>