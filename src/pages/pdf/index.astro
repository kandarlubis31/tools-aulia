---
import BaseLayout from '../../layouts/BaseLayout.astro';

// --- 1. DATA TOOLS ---
const pdfTools = [
  // MANIPULASI
  { 
    title: "Merge PDF", 
    desc: "Gabungin beberapa PDF jadi satu file gampang banget.", 
    href: "/pdf/merge", 
    color: "bg-red-100 text-red-600 dark:bg-red-900/30 dark:text-red-400",
    icon: '<path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>' 
  },
  { 
    title: "Split PDF", 
    desc: "Pisah PDF per halaman atau sesuai kebutuhan.", 
    href: "/pdf/split", 
    color: "bg-orange-100 text-orange-600 dark:bg-orange-900/30 dark:text-orange-400",
    icon: '<line x1="12" y1="3" x2="12" y2="21"/><path d="M8 8l-4 4 4 4"/><path d="M16 8l4 4-4 4"/>' 
  },
  { 
    title: "Compress PDF", 
    desc: "Kecilin ukuran PDF biar nggak makan storage.", 
    href: "/pdf/compress", 
    color: "bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400",
    icon: '<path d="M4 14l6 6 6-6"/><path d="M12 20v-9"/><path d="M20 10c0-4.418-3.582-8-8-8s-8 3.582-8 8"/>' 
  },

  // EDITING
  { 
    title: "Rotate PDF", 
    desc: "Putar halaman dari portrait ke landscape atau sebaliknya.", 
    href: "/pdf/rotate", 
    color: "bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400",
    icon: '<path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/>' 
  },
  { 
    title: "Reorder Pages", 
    desc: "Atur ulang urutan halaman sesuai selera.", 
    href: "/pdf/reorder", 
    color: "bg-indigo-100 text-indigo-600 dark:bg-indigo-900/30 dark:text-indigo-400",
    icon: '<line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>' 
  },
  { 
    title: "Delete Pages", 
    desc: "Buang halaman yang nggak penting dengan sekali klik.", 
    href: "/pdf/delete", 
    color: "bg-rose-100 text-rose-600 dark:bg-rose-900/30 dark:text-rose-400",
    icon: '<path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>' 
  },
  { 
    title: "Extract Pages", 
    desc: "Ambil halaman tertentu buat jadi file baru.", 
    href: "/pdf/extract", 
    color: "bg-teal-100 text-teal-600 dark:bg-teal-900/30 dark:text-teal-400",
    icon: '<path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M16 22h2a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v4"/><path d="M14 22v-4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2Z"/>' 
  },

  // KONVERSI
  { 
    title: "PDF to JPG", 
    desc: "Ubah halaman PDF jadi gambar JPG/PNG.", 
    href: "/pdf/to-jpg", 
    color: "bg-yellow-100 text-yellow-600 dark:bg-yellow-900/30 dark:text-yellow-400",
    icon: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>' 
  },
  { 
    title: "JPG to PDF", 
    desc: "Kumpulin foto-foto jadi satu file PDF.", 
    href: "/pdf/jpg-to-pdf", 
    color: "bg-yellow-100 text-yellow-600 dark:bg-yellow-900/30 dark:text-yellow-400",
    icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/>' 
  },
  { 
    title: "HTML to PDF", 
    desc: "Ubah halaman web atau HTML jadi dokumen PDF.", 
    href: "/pdf/html-to-pdf", 
    color: "bg-purple-100 text-purple-600 dark:bg-purple-900/30 dark:text-purple-400",
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>' 
  },
  { 
    title: "PDF to PPT", 
    desc: "Konversi PDF jadi slide presentasi PowerPoint.", 
    href: "/pdf/to-ppt", 
    color: "bg-orange-100 text-orange-600 dark:bg-orange-900/30 dark:text-orange-400",
    icon: '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><rect x="8" y="13" width="8" height="4"/>' 
  },

  // SECURITY & UTILS
  { 
    title: "Sign PDF", 
    desc: "Tanda tangani PDF langsung dari browser.", 
    href: "/pdf/sign", 
    color: "bg-emerald-100 text-emerald-600 dark:bg-emerald-900/30 dark:text-emerald-400",
    icon: '<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>' 
  },
  { 
    title: "Watermark", 
    desc: "Kasih watermark biar dokumen aman dari plagiarisme.", 
    href: "/pdf/watermark", 
    color: "bg-cyan-100 text-cyan-600 dark:bg-cyan-900/30 dark:text-cyan-400",
    icon: '<path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/><path d="M9 12l2 2l4 -4"/>' 
  },
  { 
    title: "Page Numbers", 
    desc: "Tambahin nomor halaman otomatis di PDF.", 
    href: "/pdf/page-numbers", 
    color: "bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-300",
    icon: '<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>' 
  },
  { 
    title: "Edit Metadata", 
    desc: "Ganti judul, author, atau info lain di PDF.", 
    href: "/pdf/metadata", 
    color: "bg-pink-100 text-pink-600 dark:bg-pink-900/30 dark:text-pink-400",
    icon: '<circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>' 
  },
  { 
    title: "Grayscale", 
    desc: "Ubah PDF jadi hitam putih buat hemat kuota printer.", 
    href: "/pdf/grayscale", 
    color: "bg-gray-200 text-gray-700 dark:bg-gray-800 dark:text-gray-300",
    icon: '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>' 
  },
];

const categories = [
  { id: 'all', name: 'Semua Tools', icon: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>' },
  { id: 'manipulasi', name: 'Manipulasi', icon: '<path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>' },
  { id: 'editing', name: 'Editing Halaman', icon: '<line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>' },
  { id: 'konversi', name: 'Konversi', icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>' },
  { id: 'security', name: 'Security & Utils', icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>' },
];

const popularTools = ['merge', 'compress', 'split', 'rotate'];

// --- HELPER FUNCTION (SERVER SIDE) ---
// Dipindahkan ke sini agar bisa dipakai saat render HTML
function getCategoryFromHref(href) {
  if (href.includes('merge') || href.includes('split') || href.includes('compress')) return 'manipulasi';
  if (href.includes('rotate') || href.includes('reorder') || href.includes('delete') || href.includes('extract')) return 'editing';
  if (href.includes('to-') || href.includes('-to-') || href.includes('html-to-pdf')) return 'konversi';
  if (href.includes('sign') || href.includes('watermark') || href.includes('page-numbers') || href.includes('metadata') || href.includes('grayscale')) return 'security';
  return 'all';
}
---

<BaseLayout pageTitle="PDF Mas Aul">
   
  <div class="relative py-16 px-4 mb-10 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-4xl bg-gradient-to-b from-red-50/50 to-transparent dark:from-red-900/10 pointer-events-none -z-10 rounded-full blur-3xl"></div>

    <div class="animate-fade-in-up">
      <div class="inline-flex items-center justify-center p-3 mb-6 bg-red-100 dark:bg-red-900/40 rounded-2xl shadow-sm text-red-600 dark:text-red-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="M9 15h6"/></svg>
      </div>
       
      <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 dark:text-white mb-4 tracking-tight">
        PDF <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-600 to-orange-600">Mas Aul</span>
      </h1>
       
      <p class="text-lg md:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Koleksi tools PDF paling lengkap. <br>
        <span class="font-bold text-red-600 dark:text-red-400">100% di Browser</span>, file kamu aman dan nggak pernah diupload ke server.
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 mb-8">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg p-6 border border-slate-200 dark:border-slate-700">
      <div class="flex flex-col md:flex-row gap-4">
        <div class="relative flex-1">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </div>
          <input 
            type="text" 
            id="search-input" 
            placeholder="Cari tools yang kamu butuhin..." 
            class="w-full pl-10 pr-4 py-3 rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 focus:ring-2 focus:ring-red-500 outline-none text-slate-800 dark:text-white transition-all"
          >
        </div>
        <div class="flex gap-2 overflow-x-auto pb-1 md:pb-0 custom-scrollbar">
          {categories.map((category) => (
            <button 
              class={`category-btn px-4 py-2 rounded-lg transition-colors whitespace-nowrap flex items-center gap-2 text-sm font-medium border border-transparent ${category.id === 'all' ? 'bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400' : 'bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-red-100 dark:hover:bg-red-900/30 hover:text-red-600 dark:hover:text-red-400'}`}
              data-category={category.id}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={category.icon} />
              {category.name}
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-bold text-slate-800 dark:text-white flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        Tools Paling Laku
      </h2>
      <button id="toggle-popular" class="text-sm text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors">
        Sembunyiin
      </button>
    </div>
    
    <div id="popular-tools" class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {pdfTools.filter(tool => popularTools.some(popular => tool.href.includes(popular))).map((tool) => (
        <a href={tool.href} class="group relative bg-gradient-to-br from-white to-slate-50 dark:from-slate-800 dark:to-slate-900 rounded-xl p-4 border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class={`inline-flex p-2 rounded-lg ${tool.color} mb-3 group-hover:scale-110 transition-transform duration-300`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={tool.icon} />
          </div>
          <h3 class="font-bold text-slate-800 dark:text-white text-sm mb-1 group-hover:text-red-600 dark:group-hover:text-red-400 transition-colors">
            {tool.title}
          </h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2">
            {tool.desc}
          </p>
        </a>
      ))}
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 pb-24">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-slate-800 dark:text-white">Semua Tools</h2>
      <div class="flex items-center gap-2">
        <span class="text-sm text-slate-500 dark:text-slate-400">Nongolin:</span>
        <span id="tool-count" class="text-sm font-bold text-red-600 dark:text-red-400">{pdfTools.length} tools</span>
      </div>
    </div>
    
    <div id="tools-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {pdfTools.map((tool) => (
        <a href={tool.href} class="tool-card group relative bg-white dark:bg-slate-800 rounded-2xl p-6 border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full overflow-hidden" data-title={tool.title.toLowerCase()} data-category={getCategoryFromHref(tool.href)}>
           
          <div class="absolute inset-0 bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-800 dark:to-slate-900 opacity-0 group-hover:opacity-100 transition-opacity duration-300 -z-10"></div>
           
          <div class="flex items-start justify-between mb-4">
            <div class={`p-3 rounded-xl ${tool.color} ring-1 ring-inset ring-black/5 dark:ring-white/10 group-hover:scale-110 transition-transform duration-300`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={tool.icon} />
            </div>
            
            <div class="text-slate-300 dark:text-slate-600 group-hover:text-slate-600 dark:group-hover:text-slate-300 transition-colors transform translate-x-2 opacity-0 group-hover:translate-x-0 group-hover:opacity-100">
               <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
          </div>

          <div>
            <h3 class="text-lg font-bold text-slate-800 dark:text-white mb-2 group-hover:text-red-600 dark:group-hover:text-red-400 transition-colors">
              {tool.title}
            </h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">
              {tool.desc}
            </p>
          </div>

        </a>
      ))}

    </div>

    <div id="no-results" class="hidden text-center py-12">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-slate-300 dark:text-slate-600 mb-4"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M8 11h6"/></svg>
      <h3 class="text-xl font-bold text-slate-700 dark:text-slate-300 mb-2">Wah, toolsnya nggak ketemu</h3>
      <p class="text-slate-500 dark:text-slate-400">Coba kata kunci lain atau reset filter ya</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 pb-16">
    <div class="bg-gradient-to-r from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-2xl p-6 border border-emerald-100 dark:border-emerald-800">
      <div class="flex flex-col md:flex-row items-center gap-4">
        <div class="flex-shrink-0 p-3 bg-emerald-100 dark:bg-emerald-900/40 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-600 dark:text-emerald-400"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div class="text-center md:text-left flex-1">
          <h3 class="text-lg font-bold text-emerald-800 dark:text-emerald-300 mb-1">Privasi Terjamin</h3>
          <p class="text-emerald-700 dark:text-emerald-400">Semua proses dilakukan offline di browser kamu. File kamu nggak akan pernah kita lihat.</p>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

<script is:inline>
  // Menggunakan astro:page-load agar script jalan setiap navigasi
  document.addEventListener('astro:page-load', () => {
    // DOM Elements
    const searchInput = document.getElementById('search-input');
    const categoryBtns = document.querySelectorAll('.category-btn');
    const toolCards = document.querySelectorAll('.tool-card');
    const toolsGrid = document.getElementById('tools-grid');
    const noResults = document.getElementById('no-results');
    const toolCount = document.getElementById('tool-count');
    const togglePopular = document.getElementById('toggle-popular');
    const popularTools = document.getElementById('popular-tools');

    // Cek dulu apakah elemennya ada biar nggak error
    if (!toolsGrid) return;

    // State
    let activeCategory = 'all';
    let searchTerm = '';

    // Initialize
    updateToolDisplay();

    // Search functionality
    searchInput.addEventListener('input', (e) => {
      searchTerm = e.target.value.toLowerCase();
      updateToolDisplay();
    });

    // Category filter functionality
    categoryBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Update active visual state
        categoryBtns.forEach(b => {
          b.className = 'category-btn px-4 py-2 rounded-lg transition-colors whitespace-nowrap flex items-center gap-2 text-sm font-medium border border-transparent bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-red-100 dark:hover:bg-red-900/30 hover:text-red-600 dark:hover:text-red-400';
        });
        
        btn.className = 'category-btn px-4 py-2 rounded-lg transition-colors whitespace-nowrap flex items-center gap-2 text-sm font-medium border border-transparent bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400';
        
        activeCategory = btn.getAttribute('data-category');
        updateToolDisplay();
      });
    });

    // Toggle popular tools
    togglePopular.addEventListener('click', () => {
      if (popularTools.style.display === 'none') {
        popularTools.style.display = 'grid';
        togglePopular.textContent = 'Sembunyiin';
      } else {
        popularTools.style.display = 'none';
        togglePopular.textContent = 'Tampilin';
      }
    });

    // Update tool display based on filters
    function updateToolDisplay() {
      let visibleCount = 0;
      
      toolCards.forEach(card => {
        const title = card.getAttribute('data-title');
        const category = card.getAttribute('data-category');
        
        const matchesSearch = title.includes(searchTerm);
        const matchesCategory = activeCategory === 'all' || category === activeCategory;
        
        if (matchesSearch && matchesCategory) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });
      
      // Update count
      toolCount.textContent = `${visibleCount} tools`;
      
      // Show/hide no results message
      if (visibleCount === 0) {
        noResults.classList.remove('hidden');
        toolsGrid.classList.add('hidden');
      } else {
        noResults.classList.add('hidden');
        toolsGrid.classList.remove('hidden');
      }
    }
  });
</script>

<style>
  /* Custom Scrollbar */
  .custom-scrollbar::-webkit-scrollbar { height: 4px; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background-color: #cbd5e1; border-radius: 4px; }
  .dark .custom-scrollbar::-webkit-scrollbar-thumb { background-color: #475569; }

  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in-up {
    animation: fade-in-up 0.6s ease-out;
  }
  
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>