---
import BaseLayout from '../../layouts/BaseLayout.astro';

// --- DATA TOOLS (Structure preserved, Colors adjusted for accent usage) ---
const pdfTools = [
  // MANIPULASI
  { 
    title: "Merge PDF", 
    desc: "Gabungin beberapa PDF jadi satu file gampang banget.", 
    href: "/pdf/merge", 
    category: "manipulasi",
    iconColor: "text-rose-600 dark:text-rose-400 bg-rose-50 dark:bg-rose-900/20",
    icon: '<path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>' 
  },
  { 
    title: "Split PDF", 
    desc: "Pisah PDF per halaman atau sesuai kebutuhan.", 
    href: "/pdf/split", 
    category: "manipulasi",
    iconColor: "text-orange-600 dark:text-orange-400 bg-orange-50 dark:bg-orange-900/20",
    icon: '<line x1="12" y1="3" x2="12" y2="21"/><path d="M8 8l-4 4 4 4"/><path d="M16 8l4 4-4 4"/>' 
  },
  { 
    title: "Compress PDF", 
    desc: "Kecilin ukuran PDF biar nggak makan storage.", 
    href: "/pdf/compress", 
    category: "manipulasi",
    iconColor: "text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/20",
    icon: '<path d="M4 14l6 6 6-6"/><path d="M12 20v-9"/><path d="M20 10c0-4.418-3.582-8-8-8s-8 3.582-8 8"/>' 
  },

  // EDITING
  { 
    title: "Rotate PDF", 
    desc: "Putar halaman dari portrait ke landscape.", 
    href: "/pdf/rotate", 
    category: "editing",
    iconColor: "text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20",
    icon: '<path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/>' 
  },
  { 
    title: "Reorder Pages", 
    desc: "Atur ulang urutan halaman sesuai selera.", 
    href: "/pdf/reorder", 
    category: "editing",
    iconColor: "text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/20",
    icon: '<line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>' 
  },
  { 
    title: "Delete Pages", 
    desc: "Buang halaman yang nggak penting.", 
    href: "/pdf/delete", 
    category: "editing",
    iconColor: "text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20",
    icon: '<path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>' 
  },
  { 
    title: "Extract Pages", 
    desc: "Ambil halaman tertentu buat file baru.", 
    href: "/pdf/extract", 
    category: "editing",
    iconColor: "text-teal-600 dark:text-teal-400 bg-teal-50 dark:bg-teal-900/20",
    icon: '<path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M16 22h2a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v4"/><path d="M14 22v-4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2Z"/>' 
  },

  // KONVERSI
  { 
    title: "PDF to JPG", 
    desc: "Ubah halaman PDF jadi gambar JPG/PNG.", 
    href: "/pdf/to-jpg", 
    category: "konversi",
    iconColor: "text-amber-600 dark:text-amber-400 bg-amber-50 dark:bg-amber-900/20",
    icon: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>' 
  },
  { 
    title: "JPG to PDF", 
    desc: "Kumpulin foto-foto jadi satu file PDF.", 
    href: "/pdf/jpg-to-pdf", 
    category: "konversi",
    iconColor: "text-amber-600 dark:text-amber-400 bg-amber-50 dark:bg-amber-900/20",
    icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/>' 
  },
  { 
    title: "HTML to PDF", 
    desc: "Ubah halaman web atau HTML jadi PDF.", 
    href: "/pdf/html-to-pdf", 
    category: "konversi",
    iconColor: "text-purple-600 dark:text-purple-400 bg-purple-50 dark:bg-purple-900/20",
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>' 
  },
  { 
    title: "PDF to PPT", 
    desc: "Konversi PDF jadi slide PowerPoint.", 
    href: "/pdf/to-ppt", 
    category: "konversi",
    iconColor: "text-orange-600 dark:text-orange-400 bg-orange-50 dark:bg-orange-900/20",
    icon: '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><rect x="8" y="13" width="8" height="4"/>' 
  },

  // SECURITY & UTILS
  { 
    title: "Sign PDF", 
    desc: "Tanda tangani PDF langsung dari browser.", 
    href: "/pdf/sign", 
    category: "security",
    iconColor: "text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/20",
    icon: '<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>' 
  },
  { 
    title: "Watermark", 
    desc: "Kasih watermark biar dokumen aman.", 
    href: "/pdf/watermark", 
    category: "security",
    iconColor: "text-cyan-600 dark:text-cyan-400 bg-cyan-50 dark:bg-cyan-900/20",
    icon: '<path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/><path d="M9 12l2 2l4 -4"/>' 
  },
  { 
    title: "Page Numbers", 
    desc: "Tambahin nomor halaman otomatis.", 
    href: "/pdf/page-numbers", 
    category: "security",
    iconColor: "text-slate-600 dark:text-slate-400 bg-slate-100 dark:bg-slate-800",
    icon: '<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>' 
  },
  { 
    title: "Edit Metadata", 
    desc: "Ganti judul, author, atau info PDF.", 
    href: "/pdf/metadata", 
    category: "security",
    iconColor: "text-pink-600 dark:text-pink-400 bg-pink-50 dark:bg-pink-900/20",
    icon: '<circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>' 
  },
  { 
    title: "Grayscale", 
    desc: "Ubah jadi hitam putih hemat tinta.", 
    href: "/pdf/grayscale", 
    category: "security",
    iconColor: "text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-gray-800",
    icon: '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>' 
  },
];

const categories = [
  { id: 'all', name: 'Semua Tools' },
  { id: 'manipulasi', name: 'Manipulasi' },
  { id: 'editing', name: 'Editing' },
  { id: 'konversi', name: 'Konversi' },
  { id: 'security', name: 'Security' },
];

const popularTools = ['merge', 'compress', 'split', 'to-jpg'];
---

<BaseLayout pageTitle="PDF Mas Aul - Tools PDF Gratis">
  
  {/* HERO SECTION - Clean, Centered, Typography focused */}
  <section class="relative pt-20 pb-16 px-4 overflow-hidden">
    <div class="max-w-4xl mx-auto text-center z-10 relative">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-rose-50 dark:bg-rose-900/30 text-rose-600 dark:text-rose-300 text-sm font-semibold mb-8 animate-fade-in border border-rose-100 dark:border-rose-800">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-rose-500"></span>
        </span>
        100% Gratis & Aman
      </div>

      <h1 class="text-5xl md:text-7xl font-bold text-slate-900 dark:text-white mb-6 tracking-tight leading-tight">
        Kelola PDF jadi <br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-rose-600 to-orange-600">Lebih Simpel.</span>
      </h1>
      
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed mb-10">
        Kumpulan tools PDF lengkap tanpa ribet. Semua proses berjalan di browser kamu (offline-mode), jadi dokumen rahasia tetap aman.
      </p>

      {/* SEARCH BAR - Elevated Component */}
      <div class="max-w-2xl mx-auto relative group">
        <div class="absolute -inset-1 bg-gradient-to-r from-rose-500 to-orange-500 rounded-2xl opacity-20 group-hover:opacity-40 blur transition duration-500"></div>
        <div class="relative bg-white dark:bg-slate-800 rounded-2xl shadow-xl flex items-center p-2 border border-slate-100 dark:border-slate-700">
          <div class="pl-4 text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </div>
          <input 
            type="text" 
            id="search-input" 
            placeholder="Cari tool (misal: merge, compress)..." 
            class="w-full bg-transparent border-none text-lg px-4 py-3 focus:ring-0 text-slate-800 dark:text-white placeholder:text-slate-400"
          >
          <div class="hidden md:flex text-xs text-slate-400 border border-slate-200 dark:border-slate-700 rounded px-2 py-1 mr-2 bg-slate-50 dark:bg-slate-900">
            ⌘K
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* MAIN APP INTERFACE */}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-32">
    
    {/* CATEGORY FILTER - Pill Design */}
    <div class="flex flex-wrap items-center justify-center gap-2 mb-12">
      {categories.map((category) => (
        <button 
          class={`category-btn px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 border ${category.id === 'all' 
            ? 'bg-slate-900 text-white border-slate-900 shadow-lg shadow-slate-900/20 dark:bg-white dark:text-slate-900' 
            : 'bg-white text-slate-600 border-slate-200 hover:border-slate-300 hover:bg-slate-50 dark:bg-slate-800 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-700'}`}
          data-category={category.id}
        >
          {category.name}
        </button>
      ))}
    </div>

    {/* TOOLS GRID */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="tools-grid">
      {/* POPULAR BADGE SECTION (Optional logic inside loop) */}
      {pdfTools.map((tool) => (
        <a 
          href={tool.href} 
          class="tool-card group relative bg-white dark:bg-slate-800 rounded-2xl p-6 border border-slate-200 dark:border-slate-700 hover:border-rose-500/50 dark:hover:border-rose-500/50 hover:shadow-xl hover:shadow-rose-500/5 hover:-translate-y-1 transition-all duration-300 flex flex-col h-full"
          data-title={tool.title.toLowerCase()}
          data-category={tool.category}
        >
          {popularTools.some(p => tool.href.includes(p)) && (
            <span class="absolute top-4 right-4 flex h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-rose-500"></span>
            </span>
          )}

          <div class={`w-14 h-14 rounded-2xl flex items-center justify-center mb-6 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3 ${tool.iconColor}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={tool.icon} />
          </div>

          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-rose-600 dark:group-hover:text-rose-400 transition-colors">
            {tool.title}
          </h3>
          
          <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed mb-4 flex-grow">
            {tool.desc}
          </p>

          <div class="flex items-center text-rose-600 dark:text-rose-400 text-sm font-semibold opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
            Gunakan Tool <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </div>
        </a>
      ))}
    </div>

    {/* EMPTY STATE */}
    <div id="no-results" class="hidden flex-col items-center justify-center py-20 text-center">
      <div class="w-20 h-20 bg-slate-100 dark:bg-slate-800 rounded-full flex items-center justify-center mb-4 text-slate-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M8 11h6"/></svg>
      </div>
      <h3 class="text-xl font-bold text-slate-900 dark:text-white">Tool tidak ditemukan</h3>
      <p class="text-slate-500 mt-2">Coba kata kunci lain atau reset kategori.</p>
    </div>

  </div>

  {/* TRUST INDICATOR */}
  <div class="border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 py-12">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <p class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-6">KEAMANAN TERJAMIN</p>
      <div class="flex flex-col md:flex-row items-center justify-center gap-8 md:gap-16 opacity-70 grayscale hover:grayscale-0 transition-all duration-500">
         <div class="flex items-center gap-3">
            <svg class="text-emerald-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span class="font-medium text-slate-700 dark:text-slate-300">Enkripsi Browser-side</span>
         </div>
         <div class="flex items-center gap-3">
            <svg class="text-blue-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
            <span class="font-medium text-slate-700 dark:text-slate-300">File Tidak Diupload</span>
         </div>
         <div class="flex items-center gap-3">
            <svg class="text-purple-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="m17 5-5-3-5 3"/><path d="m17 19-5 3-5-3"/></svg>
            <span class="font-medium text-slate-700 dark:text-slate-300">Bebas Virus</span>
         </div>
      </div>
    </div>
  </div>

</BaseLayout>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const searchInput = document.getElementById('search-input');
    const categoryBtns = document.querySelectorAll('.category-btn');
    const toolCards = document.querySelectorAll('.tool-card');
    const toolsGrid = document.getElementById('tools-grid');
    const noResults = document.getElementById('no-results');

    if (!toolsGrid) return;

    let activeCategory = 'all';
    let searchTerm = '';

    // Keyboard Shortcut (Cmd/Ctrl + K)
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        searchInput?.focus();
      }
    });

    const updateUI = () => {
      let visible = 0;
      toolCards.forEach(card => {
        const title = card.getAttribute('data-title');
        const cat = card.getAttribute('data-category');
        const matchSearch = title.includes(searchTerm);
        const matchCat = activeCategory === 'all' || cat === activeCategory;

        if (matchSearch && matchCat) {
          card.style.display = 'flex'; // Restore flex display
          visible++;
          // Animation trigger for entering items (optional polish)
          card.style.opacity = '1';
          card.style.transform = 'translateY(0)';
        } else {
          card.style.display = 'none';
        }
      });

      if (visible === 0) {
        noResults.classList.remove('hidden');
        noResults.classList.add('flex');
        toolsGrid.classList.add('hidden');
      } else {
        noResults.classList.add('hidden');
        noResults.classList.remove('flex');
        toolsGrid.classList.remove('hidden');
      }
    };

    searchInput?.addEventListener('input', (e) => {
      searchTerm = e.target.value.toLowerCase();
      updateUI();
    });

    categoryBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Reset styles for all buttons
        categoryBtns.forEach(b => {
            b.className = 'category-btn px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 border bg-white text-slate-600 border-slate-200 hover:border-slate-300 hover:bg-slate-50 dark:bg-slate-800 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-700';
        });

        // Set active style
        btn.className = 'category-btn px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 border bg-slate-900 text-white border-slate-900 shadow-lg shadow-slate-900/20 dark:bg-white dark:text-slate-900 scale-105';
        
        activeCategory = btn.getAttribute('data-category');
        updateUI();
      });
    });
  });
</script>

<style>
  /* Base animation keyframes */
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.8s ease-out forwards;
  }
</style>