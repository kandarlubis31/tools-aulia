---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Split PDF Pages">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js" async></script>
  <script is:inline async>
    (function waitForPdfjs() {
      if (window.pdfjsLib) {
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
      } else {
        setTimeout(waitForPdfjs, 50);
      }
    })();
  </script>

  <div class="max-w-6xl mx-auto px-4 min-h-[60vh]">
    
    <div class="text-center mb-10 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-amber-600">
        Split PDF
      </h1>
      <p class="text-slate-600 dark:text-slate-400" data-i18n="header.split_desc">
        Pilih halaman yang ingin Anda ambil, lalu simpan sebagai PDF terpisah.
      </p>
    </div>

    <div 
      id="drop-zone"
      class="max-w-2xl mx-auto border-3 border-dashed border-slate-300 dark:border-slate-600 rounded-3xl p-12 cursor-pointer hover:border-orange-500 hover:bg-orange-50 dark:hover:bg-slate-800/50 transition-all group text-center animate-on-scroll"
    >
      <div class="w-20 h-20 bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
      </div>
      <h3 class="text-2xl font-bold text-slate-700 dark:text-slate-200 mb-2" data-i18n="upload.select_pdf">Pilih File PDF</h3>
      <p class="text-slate-500 dark:text-slate-400 font-medium" data-i18n="upload.drop_pdf">Klik atau tarik file ke area ini</p>
      <input type="file" id="file-input" accept="application/pdf" class="hidden" />
    </div>

    <div id="loading" class="hidden flex-col items-center justify-center py-20">
      <div class="animate-spin rounded-full h-12 w-12 border-4 border-slate-200 border-t-orange-500 mb-4"></div>
      <p class="text-slate-600 dark:text-slate-300 font-semibold animate-pulse" data-i18n="common.loading">Memuat halaman...</p>
    </div>

    <div id="editor-area" class="hidden pb-20">
      
      <div class="sticky top-20 z-40 mx-auto max-w-4xl bg-slate-900/90 dark:bg-slate-800/90 backdrop-blur-md text-white p-4 rounded-xl shadow-2xl mb-8 flex flex-wrap gap-4 items-center justify-between border border-slate-700/50 ring-1 ring-white/10">
        
        <div class="flex items-center gap-3">
          <span id="selected-count" class="text-sm font-bold text-orange-400 bg-orange-400/10 px-3 py-1 rounded-lg border border-orange-400/20"><span data-i18n="label.pages">Halaman</span> Dipilih</span>
          <button id="select-all-btn" class="px-3 py-1.5 hover:bg-slate-700 rounded-lg text-xs font-medium transition-colors text-slate-300 border border-slate-600" data-i18n="btn.select_all">
            Pilih Semua
          </button>
          <button id="clear-sel-btn" class="px-3 py-1.5 hover:bg-slate-700 rounded-lg text-xs font-medium transition-colors text-slate-300 border border-slate-600" data-i18n="btn.reset">
            Reset
          </button>
        </div>          <button id="split-btn" class="bg-orange-500 hover:bg-orange-600 text-white font-bold py-2.5 px-6 rounded-lg shadow-lg shadow-orange-500/30 transition-all active:scale-95 flex items-center gap-2 border border-orange-400/20 disabled:opacity-50 disabled:cursor-not-allowed">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            <span data-i18n="btn.download_selected">Download PDF Terpilih</span>
          </button>
      </div>

      <div id="pages-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6"></div>
    </div>

  </div>
</BaseLayout>

<script>
  let PDFDocument;

  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const loading = document.getElementById('loading');
  const editorArea = document.getElementById('editor-area');
  const pagesGrid = document.getElementById('pages-grid');
  const splitBtn = document.getElementById('split-btn') as HTMLButtonElement;
  const selectedCountSpan = document.getElementById('selected-count');
  const selectAllBtn = document.getElementById('select-all-btn');
  const clearSelBtn = document.getElementById('clear-sel-btn');

  let currentFile: File | null = null;
  let selectedPages = new Set<number>(); 
  let totalPages = 0;

  dropZone?.addEventListener('click', () => fileInput.click());

  fileInput?.addEventListener('change', async (e) => {
    if (fileInput.files && fileInput.files[0]) {
      const file = fileInput.files[0];
      if (file.type !== 'application/pdf') return alert(window._tToast ? window._tToast('Mohon upload file PDF!') : 'Mohon upload file PDF!');
      currentFile = file;
      await renderThumbnails(file);
    }
  });

  async function renderThumbnails(file: File) {
    if(!dropZone || !loading || !editorArea || !pagesGrid) return;

    dropZone.classList.add('hidden');
    loading.classList.remove('hidden');
    loading.classList.add('flex');
    editorArea.classList.add('hidden');
    pagesGrid.innerHTML = '';
    selectedPages.clear();
    updateUI();

    try {
      const arrayBuffer = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument(arrayBuffer).promise;
      totalPages = pdf.numPages;

      loading.classList.add('hidden');
      loading.classList.remove('flex');
      editorArea.classList.remove('hidden');

      for (let i = 1; i <= totalPages; i++) {
        const page = await pdf.getPage(i);
        const viewport = page.getViewport({ scale: 0.8 }); // Scale cukup 0.8 buat thumbnail

        const canvas = document.createElement('canvas');
        const context = canvas.getContext('2d');
        canvas.height = viewport.height;
        canvas.width = viewport.width;
        canvas.className = "w-full h-auto pointer-events-none bg-white";

        await page.render({ canvasContext: context, viewport: viewport }).promise;

        // Wrapper
        const wrapper = document.createElement('div');
        wrapper.className = "relative group cursor-pointer transition-all";
        wrapper.onclick = () => toggleSelection(i - 1, wrapper);

        // Container Image
        const imgContainer = document.createElement('div');
        imgContainer.className = "relative bg-slate-200 dark:bg-slate-700 rounded-lg overflow-hidden border-4 border-transparent shadow-md transition-all";
        imgContainer.id = `page-card-${i-1}`;
        
        // Badge
        const badge = document.createElement('span');
        badge.className = "absolute top-2 left-2 bg-slate-900/80 text-white text-[10px] font-bold px-2 py-1 rounded z-10 shadow-sm";
        badge.innerText = `${i}`;

        // Checkmark Overlay
        const checkmark = document.createElement('div');
        checkmark.className = "absolute inset-0 bg-orange-500/20 hidden items-center justify-center z-20 check-overlay";
        checkmark.innerHTML = `<div class="bg-orange-500 text-white p-2 rounded-full shadow-lg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>`;

        imgContainer.appendChild(badge);
        imgContainer.appendChild(canvas);
        imgContainer.appendChild(checkmark);
        wrapper.appendChild(imgContainer);
        pagesGrid.appendChild(wrapper);
      }
    } catch (err) {
      console.error(err);
      alert(window._tToast ? window._tToast('Gagal memuat PDF.') : 'Gagal memuat PDF.');
      loading.classList.add('hidden');
      dropZone.classList.remove('hidden');
    }
  }

  function toggleSelection(index: number, wrapper: HTMLElement) {
    const card = wrapper.querySelector('div');
    const check = wrapper.querySelector('.check-overlay');
    
    if (selectedPages.has(index)) {
      selectedPages.delete(index);
      card?.classList.remove('border-orange-500');
      card?.classList.add('border-transparent');
      check?.classList.remove('flex');
      check?.classList.add('hidden');
    } else {
      selectedPages.add(index);
      card?.classList.remove('border-transparent');
      card?.classList.add('border-orange-500');
      check?.classList.remove('hidden');
      check?.classList.add('flex');
    }
    updateUI();
  }

  function updateUI() {
    if(selectedCountSpan) {
      var countText = selectedPages.size + ' ' + (window._tToast ? window._tToast('Halaman Dipilih') : 'Halaman Dipilih');
      selectedCountSpan.innerText = countText;
    }
    if(splitBtn) splitBtn.disabled = selectedPages.size === 0;
  }

  // --- CONTROLS ---
  selectAllBtn?.addEventListener('click', () => {
    selectedPages.clear();
    const wrappers = pagesGrid?.children;
    if(wrappers) {
      for(let i=0; i<wrappers.length; i++) {
        selectedPages.add(i);
        const w = wrappers[i] as HTMLElement;
        w.querySelector('div')?.classList.add('border-orange-500');
        w.querySelector('div')?.classList.remove('border-transparent');
        w.querySelector('.check-overlay')?.classList.remove('hidden');
        w.querySelector('.check-overlay')?.classList.add('flex');
      }
    }
    updateUI();
  });

  clearSelBtn?.addEventListener('click', () => {
    selectedPages.clear();
    const wrappers = pagesGrid?.children;
    if(wrappers) {
      for(let i=0; i<wrappers.length; i++) {
        const w = wrappers[i] as HTMLElement;
        w.querySelector('div')?.classList.remove('border-orange-500');
        w.querySelector('div')?.classList.add('border-transparent');
        w.querySelector('.check-overlay')?.classList.add('hidden');
        w.querySelector('.check-overlay')?.classList.remove('flex');
      }
    }
    updateUI();
  });

  // --- SPLIT ACTION ---
  splitBtn?.addEventListener('click', async () => {
    if (!currentFile || selectedPages.size === 0) return;

    const originalText = splitBtn.innerHTML;
    splitBtn.innerHTML = `Memproses...`;
    splitBtn.disabled = true;

    try {
      // Lazy load pdf-lib
      if (!PDFDocument) {
        const pdfLib = await import('pdf-lib');
        PDFDocument = pdfLib.PDFDocument;
      }
      const arrayBuffer = await currentFile.arrayBuffer();
      const pdfDoc = await PDFDocument.load(arrayBuffer);
      
      // Buat PDF Baru
      const newPdf = await PDFDocument.create();
      
      // Urutkan index halaman biar rapi
      const sortedIndices = Array.from(selectedPages).sort((a, b) => a - b);
      
      // Copy halaman terpilih
      const copiedPages = await newPdf.copyPages(pdfDoc, sortedIndices);
      copiedPages.forEach((page) => newPdf.addPage(page));

      const pdfBytes = await newPdf.save();
      const blob = new Blob([pdfBytes], { type: 'application/pdf' });
      const link = document.createElement('a');
      link.href = URL.createObjectURL(blob);
      link.download = `split-${currentFile.name}`;
      link.click();

    } catch (err) {
      console.error(err);
      alert(window._tToast ? window._tToast("Gagal memproses PDF.") : "Gagal memproses PDF.");
    } finally {
      splitBtn.innerHTML = originalText;
      splitBtn.disabled = false;
    }
  });
</script>