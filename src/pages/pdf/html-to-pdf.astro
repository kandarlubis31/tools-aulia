---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="HTML to PDF">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js" async></script>

  <div class="max-w-6xl mx-auto px-4 min-h-[80vh] flex flex-col">
    <div class="text-center mb-6 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-2 text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-rose-500" data-i18n="header.html_to_pdf">
        HTML to PDF
      </h1>
      <p class="text-matte-600 dark:text-matte-400" data-i18n="text.write_html_convert_pdf">
        Tulis kode HTML dan ubah menjadi dokumen PDF.
      </p>
    </div>

    <div class="flex-1 grid grid-cols-1 lg:grid-cols-2 gap-6 pb-12 animate-fade-in">
      
      <div class="flex flex-col h-full bg-white dark:bg-matte-800 rounded-xl shadow-lg border border-matte-200 dark:border-matte-700 overflow-hidden">
        <div class="bg-matte-100 dark:bg-matte-900 px-4 py-2 border-b border-matte-200 dark:border-matte-700 flex justify-between items-center">
           <span class="text-xs font-bold text-matte-500 uppercase" data-i18n="label.html_editor">Editor HTML</span>
           <button id="convert-btn" class="bg-pink-600 hover:bg-pink-700 text-white text-xs font-bold py-1.5 px-4 rounded shadow transition-all active:scale-95" data-i18n="btn.download_pdf">
             Download PDF
           </button>
        </div>
        <textarea id="html-input" class="flex-1 w-full p-4 font-mono text-sm bg-matte-50 dark:bg-matte-900 text-matte-800 dark:text-matte-200 outline-none resize-none" spellcheck="false">
<h1>Invoice #1023</h1>
<p>Tanggal: 05 Januari 2024</p>
<hr>
<table style="width: 100%; text-align: left; border-collapse: collapse;">
  <tr style="background: #f0f0f0;">
    <th style="padding: 8px;">Item</th>
    <th style="padding: 8px;">Harga</th>
  </tr>
  <tr>
    <td style="padding: 8px;">Jasa Pembuatan Web</td>
    <td style="padding: 8px;">Rp 5.000.000</td>
  </tr>
  <tr>
    <td style="padding: 8px;">Domain & Hosting</td>
    <td style="padding: 8px;">Rp 1.500.000</td>
  </tr>
</table>
<h3 style="text-align: right; margin-top: 20px;">Total: Rp 6.500.000</h3>
        </textarea>
      </div>

      <div class="flex flex-col h-full bg-white rounded-xl shadow-lg border border-matte-200 overflow-hidden">
        <div class="bg-matte-100 px-4 py-2 border-b border-matte-200 flex justify-between items-center">
           <span class="text-xs font-bold text-matte-500 uppercase" data-i18n="text.live_preview_a4">Live Preview (A4 View)</span>
        </div>
        <div class="flex-1 p-8 overflow-auto bg-matte-200 flex justify-center">
           <div id="preview-content" class="bg-white shadow-2xl w-[210mm] min-h-[297mm] p-[20mm] text-black text-base">
             </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  const htmlInput = document.getElementById('html-input');
  const previewContent = document.getElementById('preview-content');
  const convertBtn = document.getElementById('convert-btn');

  // 1. Live Preview dengan debounce
  function updatePreview() {
    previewContent.innerHTML = htmlInput.value;
  }

  let debounceTimer;
  htmlInput.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(updatePreview, 500);
  });

  // Init Preview
  updatePreview();

  // 2. Convert to PDF
  let _html2pdfRetries = 0;
  const MAX_RETRIES = 30; // ~3 detik

  convertBtn.addEventListener('click', () => {
    const element = document.getElementById('preview-content');
    if (!element || !element.innerHTML.trim()) {
      window.showToast?.(window._tToast ? window._tToast('Editor HTML kosong. Tulis kode dulu.') : 'Editor HTML kosong. Tulis kode dulu.', 'warning');
      return;
    }

    // Cek html2pdf tersedia
    if (typeof html2pdf === 'undefined') {
      if (_html2pdfRetries++ < MAX_RETRIES) {
        setTimeout(() => convertBtn.click(), 100);
        return;
      }
      _html2pdfRetries = 0;
      window.showToast?.(window._tToast ? window._tToast('Gagal memuat library html2pdf. Cek koneksi internet.') : 'Gagal memuat library html2pdf. Cek koneksi internet.', 'error');
      return;
    }
    _html2pdfRetries = 0;

    const originalBtnText = convertBtn.innerText;
    convertBtn.innerText = window._tToast ? window._tToast('Generating...') : 'Generating...';
    convertBtn.disabled = true;

    const opt = {
      margin: 0,
      filename: 'document.pdf',
      image: { type: 'jpeg', quality: 0.98 },
      html2canvas: { scale: 2, logging: false },
      jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
    };

    html2pdf().set(opt).from(element).save().then(() => {
      convertBtn.innerText = originalBtnText;
      convertBtn.disabled = false;
      window.showToast?.(window._tToast ? window._tToast('PDF berhasil dibuat!') : 'PDF berhasil dibuat!', 'success');
    }).catch(() => {
      convertBtn.innerText = originalBtnText;
      convertBtn.disabled = false;
      window.showToast?.(window._tToast ? window._tToast('Gagal membuat PDF. Coba lagi.') : 'Gagal membuat PDF. Coba lagi.', 'error');
    });
  });
</script>