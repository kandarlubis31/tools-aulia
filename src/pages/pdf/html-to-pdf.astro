---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="HTML to PDF">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

  <div class="max-w-6xl mx-auto px-4 min-h-[80vh] flex flex-col">
    <div class="text-center mb-6 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-2 text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-rose-500">
        HTML to PDF
      </h1>
      <p class="text-slate-600 dark:text-slate-400">
        Tulis kode HTML dan ubah menjadi dokumen PDF.
      </p>
    </div>

    <div class="flex-1 grid grid-cols-1 lg:grid-cols-2 gap-6 pb-12 animate-fade-in">
      
      <div class="flex flex-col h-full bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 overflow-hidden">
        <div class="bg-slate-100 dark:bg-slate-900 px-4 py-2 border-b border-slate-200 dark:border-slate-700 flex justify-between items-center">
           <span class="text-xs font-bold text-slate-500 uppercase">Editor HTML</span>
           <button id="convert-btn" class="bg-pink-600 hover:bg-pink-700 text-white text-xs font-bold py-1.5 px-4 rounded shadow transition-all active:scale-95">
             Download PDF
           </button>
        </div>
        <textarea id="html-input" class="flex-1 w-full p-4 font-mono text-sm bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-200 outline-none resize-none" spellcheck="false">
<h1>Invoice #1023</h1>
<p>Tanggal: 05 Januari 2024</p>
<hr>
<table style="width: 100%; text-align: left; border-collapse: collapse;">
  <tr style="background: #f0f0f0;">
    <th style="padding: 8px;">Item</th>
    <th style="padding: 8px;">Harga</th>
  </tr>
  <tr>
    <td style="padding: 8px;">Jasa Pembuatan Web</td>
    <td style="padding: 8px;">Rp 5.000.000</td>
  </tr>
  <tr>
    <td style="padding: 8px;">Domain & Hosting</td>
    <td style="padding: 8px;">Rp 1.500.000</td>
  </tr>
</table>
<h3 style="text-align: right; margin-top: 20px;">Total: Rp 6.500.000</h3>
        </textarea>
      </div>

      <div class="flex flex-col h-full bg-white rounded-xl shadow-lg border border-slate-200 overflow-hidden">
        <div class="bg-slate-100 px-4 py-2 border-b border-slate-200 flex justify-between items-center">
           <span class="text-xs font-bold text-slate-500 uppercase">Live Preview (A4 View)</span>
        </div>
        <div class="flex-1 p-8 overflow-auto bg-slate-200 flex justify-center">
           <div id="preview-content" class="bg-white shadow-2xl w-[210mm] min-h-[297mm] p-[20mm] text-black text-base">
             </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  const htmlInput = document.getElementById('html-input');
  const previewContent = document.getElementById('preview-content');
  const convertBtn = document.getElementById('convert-btn');

  // Live Preview Logic
  function updatePreview() {
    previewContent.innerHTML = htmlInput.value;
  }

  htmlInput.addEventListener('input', updatePreview);
  
  // Init Preview
  updatePreview();

  // Convert Logic
  convertBtn.addEventListener('click', () => {
    const element = document.getElementById('preview-content');
    const opt = {
      margin:       0, // Margin diatur di CSS container preview
      filename:     'document.pdf',
      image:        { type: 'jpeg', quality: 0.98 },
      html2canvas:  { scale: 2 },
      jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
    };

    convertBtn.innerText = "Generating...";
    convertBtn.disabled = true;

    // @ts-ignore
    html2pdf().set(opt).from(element).save().then(() => {
        convertBtn.innerText = "Download PDF";
        convertBtn.disabled = false;
        window.showToast("PDF berhasil dibuat!", "success");
    });
  });
</script>