---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Delete PDF Pages">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
  <script is:inline>
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
  </script>

  <div class="max-w-6xl mx-auto px-4 min-h-[60vh]">
    <div class="text-center mb-10 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-red-600 to-rose-600">Delete Pages</h1>
      <p class="text-slate-600 dark:text-slate-400">Klik pada halaman yang ingin Anda <strong class="text-red-500">HAPUS</strong>.</p>
    </div>

    <div id="drop-zone" class="max-w-2xl mx-auto border-3 border-dashed border-slate-300 dark:border-slate-600 rounded-3xl p-12 cursor-pointer hover:border-red-500 hover:bg-red-50 dark:hover:bg-slate-800/50 transition-all group text-center animate-on-scroll">
      <div class="w-20 h-20 bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
      </div>
      <h3 class="text-2xl font-bold text-slate-700 dark:text-slate-200 mb-2">Upload PDF</h3>
      <input type="file" id="file-input" accept="application/pdf" class="hidden" />
    </div>

    <div id="loading" class="hidden flex-col items-center justify-center py-20">
      <div class="animate-spin rounded-full h-12 w-12 border-4 border-slate-200 border-t-red-600 mb-4"></div>
      <p class="text-slate-600 dark:text-slate-300 font-semibold animate-pulse">Memuat halaman...</p>
    </div>
    <div id="editor-area" class="hidden pb-20">
        <div class="sticky top-20 z-40 mx-auto max-w-4xl bg-slate-900/90 dark:bg-slate-800/90 backdrop-blur-md text-white p-4 rounded-xl shadow-2xl mb-8 flex flex-wrap gap-4 items-center justify-between border border-slate-700/50 ring-1 ring-white/10">
            <span id="selected-count" class="text-sm font-bold text-red-400 bg-red-400/10 px-3 py-1 rounded-lg border border-red-400/20">0 Akan Dihapus</span>
            <button id="delete-btn" class="bg-red-600 hover:bg-red-700 text-white font-bold py-2.5 px-6 rounded-lg shadow-lg shadow-red-600/30 transition-all active:scale-95 flex items-center gap-2 border border-red-500/20 disabled:opacity-50 disabled:cursor-not-allowed">
              Hapus & Simpan PDF
            </button>
        </div>
        <div id="pages-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6"></div>
    </div>
  </div>
</BaseLayout>

<script>
  import { PDFDocument } from 'pdf-lib';

  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input');
  const loading = document.getElementById('loading');
  const editorArea = document.getElementById('editor-area');
  const pagesGrid = document.getElementById('pages-grid');
  const deleteBtn = document.getElementById('delete-btn');
  const selectedCountSpan = document.getElementById('selected-count');

  let currentFile = null;
  let pagesToDelete = new Set(); 
  let totalPages = 0;

  dropZone?.addEventListener('click', () => fileInput.click());

  fileInput?.addEventListener('change', async (e) => {
    if (fileInput.files && fileInput.files[0]) {
      currentFile = fileInput.files[0];
      await renderThumbnails(currentFile);
    }
  });

  async function renderThumbnails(file) {
    if(!dropZone) return;
    dropZone.classList.add('hidden');
    loading.classList.remove('hidden');
    loading.classList.add('flex');
    editorArea.classList.add('hidden');
    pagesGrid.innerHTML = '';
    pagesToDelete.clear();
    updateUI();

    try {
      const arrayBuffer = await file.arrayBuffer();
      // @ts-ignore
      const pdf = await pdfjsLib.getDocument(arrayBuffer).promise;
      totalPages = pdf.numPages;

      loading.classList.add('hidden');
      loading.classList.remove('flex');
      editorArea.classList.remove('hidden');

      for (let i = 1; i <= totalPages; i++) {
        const page = await pdf.getPage(i);
        const viewport = page.getViewport({ scale: 0.8 });
        const canvas = document.createElement('canvas');
        const context = canvas.getContext('2d');
        canvas.height = viewport.height;
        canvas.width = viewport.width;
        canvas.className = "w-full h-auto pointer-events-none bg-white opacity-100 transition-opacity duration-300";

        await page.render({ canvasContext: context, viewport: viewport }).promise;

        const wrapper = document.createElement('div');
        wrapper.className = "relative group cursor-pointer transition-all";
        wrapper.onclick = () => toggleDelete(i - 1, wrapper);

        const imgContainer = document.createElement('div');
        imgContainer.className = "relative bg-slate-200 dark:bg-slate-700 rounded-lg overflow-hidden border-4 border-transparent shadow-md transition-all";
        
        const badge = document.createElement('span');
        badge.className = "absolute top-2 left-2 bg-slate-900/80 text-white text-[10px] font-bold px-2 py-1 rounded z-10 shadow-sm";
        badge.innerText = `${i}`;
        
        const deleteOverlay = document.createElement('div');
        deleteOverlay.className = "absolute inset-0 bg-red-900/60 hidden items-center justify-center z-20 del-overlay backdrop-blur-sm";
        deleteOverlay.innerHTML = `<div class="bg-red-600 text-white p-3 rounded-full shadow-lg"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></div>`;

        imgContainer.appendChild(badge);
        imgContainer.appendChild(canvas);
        imgContainer.appendChild(deleteOverlay);
        wrapper.appendChild(imgContainer);
        pagesGrid.appendChild(wrapper);
      }
    } catch (err) {
      console.error(err);
      window.showToast("Gagal memuat PDF. File mungkin rusak.", "error");
    }
  }

  function toggleDelete(index, wrapper) {
    const card = wrapper.querySelector('div');
    const overlay = wrapper.querySelector('.del-overlay');
    
    if (pagesToDelete.has(index)) {
      pagesToDelete.delete(index);
      card.classList.remove('border-red-500');
      card.classList.add('border-transparent');
      overlay.classList.remove('flex');
      overlay.classList.add('hidden');
    } else {
      pagesToDelete.add(index);
      card.classList.remove('border-transparent');
      card.classList.add('border-red-500');
      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
    }
    updateUI();
  }

  function updateUI() {
    if(selectedCountSpan) selectedCountSpan.innerText = `${pagesToDelete.size} Akan Dihapus`;
    if(deleteBtn) deleteBtn.disabled = pagesToDelete.size === 0 || pagesToDelete.size === totalPages;
  }

  deleteBtn?.addEventListener('click', async () => {
    if (!currentFile || pagesToDelete.size === 0) return;

    const originalText = deleteBtn.innerHTML;
    deleteBtn.innerHTML = "Menghapus...";
    deleteBtn.disabled = true;

    try {
      const arrayBuffer = await currentFile.arrayBuffer();
      const pdfDoc = await PDFDocument.load(arrayBuffer);
      
      const indicesToDelete = Array.from(pagesToDelete).sort((a, b) => b - a);
      for (const idx of indicesToDelete) {
        pdfDoc.removePage(idx);
      }

      const pdfBytes = await pdfDoc.save();
      const blob = new Blob([pdfBytes], { type: 'application/pdf' });
      const link = document.createElement('a');
      link.href = URL.createObjectURL(blob);
      link.download = `cleaned-${currentFile.name}`;
      link.click();

      window.showToast("Halaman berhasil dihapus!", "success");

    } catch (err) {
      console.error(err);
      window.showToast("Gagal menyimpan PDF.", "error");
    } finally {
      deleteBtn.innerHTML = originalText;
      deleteBtn.disabled = false;
    }
  });
</script>