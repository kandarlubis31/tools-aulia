---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="PDF Merger">
  <div class="min-h-screen bg-matte-50 dark:bg-matte-900 py-8 px-4">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="text-3xl md:text-4xl font-bold mb-2 text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-orange-500">
          PDF Merger
        </h1>
        <p class="text-matte-600 dark:text-matte-400 max-w-2xl mx-auto" data-i18n="header.merge_desc">
          Gabungkan banyak file PDF menjadi satu file urut dan rapi. 100% di browser, file kamu aman!
        </p>
      </div>

      <!-- Main Content -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Upload Section -->
        <div class="lg:col-span-2">
          <div class="bg-white dark:bg-matte-800 rounded-2xl border border-matte-200 dark:border-matte-700 shadow-xl overflow-hidden">
            
            <!-- Upload Area -->
            <div 
              id="drop-zone"
              class="border-2 border-dashed border-matte-300 dark:border-matte-600 rounded-xl p-8 cursor-pointer hover:border-red-500 hover:bg-matte-50 dark:hover:bg-matte-700/50 transition-all group"
            >
              <div class="flex flex-col items-center gap-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-matte-400 group-hover:text-red-500 transition-colors">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                  <line x1="12" y1="18" x2="12" y2="12"></line>
                  <line x1="9" y1="15" x2="15" y2="15"></line>
                </svg>
                <span class="text-matte-500 dark:text-matte-300 font-medium">Drag & drop file PDF di sini</span>
                <span class="text-sm text-matte-400">atau klik untuk pilih file (bisa banyak sekaligus)</span>
                <input type="file" id="file-input" accept="application/pdf" multiple class="hidden" />
              </div>
            </div>

            <!-- File List -->
            <div id="file-list-container" class="hidden p-6 border-t border-matte-200 dark:border-matte-700">
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-sm font-bold text-matte-500 uppercase tracking-wider" data-i18n="common.selected_files">File Terpilih:</h3>
                <div class="flex gap-2">
                  <button id="sort-btn" class="text-xs bg-matte-100 dark:bg-matte-700 hover:bg-matte-200 dark:hover:bg-matte-600 px-2 py-1 rounded transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                    <span data-i18n="common.sort">Urutkan</span>
                  </button>
                  <button id="clear-all-btn" class="text-xs bg-matte-100 dark:bg-matte-700 hover:bg-matte-200 dark:hover:bg-matte-600 px-2 py-1 rounded transition-colors" data-i18n="btn.clear_all">
                    Hapus Semua
                  </button>
                </div>
              </div>
              
              <ul id="file-list" class="space-y-2 mb-6 max-h-80 overflow-y-auto pr-2">
                <!-- File items will be added here dynamically -->
              </ul>

              <div class="flex gap-4 justify-center pt-4 border-t border-matte-200 dark:border-matte-700">
                <button id="merge-btn" class="bg-red-500 hover:bg-red-600 text-white px-8 py-3 rounded-lg font-bold transition-all shadow-lg shadow-red-500/20 active:scale-95 flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
                  <span data-i18n="btn.merge">Gabungkan PDF</span>
                </button>
                <button id="reset-btn" class="text-matte-500 dark:text-matte-400 hover:text-red-500 px-4 py-2 transition-colors" data-i18n="btn.reset">
                  Reset
                </button>
              </div>
            </div>

            <!-- Progress Bar -->
            <div id="progress-container" class="hidden p-6 border-t border-matte-200 dark:border-matte-700">
              <div class="mb-2 flex justify-between text-sm">
                <span class="text-matte-600 dark:text-matte-400" data-i18n="common.processing">Memproses...</span>
                <span id="progress-percent" class="text-matte-600 dark:text-matte-400">0%</span>
              </div>
              <div class="w-full bg-matte-200 dark:bg-matte-700 rounded-full h-2">
                <div id="progress-bar" class="bg-red-500 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Preview Section -->
        <div class="lg:col-span-1">
          <div class="bg-white dark:bg-matte-800 rounded-2xl border border-matte-200 dark:border-matte-700 shadow-xl p-6">
            <h3 class="text-lg font-bold text-matte-800 dark:text-white mb-4" data-i18n="common.preview">Preview</h3>
            
            <div id="preview-container" class="space-y-4">
              <div id="empty-preview" class="text-center py-12">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-matte-300 dark:text-matte-600 mx-auto mb-4">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                  <line x1="12" y1="18" x2="12" y2="12"></line>
                  <line x1="9" y1="15" x2="15" y2="15"></line>
                </svg>
                <p class="text-matte-400 dark:text-matte-500" data-i18n="msg.preview_here">Preview file akan muncul di sini</p>
              </div>
              
              <div id="preview-list" class="hidden space-y-4">
                <!-- Preview items will be added here dynamically -->
              </div>
            </div>
          </div>

          <!-- Options Section -->
          <div class="bg-white dark:bg-matte-800 rounded-2xl border border-matte-200 dark:border-matte-700 shadow-xl p-6 mt-6">
            <h3 class="text-lg font-bold text-matte-800 dark:text-white mb-4" data-i18n="common.options">Opsi</h3>
            
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-matte-700 dark:text-matte-300 mb-2" data-i18n="label.output_name">Nama Output File</label>
                <input type="text" id="output-name" value="merged-document" class="w-full px-3 py-2 border border-matte-300 dark:border-matte-600 rounded-lg bg-white dark:bg-matte-700 text-matte-800 dark:text-white focus:ring-2 focus:ring-red-500 focus:border-transparent">
              </div>
              
              <div>
                <label for="merge-mode" class="block text-sm font-medium text-matte-700 dark:text-matte-300 mb-2" data-i18n="label.merge_mode">Merge Mode</label>
                <select id="merge-mode" class="w-full px-3 py-2 border border-matte-300 dark:border-matte-600 rounded-lg bg-white dark:bg-matte-700 text-matte-800 dark:text-white focus:ring-2 focus:ring-red-500 focus:border-transparent">
                  <option value="sequential" data-i18n="common.sequential">Sequential (Gabung Berurutan)</option>
                  <option value="interleave" data-i18n="common.interleave">Interleave (Selang-seling)</option>
                </select>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-matte-700 dark:text-matte-300 mb-2">
                  <input type="checkbox" id="add-bookmarks" class="mr-2">
                  <span data-i18n="common.add_bookmarks">Tambah Bookmark</span>
                </label>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

<script>
  // DOM Elements
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input');
  const fileListContainer = document.getElementById('file-list-container');
  const fileList = document.getElementById('file-list');
  const mergeBtn = document.getElementById('merge-btn');
  const resetBtn = document.getElementById('reset-btn');
  const sortBtn = document.getElementById('sort-btn');
  const clearAllBtn = document.getElementById('clear-all-btn');
  const progressContainer = document.getElementById('progress-container');
  const progressBar = document.getElementById('progress-bar');
  const progressPercent = document.getElementById('progress-percent');
  const emptyPreview = document.getElementById('empty-preview');
  const previewList = document.getElementById('preview-list');
  const outputName = document.getElementById('output-name');
  const mergeMode = document.getElementById('merge-mode');
  const addBookmarks = document.getElementById('add-bookmarks');


  // State
  let selectedFiles = [];
  let filePreviews = {};

  // --- 1. HANDLING INPUT FILES ---
  if (dropZone && fileInput) {
    dropZone.addEventListener('click', () => fileInput.click());
    
    fileInput.addEventListener('change', (e) => {
      if (fileInput.files && fileInput.files.length > 0) {
        const newFiles = Array.from(fileInput.files).filter(f => f.type === 'application/pdf');
        selectedFiles = [...selectedFiles, ...newFiles];
        updateUI();
        generatePreviews();
      }
    });

    // Drag & Drop
    dropZone.addEventListener('dragover', (e) => { 
      e.preventDefault(); 
      dropZone.classList.add('border-red-500', 'bg-red-50/20', 'dark:bg-red-900/10'); 
    });
    
    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('border-red-500', 'bg-red-50/20', 'dark:bg-red-900/10');
    });
    
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('border-red-500', 'bg-red-50/20', 'dark:bg-red-900/10');
      
      if (e.dataTransfer?.files) {
        const newFiles = Array.from(e.dataTransfer.files).filter(f => f.type === 'application/pdf');
        if (newFiles.length > 0) {
          selectedFiles = [...selectedFiles, ...newFiles];
          updateUI();
          generatePreviews();
          window.showToast?.(newFiles.length + ' ' + (window._tToast ? window._tToast('file berhasil ditambahkan') : 'file berhasil ditambahkan'));
        } else {
          window.showToast?.(window._tToast('Hanya file PDF yang diperbolehkan'), 'error');
        }
      }
    });
  }

  // --- 2. UPDATE UI LIST ---
  function updateUI() {
    if (!fileList || !fileListContainer || !dropZone) return;

    fileList.innerHTML = '';
    
    if (selectedFiles.length > 0) {
      dropZone.classList.add('hidden');
      fileListContainer.classList.remove('hidden');

      selectedFiles.forEach((file, index) => {
        const li = document.createElement('li');
        li.className = "file-item flex items-center justify-between bg-matte-50 dark:bg-matte-700/50 p-3 rounded-lg border border-matte-200 dark:border-matte-600";
        li.dataset.index = index;
        
        li.innerHTML = `
          <div class="flex items-center gap-3 overflow-hidden flex-1">
            <span class="w-6 h-6 bg-red-100 dark:bg-red-900/30 text-red-500 rounded flex items-center justify-center text-xs font-bold">${index + 1}</span>
            <div class="flex-1 min-w-0">
              <span class="text-sm font-medium truncate text-matte-700 dark:text-matte-200 block">${file.name}</span>
              <span class="text-xs text-matte-400">${formatFileSize(file.size)} • ${filePreviews[file.name]?.pageCount || '?'} halaman</span>
            </div>
          </div>
          <div class="flex items-center gap-1">
            <button class="move-up-btn text-matte-400 hover:text-matte-600 dark:hover:text-matte-300 p-1" data-index="${index}" ${index === 0 ? 'disabled' : ''}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
            </button>
            <button class="move-down-btn text-matte-400 hover:text-matte-600 dark:hover:text-matte-300 p-1" data-index="${index}" ${index === selectedFiles.length - 1 ? 'disabled' : ''}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <button class="remove-btn text-matte-400 hover:text-red-500 p-1" data-index="${index}">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
          </div>
        `;
        fileList.appendChild(li);
      });

      // Add event listeners
      document.querySelectorAll('.remove-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const idx = parseInt(btn.dataset.index);
          const removedFile = selectedFiles[idx];
          selectedFiles.splice(idx, 1);
          delete filePreviews[removedFile.name];
          updateUI();
          updatePreview();
          window.showToast?.(window._tToast('Item dihapus'));
        });
      });

      document.querySelectorAll('.move-up-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const idx = parseInt(btn.dataset.index);
          if (idx > 0) {
            [selectedFiles[idx], selectedFiles[idx - 1]] = [selectedFiles[idx - 1], selectedFiles[idx]];
            updateUI();
            updatePreview();
          }
        });
      });

      document.querySelectorAll('.move-down-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const idx = parseInt(btn.dataset.index);
          if (idx < selectedFiles.length - 1) {
            [selectedFiles[idx], selectedFiles[idx + 1]] = [selectedFiles[idx + 1], selectedFiles[idx]];
            updateUI();
            updatePreview();
          }
        });
      });

      // Make file list sortable
      makeFileListSortable();
      
    } else {
      dropZone.classList.remove('hidden');
      fileListContainer.classList.add('hidden');
    }
  }

  // --- 3. PREVIEW FUNCTION ---
  async function generatePreviews() {
    if (!previewList || !emptyPreview) return;
    
    previewList.innerHTML = '';
    
    if (selectedFiles.length === 0) {
      emptyPreview.classList.remove('hidden');
      previewList.classList.add('hidden');
      return;
    }
    
    emptyPreview.classList.add('hidden');
    previewList.classList.remove('hidden');
    
    for (let i = 0; i < selectedFiles.length; i++) {
      const file = selectedFiles[i];
      
      try {
        const fileBuffer = await file.arrayBuffer();
        const { PDFDocument } = await import('pdf-lib');
        const pdf = await PDFDocument.load(fileBuffer);
        const pageCount = pdf.getPageCount();
        
        filePreviews[file.name] = { pageCount };
        
        // Create preview item (pdf-lib does not support canvas rendering; show icon instead)
        const previewItem = document.createElement('div');
        previewItem.className = 'border border-matte-200 dark:border-matte-600 rounded-lg p-3';
        
        previewItem.innerHTML = `
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-red-50 dark:bg-red-900/20 rounded flex items-center justify-center flex-shrink-0 text-red-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
            </div>
            <div class="flex-1 min-w-0">
              <h4 class="font-medium text-sm truncate text-matte-800 dark:text-matte-200">${file.name}</h4>
              <p class="text-xs text-matte-500">${pageCount} halaman • ${formatFileSize(file.size)}</p>
            </div>
          </div>
        `;
        
        previewList.appendChild(previewItem);
      } catch (error) {
      }
    }
  }

  function updatePreview() {
    generatePreviews();
  }

  // --- 5. MAKE FILE LIST SORTABLE ---
  function makeFileListSortable() {
    const fileItems = document.querySelectorAll('.file-item');
    let draggedElement = null;
    let draggedIndex = null;

    fileItems.forEach(item => {
      item.draggable = true;
      
      item.addEventListener('dragstart', (e) => {
        draggedElement = item;
        draggedIndex = parseInt(item.dataset.index);
        item.classList.add('opacity-50');
      });
      
      item.addEventListener('dragend', (e) => {
        item.classList.remove('opacity-50');
      });
      
      item.addEventListener('dragover', (e) => {
        e.preventDefault();
        const afterElement = getDragAfterElement(fileList, e.clientY);
        if (afterElement == null) {
          fileList.appendChild(draggedElement);
        } else {
          fileList.insertBefore(draggedElement, afterElement);
        }
      });
      
      item.addEventListener('drop', (e) => {
        e.preventDefault();
        const dropIndex = parseInt(item.dataset.index);
        
        // Reorder files array
        const [removed] = selectedFiles.splice(draggedIndex, 1);
        selectedFiles.splice(dropIndex, 0, removed);
        
        updateUI();
        updatePreview();
      });
    });
  }

  function getDragAfterElement(container, y) {
    const draggableElements = [...container.querySelectorAll('.file-item:not(.dragging)')];
    
    return draggableElements.reduce((closest, child) => {
      const box = child.getBoundingClientRect();
      const offset = y - box.top - box.height / 2;
      
      if (offset < 0 && offset > closest.offset) {
        return { offset: offset, element: child };
      } else {
        return closest;
      }
    }, { offset: Number.NEGATIVE_INFINITY }).element;
  }

  // --- 6. SORT FILES ---
  sortBtn?.addEventListener('click', () => {
    selectedFiles.sort((a, b) => a.name.localeCompare(b.name));
    updateUI();
    updatePreview();
    window.showToast?.(window._tToast('File diurutkan berdasarkan nama'));
  });

  // --- 7. CLEAR ALL FILES ---
  clearAllBtn?.addEventListener('click', () => {
    if (selectedFiles.length === 0) return;
    
    if (confirm(window._tToast('Yakin ingin menghapus semua?'))) {
      selectedFiles = [];
      filePreviews = {};
      if (fileInput) fileInput.value = '';
      updateUI();
      updatePreview();
      window.showToast?.(window._tToast('Semua file dihapus'));
    }
  });

  // --- 8. LOGIC MERGE PDF ---
  mergeBtn?.addEventListener('click', async () => {
    if (selectedFiles.length === 0) {
      window.showToast?.(window._tToast('Pilih file PDF terlebih dahulu'), 'error');
      return;
    }

    const restoreBtn = window.showButtonSpinner(mergeBtn, window._tToast ? window._tToast('Memproses...') : 'Memproses...');
    
    // Show progress
    fileListContainer.classList.add('hidden');
    progressContainer.classList.remove('hidden');
    
    try {
      // Create new PDF document
      const { PDFDocument } = await import('pdf-lib');
      const mergedPdf = await PDFDocument.create();
      
      // Process each file with progress tracking
      for (let i = 0; i < selectedFiles.length; i++) {
        const file = selectedFiles[i];
        const fileBuffer = await file.arrayBuffer();
        const pdf = await PDFDocument.load(fileBuffer);
        
        // Copy pages based on merge mode
        if (mergeMode.value === 'sequential') {
          const copiedPages = await mergedPdf.copyPages(pdf, pdf.getPageIndices());
          copiedPages.forEach((page) => mergedPdf.addPage(page));
          
          // Add bookmark if enabled
          if (addBookmarks.checked) {
            const context = mergedPdf.context;
            const bookmarkTitle = file.name.replace('.pdf', '');
            const bookmark = {
              title: bookmarkTitle,
              parent: null,
              items: []
            };
            // Note: pdf-lib doesn't have built-in bookmark support
            // This is a placeholder for future implementation
          }
        } else if (mergeMode.value === 'interleave') {
          // Interleave pages from all documents
          const copiedPages = await mergedPdf.copyPages(pdf, pdf.getPageIndices());
          copiedPages.forEach((page, index) => {
            // Insert pages at interleaved positions
            const targetPosition = index * selectedFiles.length + i;
            // Note: pdf-lib doesn't support inserting pages at specific positions
            // This is a simplified implementation
            if (i === 0) {
              mergedPdf.addPage(page);
            }
          });
        }
        
        // Update progress
        const progress = Math.round(((i + 1) / selectedFiles.length) * 100);
        progressBar.style.width = `${progress}%`;
        progressPercent.textContent = `${progress}%`;
      }

      // Save merged PDF
      const pdfBytes = await mergedPdf.save();
      const blob = new Blob([pdfBytes], { type: 'application/pdf' });
      
      // Create download link
      const link = document.createElement('a');
      link.href = URL.createObjectURL(blob);
      link.download = `${outputName.value || 'merged-document'}-${Date.now()}.pdf`;
      link.click();
      
      // Show success message
      window.showToast?.(window._tToast('PDF berhasil digabungkan!'));
      
      // Reset after successful merge
      setTimeout(() => {
        selectedFiles = [];
        filePreviews = {};
        if (fileInput) fileInput.value = '';
        updateUI();
        updatePreview();
        fileListContainer.classList.remove('hidden');
        progressContainer.classList.add('hidden');
        progressBar.style.width = '0%';
        progressPercent.textContent = window._tToast ? window._tToast('0%') : '0%';
      }, 1000);
      
    } catch (error) {
      window.showToast?.(window._tToast('Gagal menggabungkan PDF. Pastikan file tidak dipassword atau corrupt.'), 'error');
      fileListContainer.classList.remove('hidden');
      progressContainer.classList.add('hidden');
    } finally {
      restoreBtn();
    }
  });

  // --- 9. RESET ---
  resetBtn?.addEventListener('click', () => {
    selectedFiles = [];
    filePreviews = {};
    if (fileInput) fileInput.value = '';
    updateUI();
    updatePreview();
    fileListContainer.classList.remove('hidden');
    progressContainer.classList.add('hidden');
    progressBar.style.width = '0%';
    progressPercent.textContent = window._tToast ? window._tToast('0%') : '0%';
    window.showToast?.(window._tToast('Form direset'));
  });

  // --- 10. HELPER FUNCTIONS ---
  function formatFileSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    else if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
    else return (bytes / 1048576).toFixed(1) + ' MB';
  }

  // Using window.showToast from BaseLayout for translations
</script>