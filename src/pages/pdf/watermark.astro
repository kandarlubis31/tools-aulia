---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Add Watermark PDF (Live Preview)">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js" async></script>
  <script is:inline async>
    (function waitForPdfjs() {
      if (window.pdfjsLib) {
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
      } else {
        setTimeout(waitForPdfjs, 50);
      }
    })();
  </script>
  <script type="module" src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>

  <div class="max-w-6xl mx-auto px-4 min-h-[80vh]">
    <div class="text-center mb-8 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-cyan-500 to-blue-600" data-i18n="header.watermark">
        Live Watermark
      </h1>
      <p class="text-slate-600 dark:text-slate-400" data-i18n="header.watermark_desc">
        Geser, putar, dan atur posisi watermark langsung di layar.
      </p>
    </div>

    <div id="drop-zone" class="max-w-2xl mx-auto border-3 border-dashed border-slate-300 dark:border-slate-600 rounded-3xl p-12 cursor-pointer hover:border-cyan-500 hover:bg-cyan-50 dark:hover:bg-slate-800/50 transition-all group text-center animate-on-scroll">
      <div class="w-20 h-20 bg-cyan-100 dark:bg-cyan-900/30 text-cyan-600 dark:text-cyan-400 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/><path d="M9 12l2 2l4 -4"/></svg>
      </div>
      <h3 class="text-2xl font-bold text-slate-700 dark:text-slate-200 mb-2" data-i18n="btn.select_pdf">Pilih PDF</h3>
      <input type="file" id="file-input" accept="application/pdf" class="hidden" />
    </div>

    <div id="workspace" class="hidden grid grid-cols-1 lg:grid-cols-3 gap-8 pb-20 animate-fade-in">
      
      <div class="lg:col-span-1 space-y-6">
        <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-lg sticky top-24">            <h3 class="font-bold text-slate-700 dark:text-slate-200 mb-4 flex items-center gap-2" data-i18n="btn.settings">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-500"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
            Pengaturan
          </h3>

          <div class="mb-4">
            <label class="block text-xs font-bold text-slate-500 mb-1" data-i18n="label.watermark_text">Teks Watermark</label>
            <input type="text" id="wm-text" value="DRAFT" class="w-full p-3 rounded-lg bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 focus:border-cyan-500 outline-none font-bold" />
          </div>

          <div class="grid grid-cols-2 gap-4 mb-4">
             <div>
                <label class="block text-xs font-bold text-slate-500 mb-1" data-i18n="label.color">Warna</label>
                <input type="color" id="wm-color" value="#ff0000" class="w-full h-10 p-1 rounded cursor-pointer bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600" />
             </div>
             <div>
                <label class="block text-xs font-bold text-slate-500 mb-1" data-i18n="label.font_size">Ukuran Font</label>
                <input type="number" id="wm-size" value="60" class="w-full p-2 h-10 rounded bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600" />
             </div>
          </div>

          <div class="mb-4">
            <div class="flex justify-between text-xs font-bold text-slate-500 mb-1">
                <span data-i18n="label.opacity">Opasitas</span>
                <span id="opacity-val">50%</span>
            </div>
            <input type="range" id="wm-opacity" min="0" max="1" step="0.1" value="0.5" class="w-full h-2 bg-slate-200 dark:bg-slate-700 rounded-lg appearance-none cursor-pointer accent-cyan-500" />
          </div>

          <div class="mb-6">
            <div class="flex justify-between text-xs font-bold text-slate-500 mb-1">
                <span data-i18n="label.rotation">Rotasi</span>
                <span id="rotate-val">45°</span>
            </div>
            <input type="range" id="wm-rotate" min="0" max="360" step="15" value="45" class="w-full h-2 bg-slate-200 dark:bg-slate-700 rounded-lg appearance-none cursor-pointer accent-cyan-500" />
          </div>
          
          <button id="save-btn" class="w-full bg-cyan-600 hover:bg-cyan-700 text-white font-bold py-3 px-6 rounded-xl shadow-lg transition-all active:scale-95 flex items-center justify-center gap-2" data-i18n="btn.save_pdf">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            Simpan PDF
          </button>
        </div>
      </div>

      <div class="lg:col-span-2 flex flex-col items-center">
        <div class="bg-slate-100 dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-700 shadow-inner w-full flex justify-center overflow-auto relative">
           
           <p class="absolute top-2 text-xs text-slate-400 font-mono z-0" data-i18n="text.page_preview">Preview Halaman 1</p>

           <div id="preview-container" class="relative shadow-2xl mt-6 cursor-crosshair touch-none select-none">
              <canvas id="pdf-render" class="max-w-full h-auto rounded-lg"></canvas>
              
              <div id="wm-overlay" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 border-2 border-dashed border-cyan-500 bg-cyan-500/10 p-2 cursor-move select-none whitespace-nowrap origin-center" style="transform: translate(-50%, -50%) rotate(45deg);">
                 <span id="wm-display" class="font-bold">DRAFT</span>
              </div>
           </div>

        </div>
        <p class="text-xs text-slate-500 mt-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 9l4 4l-4 4"/><path d="M3 3l18 18"/><path d="M9 5l4 4l-4 4"/></svg>
            <span data-i18n="text.wm_preview_tip">Tips: Klik dan seret teks pada preview untuk memindahkan posisi.</span>
        </p>
      </div>

    </div>
  </div>
</BaseLayout>

<script type="module">
  // Dynamic Import untuk library (menghindari error encrypt kemarin)
  const { PDFDocument, rgb, degrees, StandardFonts } = await import('https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.esm.js');

  // Elements
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input');
  const workspace = document.getElementById('workspace');
  const previewContainer = document.getElementById('preview-container');
  const canvas = document.getElementById('pdf-render');
  const wmOverlay = document.getElementById('wm-overlay');
  const wmDisplay = document.getElementById('wm-display');
  const saveBtn = document.getElementById('save-btn');

  // Inputs
  const inpText = document.getElementById('wm-text');
  const inpColor = document.getElementById('wm-color');
  const inpSize = document.getElementById('wm-size');
  const inpOpacity = document.getElementById('wm-opacity');
  const inpRotate = document.getElementById('wm-rotate');

  // Displays
  const opVal = document.getElementById('opacity-val');
  const rotVal = document.getElementById('rotate-val');

  let currentFile = null;
  let pdfWidth = 0; // Ukuran asli PDF (points)
  let pdfHeight = 0;

  // --- 1. HANDLE UPLOAD & RENDER ---
  dropZone.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', async (e) => {
    if (fileInput.files[0]) {
      currentFile = fileInput.files[0];
      dropZone.classList.add('hidden');
      workspace.classList.remove('hidden');
      workspace.classList.add('grid'); // Balikin grid display
      await renderPageOne(currentFile);
    }
  });

  async function renderPageOne(file) {
    const arrayBuffer = await file.arrayBuffer();
    const pdf = await pdfjsLib.getDocument(arrayBuffer).promise;
    const page = await pdf.getPage(1);
    
    // Simpan ukuran asli PDF (penting buat kalkulasi nanti)
    const view = page.getViewport({ scale: 1.0 });
    pdfWidth = view.width;
    pdfHeight = view.height;

    // Render ke Canvas (Scale 1.5 biar tajam di layar)
    const viewport = page.getViewport({ scale: 1.0 }); // Pakai 1.0 biar mapping coordinate gampang
    // Kita biarkan canvas menyesuaikan lebar via CSS (max-w-full)
    // Tapi attribute width/height canvas harus sesuai render
    canvas.width = viewport.width;
    canvas.height = viewport.height;

    const context = canvas.getContext('2d');
    await page.render({ canvasContext: context, viewport: viewport }).promise;

    // Set ukuran container sama dengan canvas biar overlay pas
    previewContainer.style.width = `${viewport.width}px`;
    previewContainer.style.height = `${viewport.height}px`;
    
    updateVisuals();
  }

  // --- 2. LIVE PREVIEW LOGIC ---
  function updateVisuals() {
    // Update Text
    wmDisplay.innerText = inpText.value || "WATERMARK";
    
    // Update Style
    wmDisplay.style.fontSize = `${inpSize.value}px`;
    wmDisplay.style.color = inpColor.value;
    wmOverlay.style.opacity = inpOpacity.value;
    
    // Update Transform (Rotation)
    // Kita pake translate(-50%, -50%) biar pivot di tengah, lalu rotate
    wmOverlay.style.transform = `translate(-50%, -50%) rotate(${inpRotate.value}deg)`;
    
    // Update Labels
    opVal.innerText = `${Math.round(inpOpacity.value * 100)}%`;
    rotVal.innerText = `${inpRotate.value}°`;
  }

  // Event Listeners Inputs
  [inpText, inpColor, inpSize, inpOpacity, inpRotate].forEach(el => {
    el.addEventListener('input', updateVisuals);
  });


  // --- 3. DRAG & DROP LOGIC ---
  let isDragging = false;
  
  // Posisi relatif overlay (0% - 100%) terhadap container
  let currentXPercent = 50; 
  let currentYPercent = 50; 

  previewContainer.addEventListener('mousedown', startDrag);
  previewContainer.addEventListener('touchstart', startDrag, { passive: false });

  document.addEventListener('mousemove', drag);
  document.addEventListener('touchmove', drag, { passive: false });

  document.addEventListener('mouseup', stopDrag);
  document.addEventListener('touchend', stopDrag);

  function startDrag(e) {
    // Hanya start kalau klik di overlay atau area container
    if (e.target.closest('#wm-overlay') || e.target === previewContainer) {
       isDragging = true;
       e.preventDefault();
       drag(e); // Langsung pindah ke posisi klik
    }
  }

  function drag(e) {
    if (!isDragging) return;
    e.preventDefault();

    let clientX, clientY;
    if (e.type.includes('touch')) {
        clientX = e.touches[0].clientX;
        clientY = e.touches[0].clientY;
    } else {
        clientX = e.clientX;
        clientY = e.clientY;
    }

    // Hitung posisi mouse relatif terhadap container preview
    const rect = previewContainer.getBoundingClientRect();
    let x = clientX - rect.left;
    let y = clientY - rect.top;

    // Batasi biar gak keluar jauh
    x = Math.max(0, Math.min(x, rect.width));
    y = Math.max(0, Math.min(y, rect.height));

    // Konversi ke Persentase (biar responsif & gampang mapping ke PDF)
    currentXPercent = (x / rect.width) * 100;
    currentYPercent = (y / rect.height) * 100;

    // Pindahkan Overlay (Pakai top/left %)
    wmOverlay.style.left = `${currentXPercent}%`;
    wmOverlay.style.top = `${currentYPercent}%`;
  }

  function stopDrag() {
    isDragging = false;
  }

  // --- 4. SAVE LOGIC (MATH HELL) ---
  saveBtn.addEventListener('click', async () => {
    if (!currentFile) return;
    
    saveBtn.innerText = (window._tToast) ? window._tToast('Memproses...') : 'Memproses...';
    saveBtn.disabled = true;

    try {
        const arrayBuffer = await currentFile.arrayBuffer();
        const pdfDoc = await PDFDocument.load(arrayBuffer);
        const pages = pdfDoc.getPages();
        const font = await pdfDoc.embedFont(StandardFonts.HelveticaBold);

        // Ambil nilai dari input
        const text = inpText.value;
        const size = parseInt(inpSize.value);
        const opacity = parseFloat(inpOpacity.value);
        const rotation = parseInt(inpRotate.value);
        
        // Konversi warna Hex ke RGB (0-1)
        const hex = inpColor.value;
        const r = parseInt(hex.slice(1, 3), 16) / 255;
        const g = parseInt(hex.slice(3, 5), 16) / 255;
        const b = parseInt(hex.slice(5, 7), 16) / 255;

        // Terapkan ke SEMUA halaman
        pages.forEach(page => {
            const { width, height } = page.getSize();
            
            // MATH MAGIC: Konversi Koordinat Layar ke PDF
            // Layar: (0,0) di Kiri-Atas. PDF: (0,0) di Kiri-Bawah.
            // Kita pakai persentase (currentXPercent) biar aman dari skala.
            
            const xPos = width * (currentXPercent / 100);
            
            // Y position perlu dibalik
            const yPos = height - (height * (currentYPercent / 100));

            // Perlu adjustment karena drawText anchor-nya di sudut kiri bawah teks
            // Sedangkan di CSS kita pakai translate(-50%, -50%) alias center.
            // Kita hitung lebar teks kasar untuk adjustment centering.
            const textWidth = font.widthOfTextAtSize(text, size);
            const textHeight = size; // Estimasi kasar

            page.drawText(text, {
                x: xPos - (textWidth / 2), // Adjust ke center
                y: yPos - (textHeight / 4), // Adjust ke center vertikal
                size: size,
                font: font,
                color: rgb(r, g, b),
                opacity: opacity,
                rotate: degrees(rotation),
            });
        });

        const pdfBytes = await pdfDoc.save();
        const blob = new Blob([pdfBytes], { type: 'application/pdf' });
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = `watermarked-${currentFile.name}`;
        link.click();
        
        window.showToast(window._tToast ? window._tToast("Berhasil! Watermark diterapkan.") : "Berhasil! Watermark diterapkan.", "success");

    } catch (err) {
        console.error(err);
        window.showToast(window._tToast ? window._tToast("Gagal menyimpan PDF.") : "Gagal menyimpan PDF.", "error");
    } finally {
        saveBtn.innerText = window._tToast ? window._tToast("Simpan PDF") : "Simpan PDF";
        saveBtn.disabled = false;
    }
  });

  // Init
  updateVisuals();
</script>