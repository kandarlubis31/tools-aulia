---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="URL Encoder / Decoder">
  <div class="max-w-4xl mx-auto px-4 min-h-[60vh]">
    <div class="text-center mb-10 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-teal-500 to-emerald-500">
        URL Encoder / Decoder
      </h1>
      <p class="text-matte-600 dark:text-matte-400" data-i18n="header.url_desc">
        Encode URL agar aman digunakan atau Decode URL yang berantakan (%20).
      </p>
    </div>

    <div class="bg-white dark:bg-matte-800 p-1 rounded-xl inline-flex mb-8 border border-matte-200 dark:border-matte-700 animate-fade-in mx-auto relative left-1/2 -tranmatte-x-1/2">
       <button id="mode-encode" class="px-6 py-2 rounded-lg text-sm font-bold bg-teal-500 text-white shadow-md transition-all" data-i18n="btn.encoder">Encoder</button>
       <button id="mode-decode" class="px-6 py-2 rounded-lg text-sm font-medium text-matte-500 hover:text-matte-700 dark:text-matte-400 transition-all" data-i18n="btn.decoder">Decoder</button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 animate-fade-in">
      
      <div class="flex flex-col h-full bg-white dark:bg-matte-800 rounded-xl shadow-lg border border-matte-200 dark:border-matte-700 overflow-hidden">
         <div class="bg-matte-100 dark:bg-matte-900 px-4 py-2 border-b border-matte-200 dark:border-matte-700 flex justify-between items-center">
            <span class="text-xs font-bold text-matte-500 uppercase">Input</span>
            <button id="clear-btn" class="text-xs font-bold text-red-500 hover:text-red-600">Clear</button>
         </div>
         <textarea id="input-text" class="flex-1 w-full p-4 font-mono text-sm bg-matte-50 dark:bg-matte-900 text-matte-800 dark:text-matte-200 outline-none resize-none min-h-[200px]" placeholder="https://example.com/search?q=hello world"></textarea>
      </div>

      <div class="flex flex-col h-full bg-white dark:bg-matte-800 rounded-xl shadow-lg border border-matte-200 dark:border-matte-700 overflow-hidden">
         <div class="bg-matte-100 dark:bg-matte-900 px-4 py-2 border-b border-matte-200 dark:border-matte-700 flex justify-between items-center">
            <span class="text-xs font-bold text-matte-500 uppercase">Result</span>
            <button id="copy-btn" class="text-xs font-bold text-teal-600 hover:text-teal-700">Copy</button>
         </div>
         <textarea id="output-text" readonly class="flex-1 w-full p-4 font-mono text-sm bg-matte-50 dark:bg-matte-900 text-matte-800 dark:text-matte-200 outline-none resize-none min-h-[200px]" placeholder="https://example.com/search?q=hello%20world"></textarea>
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  const input = document.getElementById('input-text');
  const output = document.getElementById('output-text');
  const modeEncode = document.getElementById('mode-encode');
  const modeDecode = document.getElementById('mode-decode');
  const clearBtn = document.getElementById('clear-btn');
  const copyBtn = document.getElementById('copy-btn');

  let isEncode = true;

  function process() {
    const val = input.value;
    if(!val) { output.value = ""; return; }

    try {
        if (isEncode) {
            output.value = encodeURIComponent(val).replace(/%20/g, '+'); // Standard URL encoding
        } else {
            output.value = decodeURIComponent(val.replace(/\+/g, '%20'));
        }
    } catch (e) {
        output.value = window._tToast ? window._tToast('Error: Invalid URL format') : 'Error: Invalid URL format';
    }
  }

  function setMode(encode) {
    isEncode = encode;
    
    if (encode) {
        modeEncode.className = "px-6 py-2 rounded-lg text-sm font-bold bg-teal-500 text-white shadow-md transition-all";
        modeDecode.className = "px-6 py-2 rounded-lg text-sm font-medium text-matte-500 hover:text-matte-700 dark:text-matte-400 transition-all";
    } else {
        modeDecode.className = "px-6 py-2 rounded-lg text-sm font-bold bg-teal-500 text-white shadow-md transition-all";
        modeEncode.className = "px-6 py-2 rounded-lg text-sm font-medium text-matte-500 hover:text-matte-700 dark:text-matte-400 transition-all";
    }
    process();
  }

  modeEncode.addEventListener('click', () => setMode(true));
  modeDecode.addEventListener('click', () => setMode(false));
  input.addEventListener('input', process);
  
  clearBtn.addEventListener('click', () => {
    input.value = ""; output.value = ""; input.focus();
  });

  copyBtn.addEventListener('click', () => {
    if(!output.value) return;
    navigator.clipboard.writeText(output.value);
    window.showToast(window._tToast ? window._tToast('URL disalin!') : 'URL disalin!', "success");
  });
</script>
