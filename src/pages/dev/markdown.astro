---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Markdown Editor">
  <script is:inline src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

  <div class="max-w-7xl mx-auto px-4 min-h-[80vh] flex flex-col">
    <div class="text-center mb-6 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-2 text-transparent bg-clip-text bg-gradient-to-r from-matte-700 to-matte-900 dark:from-matte-100 dark:to-matte-300">
        Markdown Editor
      </h1>
      <p class="text-matte-600 dark:text-matte-400">
        Tulis Markdown di kiri, lihat hasilnya di kanan secara real-time.
      </p>
    </div>

    <div class="flex justify-end gap-2 mb-4 animate-fade-in">
       <button id="copy-html" class="px-4 py-2 bg-matte-200 dark:bg-matte-700 hover:bg-matte-300 dark:hover:bg-matte-600 text-sm font-bold rounded-lg transition" data-i18n="btn.copy_html">Copy HTML</button>
       <button id="copy-md" class="px-4 py-2 bg-matte-800 hover:bg-matte-900 text-white text-sm font-bold rounded-lg transition" data-i18n="btn.copy_md">Copy Markdown</button>
    </div>

    <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-0 md:gap-4 pb-12 animate-fade-in h-[600px]">
       
       <textarea id="editor" class="w-full h-full p-6 font-mono text-sm bg-matte-50 dark:bg-matte-900 border border-matte-300 dark:border-matte-700 rounded-xl resize-none outline-none focus:border-matte-500" spellcheck="false" placeholder="# Hello World&#10;&#10;Tulis **Markdown** di sini..."></textarea>

       <div id="preview" class="w-full h-full p-6 bg-white dark:bg-matte-800 border border-matte-300 dark:border-matte-700 rounded-xl overflow-y-auto prose dark:prose-invert max-w-none">
          </div>

    </div>
  </div>
</BaseLayout>

<script>
  const editor = document.getElementById('editor');
  const preview = document.getElementById('preview');
  const btnCopyHtml = document.getElementById('copy-html');
  const btnCopyMd = document.getElementById('copy-md');

  // Default Content
  const defaultText = `# " + (window._t ? window._t("Selamat Datang!") : "Selamat Datang!");

Ini adalah **Markdown Editor** sederhana. 
Kamu bisa menulis:

- List item
- [Links](https://paklubis.my.id)
- \`Code block\`

> Blockquote juga bisa lho!

Coba ketik sesuatu di sebelah kiri...`;

  function render() {
    const text = editor.value;
    preview.innerHTML = marked.parse(text);
  }

  editor.addEventListener('input', render);
  
  // Set default
  editor.value = defaultText;
  render();

  btnCopyMd.addEventListener('click', () => {
    navigator.clipboard.writeText(editor.value);
    window.showToast(window._tToast ? window._tToast('Markdown disalin!') : 'Markdown disalin!', 'success');
  });

  btnCopyHtml.addEventListener('click', () => {
    navigator.clipboard.writeText(preview.textContent || '');
    window.showToast(window._tToast ? window._tToast('HTML Code disalin!') : 'HTML Code disalin!', 'success');
  });
</script>
