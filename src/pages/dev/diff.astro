---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Text Diff Checker">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jsdiff/5.1.0/diff.min.js"></script>

  <div class="max-w-6xl mx-auto px-4 min-h-[80vh] flex flex-col">
    <div class="text-center mb-8 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-red-500">
        Diff Checker
      </h1>
      <p class="text-matte-600 dark:text-matte-400">
        Bandingkan dua teks untuk melihat perbedaan karakter atau baris.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6 animate-fade-in">
      <div class="flex flex-col h-64 bg-white dark:bg-matte-800 rounded-xl shadow border border-matte-200 dark:border-matte-700 overflow-hidden">
         <div class="bg-matte-50 dark:bg-matte-900 px-4 py-2 border-b border-matte-200 dark:border-matte-700 font-bold text-matte-500 text-xs uppercase" data-i18n="label.original_text">Original Text</div>
         <textarea id="text-original" class="flex-1 w-full p-4 font-mono text-sm bg-transparent outline-none resize-none dark:text-matte-200" placeholder="Paste original text here..."></textarea>
      </div>
      <div class="flex flex-col h-64 bg-white dark:bg-matte-800 rounded-xl shadow border border-matte-200 dark:border-matte-700 overflow-hidden">
         <div class="bg-matte-50 dark:bg-matte-900 px-4 py-2 border-b border-matte-200 dark:border-matte-700 font-bold text-matte-500 text-xs uppercase" data-i18n="label.modified_text">Modified Text</div>
         <textarea id="text-modified" class="flex-1 w-full p-4 font-mono text-sm bg-transparent outline-none resize-none dark:text-matte-200" placeholder="Paste modified text here..."></textarea>
      </div>
    </div>

    <div class="flex justify-center mb-8 animate-fade-in">
       <button id="compare-btn" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-8 rounded-full shadow-lg transition-transform active:scale-95 flex items-center gap-2" data-i18n="btn.compare_diff">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3h5v5"/><path d="M4 20L21 3"/><path d="M21 16v5h-5"/><path d="M15 15l5 5"/><path d="M4 4l5 5"/></svg>
          <span data-i18n="btn.compare">Bandingkan</span>
       </button>
    </div>

    <div class="flex-1 bg-white dark:bg-matte-800 rounded-xl shadow-lg border border-matte-200 dark:border-matte-700 overflow-hidden animate-fade-in mb-12">
       <div class="bg-matte-50 dark:bg-matte-900 px-4 py-2 border-b border-matte-200 dark:border-matte-700 flex justify-between items-center">
          <span class="font-bold text-matte-500 text-xs uppercase" data-i18n="text.result_comparison">Result Comparison</span>
          <div class="flex gap-4 text-xs font-bold">
             <span class="text-red-500 flex items-center gap-1"><span class="w-2 h-2 bg-red-500 rounded-full"></span> <span data-i18n="text.removed">Removed</span></span>
             <span class="text-green-500 flex items-center gap-1"><span class="w-2 h-2 bg-green-500 rounded-full"></span> <span data-i18n="text.added">Added</span></span>
          </div>
       </div>
       <div id="diff-output" class="p-6 font-mono text-sm leading-relaxed whitespace-pre-wrap dark:text-matte-300 min-h-[200px]"></div>
    </div>

  </div>
</BaseLayout>

<script>
  const original = document.getElementById('text-original');
  const modified = document.getElementById('text-modified');
  const btn = document.getElementById('compare-btn');
  const output = document.getElementById('diff-output');

  btn.addEventListener('click', () => {
    const text1 = original.value;
    const text2 = modified.value;

    if (!text1 && !text2) return;

    // Gunakan library jsdiff
    const diff = Diff.diffWords(text1, text2);
    
    const fragment = document.createDocumentFragment();

    diff.forEach((part) => {
      // Tentukan warna: Merah (hapus), Hijau (tambah), Abu (tetap)
      const color = part.added ? 'bg-green-200 dark:bg-green-900 text-green-800 dark:text-green-200 px-1 rounded' :
                    part.removed ? 'bg-red-200 dark:bg-red-900 text-red-800 dark:text-red-200 px-1 rounded line-through decoration-red-500' : 
                    'text-matte-600 dark:text-matte-400';
      
      const span = document.createElement('span');
      span.className = color;
      span.appendChild(document.createTextNode(part.value));
      fragment.appendChild(span);
    });

    output.innerHTML = '';
    output.appendChild(fragment);
    window.showToast(window._tToast ? window._tToast('Perbandingan selesai!') : 'Perbandingan selesai!', 'success');
  });
</script>
