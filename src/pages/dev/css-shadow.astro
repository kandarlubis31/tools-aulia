---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="CSS Shadow Generator">
  <div class="max-w-4xl mx-auto px-4 min-h-[60vh]">
    <div class="text-center mb-8 pt-8 animate-on-scroll">
      <h1 class="text-3xl font-extrabold mb-2 text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-rose-500" data-i18n="css_shadow.title">CSS Box Shadow</h1>
      <p class="text-slate-600 dark:text-slate-400" data-i18n="header.css_shadow_desc">Generator efek bayangan CSS visual.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 animate-fade-in">
       <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-lg border border-slate-200 dark:border-slate-700 space-y-4">
          <div><label class="text-xs font-bold text-slate-500" data-i18n="label.shift_right">Shift Right</label><input type="range" id="x-offset" min="-50" max="50" value="10" class="w-full h-2 bg-slate-200 rounded-lg accent-pink-500"></div>
          <div><label class="text-xs font-bold text-slate-500" data-i18n="label.shift_down">Shift Down</label><input type="range" id="y-offset" min="-50" max="50" value="10" class="w-full h-2 bg-slate-200 rounded-lg accent-pink-500"></div>
          <div><label class="text-xs font-bold text-slate-500" data-i18n="label.blur">Blur</label><input type="range" id="blur" min="0" max="100" value="20" class="w-full h-2 bg-slate-200 rounded-lg accent-pink-500"></div>
          <div><label class="text-xs font-bold text-slate-500" data-i18n="label.spread">Spread</label><input type="range" id="spread" min="-50" max="50" value="0" class="w-full h-2 bg-slate-200 rounded-lg accent-pink-500"></div>
          <div><label class="text-xs font-bold text-slate-500" data-i18n="label.opacity">Opacity</label><input type="range" id="opacity" min="0" max="1" step="0.01" value="0.2" class="w-full h-2 bg-slate-200 rounded-lg accent-pink-500"></div>
          <div class="flex items-center gap-2"><label class="text-xs font-bold text-slate-500" data-i18n="label.color">Color</label><input type="color" id="color" value="#000000" class="h-8 w-full rounded cursor-pointer"></div>
       </div>

       <div class="flex flex-col items-center justify-center bg-slate-50 dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-700 p-8">
          <div id="box" class="w-32 h-32 bg-white dark:bg-slate-800 rounded-xl mb-8 transition-all duration-200"></div>
          <code id="code-out" class="p-3 bg-slate-200 dark:bg-slate-800 rounded text-xs font-mono text-slate-700 dark:text-slate-300 w-full break-all">box-shadow: 10px 10px 20px 0px rgba(0,0,0,0.2);</code>
       </div>
    </div>
  </div>
</BaseLayout>

<script>
  const inputs = document.querySelectorAll('input');
  const box = document.getElementById('box');
  const code = document.getElementById('code-out');

  function hexToRgb(hex) {
    const r = parseInt(hex.slice(1, 3), 16), g = parseInt(hex.slice(3, 5), 16), b = parseInt(hex.slice(5, 7), 16);
    return `${r}, ${g}, ${b}`;
  }

  function update() {
    const x = (document.getElementById('x-offset') as HTMLInputElement).value;
    const y = (document.getElementById('y-offset') as HTMLInputElement).value;
    const blur = (document.getElementById('blur') as HTMLInputElement).value;
    const spread = (document.getElementById('spread') as HTMLInputElement).value;
    const op = (document.getElementById('opacity') as HTMLInputElement).value;
    const col = (document.getElementById('color') as HTMLInputElement).value;
    
    const shadow = `${x}px ${y}px ${blur}px ${spread}px rgba(${hexToRgb(col)}, ${op})`;
    box!.style.boxShadow = shadow;
    code!.innerText = `box-shadow: ${shadow};`;
  }

  inputs.forEach(i => i.addEventListener('input', update));
  update();
</script>
