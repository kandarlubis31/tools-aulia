---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Unix Timestamp Converter">
  <div class="max-w-3xl mx-auto px-4 min-h-[60vh]">
    <div class="text-center mb-10 pt-8 animate-on-scroll">
      <h1 class="text-3xl font-extrabold mb-2 text-transparent bg-clip-text bg-gradient-to-r from-violet-500 to-purple-500">Timestamp Converter</h1>
      <p class="text-slate-600 dark:text-slate-400">Konversi Unix Timestamp ke format tanggal manusia atau sebaliknya.</p>
    </div>

    <div class="bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-xl border border-slate-200 dark:border-slate-700 animate-fade-in grid gap-8">
      
      <div class="text-center p-4 bg-slate-100 dark:bg-slate-900 rounded-xl">
         <p class="text-xs font-bold text-slate-500 uppercase mb-1">Saat Ini (Unix)</p>
         <div id="current-ts" class="text-3xl font-mono font-bold text-violet-600 dark:text-violet-400">...</div>
      </div>

      <div>
         <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Timestamp to Date</label>
         <div class="flex gap-2">
            <input type="number" id="ts-input" class="flex-1 p-3 rounded-lg bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 outline-none font-mono" placeholder="1678900000" />
            <button id="ts-btn" class="px-6 bg-violet-600 text-white rounded-lg font-bold">Convert</button>
         </div>
         <div id="ts-result" class="mt-2 text-sm font-mono text-slate-700 dark:text-slate-300"></div>
      </div>

      <div>
         <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Date to Timestamp</label>
         <div class="flex gap-2">
            <input type="datetime-local" id="date-input" class="flex-1 p-3 rounded-lg bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 outline-none" />
            <button id="date-btn" class="px-6 bg-violet-600 text-white rounded-lg font-bold">Convert</button>
         </div>
         <div id="date-result" class="mt-2 text-sm font-mono text-slate-700 dark:text-slate-300"></div>
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  setInterval(() => {
    document.getElementById('current-ts')!.innerText = Math.floor(Date.now() / 1000).toString();
  }, 1000);

  document.getElementById('ts-btn')?.addEventListener('click', () => {
    const val = (document.getElementById('ts-input') as HTMLInputElement).value;
    if(!val) return;
    const date = new Date(parseInt(val) * 1000); // Assume seconds
    document.getElementById('ts-result')!.innerText = `GMT: ${date.toUTCString()} \nLocal: ${date.toLocaleString()}`;
  });

  document.getElementById('date-btn')?.addEventListener('click', () => {
    const val = (document.getElementById('date-input') as HTMLInputElement).value;
    if(!val) return;
    const ts = Math.floor(new Date(val).getTime() / 1000);
    document.getElementById('date-result')!.innerText = `Timestamp: ${ts}`;
  });
</script>
