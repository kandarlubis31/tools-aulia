---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Base64 Encoder / Decoder">
  <div class="max-w-4xl mx-auto px-4 min-h-[60vh]">
    <div class="text-center mb-10 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-amber-500">
        Base64 Converter
      </h1>
      <p class="text-slate-600 dark:text-slate-400">
        Encode teks ke Base64 atau Decode Base64 kembali ke teks biasa.
      </p>
    </div>

    <div class="bg-white dark:bg-slate-800 p-1 rounded-xl inline-flex mb-8 border border-slate-200 dark:border-slate-700 animate-fade-in mx-auto relative left-1/2 -translate-x-1/2">
       <button id="mode-encode" class="px-6 py-2 rounded-lg text-sm font-bold bg-amber-500 text-white shadow-md transition-all">Encoder</button>
       <button id="mode-decode" class="px-6 py-2 rounded-lg text-sm font-medium text-slate-500 hover:text-slate-700 dark:text-slate-400 transition-all">Decoder</button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 animate-fade-in">
      
      <div class="flex flex-col h-full bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 overflow-hidden">
         <div class="bg-slate-100 dark:bg-slate-900 px-4 py-2 border-b border-slate-200 dark:border-slate-700 flex justify-between items-center">
            <span id="label-input" class="text-xs font-bold text-slate-500 uppercase">Input Text</span>
            <button id="clear-btn" class="text-xs font-bold text-red-500 hover:text-red-600">Clear</button>
         </div>
         <textarea id="input-text" class="flex-1 w-full p-4 font-mono text-sm bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-200 outline-none resize-none min-h-[250px]" placeholder="Ketik di sini..."></textarea>
      </div>

      <div class="flex flex-col h-full bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 overflow-hidden">
         <div class="bg-slate-100 dark:bg-slate-900 px-4 py-2 border-b border-slate-200 dark:border-slate-700 flex justify-between items-center">
            <span id="label-output" class="text-xs font-bold text-slate-500 uppercase">Output Base64</span>
            <button id="copy-btn" class="text-xs font-bold text-amber-600 hover:text-amber-700">Copy Result</button>
         </div>
         <textarea id="output-text" readonly class="flex-1 w-full p-4 font-mono text-sm bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-200 outline-none resize-none min-h-[250px]" placeholder="Hasil..."></textarea>
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  const input = document.getElementById('input-text');
  const output = document.getElementById('output-text');
  const modeEncode = document.getElementById('mode-encode');
  const modeDecode = document.getElementById('mode-decode');
  const labelInput = document.getElementById('label-input');
  const labelOutput = document.getElementById('label-output');
  const clearBtn = document.getElementById('clear-btn');
  const copyBtn = document.getElementById('copy-btn');

  let isEncode = true;

  function process() {
    const val = input.value;
    if(!val) {
        output.value = "";
        return;
    }

    try {
        if (isEncode) {
            // Encode (mendukung utf-8 character)
            output.value = btoa(unescape(encodeURIComponent(val)));
            input.classList.remove('border-red-500', 'border-2');
        } else {
            // Decode
            output.value = decodeURIComponent(escape(atob(val)));
            input.classList.remove('border-red-500', 'border-2');
        }
    } catch (e) {
        output.value = "Error: Invalid Input format";
        if(!isEncode) input.classList.add('border-red-500', 'border-2');
    }
  }

  function setMode(encode) {
    isEncode = encode;
    input.value = "";
    output.value = "";
    
    if (encode) {
        modeEncode.className = "px-6 py-2 rounded-lg text-sm font-bold bg-amber-500 text-white shadow-md transition-all";
        modeDecode.className = "px-6 py-2 rounded-lg text-sm font-medium text-slate-500 hover:text-slate-700 dark:text-slate-400 transition-all";
        labelInput.innerText = "Input Text";
        labelOutput.innerText = "Output Base64";
        input.placeholder = "Ketik teks biasa...";
    } else {
        modeDecode.className = "px-6 py-2 rounded-lg text-sm font-bold bg-amber-500 text-white shadow-md transition-all";
        modeEncode.className = "px-6 py-2 rounded-lg text-sm font-medium text-slate-500 hover:text-slate-700 dark:text-slate-400 transition-all";
        labelInput.innerText = "Input Base64";
        labelOutput.innerText = "Output Text";
        input.placeholder = "Tempel kode Base64...";
    }
  }

  modeEncode.addEventListener('click', () => setMode(true));
  modeDecode.addEventListener('click', () => setMode(false));
  input.addEventListener('input', process);
  
  clearBtn.addEventListener('click', () => {
    input.value = "";
    output.value = "";
    input.focus();
  });

  copyBtn.addEventListener('click', () => {
    if(!output.value) return;
    navigator.clipboard.writeText(output.value);
    window.showToast("Hasil disalin!", "success");
  });
</script>
