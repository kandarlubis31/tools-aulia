---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="My IP & Network Info">
  <div class="max-w-6xl mx-auto px-4 py-10 min-h-[85vh]">
    
    <div class="text-center mb-10 animate-on-scroll">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-cyan-400 tracking-tight" data-i18n="header.my_ip_full">
        Cek IP & Koneksi
      </h1>
      <p class="text-matte-600 dark:text-matte-400 text-lg" data-i18n="header.my_ip_detail">
        Lihat info detail tentang koneksi internet dan identitas digital kamu.
      </p>
    </div>

    <div id="network-status" class="hidden fixed top-24 right-4 px-4 py-2 rounded-lg text-sm font-bold z-50 transition-all duration-300 shadow-lg border border-white/20 backdrop-blur-md">
        <span id="network-text"></span>
    </div>

    <div class="bg-white dark:bg-matte-800 rounded-3xl p-8 shadow-xl border border-matte-200 dark:border-matte-700 relative overflow-hidden group mb-8 transition-all hover:shadow-2xl hover:shadow-blue-500/10">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-500 to-cyan-400"></div>
        
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 relative z-10">
            <div class="text-center md:text-left" aria-live="polite">
                <p class="text-xs font-bold text-matte-400 uppercase tracking-widest mb-2" data-i18n="label.public_ip">IP Publik Kamu</p>
                <div class="flex flex-col md:flex-row items-center gap-4">
                    <h2 id="ip-display" class="text-4xl md:text-6xl font-black text-matte-800 dark:text-white font-mono tracking-tight">
                        <span class="inline-block w-48 h-10 bg-matte-200 dark:bg-matte-700 rounded-lg animate-pulse skeleton">&nbsp;</span>
                    </h2>
                    <button id="copy-ip-btn" class="p-2 rounded-lg bg-matte-100 dark:bg-matte-700 text-matte-500 hover:text-blue-500 transition-colors cursor-pointer hidden" title="Copy IP">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                    </button>
                </div>
                
                <div class="flex items-center justify-center md:justify-start gap-3 mt-4">
                    <span id="ipv-badge" class="hidden px-2 py-1 rounded text-[10px] font-bold bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 uppercase tracking-wide">IPv4</span>
                    <span id="connection-type-badge" class="hidden px-2 py-1 rounded text-[10px] font-bold bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300 uppercase tracking-wide">4G</span>
                    <span class="text-xs text-emerald-500 font-bold flex items-center gap-1.5 px-2 py-1 bg-emerald-50 dark:bg-emerald-900/10 rounded">
                        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span> <span data-i18n="text.connected">Terhubung</span>
                    </span>
                </div>
            </div>

            <div class="flex gap-3 w-full md:w-auto">
                <button id="refresh-btn" class="flex-1 md:flex-none flex items-center justify-center gap-2 px-5 py-3 bg-matte-100 dark:bg-matte-700 hover:bg-matte-200 dark:hover:bg-matte-600 text-matte-600 dark:text-matte-200 font-bold rounded-xl transition-all active:scale-95" data-i18n="btn.refresh">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.3"/></svg>
                    Refresh
                </button>
                <button id="speed-test-btn" class="flex-1 md:flex-none flex items-center justify-center gap-2 px-5 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-all shadow-lg shadow-blue-500/20 active:scale-95" data-i18n="btn.speed_test">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    Speed Test
                </button>
            </div>
        </div>

        <div class="absolute -right-6 -bottom-12 opacity-[0.03] dark:opacity-[0.05] pointer-events-none select-none">
            <svg width="350" height="350" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM4 12c0-.61.08-1.21.21-1.78L8.99 15v1c0 1.1.9 2 2 2v1.93C7.06 19.43 4 16.07 4 12zm13.89 5.4c-.26-.81-1-1.4-1.9-1.4h-1v-3c0-.55-.45-1-1-1h-6v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41C17.92 5.77 20 8.65 20 12c0 2.08-.81 3.98-2.11 5.4z"/></svg>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <!-- Provider Info Card -->
        <div class="bg-white dark:bg-matte-800 p-6 rounded-2xl border border-matte-200 dark:border-matte-700 shadow-sm hover:shadow-md transition-all group" aria-live="polite">
            <div class="flex items-center gap-3 mb-5 pb-4 border-b border-matte-100 dark:border-matte-700">
                <div class="p-2.5 bg-purple-100 dark:bg-purple-900/30 text-purple-600 rounded-lg group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                </div>
                <h3 class="font-bold text-matte-800 dark:text-white" data-i18n="label.provider_info">Info Provider</h3>
            </div>
            <div class="space-y-4">
                <div>
                    <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.provider">Provider</p>
                    <p id="isp-name" class="font-medium text-matte-700 dark:text-matte-200 text-lg truncate">
                        <span class="inline-block w-32 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                    </p>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.asn">ASN</p>
                        <p id="asn-name" class="font-medium text-matte-700 dark:text-matte-200">
                            <span class="inline-block w-20 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                        </p>
                    </div>
                    <div>
                        <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.type">Tipe</p>
                        <p id="connection-type" class="font-medium text-matte-700 dark:text-matte-200">
                            <span class="inline-block w-16 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                        </p>
                    </div>
                </div>
                <div>
                    <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.organization">Organisasi</p>
                    <p id="isp-domain" class="font-medium text-matte-700 dark:text-matte-200 truncate text-sm">
                        <span class="inline-block w-40 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                    </p>
                </div>
            </div>
        </div>

        <!-- Location Card -->
        <div class="bg-white dark:bg-matte-800 p-6 rounded-2xl border border-matte-200 dark:border-matte-700 shadow-sm hover:shadow-md transition-all group" aria-live="polite">
            <div class="flex items-center gap-3 mb-5 pb-4 border-b border-matte-100 dark:border-matte-700">
                <div class="p-2.5 bg-rose-100 dark:bg-rose-900/30 text-rose-600 rounded-lg group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <h3 class="font-bold text-matte-800 dark:text-white" data-i18n="label.location_server">Lokasi Server</h3>
            </div>
            <div class="space-y-4">
                <div class="flex items-center gap-3">
                    <img id="flag-img" src="" alt="Flag" class="w-10 h-auto rounded shadow-sm hidden border border-matte-100 dark:border-matte-600">
                    <div>
                        <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.country">Negara</p>
                        <p id="loc-country" class="font-medium text-matte-700 dark:text-matte-200">
                            <span class="inline-block w-28 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                        </p>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.city">Kota</p>
                        <p id="loc-city" class="font-medium text-matte-700 dark:text-matte-200 truncate">
                            <span class="inline-block w-24 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                        </p>
                    </div>
                    <div>
                        <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.timezone">Zona Waktu</p>
                        <p id="loc-timezone" class="font-medium text-matte-700 dark:text-matte-200 text-sm">
                            <span class="inline-block w-20 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                        </p>
                    </div>
                </div>
                <div>
                    <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.coordinates">Koordinat</p>
                    <div class="flex justify-between items-center">
                        <p id="loc-coords" class="font-mono text-sm text-matte-600 dark:text-matte-300">
                            <span class="inline-block w-32 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                        </p>
                        <a id="maps-link" href="#" target="_blank" class="text-xs font-bold text-blue-500 hover:text-blue-600 hidden bg-blue-50 dark:bg-blue-900/20 px-2 py-1 rounded">
                            Maps ↗
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Device Info Card -->
        <div class="bg-white dark:bg-matte-800 p-6 rounded-2xl border border-matte-200 dark:border-matte-700 shadow-sm hover:shadow-md transition-all group" aria-live="polite">
            <div class="flex items-center gap-3 mb-5 pb-4 border-b border-matte-100 dark:border-matte-700">
                <div class="p-2.5 bg-amber-100 dark:bg-amber-900/30 text-amber-600 rounded-lg group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="12" x="3" y="4" rx="2" ry="2"/><line x1="2" x2="22" y1="20" y2="20"/></svg>
                </div>
                <h3 class="font-bold text-matte-800 dark:text-white" data-i18n="label.device_info">Info Device</h3>
            </div>
            <div class="space-y-4">
                <div>
                    <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.browser_os">Browser & OS</p>
                    <p id="dev-browser" class="font-medium text-matte-700 dark:text-matte-200 truncate">
                        <span class="inline-block w-40 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                    </p>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.resolution">Resolusi</p>
                        <p id="dev-res" class="font-medium text-matte-700 dark:text-matte-200">
                            <span class="inline-block w-24 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                        </p>
                    </div>
                    <div>
                        <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.battery">Baterai</p>
                        <p id="dev-battery" class="font-medium text-matte-700 dark:text-matte-200">
                            <span class="inline-block w-16 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                        </p>
                    </div>
                </div>
                <div>
                    <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.local_ip">IP Lokal (WebRTC)</p>
                    <p id="local-ip" class="font-mono text-sm text-matte-600 dark:text-matte-300 truncate">
                        <span class="inline-block w-28 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                    </p>
                </div>
            </div>
        </div>

        <!-- Additional Info Card -->
        <div class="bg-white dark:bg-matte-800 p-6 rounded-2xl border border-matte-200 dark:border-matte-700 shadow-sm hover:shadow-md transition-all group lg:col-span-3" aria-live="polite">
            <div class="flex items-center gap-3 mb-5 pb-4 border-b border-matte-100 dark:border-matte-700">
                <div class="p-2.5 bg-green-100 dark:bg-green-900/30 text-green-600 rounded-lg group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 0 0-7z"/></svg>
                </div>
                <h3 class="font-bold text-matte-800 dark:text-white" data-i18n="label.additional_info">Info Tambahan</h3>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.proxy_vpn">Proxy / VPN</p>
                    <p id="proxy-status" class="font-medium text-matte-700 dark:text-matte-200">
                        <span class="inline-block w-28 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                    </p>
                </div>
                <div>
                    <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.connection">Koneksi</p>
                    <p id="connection-info" class="font-medium text-matte-700 dark:text-matte-200 truncate">
                        <span class="inline-block w-32 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                    </p>
                </div>
                <div>
                    <p class="text-[10px] text-matte-400 uppercase font-bold tracking-wider" data-i18n="label.user_agent">User Agent</p>
                    <p id="user-agent" class="font-medium text-matte-700 dark:text-matte-200 truncate text-xs">
                        <span class="inline-block w-48 h-4 bg-matte-200 dark:bg-matte-700 rounded animate-pulse skeleton">&nbsp;</span>
                    </p>
                </div>
            </div>
        </div>

    </div>

    <!-- IP History Section -->
    <div id="ip-history-section" class="mt-8 hidden">
        <div class="bg-white dark:bg-matte-800 rounded-2xl p-6 border border-matte-200 dark:border-matte-700 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-2">
                    <div class="p-2 bg-blue-100 dark:bg-blue-900/30 text-blue-600 rounded-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <h3 class="font-bold text-matte-800 dark:text-white" data-i18n="label.ip_history">Riwayat IP</h3>
                    <span id="ip-history-count" class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-matte-100 dark:bg-matte-700 text-matte-500">0</span>
                </div>
                <button id="clear-ip-history" class="hidden text-xs font-bold text-rose-500 hover:text-rose-600 transition-colors px-2 py-1 rounded-lg hover:bg-rose-50 dark:hover:bg-rose-900/10" data-i18n="btn.clear_history">
                    Hapus Riwayat
                </button>
            </div>
            <div id="ip-history-list" class="space-y-1.5 max-h-60 overflow-y-auto pr-1">
                <p class="text-sm text-matte-400 italic text-center py-6" data-i18n="text.no_ip_history">Belum ada riwayat pengecekan IP.</p>
            </div>
        </div>
    </div>

    <div class="mt-8 flex justify-center gap-4">
        <button id="toggle-json" class="group flex items-center gap-2 px-4 py-2 rounded-full bg-white dark:bg-matte-800 border border-matte-200 dark:border-matte-700 text-sm font-bold text-matte-500 hover:text-blue-500 transition-all hover:shadow-md">
            <span data-i18n="btn.dev_mode">Mode Developer (JSON)</span>
            <svg id="arrow-json" class="w-4 h-4 transition-transform group-hover:tranmatte-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        <button id="save-report" class="group flex items-center gap-2 px-4 py-2 rounded-full bg-white dark:bg-matte-800 border border-matte-200 dark:border-matte-700 text-sm font-bold text-matte-500 hover:text-green-500 transition-all hover:shadow-md">
            <span data-i18n="btn.save_report">Simpan Laporan</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
        </button>
    </div>
    
    <div id="json-container" class="hidden mt-4 max-w-3xl mx-auto">
        <div class="bg-matte-900 rounded-xl p-4 overflow-x-auto relative group border border-matte-700 shadow-inner">
            <button id="copy-json" class="absolute top-4 right-4 p-2 bg-matte-700 hover:bg-matte-600 rounded-lg text-matte-300 transition-colors" title="Copy JSON">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            </button>
            <pre id="json-code" class="text-xs text-emerald-400 font-mono leading-relaxed"></pre>
        </div>
    </div>

    <!-- Speed Test Modal -->
    <div id="speed-test-modal" class="hidden fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4 backdrop-blur-sm transition-opacity">
        <div class="bg-white dark:bg-matte-800 rounded-2xl p-6 md:p-8 max-w-md w-full shadow-2xl border border-matte-200 dark:border-matte-700 transform transition-all overflow-y-auto max-h-[95vh]">
            <!-- Header -->
            <div class="flex justify-between items-center mb-4">
                <div class="flex items-center gap-2">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-blue-500"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    <h3 class="font-bold text-matte-800 dark:text-white" data-i18n="btn.speed_test">Speed Test</h3>
                </div>
                <div class="flex items-center gap-2">
                    <span id="speed-server-info" class="hidden md:block text-[10px] font-medium text-matte-400 bg-matte-100 dark:bg-matte-700 px-2 py-0.5 rounded-full">cdnjs</span>
                    <button id="close-speed-test" class="text-matte-400 hover:text-matte-600 dark:hover:text-matte-300 transition-colors p-1 rounded-lg hover:bg-matte-100 dark:hover:bg-matte-700">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
            </div>

            <!-- Needle Gauge -->
            <div class="flex justify-center mb-2">
                <div class="relative w-56 h-40 md:w-64 md:h-44">
                    <svg viewBox="0 0 220 140" class="w-full h-full drop-shadow-md">
                        <!-- Background arc -->
                        <path d="M 30 110 A 80 80 0 0 1 190 110" fill="none" stroke="currentColor" stroke-width="14" stroke-linecap="round" class="text-matte-100 dark:text-matte-700"/>
                        <!-- Colored zones: Red (poor), Yellow (fair), Green (good), Blue (excellent) -->
                        <path d="M 30 110 A 80 80 0 0 1 53 53" fill="none" stroke="#ef4444" stroke-width="14" stroke-linecap="round" opacity="0.9"/>
                        <path d="M 53 53 A 80 80 0 0 1 110 30" fill="none" stroke="#f59e0b" stroke-width="14" stroke-linecap="round" opacity="0.9"/>
                        <path d="M 110 30 A 80 80 0 0 1 167 53" fill="none" stroke="#22c55e" stroke-width="14" stroke-linecap="round" opacity="0.9"/>
                        <path d="M 167 53 A 80 80 0 0 1 190 110" fill="none" stroke="#3b82f6" stroke-width="14" stroke-linecap="round" opacity="0.9"/>
                        <!-- Needle -->
                        <g id="needle-group" style="transform-origin: 110px 110px; transition: transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);">
                            <line x1="110" y1="110" x2="175" y2="55" stroke="currentColor" stroke-width="3" stroke-linecap="round" class="text-matte-800 dark:text-white"/>
                            <circle cx="175" cy="55" r="5" fill="currentColor" class="text-matte-800 dark:text-white"/>
                            <circle cx="110" cy="110" r="9" fill="#3b82f6" stroke="white" stroke-width="3" class="drop-shadow-sm"/>
                        </g>
                        <!-- Tick marks -->
                        <line x1="110" y1="30" x2="110" y2="24" stroke="currentColor" stroke-width="2" class="text-matte-300 dark:text-matte-600"/>
