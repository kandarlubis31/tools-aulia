<script>
  // ================================================================
  // 1. NETWORK STATUS
  // ================================================================
  function updateNetworkStatus() {
    const statusText = document.getElementById('network-status');
    const text = document.getElementById('network-text');
    if (!statusText || !text) return;
    
    if (navigator.onLine) {
        statusText.classList.remove('bg-red-500', 'border-red-400');
        statusText.classList.add('bg-emerald-500', 'border-emerald-400', 'text-white');
        text.textContent = window._tToast ? window._tToast('● Online') : '● Online';
        setTimeout(() => statusText.classList.add('hidden'), 2000);
    } else {
        statusText.classList.remove('hidden', 'bg-emerald-500', 'border-emerald-400');
        statusText.classList.add('bg-red-500', 'border-red-400', 'text-white');
        text.textContent = window._tToast ? window._tToast('● Offline') : '● Offline';
    }
  }

  // ================================================================
  // 2. DEVICE / BROWSER INFO
  // ================================================================
  function getBrowserInfo() {
      const ua = navigator.userAgent;
      let browser = "Unknown";
      let os = "Unknown";
      
      if (ua.indexOf("Firefox") > -1) browser = "Firefox";
      else if (ua.indexOf("SamsungBrowser") > -1) browser = "Samsung Internet";
      else if (ua.indexOf("Opera") > -1 || ua.indexOf("OPR") > -1) browser = "Opera";
      else if (ua.indexOf("Edge") > -1) browser = "Edge";
      else if (ua.indexOf("Chrome") > -1) browser = "Chrome";
      else if (ua.indexOf("Safari") > -1) browser = "Safari";
      
      if (ua.indexOf("Win") > -1) os = "Windows";
      else if (ua.indexOf("Mac") > -1) os = "macOS";
      else if (ua.indexOf("Linux") > -1) os = "Linux";
      else if (ua.indexOf("Android") > -1) os = "Android";
      else if (ua.indexOf("iPhone") > -1) os = "iOS";
      
      return { browser, os };
  }

  // Battery API — graceful degrade (API deprecated in some browsers)
  async function getBatteryInfo() {
    try {
      if ('getBattery' in navigator) {
        const battery = await (navigator as any).getBattery();
        return `${Math.round(battery.level * 100)}% ${battery.charging ? '⚡' : ''}`;
      }
    } catch {}
    return 'N/A';
  }

  // ================================================================
  // 3. LOCAL IP (WebRTC — may fail in modern browsers)
  // ================================================================
  async function getLocalIP() {
    return new Promise(resolve => {
        try {
          const pc = new RTCPeerConnection({iceServers: []});
          pc.createDataChannel('');
          pc.createOffer().then(o => pc.setLocalDescription(o)).catch(() => {});
          let resolved = false;
          pc.onicecandidate = e => {
              if (e.candidate && !resolved) {
                  const match = e.candidate.candidate.match(/([0-9]{1,3}(\.[0-9]{1,3}){3})/);
                  if (match) { 
                    resolve(match[1]); 
                    resolved = true;
                    pc.close(); 
                  }
              }
          };
          setTimeout(() => { 
            if (!resolved) {
              resolve((window._tToast) ? window._tToast('Diproteksi') : 'Diproteksi'); 
              pc.close(); 
            }
          }, 2000);
        } catch {
          resolve((window._tToast) ? window._tToast('Tidak tersedia') : 'Tidak tersedia');
        }
    });
  }

  // ================================================================
  // 4. PROXY / VPN DETECTION
  // ================================================================
  async function checkProxy() {
    // Lightweight: deteksi proxy via Cloudflare trace (sangat cepat, CORS-friendly)
    try {
      const res = await fetch('https://1.1.1.1/cdn-cgi/trace', { 
        signal: AbortSignal.timeout(2000), 
        cache: 'no-store' 
      });
      if (res.ok) {
        const text = await res.text();
        if (text.includes('warp=on')) {
          return window._tToast ? window._tToast('Cloudflare WARP / Proxy aktif') : 'Cloudflare WARP / Proxy aktif';
        }
      }
    } catch {}
    // Akan diperbarui dengan data IP API setelah main fetch selesai
    return window._tToast ? window._tToast('Memeriksa...') : 'Memeriksa...';
  }

  // ================================================================
  // 5. CONNECTION INFO (replaces broken DNS check)
  // ================================================================
  function getConnectionInfo(): string {
    const conn = (navigator as any).connection;
    if (!conn) return 'Tidak tersedia';
    const parts: string[] = [];
    if (conn.effectiveType) parts.push(conn.effectiveType.toUpperCase());
    if (conn.downlink) parts.push(`${conn.downlink} Mbps`);
    if (conn.rtt && conn.rtt > 0) parts.push(`${conn.rtt}ms`);
    return parts.length > 0 ? parts.join(' · ') : 'Tidak tersedia';
  }

  // ================================================================
  // 6. IP API — Multi-fallback
  // ================================================================
  async function fetchIPData() {
    // Tier 1: Race full-data APIs in parallel — first valid wins (typically <1s)
    const fullApis = [
      { url: 'https://ipapi.co/json/', transform: (d: any) => ({ ...d, _proxy: d.proxy, _hosting: d.hosting }) },
      { 
        url: 'http://ip-api.com/json/', 
        transform: (d: any) => ({
          ip: d.query,
          org: d.isp || d.org,
          asn: d.as,
          version: d.type === 'ipv4' ? 'IPv4' : 'IPv6',
          country_name: d.country,
          country_code: d.countryCode,
          city: d.city,
          region: d.regionName,
          timezone: d.timezone,
          latitude: d.lat,
          longitude: d.lon,
          _proxy: d.proxy,
          _hosting: d.hosting
        })
      }
    ];

    try {
      return await Promise.any(
        fullApis.map(api =>
          (async () => {
            const res = await fetch(api.url, { signal: AbortSignal.timeout(3000) });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const data = await res.json();
            if (data && !data.error) return api.transform(data);
            throw new Error('Invalid response');
          })()
        )
      );
    } catch {
      // Tier 2: Last resort — IP only
      try {
        const res = await fetch('https://api.ipify.org?format=json', { signal: AbortSignal.timeout(3000) });
        if (res.ok) {
          const data = await res.json();
          if (data && data.ip) return { ip: data.ip };
        }
      } catch {}
      throw new Error('All IP APIs failed');
    }
  }

  // ================================================================
  // 7. IMPROVED SPEED TEST — Speedtest.net inspired
  // ================================================================

  const TEST_FILES = [
    { url: 'https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js', size: 87300 },
    { url: 'https://cdnjs.cloudflare.com/ajax/libs/lodash.js/4.17.21/lodash.min.js', size: 71200 },
    { url: 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js', size: 545000 },
    { url: 'https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js', size: 87300 },
    { url: 'https://cdn.jsdelivr.net/npm/lodash@4.17.21/lodash.min.js', size: 71200 },
  ];

  // Upload test endpoints (CORS-friendly)
  const UPLOAD_ENDPOINTS = [
    'https://httpbin.org/post',
    'https://httpbin.org/anything',
  ];

  // —— Quality Rating ——
  function getQuality(dlMbps: number, pingMs: number): { label: string; labelKey: string; stars: number; color: string; bg: string; border: string } {
    if (dlMbps >= 100 && pingMs < 30) return { label: 'Luar Biasa', labelKey: 'speed.quality_excellent', stars: 5, color: 'text-blue-600 dark:text-blue-400', bg: 'bg-blue-50 dark:bg-blue-900/20', border: 'border-blue-200 dark:border-blue-800' };
    if (dlMbps >= 25 && pingMs < 60) return { label: 'Baik', labelKey: 'speed.quality_good', stars: 4, color: 'text-emerald-600 dark:text-emerald-400', bg: 'bg-emerald-50 dark:bg-emerald-900/20', border: 'border-emerald-200 dark:border-emerald-800' };
    if (dlMbps >= 5 && pingMs < 120) return { label: 'Cukup', labelKey: 'speed.quality_fair', stars: 3, color: 'text-amber-600 dark:text-amber-400', bg: 'bg-amber-50 dark:bg-amber-900/20', border: 'border-amber-200 dark:border-amber-800' };
    return { label: 'Buruk', labelKey: 'speed.quality_poor', stars: 1, color: 'text-red-600 dark:text-red-400', bg: 'bg-red-50 dark:bg-red-900/20', border: 'border-red-200 dark:border-red-800' };
  }

  function getActivity(dlMbps: number, pingMs: number) {
    return {
      streaming: dlMbps >= 25 ? '4K ✅' : dlMbps >= 5 ? 'HD ✅' : dlMbps >= 2 ? 'SD ✅' : '❌',
      gaming: pingMs < 30 && dlMbps >= 10 ? 'Pro ✅' : pingMs < 80 && dlMbps >= 3 ? 'Casual ✅' : 'Lag ❌',
      browsing: dlMbps >= 1 ? 'Lancar ✅' : 'Ok ✅',
    };
  }

  function getNeedleRotation(speed: number, maxSpeed: number): number {
    const pct = Math.min(speed / maxSpeed, 1);
    return -90 + pct * 180; // from -90Â° (left) to 90Â° (right)
  }

  // —— Ping + Jitter ——
  async function measureLatency(): Promise<{ avg: number; jitter: number } | null> {
    const samples: number[] = [];
    for (let i = 0; i < 5; i++) {
      const start = performance.now();
      try {
        await fetch('https://www.google.com/favicon.ico', { mode: 'no-cors', cache: 'no-store' });
        samples.push(performance.now() - start);
      } catch {
        try {
          const start2 = performance.now();
          await fetch('https://1.1.1.1/cdn-cgi/trace', { cache: 'no-store', signal: AbortSignal.timeout(2000) });
          samples.push(performance.now() - start2);
        } catch { return null; }
      }
    }
    if (samples.length === 0) return null;
    samples.sort((a, b) => a - b);
    const avg = samples[Math.floor(samples.length / 2)]; // median
    // Jitter = average deviation from median
    const jitter = Math.round(samples.reduce((sum, s) => sum + Math.abs(s - avg), 0) / samples.length);
    return { avg: Math.round(avg), jitter };
  }

  // —— Download Test (parallel) ——
  async function measureDownloadThroughput(onProgress: (speed: number) => void): Promise<{ speed: number; bytes: number; time: number } | null> {
    const files = [...TEST_FILES].sort(() => Math.random() - 0.5); // shuffle
    let totalBytes = 0;
    const startTime = performance.now();
    let completed = 0;
    const results: { bytes: number; time: number }[] = [];

    // Progress ticker
    const progressInterval = setInterval(() => {
      const elapsed = (performance.now() - startTime) / 1000;
      if (elapsed > 0 && totalBytes > 0) {
        const currentSpeed = (totalBytes * 8) / elapsed / 1_000_000;
        onProgress(currentSpeed);
      }
    }, 200);

    // Parallel downloads
    await Promise.all(files.map(async (file) => {
      try {
        const dlStart = performance.now();
        const res = await fetch(file.url, { cache: 'no-store', signal: AbortSignal.timeout(4000) });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const blob = await res.blob();
        const dlEnd = performance.now();
        const elapsed = dlEnd - dlStart;
        if (blob.size > 0 && elapsed > 10) {
          results.push({ bytes: blob.size, time: elapsed });
          totalBytes += blob.size;
        }
      } catch {}
      completed++;
    }));

    clearInterval(progressInterval);
    const totalTime = performance.now() - startTime;

    if (results.length === 0 || totalBytes <= 0) return null;
    const speedMbps = (totalBytes * 8) / (totalTime / 1000) / 1_000_000;
    return { speed: parseFloat(speedMbps.toFixed(1)), bytes: totalBytes, time: Math.round(totalTime) };
  }

  // —— Upload Test (real via httpbin POST) ——
  async function measureUploadThroughput(): Promise<number | null> {
    // Generate 512KB of random data
    const size = 512 * 1024;
    const buf = new Uint8Array(size);
    for (let i = 0; i < size; i += 4096) {
      buf[i] = Math.random() * 256;
    }
    const blob = new Blob([buf], { type: 'application/octet-stream' });

    for (const endpoint of UPLOAD_ENDPOINTS) {
      try {
        const start = performance.now();
        const res = await fetch(endpoint, {
          method: 'POST',
          body: blob,
          cache: 'no-store',
          signal: AbortSignal.timeout(7000),
        });
        if (!res.ok) continue;
        const end = performance.now();
        const elapsed = end - start;
        if (elapsed <= 50) continue;
        const speedMbps = (size * 8) / (elapsed / 1000) / 1_000_000;
        return parseFloat(speedMbps.toFixed(1));
      } catch { continue; }
    }
    return null;
  }

  // —— Estimate upload from download + latency ——
  function estimateUploadSpeed(dlMbps: number, latencyMs: number): number {
    let ratio: number;
    if (latencyMs < 20) ratio = 0.5;
    else if (latencyMs < 40) ratio = 0.4;
    else if (latencyMs < 80) ratio = 0.35;
    else ratio = 0.25;
    return parseFloat((dlMbps * ratio).toFixed(1));
  }

  // —— Speed Test History ——
  const SPEED_HISTORY_KEY = 'speed_test_history';
  const MAX_SPEED_HISTORY = 10;

  function getSpeedHistory(): any[] {
    try {
      const raw = localStorage.getItem(SPEED_HISTORY_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch { return []; }
  }

  function saveSpeedTest(result: any) {
    try {
      let history = getSpeedHistory();
      history.unshift({ ...result, timestamp: Date.now() });
      history = history.slice(0, MAX_SPEED_HISTORY);
      localStorage.setItem(SPEED_HISTORY_KEY, JSON.stringify(history));
      renderSpeedHistory();
    } catch {}
  }

  function renderSpeedHistory() {
    const section = document.getElementById('speed-history-section');
    const list = document.getElementById('speed-history-list');
    const clearBtn = document.getElementById('clear-speed-history');
    if (!section || !list || !clearBtn) return;
    const history = getSpeedHistory();
    if (history.length === 0) {
      section.classList.add('hidden');
      return;
    }
    section.classList.remove('hidden');
    clearBtn.classList.remove('hidden');
    list.innerHTML = history.map((h: any, i: number) => {
      const timeAgo = getTimeAgo(h.timestamp);
      const dlColor = h.download >= 50 ? 'text-emerald-500' : h.download >= 10 ? 'text-amber-500' : 'text-red-500';
      return `<div class="flex items-center gap-2 px-2.5 py-2 rounded-lg bg-matte-50 dark:bg-matte-900/40 hover:bg-blue-50 dark:hover:bg-blue-900/10 transition-all cursor-pointer text-xs" title="${new Date(h.timestamp).toLocaleString()}">
        <span class="w-5 h-5 rounded-full bg-matte-100 dark:bg-matte-700 flex items-center justify-center font-bold text-[9px] text-matte-500 shrink-0">${h.download >= 25 ? '🚀' : '🔽'}</span>
        <span class="font-bold ${dlColor} tabular-nums">${h.download}</span>
        <span class="text-matte-400">/</span>
        <span class="font-medium text-matte-500 tabular-nums">${h.upload}</span>
        <span class="text-matte-300">Mbps</span>
        <span class="mx-1 text-matte-300">·</span>
        <span class="text-matte-400">${h.ping}ms</span>
        <span class="ml-auto text-matte-400">${timeAgo}</span>
      </div>`;
    }).join('');
  }

  // —— Main Speed Test Runner ——
  async function runSpeedTest() {
    const startBtn = document.getElementById('start-speed-test');
    const speedDisplay = document.getElementById('speed-display');
    const needleGroup = document.getElementById('needle-group');
    const phaseEl = document.getElementById('speed-test-phase');
    const resultsGrid = document.getElementById('speed-results');
    const qualitySection = document.getElementById('speed-quality');
    const activitiesSection = document.getElementById('speed-activities');
    if (!startBtn || !speedDisplay || !needleGroup || !phaseEl || !resultsGrid || !qualitySection || !activitiesSection) return;

    startBtn.disabled = true;
    startBtn.textContent = '...';

    // Reset
    speedDisplay.textContent = '0';
    document.getElementById('result-ping')!.textContent = '—';
    document.getElementById('result-jitter-label')!.textContent = '';
    document.getElementById('result-download')!.textContent = '—';
    document.getElementById('result-upload')!.textContent = '—';
    document.getElementById('dl-bar-fill')!.style.width = '0%';
    document.getElementById('ul-bar-fill')!.style.width = '0%';
    qualitySection.classList.add('hidden');
    activitiesSection.classList.add('hidden');
    resultsGrid.classList.add('opacity-0', 'max-h-0');
    resultsGrid.classList.remove('opacity-100');
    needleGroup.style.transform = 'rotate(-90deg)';
    document.getElementById('ping-dot')!.classList.remove('bg-red-400');
    document.getElementById('ping-dot')!.classList.add('bg-emerald-400');

    // Phase 1: Ping + Jitter
    phaseEl.textContent = window._tToast ? window._tToast('Mengukur latency...') : 'Mengukur latency...';
    phaseEl.style.opacity = '1';
    const latencyResult = await measureLatency();
    if (latencyResult) {
      const pingEl = document.getElementById('result-ping');
      if (pingEl) pingEl.textContent = latencyResult.avg + ' ms';
      const jitterEl = document.getElementById('result-jitter-label');
      if (jitterEl) jitterEl.textContent = 'Jitter: ' + latencyResult.jitter + ' ms';
      if (latencyResult.avg > 100) {
        document.getElementById('ping-dot')!.classList.remove('bg-emerald-400');
        document.getElementById('ping-dot')!.classList.add('bg-red-400');
      }
    }

    // Phase 2: Download (parallel)
    phaseEl.textContent = window._tToast ? window._tToast('Tes download...') : 'Tes download...';
    const dlResult = await measureDownloadThroughput((currentSpeed: number) => {
      speedDisplay.textContent = Math.round(currentSpeed).toString();
      const rotation = getNeedleRotation(currentSpeed, 200);
      needleGroup.style.transform = 'rotate(' + rotation + 'deg)';
    });

    if (dlResult) {
      speedDisplay.textContent = dlResult.speed.toString();
      const rotation = getNeedleRotation(dlResult.speed, 200);
      needleGroup.style.transform = 'rotate(' + rotation + 'deg)';

      document.getElementById('result-download')!.textContent = dlResult.speed + ' Mbps';
      const dlPct = Math.min((dlResult.speed / 200) * 100, 100);
      document.getElementById('dl-bar-fill')!.style.width = dlPct + '%';

      // Phase 3: Upload (real)
      phaseEl.textContent = window._tToast ? window._tToast('Tes upload...') : 'Tes upload...';
      let ulSpeed = await measureUploadThroughput();
      
      if (ulSpeed === null) {
        // Fallback: estimate
        ulSpeed = estimateUploadSpeed(dlResult.speed, latencyResult?.avg || 50);
        window.showToast(
          window._tToast ? window._tToast('Upload real gagal. Gunakan estimasi.') : 'Upload real gagal. Gunakan estimasi.', 
          'warning'
        );
      }

      document.getElementById('result-upload')!.textContent = ulSpeed.toFixed(1) + ' Mbps';
      const ulPct = Math.min((ulSpeed / 100) * 100, 100);
      document.getElementById('ul-bar-fill')!.style.width = ulPct + '%';

      // Show results grid
      resultsGrid.classList.remove('opacity-0', 'max-h-0');
      resultsGrid.classList.add('opacity-100');
      setTimeout(() => resultsGrid.classList.remove('max-h-0'), 50);

      // Quality rating
      const ping = latencyResult?.avg || 999;
      const quality = getQuality(dlResult.speed, ping);
      const qualityCard = document.getElementById('quality-card')!;
      qualityCard.className = 'p-3 rounded-xl border ' + quality.bg + ' ' + quality.border;
      document.getElementById('quality-label')!.textContent = quality.label;
      document.getElementById('quality-label')!.className = 'text-xs font-bold ' + quality.color;
      const descMap: Record<string, string> = {
        'speed.quality_excellent': 'speed.quality_desc_excellent',
        'speed.quality_good': 'speed.quality_desc_good',
        'speed.quality_fair': 'speed.quality_desc_fair',
        'speed.quality_poor': 'speed.quality_desc_poor',
      };
      const descKey = descMap[quality.labelKey] || 'speed.quality_desc_poor';
      const descText = window._tToast ? window._tToast(descKey) : 
        (descKey === 'speed.quality_desc_excellent' ? 'Koneksi sangat cepat. Cocok untuk 4K streaming, gaming, dan download besar.' :
         descKey === 'speed.quality_desc_good' ? 'Koneksi baik. Streaming HD lancar, gaming online oke.' :
         descKey === 'speed.quality_desc_fair' ? 'Koneksi cukup. Streaming SD oke, gaming mungkin lag.' :
         'Koneksi lambat. Hanya cocok browsing ringan & chat.');
      document.getElementById('quality-desc')!.textContent = descText;
      document.getElementById('quality-stars')!.innerHTML = '\u2B50'.repeat(quality.stars) + '\u2606'.repeat(5 - quality.stars);
      qualitySection.classList.remove('hidden');

      // Activity recommendations
      const act = getActivity(dlResult.speed, ping);
      document.getElementById('act-streaming-status')!.textContent = act.streaming;
      document.getElementById('act-gaming-status')!.textContent = act.gaming;
      document.getElementById('act-browsing-status')!.textContent = act.browsing;
      activitiesSection.classList.remove('hidden');

      // Save history
      saveSpeedTest({
        download: dlResult.speed,
        upload: ulSpeed,
        ping: ping,
        jitter: latencyResult?.jitter || 0,
      });

      phaseEl.textContent = window._tToast ? window._tToast('Selesai!') : 'Selesai!';
      window.showToast(
        window._tToast ? window._tToast('Tes selesai! ' + dlResult.speed + ' Mbps download.') : 'Tes selesai! ' + dlResult.speed + ' Mbps download.', 
        'success'
      );
    } else {
      // Fallback: connection API
      speedDisplay.textContent = '--';
      const conn = (navigator as any).connection;
      if (conn && conn.downlink) {
        const estDl = parseFloat(conn.downlink.toFixed(1));
        speedDisplay.textContent = estDl.toString();
        const rotation = getNeedleRotation(estDl, 200);
        needleGroup.style.transform = 'rotate(' + rotation + 'deg)';
        document.getElementById('result-download')!.textContent = estDl + ' Mbps (estimasi)';
        const estUl = estimateUploadSpeed(estDl, latencyResult?.avg || 50);
        document.getElementById('result-upload')!.textContent = estUl + ' Mbps (estimasi)';
        resultsGrid.classList.remove('opacity-0', 'max-h-0');
        resultsGrid.classList.add('opacity-100');
        window.showToast('Tes CDN gagal. Estimasi dari koneksi.', 'warning');
      } else {
        window.showToast('Gagal mengukur kecepatan. Coba lagi.', 'error');
      }
      phaseEl.textContent = window._tToast ? window._tToast('Tes gagal') : 'Tes gagal';
    }

    startBtn.disabled = false;
    startBtn.textContent = document.querySelector('[data-i18n="speed.test_again"]')?.getAttribute('data-i18n') 
      ? window._tToast ? window._tToast('Test Lagi') : 'Test Lagi'
      : 'Test Lagi';
  }

  // ================================================================
  // 8. SAVE REPORT
  // ================================================================
  function saveNetworkReport() {
    const getText = (id: string) => document.getElementById(id)?.innerText?.replace(/\s+/g, ' ').trim() || 'Unknown';
    const reportData = {
      timestamp: new Date().toISOString(),
      ip: getText('ip-display'),
      location: {
        country: getText('loc-country'),
        city: getText('loc-city'),
        coordinates: getText('loc-coords')
      },
      isp: {
        name: getText('isp-name'),
        asn: getText('asn-name'),
        type: getText('connection-type')
      },
      device: {
        browser_os: getText('dev-browser'),
        resolution: getText('dev-res'),
        battery: getText('dev-battery')
      }
    };
    
    const dataStr = JSON.stringify(reportData, null, 2);
    const dataUri = 'data:application/json;charset=utf-8,'+ encodeURIComponent(dataStr);
    const fileName = `network-report-${new Date().getTime()}.json`;
    const linkElement = document.createElement('a');
    linkElement.setAttribute('href', dataUri);
    linkElement.setAttribute('download', fileName);
    linkElement.click();
    window.showToast(
      window._tToast ? window._tToast('Laporan berhasil disimpan!') : 'Laporan berhasil disimpan!', 
      'success'
    );
  }

  // ================================================================
  // 9. HIDE SKELETONS, SET TEXT
  // ================================================================
  function setText(id: string, text: string) {
    const el = document.getElementById(id);
    if (!el) return;
    // Remove skeleton placeholders
    el.querySelectorAll('.skeleton').forEach(s => s.remove());
    el.innerText = text;
  }

  // ================================================================
  // 10. LOCALSTORAGE CACHE
  // ================================================================
  const CACHE_KEY = 'myip_cache';
  const CACHE_MAX_AGE = 30 * 60 * 1000; // 30 menit

  function saveCachedIPData(data: any) {
    try {
      const cache = { data, timestamp: Date.now() };
      localStorage.setItem(CACHE_KEY, JSON.stringify(cache));
    } catch {}
  }

  function loadCachedIPData(): any | null {
    try {
      const raw = localStorage.getItem(CACHE_KEY);
      if (!raw) return null;
      const cache = JSON.parse(raw);
      if (!cache.data || !cache.timestamp) return null;
      // Hapus cache kalau sudah expired
      if (Date.now() - cache.timestamp > CACHE_MAX_AGE) {
        localStorage.removeItem(CACHE_KEY);
        return null;
      }
      return cache.data;
    } catch { return null; }
  }

  function applyIPData(data: any, isFresh: boolean) {
    if (data.ip) {
      setText('ip-display', isFresh ? data.ip : '🔄 ' + data.ip);
    }
    const ipDisplay = document.getElementById('ip-display');
    if (ipDisplay && isFresh) {
      ipDisplay.classList.remove('animate-pulse');
      const copyBtn = document.getElementById('copy-ip-btn');
      if (copyBtn) copyBtn.classList.remove('hidden');
    }
    
    const ipvBadge = document.getElementById('ipv-badge');
    if (ipvBadge && data.version) {
      ipvBadge.innerText = data.version;
      ipvBadge.classList.remove('hidden');
    } else if (ipvBadge) {
      ipvBadge.classList.remove('hidden');
    }
    
    if (data.org || data.isp) setText('isp-name', data.org || data.isp || 'Unknown');
    if (data.asn) setText('asn-name', data.asn || 'Unknown');
    if (data.org) setText('isp-domain', data.org);
    setText('connection-type', data.version || 'Broadband');
    
    if (data.country_name) setText('loc-country', `${data.country_name} ${data.country_code || ''}`);
    if (data.city) setText('loc-city', `${data.city}${data.region ? ', ' + data.region : ''}`);
    if (data.timezone) setText('loc-timezone', data.timezone);
    
    if (data.latitude && data.longitude) {
      setText('loc-coords', `${data.latitude}, ${data.longitude}`);
      const maps = document.getElementById('maps-link');
      if (maps) {
        maps.href = `https://www.google.com/maps/search/?api=1&query=${data.latitude},${data.longitude}`;
        maps.classList.remove('hidden');
      }
    }

    if (data.country_code) {
      const flagImg = document.getElementById('flag-img') as HTMLImageElement;
      if (flagImg) {
        flagImg.src = `https://flagcdn.com/w40/${data.country_code.toLowerCase()}.png`;
        flagImg.classList.remove('hidden');
      }
    }
  }

  // ================================================================
  // 11. IP HISTORY MANAGEMENT
  // ================================================================
  const HISTORY_KEY = 'myip_history';
  const MAX_HISTORY = 10;

  function getIPHistory(): any[] {
    try {
      const raw = localStorage.getItem(HISTORY_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch { return []; }
  }

  function saveToIPHistory(data: any) {
    try {
      let history = getIPHistory();
      // Hapus duplikat IP yang sama
      history = history.filter((h: any) => h.ip !== data.ip);
      // Tambah ke paling atas
      history.unshift({
        ip: data.ip || 'Unknown',
        isp: data.org || data.isp || 'Unknown',
        country: data.country_name || (data.country || ''),
        city: data.city || '',
        country_code: data.country_code || '',
        timestamp: Date.now()
      });
      // Batasi maksimal
      history = history.slice(0, MAX_HISTORY);
      localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
    } catch {}
  }

  function renderIPHistory() {
    const section = document.getElementById('ip-history-section');
    const list = document.getElementById('ip-history-list');
    const count = document.getElementById('ip-history-count');
    const clearBtn = document.getElementById('clear-ip-history');
    if (!section || !list || !count || !clearBtn) return;

    const history = getIPHistory();
    
    if (history.length === 0) {
      section.classList.add('hidden');
      return;
    }
    
    section.classList.remove('hidden');
    count.textContent = history.length.toString();
    clearBtn.classList.remove('hidden');
    
    list.innerHTML = history.map((h: any, i: number) => {
      const timeAgo = getTimeAgo(h.timestamp);
      const flagSrc = h.country_code ? `https://flagcdn.com/w20/${h.country_code.toLowerCase()}.png` : '';
      const location = [h.city, h.country].filter(Boolean).join(', ') || '-';
      
      return `
        <div class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-matte-50 dark:bg-matte-900/40 hover:bg-blue-50 dark:hover:bg-blue-900/10 transition-all cursor-pointer group" data-ip="${h.ip}">
          <div class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 flex items-center justify-center font-mono font-bold text-xs shrink-0">
            ${i + 1}
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span class="font-mono font-bold text-sm text-matte-800 dark:text-white truncate">${h.ip}</span>
              ${flagSrc ? `<img src="${flagSrc}" alt="" class="w-4 h-auto rounded-sm">` : ''}
            </div>
            <div class="flex items-center gap-2 text-xs text-matte-500 dark:text-matte-400">
              <span class="truncate max-w-[180px]">${h.isp}</span>
              <span class="text-matte-300">·</span>
              <span class="truncate max-w-[140px]">${location}</span>
            </div>
          </div>
          <span class="text-[10px] text-matte-400 shrink-0" title="${new Date(h.timestamp).toLocaleString()}">${timeAgo}</span>
        </div>
      `;
    }).join('');
  }

  function getTimeAgo(timestamp: number): string {
    const diff = Date.now() - timestamp;
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return 'baru';
    if (mins < 60) return mins + 'm';
    const hours = Math.floor(mins / 60);
    if (hours < 24) return hours + 'j';
    const days = Math.floor(hours / 24);
    if (days < 30) return days + 'h';
    return Math.floor(days / 30) + 'bln';
  }

  // ================================================================
  // 12. MAIN FETCH — parallel race + cache
  // ================================================================
  let rawNetworkData: any = {};
  let isRefreshing = false;

  async function fetchNetworkInfo() {
      if (isRefreshing) return;
      isRefreshing = true;
      
      const ipDisplay = document.getElementById('ip-display');
      if(!ipDisplay) { isRefreshing = false; return; }
      
      // 11a. Show cached data instantly (sebelum network request)
      const cached = loadCachedIPData();
      if (cached) applyIPData(cached, false);
      
      // 11b. Set local device info immediately (no network needed)
      const device = getBrowserInfo();
      setText('dev-browser', `${device.browser} on ${device.os}`);
      setText('dev-res', `${window.screen.width} x ${window.screen.height}`);
      setText('user-agent', navigator.userAgent);
      
      // 11c. Fire everything in parallel — IP race + battery + localIP + connection
      const [result, battery, localIP, proxyStatus, connectionInfo] = await Promise.allSettled([
        fetchIPData().then(data => { rawNetworkData = data; return data; }),
        getBatteryInfo(),
        getLocalIP(),
        checkProxy(),
        Promise.resolve(getConnectionInfo())
      ]);
      
      // Battery
      if (battery.status === 'fulfilled') setText('dev-battery', battery.value);
      
      // Local IP
      if (localIP.status === 'fulfilled') setText('local-ip', localIP.value);
      
      // Connection info
      if (connectionInfo.status === 'fulfilled') {
        setText('connection-info', connectionInfo.value);
      }
      
      if (navigator.connection) {
         const type = (navigator as any).connection.effectiveType;
         if(type) {
             const badge = document.getElementById('connection-type-badge');
             if (badge) {
               badge.innerText = type.toUpperCase();
               badge.classList.remove('hidden');
             }
         }
      }

      // 11d. Process IP data (if successful)
      if (result.status === 'fulfilled') {
        const data = result.value;
        
        // Apply IP & full data (removes skeleton, shows data)
        applyIPData(data, true);
        
        // Proxy status dari IP API data (lebih akurat dari httpbin)
        if (data._proxy !== undefined) {
          setText('proxy-status', data._proxy ? 
            (window._tToast ? window._tToast('Proxy/VPN terdeteksi') : 'Proxy/VPN terdeteksi') :
            (window._tToast ? window._tToast('Tidak terdeteksi') : 'Tidak terdeteksi'));
        } else if (data._hosting !== undefined) {
          setText('proxy-status', data._hosting ? 
            (window._tToast ? window._tToast('Hosting/Server') : 'Hosting/Server') :
            (window._tToast ? window._tToast('Koneksi rumahan') : 'Koneksi rumahan'));
        } else if (proxyStatus.status === 'fulfilled' && proxyStatus.value !== 'Memeriksa...') {
          setText('proxy-status', proxyStatus.value);
        } else {
          // Fallback: cek nama org
          const org = (data.org || '').toLowerCase();
          if (org.includes('hosting') || org.includes('cloud') || org.includes('server') || org.includes('datacenter')) {
            setText('proxy-status', window._tToast ? window._tToast('Kemungkinan hosting/server') : 'Kemungkinan hosting/server');
          } else {
            setText('proxy-status', window._tToast ? window._tToast('Tidak terdeteksi') : 'Tidak terdeteksi');
          }
        }
        
        // Cache sukses — next load instan
        saveCachedIPData(data);
        
        // Simpan ke riwayat IP & render
        saveToIPHistory(data);
        renderIPHistory();
        
        // Build full JSON export
        const fullDataExport = { 
          ...data, 
          device_info: device, 
          local_ip_address: localIP.status === 'fulfilled' ? localIP.value : 'N/A',
          proxy_check: document.getElementById('proxy-status')?.innerText || 'N/A',
          connection: connectionInfo.status === 'fulfilled' ? connectionInfo.value : 'N/A',
          full_user_agent: navigator.userAgent
        };
        
        const jsonCode = document.getElementById('json-code');
        if (jsonCode) jsonCode.innerText = JSON.stringify(fullDataExport, null, 2);
        
      } else {
        // All APIs failed — keep cached data if available
        ipDisplay.classList.remove('animate-pulse');
        if (!cached) {
          setText('ip-display', window._tToast ? window._tToast('Gagal memuat') : 'Gagal memuat');
        }
        window.showToast(
          window._tToast ? window._tToast('Gagal memuat detail jaringan. Coba lagi nanti.') : 'Gagal memuat detail jaringan. Coba lagi nanti.', 
          'error'
        );
      }
      
      isRefreshing = false;
  }

  // ================================================================
  // 13. EVENT BINDING
  // ================================================================
  document.addEventListener('astro:page-load', () => {
      renderIPHistory();
      fetchNetworkInfo();
      updateNetworkStatus();

      const refreshBtn = document.getElementById('refresh-btn');
      if (refreshBtn) refreshBtn.onclick = fetchNetworkInfo;
      
      const copyIpBtn = document.getElementById('copy-ip-btn');
      if (copyIpBtn) copyIpBtn.onclick = () => {
          const ipText = document.getElementById('ip-display')?.innerText;
          if(ipText && !ipText.includes("Error") && !ipText.includes("Ngecek") && !ipText.includes("Gagal")) {
              navigator.clipboard.writeText(ipText);
              window.showToast(
                window._tToast ? window._tToast('IP disalin!') : 'IP disalin!'
              );
          }
      };

      const copyJsonBtn = document.getElementById('copy-json');
      if (copyJsonBtn) copyJsonBtn.onclick = () => {
          const jsonCode = document.getElementById('json-code')?.innerText;
          if (jsonCode) {
            navigator.clipboard.writeText(jsonCode);
            window.showToast(
              window._tToast ? window._tToast('JSON disalin!') : 'JSON disalin!'
            );
          }
      };

      const toggleJsonBtn = document.getElementById('toggle-json');
      if (toggleJsonBtn) toggleJsonBtn.onclick = () => {
          const jsonContainer = document.getElementById('json-container');
          const arrowJson = document.getElementById('arrow-json');
          if (jsonContainer && arrowJson) {
            jsonContainer.classList.toggle('hidden');
            arrowJson.classList.toggle('rotate-180');
          }
      };

      const saveReportBtn = document.getElementById('save-report');
      if (saveReportBtn) saveReportBtn.onclick = saveNetworkReport;

      const clearHistoryBtn = document.getElementById('clear-ip-history');
      if (clearHistoryBtn) clearHistoryBtn.onclick = () => {
        try {
          localStorage.removeItem('myip_history');
          renderIPHistory();
          window.showToast(
            window._tToast ? window._tToast('Riwayat IP dibersihkan!') : 'Riwayat IP dibersihkan!'
          );
        } catch {}
      };

      // Event delegation untuk copy IP dari history
      const historyList = document.getElementById('ip-history-list');
      if (historyList) historyList.addEventListener('click', (e) => {
        const row = (e.target as HTMLElement).closest('[data-ip]');
        if (!row) return;
        const ip = row.getAttribute('data-ip');
        if (ip) {
          navigator.clipboard.writeText(ip);
          window.showToast(
            window._tToast ? window._tToast('IP ' + ip + ' disalin!') : 'IP ' + ip + ' disalin!'
          );
        }
      });

      // Speed Test Modal
      const modal = document.getElementById('speed-test-modal');
      const speedBtn = document.getElementById('speed-test-btn');
      const closeSpeedBtn = document.getElementById('close-speed-test');
      const startSpeedBtn = document.getElementById('start-speed-test');

      if (speedBtn && modal) speedBtn.onclick = () => {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        renderSpeedHistory();
        // Reset display
        const needle = document.getElementById('needle-group');
        if (needle) needle.style.transform = 'rotate(-90deg)';
        const display = document.getElementById('speed-display');
        if (display) display.textContent = '0';
        const phase = document.getElementById('speed-test-phase');
        if (phase) { phase.textContent = ''; phase.style.opacity = '0'; }
        document.getElementById('speed-results')?.classList.add('opacity-0', 'max-h-0');
        document.getElementById('speed-results')?.classList.remove('opacity-100');
        document.getElementById('speed-quality')?.classList.add('hidden');
        document.getElementById('speed-activities')?.classList.add('hidden');
      };
      
      if (closeSpeedBtn && modal) closeSpeedBtn.onclick = () => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      };
      
      if (startSpeedBtn) startSpeedBtn.onclick = runSpeedTest;

      // Close modal on backdrop click
      if (modal) modal.onclick = (e: MouseEvent) => {
        if (e.target === modal) {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
        }
      };

      // Speed history
      renderSpeedHistory();
      const clearSpeedBtn = document.getElementById('clear-speed-history');
      if (clearSpeedBtn) clearSpeedBtn.onclick = () => {
        try {
          localStorage.removeItem('speed_test_history');
          renderSpeedHistory();
          window.showToast(
            window._tToast ? window._tToast('Riwayat tes dibersihkan!') : 'Riwayat tes dibersihkan!',
            'success'
          );
        } catch {}
      };

      // Close modal with Escape key
      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
        }
      });
  });

  window.addEventListener('online', updateNetworkStatus);
  window.addEventListener('offline', updateNetworkStatus);
</script>

