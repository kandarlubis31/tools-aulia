---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="My IP & Network Info">
  <div class="max-w-6xl mx-auto px-4 py-10 min-h-[85vh]">
    
    <div class="text-center mb-10 animate-on-scroll">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-cyan-400 tracking-tight" data-i18n="header.my_ip_full">
        Cek IP & Koneksi
      </h1>
      <p class="text-slate-600 dark:text-slate-400 text-lg" data-i18n="header.my_ip_detail">
        Lihat info detail tentang koneksi internet dan identitas digital kamu.
      </p>
    </div>

    <div id="network-status" class="hidden fixed top-24 right-4 px-4 py-2 rounded-lg text-sm font-bold z-50 transition-all duration-300 shadow-lg border border-white/20 backdrop-blur-md">
        <span id="network-text"></span>
    </div>

    <div class="bg-white dark:bg-slate-800 rounded-3xl p-8 shadow-xl border border-slate-200 dark:border-slate-700 relative overflow-hidden group mb-8 transition-all hover:shadow-2xl hover:shadow-blue-500/10">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-500 to-cyan-400"></div>
        
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 relative z-10">
            <div class="text-center md:text-left">
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2" data-i18n="label.public_ip">IP Publik Kamu</p>
                <div class="flex flex-col md:flex-row items-center gap-4">
                    <h2 id="ip-display" class="text-4xl md:text-6xl font-black text-slate-800 dark:text-white font-mono tracking-tight">
                        Ngecek...
                    </h2>
                    <button id="copy-ip-btn" class="p-2 rounded-lg bg-slate-100 dark:bg-slate-700 text-slate-500 hover:text-blue-500 transition-colors cursor-pointer" title="Copy IP">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                    </button>
                </div>
                
                <div class="flex items-center justify-center md:justify-start gap-3 mt-4">
                    <span id="ipv-badge" class="hidden px-2 py-1 rounded text-[10px] font-bold bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 uppercase tracking-wide">IPv4</span>
                    <span id="connection-type-badge" class="hidden px-2 py-1 rounded text-[10px] font-bold bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300 uppercase tracking-wide">4G</span>
                    <span class="text-xs text-emerald-500 font-bold flex items-center gap-1.5 px-2 py-1 bg-emerald-50 dark:bg-emerald-900/10 rounded">
                        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span> <span data-i18n="text.connected">Terhubung</span>
                    </span>
                </div>
            </div>

            <div class="flex gap-3 w-full md:w-auto">
                <button id="refresh-btn" class="flex-1 md:flex-none flex items-center justify-center gap-2 px-5 py-3 bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 text-slate-600 dark:text-slate-200 font-bold rounded-xl transition-all active:scale-95" data-i18n="btn.refresh">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.3"/></svg>
                    Refresh
                </button>
                <button id="speed-test-btn" class="flex-1 md:flex-none flex items-center justify-center gap-2 px-5 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-all shadow-lg shadow-blue-500/20 active:scale-95" data-i18n="btn.speed_test">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    Speed Test
                </button>
            </div>
        </div>

        <div class="absolute -right-6 -bottom-12 opacity-[0.03] dark:opacity-[0.05] pointer-events-none select-none">
            <svg width="350" height="350" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM4 12c0-.61.08-1.21.21-1.78L8.99 15v1c0 1.1.9 2 2 2v1.93C7.06 19.43 4 16.07 4 12zm13.89 5.4c-.26-.81-1-1.4-1.9-1.4h-1v-3c0-.55-.45-1-1-1h-6v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41C17.92 5.77 20 8.65 20 12c0 2.08-.81 3.98-2.11 5.4z"/></svg>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-md transition-all group">
            <div class="flex items-center gap-3 mb-5 pb-4 border-b border-slate-100 dark:border-slate-700">
                <div class="p-2.5 bg-purple-100 dark:bg-purple-900/30 text-purple-600 rounded-lg group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                </div>
                <h3 class="font-bold text-slate-800 dark:text-white" data-i18n="label.provider_info">Info Provider</h3>
            </div>
            <div class="space-y-4">
                <div>
                    <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.provider">Provider</p>
                    <p id="isp-name" class="font-medium text-slate-700 dark:text-slate-200 text-lg truncate" data-i18n="common.loading">Lagi cek...</p>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.asn">ASN</p>
                        <p id="asn-name" class="font-medium text-slate-700 dark:text-slate-200">-</p>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.type">Tipe</p>
                        <p id="connection-type" class="font-medium text-slate-700 dark:text-slate-200">-</p>
                    </div>
                </div>
                <div>
                    <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.organization">Organisasi</p>
                    <p id="isp-domain" class="font-medium text-slate-700 dark:text-slate-200 truncate text-sm">-</p>
                </div>
            </div>
        </div>

        <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-md transition-all group">
            <div class="flex items-center gap-3 mb-5 pb-4 border-b border-slate-100 dark:border-slate-700">
                <div class="p-2.5 bg-rose-100 dark:bg-rose-900/30 text-rose-600 rounded-lg group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <h3 class="font-bold text-slate-800 dark:text-white" data-i18n="label.location_server">Lokasi Server</h3>
            </div>
            <div class="space-y-4">
                <div class="flex items-center gap-3">
                    <img id="flag-img" src="" alt="Flag" class="w-10 h-auto rounded shadow-sm hidden border border-slate-100 dark:border-slate-600">
                    <div>
                        <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.country">Negara</p>
                        <p id="loc-country" class="font-medium text-slate-700 dark:text-slate-200" data-i18n="common.searching">Lagi cari...</p>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.city">Kota</p>
                        <p id="loc-city" class="font-medium text-slate-700 dark:text-slate-200 truncate">-</p>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.timezone">Zona Waktu</p>
                        <p id="loc-timezone" class="font-medium text-slate-700 dark:text-slate-200 text-sm">-</p>
                    </div>
                </div>
                <div>
                    <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.coordinates">Koordinat</p>
                    <div class="flex justify-between items-center">
                        <p id="loc-coords" class="font-mono text-sm text-slate-600 dark:text-slate-300">-</p>
                        <a id="maps-link" href="#" target="_blank" class="text-xs font-bold text-blue-500 hover:text-blue-600 hidden bg-blue-50 dark:bg-blue-900/20 px-2 py-1 rounded">
                            Maps ↗
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-md transition-all group">
            <div class="flex items-center gap-3 mb-5 pb-4 border-b border-slate-100 dark:border-slate-700">
                <div class="p-2.5 bg-amber-100 dark:bg-amber-900/30 text-amber-600 rounded-lg group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="12" x="3" y="4" rx="2" ry="2"/><line x1="2" x2="22" y1="20" y2="20"/></svg>
                </div>
                <h3 class="font-bold text-slate-800 dark:text-white" data-i18n="label.device_info">Info Device</h3>
            </div>
            <div class="space-y-4">
                <div>
                    <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.browser_os">Browser & OS</p>
                    <p id="dev-browser" class="font-medium text-slate-700 dark:text-slate-200 truncate" data-i18n="common.loading">Lagi detek...</p>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.resolution">Resolusi</p>
                        <p id="dev-res" class="font-medium text-slate-700 dark:text-slate-200">-</p>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.battery">Baterai</p>
                        <p id="dev-battery" class="font-medium text-slate-700 dark:text-slate-200">-</p>
                    </div>
                </div>
                <div>
                    <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.local_ip">IP Lokal (WebRTC)</p>
                    <p id="local-ip" class="font-mono text-sm text-slate-600 dark:text-slate-300 truncate" data-i18n="text.protected">Diproteksi</p>
                </div>
            </div>
        </div>

        <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-md transition-all group lg:col-span-3">
            <div class="flex items-center gap-3 mb-5 pb-4 border-b border-slate-100 dark:border-slate-700">
                <div class="p-2.5 bg-green-100 dark:bg-green-900/30 text-green-600 rounded-lg group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 0 0-7z"/></svg>
                </div>
                <h3 class="font-bold text-slate-800 dark:text-white" data-i18n="label.additional_info">Info Tambahan</h3>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.proxy_vpn">Proxy / VPN</p>
                    <p id="proxy-status" class="font-medium text-slate-700 dark:text-slate-200">Lagi cek...</p>
                </div>
                <div>
                    <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.dns_server">DNS Server</p>
                    <p id="dns-server" class="font-medium text-slate-700 dark:text-slate-200 truncate">-</p>
                </div>
                <div>
                    <p class="text-[10px] text-slate-400 uppercase font-bold tracking-wider" data-i18n="label.user_agent">User Agent</p>
                    <p id="user-agent" class="font-medium text-slate-700 dark:text-slate-200 truncate text-xs">-</p>
                </div>
            </div>
        </div>

    </div>

    <div class="mt-8 flex justify-center gap-4">
        <button id="toggle-json" class="group flex items-center gap-2 px-4 py-2 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-sm font-bold text-slate-500 hover:text-blue-500 transition-all hover:shadow-md">
            <span data-i18n="btn.dev_mode">Mode Developer (JSON)</span>
            <svg id="arrow-json" class="w-4 h-4 transition-transform group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        <button id="save-report" class="group flex items-center gap-2 px-4 py-2 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-sm font-bold text-slate-500 hover:text-green-500 transition-all hover:shadow-md">
            <span data-i18n="btn.save_report">Simpan Laporan</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
        </button>
    </div>
    
    <div id="json-container" class="hidden mt-4 max-w-3xl mx-auto">
        <div class="bg-slate-900 rounded-xl p-4 overflow-x-auto relative group border border-slate-700 shadow-inner">
            <button id="copy-json" class="absolute top-4 right-4 p-2 bg-slate-700 hover:bg-slate-600 rounded-lg text-slate-300 transition-colors" title="Copy JSON">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            </button>
            <pre id="json-code" class="text-xs text-emerald-400 font-mono leading-relaxed"></pre>
        </div>
    </div>

    <div id="speed-test-modal" class="hidden fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4 backdrop-blur-sm transition-opacity">
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 max-w-md w-full shadow-2xl border border-slate-200 dark:border-slate-700 transform transition-all">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-bold text-slate-800 dark:text-white flex items-center gap-2" data-i18n="btn.speed_test">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    Speed Test
                </h3>
                <button id="close-speed-test" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            
            <div class="mb-8">
                <div class="flex justify-center mb-6">
                    <div class="relative w-40 h-40">
                        <svg class="w-40 h-40 transform -rotate-90 drop-shadow-xl">
                            <circle cx="80" cy="80" r="70" stroke="currentColor" stroke-width="12" fill="none" class="text-slate-100 dark:text-slate-700"></circle>
                            <circle id="speed-progress" cx="80" cy="80" r="70" stroke="currentColor" stroke-width="12" fill="none" class="text-blue-500 transition-all duration-300 ease-out" stroke-dasharray="440" stroke-dashoffset="440" stroke-linecap="round"></circle>
                        </svg>
                        <div class="absolute inset-0 flex flex-col items-center justify-center">
                            <span id="speed-value" class="text-4xl font-black text-slate-800 dark:text-white tracking-tighter">0</span>
                            <span class="text-xs font-bold text-slate-400 uppercase">Mbps</span>
                        </div>
                    </div>
                </div>
                
                <div class="grid grid-cols-3 gap-4 text-center bg-slate-50 dark:bg-slate-900/50 p-4 rounded-xl border border-slate-100 dark:border-slate-700">
                    <div>
                        <p class="text-[10px] text-slate-400 uppercase font-bold" data-i18n="label.download">Download</p>
                        <p id="test-download" class="text-sm font-bold text-slate-700 dark:text-slate-200">-</p>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-400 uppercase font-bold" data-i18n="label.upload">Upload</p>
                        <p id="test-upload" class="text-sm font-bold text-slate-700 dark:text-slate-200">-</p>
                    </div>
                    <div>
                        <p class="text-[10px] text-slate-400 uppercase font-bold" data-i18n="label.ping">Ping</p>
                        <p id="latency" class="text-sm font-bold text-slate-700 dark:text-slate-200">-</p>
                    </div>
                </div>
            </div>
            
            <div class="flex gap-3">
                <button id="start-speed-test" class="flex-1 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-all shadow-lg shadow-blue-500/25 active:scale-95" data-i18n="text.start_test">
                    Mulai Test
                </button>
            </div>
            <p class="text-[10px] text-center text-slate-400 mt-4" data-i18n="text.note_ping_simulated">Catatan: Ping adalah latensi asli, kecepatan adalah simulasi.</p>
        </div>
    </div>

  </div>
</BaseLayout>

<script>

  function updateNetworkStatus() {
    const statusText = document.getElementById('network-status');
    const text = document.getElementById('network-text');
    if (!statusText || !text) return;
    
    if (navigator.onLine) {
        statusText.classList.remove('bg-red-500', 'border-red-400');
        statusText.classList.add('bg-emerald-500', 'border-emerald-400', 'text-white');
        text.textContent = window._tToast ? window._tToast('● Online') : '● Online';
        setTimeout(() => statusText.classList.add('hidden'), 2000);
    } else {
        statusText.classList.remove('hidden', 'bg-emerald-500', 'border-emerald-400');
        statusText.classList.add('bg-red-500', 'border-red-400', 'text-white');
        text.textContent = window._tToast ? window._tToast('● Offline') : '● Offline';
    }
  }

  function getBrowserInfo() {
      const ua = navigator.userAgent;
      let browser = "Unknown";
      let os = "Unknown";
      
      if (ua.indexOf("Firefox") > -1) browser = "Firefox";
      else if (ua.indexOf("SamsungBrowser") > -1) browser = "Samsung Internet";
      else if (ua.indexOf("Opera") > -1 || ua.indexOf("OPR") > -1) browser = "Opera";
      else if (ua.indexOf("Edge") > -1) browser = "Edge";
      else if (ua.indexOf("Chrome") > -1) browser = "Chrome";
      else if (ua.indexOf("Safari") > -1) browser = "Safari";
      
      if (ua.indexOf("Win") > -1) os = "Windows";
      else if (ua.indexOf("Mac") > -1) os = "macOS";
      else if (ua.indexOf("Linux") > -1) os = "Linux";
      else if (ua.indexOf("Android") > -1) os = "Android";
      else if (ua.indexOf("iPhone") > -1) os = "iOS";
      
      return { browser, os };
  }

  async function getBatteryInfo() {
    if ('getBattery' in navigator) {
      try {
        const battery = await navigator.getBattery();
        return `${Math.round(battery.level * 100)}% ${battery.charging ? '⚡' : ''}`;
      } catch (e) { 
        return 'N/A'; 
      }
    }
    return 'N/A';
  }

  async function measureLatency() {
      const start = performance.now();
      try {
          await fetch('https://www.google.com/favicon.ico', { 
            mode: 'no-cors', 
            cache: 'no-store' 
          });
          const end = performance.now();
          return Math.round(end - start);
      } catch (e) { 
        return null; 
      }
  }

  async function getLocalIP() {
    return new Promise(resolve => {
        const pc = new RTCPeerConnection({iceServers: []});
        pc.createDataChannel('');
        pc.createOffer().then(o => pc.setLocalDescription(o)).catch(() => {});
        pc.onicecandidate = e => {
            if (e.candidate) {
                const match = e.candidate.candidate.match(/([0-9]{1,3}(\.[0-9]{1,3}){3})/);
                if (match) { 
                  resolve(match[1]); 
                  pc.close(); 
                }
            }
        };
        setTimeout(() => { 
          resolve((window._tToast) ? window._tToast('Diproteksi') : 'Diproteksi'); 
          pc.close(); 
        }, 1000); 
    });
  }

  async function checkProxy() {
    try {
      const response = await fetch('https://httpbin.org/headers');
      const data = await response.json();
      const proxyHeaders = ['X-Forwarded-For', 'X-Real-Ip', 'X-Client-Ip', 'X-Cluster-Client-Ip', 'CF-Connecting-IP'];
      for (const header of proxyHeaders) {
        if (data.headers[header]) return (window._tToast) ? window._tToast('Mungkin menggunakan proxy/VPN') : 'Mungkin menggunakan proxy/VPN';
      }
      return (window._tToast) ? window._tToast('Tidak terdeteksi proxy/VPN') : 'Tidak terdeteksi proxy/VPN';
    } catch (e) { 
      return (window._tToast) ? window._tToast('Gagal mendeteksi') : 'Gagal mendeteksi'; 
    }
  }

  async function getDNSServer() {
    try {
      const response = await fetch('https://1.1.1.1/dns-query?name=example.com&type=A', {
        method: 'GET',
        headers: { 'Accept': 'application/dns-json' }
      });
      if (response.ok) return 'Cloudflare DNS (1.1.1.1)';
      return 'Tidak diketahui';
    } catch (e) { 
      return (window._tToast) ? window._tToast('Tidak diketahui') : 'Tidak diketahui'; 
    }
  }

  let rawNetworkData = {};
  let isRefreshing = false;

  async function fetchNetworkInfo() {
      if (isRefreshing) return;
      isRefreshing = true;
      
      const ipDisplay = document.getElementById('ip-display');
      if(!ipDisplay) return;
      
      ipDisplay.innerText = (window._tToast) ? window._tToast('Ngecek...') : 'Ngecek...';
      ipDisplay.classList.add("animate-pulse");
      
      try {
          const device = getBrowserInfo();
          const devBrowser = document.getElementById('dev-browser');
          if (devBrowser) devBrowser.innerText = `${device.browser} on ${device.os}`;
          
          const devRes = document.getElementById('dev-res');
          if (devRes) devRes.innerText = `${window.screen.width} x ${window.screen.height}`;
          
          const battery = await getBatteryInfo();
          const devBattery = document.getElementById('dev-battery');
          if (devBattery) devBattery.innerText = battery;
          
          const localIP = await getLocalIP();
          const localIpEl = document.getElementById('local-ip');
          if (localIpEl) localIpEl.innerText = localIP;
          
          const proxyStatus = await checkProxy();
          const proxyStatusEl = document.getElementById('proxy-status');
          if (proxyStatusEl) proxyStatusEl.innerText = proxyStatus;
          
          const dnsServer = await getDNSServer();
          const dnsServerEl = document.getElementById('dns-server');
          if (dnsServerEl) dnsServerEl.innerText = dnsServer;
          
          const userAgentEl = document.getElementById('user-agent');
          if (userAgentEl) userAgentEl.innerText = navigator.userAgent.substring(0, 60) + '...';

          if (navigator.connection) {
             const type = navigator.connection.effectiveType;
             if(type) {
                 const badge = document.getElementById('connection-type-badge');
                 if (badge) {
                   badge.innerText = type.toUpperCase();
                   badge.classList.remove('hidden');
                 }
             }
          }

          const response = await fetch('https://ipapi.co/json/');
          if (!response.ok) throw new Error('API request failed');
          const data = await response.json();
          
          if (data.error) {
            throw new Error(data.reason || 'API Error');
          }

          rawNetworkData = data;
          ipDisplay.innerText = data.ip;
          ipDisplay.classList.remove("animate-pulse");
          
          const ispName = document.getElementById('isp-name');
          if (ispName) ispName.innerText = data.org || "Unknown";
          
          const asnName = document.getElementById('asn-name');
          if (asnName) asnName.innerText = data.asn || 'Unknown';
          
          const connectionType = document.getElementById('connection-type');
          if (connectionType) connectionType.innerText = data.version || "Broadband";
          
          const ispDomain = document.getElementById('isp-domain');
          if (ispDomain) ispDomain.innerText = data.org || "-";
          
          const locCountry = document.getElementById('loc-country');
          if (locCountry) locCountry.innerText = `${data.country_name} ${data.country_code || ''}`;
          
          const locCity = document.getElementById('loc-city');
          if (locCity) locCity.innerText = `${data.city}, ${data.region}`;
          
          const locTimezone = document.getElementById('loc-timezone');
          if (locTimezone) locTimezone.innerText = data.timezone || "Unknown";
          
          const locCoords = document.getElementById('loc-coords');
          if (locCoords) locCoords.innerText = `${data.latitude}, ${data.longitude}`;

          const flagImg = document.getElementById('flag-img');
          if (flagImg && data.country_code) {
             flagImg.src = `https://flagcdn.com/w40/${data.country_code.toLowerCase()}.png`;
             flagImg.classList.remove('hidden');
          }

          const maps = document.getElementById('maps-link');
          if (maps) {
            maps.href = `https://www.google.com/maps/search/?api=1&query=${data.latitude},${data.longitude}`;
            maps.classList.remove('hidden');
          }
          
          const ipvBadge = document.getElementById('ipv-badge');
          if (ipvBadge) ipvBadge.classList.remove('hidden');

          const fullDataExport = { 
            ...data, 
            device_info: device, 
            local_ip_address: localIP,
            proxy_check: proxyStatus,
            dns_provider: dnsServer,
            full_user_agent: navigator.userAgent
          };
          
          const jsonCode = document.getElementById('json-code');
          if (jsonCode) jsonCode.innerText = JSON.stringify(fullDataExport, null, 2);
          
      } catch (error) {
          ipDisplay.innerText = (window._tToast) ? window._tToast('Error API') : 'Error API';
          ipDisplay.classList.remove("animate-pulse");
          window.showToast(window._tToast ? window._tToast("Gagal memuat detail jaringan. Coba lagi nanti.") : "Gagal memuat detail jaringan. Coba lagi nanti.", "error");
      } finally {
        isRefreshing = false;
      }
  }

  async function runSpeedTest() {
    const speedValue = document.getElementById('speed-value');
    const speedProgress = document.getElementById('speed-progress');
    const startBtn = document.getElementById('start-speed-test');
    if(!speedValue || !speedProgress || !startBtn) return;

    startBtn.disabled = true;        startBtn.textContent = (window._tToast) ? window._tToast('Mengukur latency...') : 'Mengukur latency...';
    
    const latency = await measureLatency();
    const latencyEl = document.getElementById('latency');
    if (latencyEl) latencyEl.innerText = latency ? `${latency} ms` : 'Error';
    
    startBtn.textContent = (window._tToast) ? window._tToast('Testing speed...') : 'Testing speed...';
    
    const circumference = 440; 
    let progress = 0;
    const interval = setInterval(() => {
        progress += 1.5;
        const offset = circumference - (progress / 100) * circumference;
        speedProgress.style.strokeDashoffset = offset.toString();
        speedValue.innerText = Math.floor(Math.random() * 80 + 10).toString();
        
        if (progress >= 100) {
            clearInterval(interval);
            const dl = Math.floor(Math.random() * 90 + 20); 
            const ul = Math.floor(dl * 0.4);
            speedValue.innerText = dl.toString();
            
            const testDownload = document.getElementById('test-download');
            if (testDownload) testDownload.innerText = `${dl} Mbps`;
            
            const testUpload = document.getElementById('test-upload');
            if (testUpload) testUpload.innerText = `${ul} Mbps`;
            
            startBtn.disabled = false;
            startBtn.textContent = (window._tToast) ? window._tToast('Test Lagi') : 'Test Lagi';
            window.showToast(window._tToast ? window._tToast('Test selesai!') : 'Test selesai!', 'success');
        }
    }, 40);
  }

  function saveNetworkReport() {
    const reportData = {
      timestamp: new Date().toISOString(),
      ip: rawNetworkData.ip || 'Unknown',
      location: {
        country: document.getElementById('loc-country')?.innerText || 'Unknown',
        city: document.getElementById('loc-city')?.innerText || 'Unknown',
        coordinates: document.getElementById('loc-coords')?.innerText || 'Unknown'
      },
      isp: {
        name: document.getElementById('isp-name')?.innerText || 'Unknown',
        asn: document.getElementById('asn-name')?.innerText || 'Unknown',
        type: document.getElementById('connection-type')?.innerText || 'Unknown'
      },
      device: {
        browser_os: document.getElementById('dev-browser')?.innerText || 'Unknown',
        resolution: document.getElementById('dev-res')?.innerText || 'Unknown',
        battery: document.getElementById('dev-battery')?.innerText || 'Unknown'
      }
    };
    
    const dataStr = JSON.stringify(reportData, null, 2);
    const dataUri = 'data:application/json;charset=utf-8,'+ encodeURIComponent(dataStr);
    const fileName = `network-report-${new Date().getTime()}.json`;
    const linkElement = document.createElement('a');
    linkElement.setAttribute('href', dataUri);
    linkElement.setAttribute('download', fileName);
    linkElement.click();
    window.showToast(window._tToast ? window._tToast('Laporan berhasil disimpan!') : 'Laporan berhasil disimpan!', 'success');
  }

  document.addEventListener('astro:page-load', () => {
      fetchNetworkInfo();
      updateNetworkStatus();

      const refreshBtn = document.getElementById('refresh-btn');
      if (refreshBtn) refreshBtn.onclick = fetchNetworkInfo;
      
      const copyIpBtn = document.getElementById('copy-ip-btn');
      if (copyIpBtn) copyIpBtn.onclick = () => {
          const ipText = document.getElementById('ip-display')?.innerText;
          if(ipText && !ipText.includes("Error") && !ipText.includes("Ngecek")) {
              navigator.clipboard.writeText(ipText);
              window.showToast(window._tToast ? window._tToast('IP disalin!') : 'IP disalin!');
          }
      };

      const copyJsonBtn = document.getElementById('copy-json');
      if (copyJsonBtn) copyJsonBtn.onclick = () => {
          const jsonCode = document.getElementById('json-code')?.innerText;
          if (jsonCode) {
            navigator.clipboard.writeText(jsonCode);
            window.showToast(window._tToast ? window._tToast('JSON disalin!') : 'JSON disalin!');
          }
      };

      const toggleJsonBtn = document.getElementById('toggle-json');
      if (toggleJsonBtn) toggleJsonBtn.onclick = () => {
          const jsonContainer = document.getElementById('json-container');
          const arrowJson = document.getElementById('arrow-json');
          if (jsonContainer && arrowJson) {
            jsonContainer.classList.toggle('hidden');
            arrowJson.classList.toggle('rotate-180');
          }
      };

      const saveReportBtn = document.getElementById('save-report');
      if (saveReportBtn) saveReportBtn.onclick = saveNetworkReport;

      const modal = document.getElementById('speed-test-modal');
      const speedBtn = document.getElementById('speed-test-btn');
      const closeSpeedBtn = document.getElementById('close-speed-test');
      const startSpeedBtn = document.getElementById('start-speed-test');

      if (speedBtn && modal) speedBtn.onclick = () => {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      };
      
      if (closeSpeedBtn && modal) closeSpeedBtn.onclick = () => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      };
      
      if (startSpeedBtn) startSpeedBtn.onclick = runSpeedTest;
  });

  window.addEventListener('online', updateNetworkStatus);
  window.addEventListener('offline', updateNetworkStatus);
</script>

