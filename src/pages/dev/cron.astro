---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<script is:inline src="https://cdn.jsdelivr.net/npm/cronstrue@2.4.1/dist/cronstrue.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/luxon@3.4.4/build/global/luxon.min.js"></script>

<BaseLayout pageTitle="Cron Generator">
  <div class="max-w-5xl mx-auto px-4 py-12">
    
    <header class="text-center mb-10 animate-fade-in">
      <h1 class="text-4xl font-extrabold text-slate-900 dark:text-white mb-2">Cron Generator</h1>
      <p class="text-slate-500">Bikin jadwal Cron Job tanpa pusing mikirin urutan bintang (*).</p>
    </header>

    

    <div class="bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-lg border border-slate-200 dark:border-slate-700 mb-8 animate-fade-in-up">
      
      <div class="mb-6 text-center min-h-[3rem] flex items-center justify-center">
        <span id="human-result" class="text-lg md:text-xl font-bold text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 px-4 py-2 rounded-lg transition-all">
          Loading...
        </span>
      </div>

      <div class="relative mb-8">
        <div class="flex gap-2 mb-2">
          <input 
            type="text" 
            id="cron-input" 
            value="* * * * *" 
            class="flex-1 text-center text-3xl md:text-5xl font-mono py-4 bg-slate-50 dark:bg-slate-900 border-2 border-slate-300 dark:border-slate-600 rounded-xl focus:border-indigo-500 focus:ring-0 outline-none text-slate-800 dark:text-slate-200 tracking-widest transition-all"
            spellcheck="false"
          >
          <button id="copy-btn" class="px-4 py-2 bg-indigo-500 hover:bg-indigo-600 text-white rounded-lg transition-colors flex items-center justify-center" title="Copy to clipboard">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          </button>
        </div>
        <p id="error-msg" class="text-red-500 text-sm mt-2 text-center hidden font-bold"></p>
      </div>

      <div class="grid grid-cols-5 gap-1 text-center text-xs font-bold text-slate-400 uppercase tracking-tighter mb-8">
        <div>Minute</div>
        <div>Hour</div>
        <div>Day (Month)</div>
        <div>Month</div>
        <div>Day (Week)</div>
      </div>

      <div class="mb-8 border-t border-slate-200 dark:border-slate-700 pt-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-bold text-slate-700 dark:text-slate-300">Visual Builder</h3>
          <button id="toggle-builder" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline">Hide</button>
        </div>
        
        <div id="visual-builder" class="space-y-4">
          <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
            <div class="space-y-2">
              <label class="text-xs font-bold text-slate-600 dark:text-slate-400">Minute</label>
              <select id="minute-select" class="w-full p-2 bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded text-sm">
                <option value="*">Every minute</option>
                <option value="0">At index 0</option>
                <option value="*/5">Every 5 mins</option>
                <option value="*/15">Every 15 mins</option>
                <option value="30">At index 30</option>
                <option value="custom">Custom</option>
              </select>
              <input type="text" id="minute-custom" class="w-full p-2 bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded text-sm hidden" placeholder="0-59">
            </div>
            
            <div class="space-y-2">
              <label class="text-xs font-bold text-slate-600 dark:text-slate-400">Hour</label>
              <select id="hour-select" class="w-full p-2 bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded text-sm">
                <option value="*">Every hour</option>
                <option value="0">Midnight (00)</option>
                <option value="9">9 AM</option>
                <option value="12">Noon (12)</option>
                <option value="17">5 PM</option>
                <option value="*/2">Every 2 hours</option>
                <option value="custom">Custom</option>
              </select>
              <input type="text" id="hour-custom" class="w-full p-2 bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded text-sm hidden" placeholder="0-23">
            </div>
            
            <div class="space-y-2">
              <label class="text-xs font-bold text-slate-600 dark:text-slate-400">Day (Month)</label>
              <select id="day-select" class="w-full p-2 bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded text-sm">
                <option value="*">Every day</option>
                <option value="1">1st of month</option>
                <option value="15">15th of month</option>
                <option value="L">Last day</option>
                <option value="custom">Custom</option>
              </select>
              <input type="text" id="day-custom" class="w-full p-2 bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded text-sm hidden" placeholder="1-31">
            </div>
            
            <div class="space-y-2">
              <label class="text-xs font-bold text-slate-600 dark:text-slate-400">Month</label>
              <select id="month-select" class="w-full p-2 bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded text-sm">
                <option value="*">Every month</option>
                <option value="1">January</option>
                <option value="6">June</option>
                <option value="12">December</option>
                <option value="*/3">Every 3 months</option>
                <option value="custom">Custom</option>
              </select>
              <input type="text" id="month-custom" class="w-full p-2 bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded text-sm hidden" placeholder="1-12">
            </div>
            
            <div class="space-y-2">
              <label class="text-xs font-bold text-slate-600 dark:text-slate-400">Weekday</label>
              <select id="weekday-select" class="w-full p-2 bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded text-sm">
                <option value="*">Every day</option>
                <option value="1-5">Mon-Fri</option>
                <option value="0,6">Sat-Sun</option>
                <option value="1">Monday</option>
                <option value="5">Friday</option>
                <option value="custom">Custom</option>
              </select>
              <input type="text" id="weekday-custom" class="w-full p-2 bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded text-sm hidden" placeholder="0-6 (Sun-Sat)">
            </div>
          </div>
          
          <button id="apply-builder" class="w-full py-2 bg-indigo-500 hover:bg-indigo-600 text-white font-bold rounded-lg transition-colors mt-4">
            Update Cron Expression
          </button>
        </div>
      </div>

      <div class="mb-8 border-t border-slate-200 dark:border-slate-700 pt-6">
        <h3 class="text-sm font-bold text-slate-700 dark:text-slate-300 mb-3">Quick Presets</h3>
        <div class="flex flex-wrap gap-2">
          <button class="preset-btn px-3 py-1.5 bg-slate-100 dark:bg-slate-700 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 text-slate-600 dark:text-slate-300 text-sm rounded-lg transition-colors" data-val="* * * * *">Every Minute</button>
          <button class="preset-btn px-3 py-1.5 bg-slate-100 dark:bg-slate-700 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 text-slate-600 dark:text-slate-300 text-sm rounded-lg transition-colors" data-val="*/5 * * * *">Every 5 Mins</button>
          <button class="preset-btn px-3 py-1.5 bg-slate-100 dark:bg-slate-700 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 text-slate-600 dark:text-slate-300 text-sm rounded-lg transition-colors" data-val="0 * * * *">Hourly</button>
          <button class="preset-btn px-3 py-1.5 bg-slate-100 dark:bg-slate-700 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 text-slate-600 dark:text-slate-300 text-sm rounded-lg transition-colors" data-val="0 0 * * *">Daily (Midnight)</button>
          <button class="preset-btn px-3 py-1.5 bg-slate-100 dark:bg-slate-700 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 text-slate-600 dark:text-slate-300 text-sm rounded-lg transition-colors" data-val="0 9 * * 1-5">Work Hours</button>
          <button class="preset-btn px-3 py-1.5 bg-slate-100 dark:bg-slate-700 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 text-slate-600 dark:text-slate-300 text-sm rounded-lg transition-colors" data-val="@reboot">@reboot</button>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-slate-800 p-6 rounded-xl border border-slate-200 dark:border-slate-700 mb-8">
      <h3 class="text-sm font-bold text-slate-800 dark:text-slate-200 mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Next Executions (Estimasi)
      </h3>
      <div id="next-executions" class="space-y-2">
        <p class="text-slate-600 dark:text-slate-400 text-sm animate-pulse">Calculating...</p>
      </div>
    </div>

    <div class="bg-white dark:bg-slate-800 p-6 rounded-xl border border-slate-200 dark:border-slate-700">
      <h3 class="text-sm font-bold text-slate-800 dark:text-slate-200 mb-4">Implementation Code</h3>
      <div class="mb-4">
        <select id="language-select" class="text-xs bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded px-2 py-1 mb-2">
          <option value="nodejs">Node.js (node-cron)</option>
          <option value="python">Python (crontab)</option>
          <option value="php">PHP (crontab)</option>
          <option value="bash">Bash / Shell</option>
          <option value="java">Java (Spring Boot)</option>
        </select>
        <div class="relative">
          <pre id="code-example" class="p-4 bg-slate-900 text-slate-100 rounded-lg overflow-x-auto text-sm font-mono"></pre>
          <button id="copy-code-btn" class="absolute top-2 right-2 p-1.5 bg-slate-700 hover:bg-slate-600 text-white rounded transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          </button>
        </div>
      </div>
    </div>

    <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 transform translate-y-20 opacity-0 transition-all duration-300 z-[100] px-6 py-3 rounded-full shadow-2xl bg-slate-900 text-white text-sm font-medium flex items-center gap-3">
        <span id="toast-msg">Copied!</span>
    </div>

  </div>
</BaseLayout>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    // --- ELEMENTS ---
    const cronInput = document.getElementById('cron-input');
    const humanResult = document.getElementById('human-result');
    const errorMsg = document.getElementById('error-msg');
    const nextExecutions = document.getElementById('next-executions');
    const codeExample = document.getElementById('code-example');
    
    // Visual Builder
    const visualBuilder = document.getElementById('visual-builder');
    const toggleBuilder = document.getElementById('toggle-builder');
    const applyBuilder = document.getElementById('apply-builder');
    const selects = ['minute', 'hour', 'day', 'month', 'weekday'].map(id => ({
        sel: document.getElementById(`${id}-select`),
        cust: document.getElementById(`${id}-custom`)
    }));

    const toast = document.getElementById('toast');
    const toastMsg = document.getElementById('toast-msg');

    // --- FUNCTIONS ---

    function showToast(msg) {
        if(!toast) return;
        toastMsg.textContent = msg;
        toast.classList.remove('translate-y-20', 'opacity-0');
        setTimeout(() => toast.classList.add('translate-y-20', 'opacity-0'), 2000);
    }

    function translateCron() {
      const val = cronInput.value;
      try {
        // @ts-ignore
        if (typeof cronstrue !== 'undefined') {
            const text = cronstrue.toString(val, { locale: "en" });
            humanResult.innerText = text;
            cronInput.classList.remove('border-red-500', 'text-red-500');
            errorMsg.classList.add('hidden');
            return true;
        }
      } catch (e) {
        humanResult.innerText = "Invalid Cron Expression";
        cronInput.classList.add('border-red-500', 'text-red-500');
        errorMsg.innerText = e;
        errorMsg.classList.remove('hidden');
        return false;
      }
      return false;
    }

    // FIX: Menggunakan 'let' untuk variabel 'now' agar bisa di-reassign
    function updateNextExecutions() {
      const val = cronInput.value;
      if (val.startsWith('@')) {
          nextExecutions.innerHTML = '<p class="text-slate-500 text-sm">Special macros cannot be previewed exactly.</p>';
          return;
      }

      try {
        // @ts-ignore
        if (typeof luxon === 'undefined') return;
        
        // Simple Simulation (Production app should use 'cron-parser' library for accuracy)
        const parts = val.split(' ');
        if (parts.length !== 5) return;

        let now = luxon.DateTime.now(); // FIX: Changed const to let
        const results = [];
        
        // Kalkulasi dummy yang aman (hanya untuk visualisasi sederhana)
        // Note: Logic cron parser asli sangat kompleks, ini simulasi kasar untuk UI
        for(let i=0; i<5; i++) {
            // Simulasi penambahan waktu (logika sederhana)
            if (parts[0] === '*') now = now.plus({ minutes: 1 });
            else if (parts[0].includes('/')) now = now.plus({ minutes: parseInt(parts[0].split('/')[1]) });
            else now = now.plus({ minutes: 1 }); // Default fallback
            
            results.push(now.toFormat('yyyy-MM-dd HH:mm:ss'));
        }

        nextExecutions.innerHTML = results.map(time => 
          `<div class="flex justify-between items-center p-2 bg-slate-50 dark:bg-slate-900 rounded border border-slate-100 dark:border-slate-700">
            <span class="text-slate-600 dark:text-slate-300 text-sm font-mono">${time}</span>
            <span class="text-xs text-slate-400">Estimated</span>
           </div>`
        ).join('');

      } catch (e) {
        console.error(e);
      }
    }

    function updateCodeExample() {
      const val = cronInput.value;
      const lang = document.getElementById('language-select').value;
      let code = '';

      switch (lang) {
        case 'nodejs': code = `const cron = require('node-cron');\n\ncron.schedule('${val}', () => {\n  console.log('Task running...');\n});`; break;
        case 'python': code = `# crontab -e\n${val} /path/to/script.py`; break;
        case 'php': code = `<?php\n// crontab entry:\n// ${val} /usr/bin/php /path/to/script.php`; break;
        case 'bash': code = `# Edit crontab:\ncrontab -e\n\n# Add line:\n${val} /bin/bash /path/to/script.sh`; break;
        case 'java': code = `@Scheduled(cron = "${val}")\npublic void scheduleTask() {\n    System.out.println("Task executed");\n}`; break;
      }
      codeExample.textContent = code;
    }

    // --- EVENT LISTENERS ---
    
    // Toggle Builder
    toggleBuilder.addEventListener('click', () => {
        const isHidden = visualBuilder.style.display === 'none';
        visualBuilder.style.display = isHidden ? 'block' : 'none';
        toggleBuilder.textContent = isHidden ? 'Hide' : 'Show Visual Builder';
    });

    // Custom Input Toggles
    selects.forEach(({sel, cust}) => {
        sel.addEventListener('change', () => {
            if(sel.value === 'custom') cust.classList.remove('hidden');
            else cust.classList.add('hidden');
        });
    });

    // Apply Builder
    applyBuilder.addEventListener('click', () => {
        const parts = selects.map(({sel, cust}) => sel.value === 'custom' ? cust.value : sel.value);
        cronInput.value = parts.join(' ');
        translateCron();
        updateNextExecutions();
        updateCodeExample();
        showToast('Cron updated!');
    });

    // Input Change
    cronInput.addEventListener('input', () => {
        translateCron();
        updateNextExecutions();
        updateCodeExample();
    });

    // Presets
    document.querySelectorAll('.preset-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            cronInput.value = btn.dataset.val;
            translateCron();
            updateNextExecutions();
            updateCodeExample();
        });
    });

    // Language Change
    document.getElementById('language-select').addEventListener('change', updateCodeExample);

    // Copy Buttons
    document.getElementById('copy-btn').addEventListener('click', () => {
        navigator.clipboard.writeText(cronInput.value);
        showToast('Cron copied!');
    });
    
    document.getElementById('copy-code-btn').addEventListener('click', () => {
        navigator.clipboard.writeText(codeExample.textContent);
        showToast('Code copied!');
    });

    // --- INIT ---
    // Retry loading libs if CDN is slow
    const init = () => {
        // @ts-ignore
        if (typeof cronstrue !== 'undefined' && typeof luxon !== 'undefined') {
            translateCron();
            updateNextExecutions();
            updateCodeExample();
        } else {
            setTimeout(init, 500);
        }
    };
    init();

  });
</script>

<style>
  .animate-fade-in { animation: fadeIn 0.6s ease-out forwards; }
  .animate-fade-in-up { animation: fadeInUp 0.6s ease-out forwards; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>