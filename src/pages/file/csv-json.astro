---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="CSV to JSON Converter">
  <div class="max-w-6xl mx-auto px-4 min-h-[80vh] flex flex-col">
    <div class="text-center mb-8 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-matte-900 dark:text-white" data-i18n="header.csv_json">
        CSV to JSON
      </h1>
      <p class="text-matte-400 dark:text-matte-300" data-i18n="header.csv_json_desc">
        Konversi data CSV (Excel) menjadi format JSON untuk developer.
      </p>
    </div>

    <div class="flex justify-between items-center mb-4 animate-fade-in">
        <label class="bg-matte-100 dark:bg-surface-elevated hover:bg-matte-200 px-4 py-2 rounded-lg text-sm font-bold cursor-pointer transition" data-i18n="btn.upload_csv">
            📂 Upload CSV
            <input type="file" id="file-csv" accept=".csv" class="hidden" />
        </label>
        
        <div class="flex gap-2">
            <button id="convert-btn" class="bg-matte-900 dark:bg-white text-white dark:text-matte-900 font-bold py-2 px-6 rounded-lg transition active:scale-95 flex items-center gap-2" data-i18n="btn.convert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
                Convert
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 flex-1 mb-12 animate-fade-in h-[500px]">
        
        <div class="flex flex-col card-base overflow-hidden">
            <div class="bg-matte-100 dark:bg-surface-hover px-4 py-2 border-b border-matte-200 dark:border-surface-border font-bold text-matte-400 text-xs uppercase" data-i18n="label.csv_input">
                CSV Input
            </div>
            <textarea id="input-csv" class="flex-1 w-full p-4 font-mono text-sm bg-transparent outline-none resize-none dark:text-matte-200 whitespace-pre" placeholder="id,name,age&#10;1,John Doe,25&#10;2,Jane Smith,30" data-i18n-attr="placeholder" data-i18n="ph.csv_input"></textarea>
        </div>

        <div class="flex flex-col card-base overflow-hidden">
            <div class="bg-matte-50 dark:bg-matte-900 px-4 py-2 border-b border-matte-200 dark:border-matte-700 flex justify-between items-center">
                <span class="font-bold text-matte-500 text-xs uppercase" data-i18n="label.json_output">JSON Output</span>
                <button id="copy-btn" class="text-xs font-bold text-accent-blue hover:opacity-80" data-i18n="btn.copy_json">Copy JSON</button>
            </div>
            <textarea id="output-json" readonly class="flex-1 w-full p-4 font-mono text-sm bg-transparent outline-none resize-none dark:text-matte-200" placeholder="Result will appear here..." data-i18n-attr="placeholder" data-i18n="ph.json_output"></textarea>
        </div>

    </div>
  </div>
</BaseLayout>

<script>
  const input = document.getElementById('input-csv') as HTMLTextAreaElement;
  const output = document.getElementById('output-json') as HTMLTextAreaElement;
  const convertBtn = document.getElementById('convert-btn');
  const fileInput = document.getElementById('file-csv');
  const copyBtn = document.getElementById('copy-btn');

  // Simple CSV Parser
  function csvToJson(csv: string) {
    const lines = csv.trim().split('\n');
    const result = [];
    // Pisahkan header dengan koma (asumsi delimiter koma)
    const headers = lines[0].split(',').map(h => h.trim().replace(/^"|"$/g, ''));

    for (let i = 1; i < lines.length; i++) {
        if (!lines[i].trim()) continue;
        const obj: any = {};
        // Handle value dengan koma di dalamnya sedikit tricky tanpa library, 
        // tapi ini pendekatan sederhana untuk format standar
        const currentline = lines[i].split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/); // Regex split by comma ignoring quotes

        for (let j = 0; j < headers.length; j++) {
            let val = currentline[j] ? currentline[j].trim() : "";
            // Remove quotes if exists
            val = val.replace(/^"|"$/g, '');
            // Auto convert number
            if (!isNaN(Number(val)) && val !== "") val = Number(val);
            obj[headers[j]] = val;
        }
        result.push(obj);
    }
    return JSON.stringify(result, null, 4); // Pretty print
  }

  convertBtn?.addEventListener('click', () => {
    try {
        const csv = input.value;
        if (!csv) return;
        const json = csvToJson(csv);
        output.value = json;
    } catch (e) {
        alert(window._tToast ? window._tToast("Gagal konversi. Pastikan format CSV benar.") : "Gagal konversi. Pastikan format CSV benar.");
    }
  });

  fileInput?.addEventListener('change', (e: any) => {
    const file = e.target.files[0];
    if (file) {
        const reader = new FileReader();
        reader.onload = (evt) => {
            input.value = evt.target?.result as string;
        };
        reader.readAsText(file);
    }
  });

  copyBtn?.addEventListener('click', () => {
    if (!output.value) return;
    navigator.clipboard.writeText(output.value);
    window.showToast(window._tToast ? window._tToast('JSON disalin!') : 'JSON disalin!', "success");
  });
</script>
