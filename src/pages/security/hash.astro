---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Hash Generator (MD5, SHA)">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>

  <div class="max-w-4xl mx-auto px-4 min-h-[60vh]">
    <div class="text-center mb-10 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-blue-700 to-cyan-600">
        Hash Generator
      </h1>
      <p class="text-slate-600 dark:text-slate-400">
        Enkripsi teks menggunakan algoritma hashing standar (MD5, SHA-1, SHA-256).
      </p>
    </div>

    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-lg mb-8 animate-fade-in">
        <label class="block text-sm font-bold text-slate-500 mb-2 uppercase">Input Text</label>
        <textarea id="hash-input" class="w-full p-4 font-mono text-sm bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded-xl outline-none focus:border-blue-500 transition-colors resize-none h-32" placeholder="Ketik teks yang ingin di-hash..."></textarea>
    </div>

    <div class="space-y-4 animate-fade-in" style="animation-delay: 0.1s;">
        
        <div class="bg-white dark:bg-slate-800 p-4 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm flex flex-col md:flex-row md:items-center gap-4">
            <div class="w-24 font-bold text-slate-500">MD5</div>
            <input type="text" id="out-md5" readonly class="flex-1 p-2 bg-transparent font-mono text-sm text-slate-800 dark:text-slate-200 outline-none truncate" placeholder="..." />
            <button class="copy-btn text-xs font-bold px-3 py-1.5 bg-blue-100 dark:bg-blue-900/30 text-blue-600 rounded hover:bg-blue-200 transition" data-target="out-md5">Copy</button>
        </div>

        <div class="bg-white dark:bg-slate-800 p-4 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm flex flex-col md:flex-row md:items-center gap-4">
            <div class="w-24 font-bold text-slate-500">SHA-1</div>
            <input type="text" id="out-sha1" readonly class="flex-1 p-2 bg-transparent font-mono text-sm text-slate-800 dark:text-slate-200 outline-none truncate" placeholder="..." />
            <button class="copy-btn text-xs font-bold px-3 py-1.5 bg-blue-100 dark:bg-blue-900/30 text-blue-600 rounded hover:bg-blue-200 transition" data-target="out-sha1">Copy</button>
        </div>

        <div class="bg-white dark:bg-slate-800 p-4 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm flex flex-col md:flex-row md:items-center gap-4 border-l-4 border-l-blue-500">
            <div class="w-24 font-bold text-slate-700 dark:text-slate-300">SHA-256</div>
            <input type="text" id="out-sha256" readonly class="flex-1 p-2 bg-transparent font-mono text-sm text-slate-800 dark:text-slate-200 outline-none truncate" placeholder="..." />
            <button class="copy-btn text-xs font-bold px-3 py-1.5 bg-blue-100 dark:bg-blue-900/30 text-blue-600 rounded hover:bg-blue-200 transition" data-target="out-sha256">Copy</button>
        </div>

        <div class="bg-white dark:bg-slate-800 p-4 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm flex flex-col md:flex-row md:items-center gap-4">
            <div class="w-24 font-bold text-slate-500">SHA-512</div>
            <input type="text" id="out-sha512" readonly class="flex-1 p-2 bg-transparent font-mono text-sm text-slate-800 dark:text-slate-200 outline-none truncate" placeholder="..." />
            <button class="copy-btn text-xs font-bold px-3 py-1.5 bg-blue-100 dark:bg-blue-900/30 text-blue-600 rounded hover:bg-blue-200 transition" data-target="out-sha512">Copy</button>
        </div>

    </div>
  </div>
</BaseLayout>

<script>
  const input = document.getElementById('hash-input');
  const outMd5 = document.getElementById('out-md5');
  const outSha1 = document.getElementById('out-sha1');
  const outSha256 = document.getElementById('out-sha256');
  const outSha512 = document.getElementById('out-sha512');
  const copyBtns = document.querySelectorAll('.copy-btn');

  function updateHash() {
    const val = input.value;
    if(!val) {
        [outMd5, outSha1, outSha256, outSha512].forEach(el => el.value = '');
        return;
    }

    // @ts-ignore
    outMd5.value = CryptoJS.MD5(val).toString();
    // @ts-ignore
    outSha1.value = CryptoJS.SHA1(val).toString();
    // @ts-ignore
    outSha256.value = CryptoJS.SHA256(val).toString();
    // @ts-ignore
    outSha512.value = CryptoJS.SHA512(val).toString();
  }

  input.addEventListener('input', updateHash);

  copyBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
        const targetId = e.target.dataset.target;
        const targetInput = document.getElementById(targetId);
        if(targetInput.value) {
            navigator.clipboard.writeText(targetInput.value);
            window.showToast("Hash disalin!", "success");
        }
    });
  });
</script>
