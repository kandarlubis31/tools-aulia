---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Password Generator">
  <div class="max-w-3xl mx-auto px-4 min-h-[60vh]">
    <div class="text-center mb-10 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-emerald-500 to-teal-500">
        Password Generator
      </h1>
      <p class="text-slate-600 dark:text-slate-400" data-i18n="header.password_desc">
        Buat kata sandi yang kuat, acak, dan sulit ditebak dalam hitungan detik.
      </p>
    </div>

    <div class="bg-white dark:bg-slate-800 p-8 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-xl animate-fade-in">
      
      <div class="relative mb-6">
        <input type="text" id="result" readonly class="w-full p-4 pr-14 text-xl font-mono font-bold text-center bg-slate-100 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded-xl text-slate-800 dark:text-slate-200 outline-none focus:border-emerald-500 transition-colors" placeholder="Hasil Password" data-i18n-attr="placeholder" data-i18n="ph.password_result" />
        <button id="copy-btn" class="absolute right-2 top-2 bottom-2 aspect-square flex items-center justify-center bg-white dark:bg-slate-800 hover:bg-emerald-50 dark:hover:bg-emerald-900/30 text-emerald-600 rounded-lg border border-slate-200 dark:border-slate-700 transition-all active:scale-95" title="Copy">
           <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        </button>
      </div>

      <div class="flex gap-1 h-2 mb-8 rounded-full overflow-hidden bg-slate-200 dark:bg-slate-700">
         <div id="strength-bar" class="w-0 bg-red-500 transition-all duration-300"></div>
      </div>

      <div class="space-y-6">
         <div>
            <div class="flex justify-between font-bold text-slate-700 dark:text-slate-300 mb-2">
               <span data-i18n="label.password_length">Panjang Karakter</span>
               <span id="length-val" class="text-emerald-500">16</span>
            </div>
            <input type="range" id="length" min="6" max="50" value="16" class="w-full h-2 bg-slate-200 dark:bg-slate-700 rounded-lg appearance-none cursor-pointer accent-emerald-500" />
         </div>

         <div class="grid grid-cols-2 gap-4">
            <label class="flex items-center gap-3 p-3 rounded-lg border border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-700/50">
               <input type="checkbox" id="inc-uppercase" checked class="w-5 h-5 accent-emerald-500 rounded" />
               <span class="font-medium text-slate-700 dark:text-slate-300" data-i18n="label.uppercase">Huruf Besar (A-Z)</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-700/50">
               <input type="checkbox" id="inc-lowercase" checked class="w-5 h-5 accent-emerald-500 rounded" />
               <span class="font-medium text-slate-700 dark:text-slate-300" data-i18n="label.lowercase">Huruf Kecil (a-z)</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-700/50">
               <input type="checkbox" id="inc-numbers" checked class="w-5 h-5 accent-emerald-500 rounded" />
               <span class="font-medium text-slate-700 dark:text-slate-300" data-i18n="label.numbers">Angka (0-9)</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-700/50">
               <input type="checkbox" id="inc-symbols" checked class="w-5 h-5 accent-emerald-500 rounded" />
               <span class="font-medium text-slate-700 dark:text-slate-300" data-i18n="label.symbols">Simbol (!@#$)</span>
            </label>
         </div>

         <button id="generate-btn" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 px-6 rounded-xl shadow-lg shadow-emerald-500/30 transition-all active:scale-95 flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/></svg>
            <span data-i18n="btn.generate">Generate Password Baru</span>
         </button>
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  const resultEl = document.getElementById('result');
  const lengthEl = document.getElementById('length');
  const lengthValEl = document.getElementById('length-val');
  const uppercaseEl = document.getElementById('inc-uppercase');
  const lowercaseEl = document.getElementById('inc-lowercase');
  const numbersEl = document.getElementById('inc-numbers');
  const symbolsEl = document.getElementById('inc-symbols');
  const generateBtn = document.getElementById('generate-btn');
  const copyBtn = document.getElementById('copy-btn');
  const strengthBar = document.getElementById('strength-bar');

  const randomFunc = {
    lower: () => String.fromCharCode(Math.floor(Math.random() * 26) + 97),
    upper: () => String.fromCharCode(Math.floor(Math.random() * 26) + 65),
    number: () => String.fromCharCode(Math.floor(Math.random() * 10) + 48),
    symbol: () => {
      const symbols = '!@#$%^&*(){}[]=<>/,.';
      return symbols[Math.floor(Math.random() * symbols.length)];
    }
  };

  function generatePassword() {
    const length = +lengthEl.value;
    const hasLower = lowercaseEl.checked;
    const hasUpper = uppercaseEl.checked;
    const hasNumber = numbersEl.checked;
    const hasSymbol = symbolsEl.checked;

    let generatedPassword = '';
    const typesArr = [{ lower: hasLower }, { upper: hasUpper }, { number: hasNumber }, { symbol: hasSymbol }].filter(item => Object.values(item)[0]);
    
    if (typesArr.length === 0) {
        window.showToast(window._tToast ? window._tToast('Pilih minimal satu jenis karakter!') : 'Pilih minimal satu jenis karakter!', 'error');
        return '';
    }

    for (let i = 0; i < length; i += typesArr.length) {
      typesArr.forEach(type => {
        const funcName = Object.keys(type)[0];
        generatedPassword += randomFunc[funcName]();
      });
    }

    const finalPassword = generatedPassword.slice(0, length)
                                         .split('').sort(() => 0.5 - Math.random()).join('');
    
    resultEl.value = finalPassword;
    updateStrength(length, typesArr.length);
  }

  function updateStrength(length, types) {
    let strength = length * types;
    let color = 'bg-red-500';
    let width = '30%';

    if (strength > 40) {
        width = '100%';
        color = 'bg-emerald-500';
    } else if (strength > 20) {
        width = '60%';
        color = 'bg-yellow-500';
    }

    strengthBar.className = `h-full transition-all duration-300 ${color}`;
    strengthBar.style.width = width;
  }

  // Event Listeners
  generateBtn.addEventListener('click', generatePassword);
  lengthEl.addEventListener('input', (e) => lengthValEl.innerText = e.target.value);
  
  copyBtn.addEventListener('click', () => {
    if (!resultEl.value) return;
    navigator.clipboard.writeText(resultEl.value);
    window.showToast(window._tToast ? window._tToast('Password disalin!') : 'Password disalin!', 'success');
  });

  // Init
  generatePassword();
</script>
