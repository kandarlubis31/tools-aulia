---

<BaseLayout pageTitle="Dashboard">
  
  <section class="text-center mb-10 pt-12 animate-fade-in px-4">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-xs font-bold text-slate-600 dark:text-slate-300 mb-6 shadow-sm">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
      </span>
      All Systems Operational
    </div>

    <h1 class="text-4xl md:text-6xl font-extrabold mb-4 text-slate-900 dark:text-white tracking-tight">
      Developer <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 to-cyan-500">Utilities</span>
    </h1>
    <p class="text-lg text-slate-500 dark:text-slate-400 max-w-xl mx-auto leading-relaxed">
      Kumpulan tools sederhana untuk mempermudah pekerjaan harian. Tanpa server, tanpa login, data aman di browser.
    </p>
  </section>

  <div class="sticky top-16 z-40 bg-slate-50/90 dark:bg-slate-900/90 backdrop-blur-md py-4 border-b border-slate-200 dark:border-slate-800 mb-8 transition-all">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row gap-4 items-center">
       
       <div class="hidden md:block flex-1 min-w-0 w-full">
          <div class="flex gap-2 overflow-x-auto py-2 px-1 custom-scrollbar" id="desktop-filters">
              {categories.map((cat, index) => (
                 <button 
                    class={`filter-btn px-4 py-2 rounded-full text-sm transition-all whitespace-nowrap shadow-sm border border-transparent 
                    ${index === 0 
                        ? 'bg-slate-900 text-white dark:bg-white dark:text-slate-900 font-bold scale-105 shadow-md active' 
                        : 'font-medium text-slate-500 hover:bg-white hover:border-slate-200 dark:hover:bg-slate-800 dark:hover:border-slate-700'}`} 
                    data-filter={cat.id}
                 >
                    {cat.name}
                 </button>
              ))}
              <div class="w-4 shrink-0"></div> 
          </div>
       </div>

       <div class="md:hidden w-full">
          <select id="mobile-filter" class="w-full p-3 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 font-bold outline-none shadow-sm">
             {categories.map(cat => (
                <option value={cat.id}>{cat.name}</option>
             ))}
          </select>
       </div>

       <div class="relative w-full md:w-64 shrink-0">
          <input type="text" id="search-input" placeholder="Cari tools..." class="w-full pl-10 pr-4 py-2 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-indigo-500 outline-none text-sm transition-all shadow-sm" />
          <svg class="absolute left-3 top-2.5 w-4 h-4 text-slate-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
       </div>

    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 pb-32">
    <div id="tools-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
       
       {allTools.map((tool) => (
          <div 
            class={`tool-item h-full transition-all duration-300 animate-fade-in ${!tool.popular ? 'hidden' : ''}`} 
            data-cat={tool.cat} 
            data-popular={tool.popular ? "true" : "false"} 
            data-title={tool.title.toLowerCase()}
          >
             <ToolCard 
                title={tool.title}
                desc={tool.desc}
                href={tool.href}
                icon={tool.icon}
                color={tool.color}
             />
          </div>
       ))}

    </div>

    <div id="empty-state" class="hidden text-center py-20 animate-fade-in">
       <div class="text-6xl mb-4">🔍</div>
       <p class="text-slate-400 text-lg font-medium">Tidak ada tools yang cocok dengan pencarian.</p>
       <button id="reset-search" class="mt-4 px-6 py-2 bg-indigo-100 text-indigo-600 rounded-full font-bold hover:bg-indigo-200 transition-colors">Reset Filter</button>
    </div>
  </div>

</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const mobileFilter = document.getElementById('mobile-filter');
  const searchInput = document.getElementById('search-input');
  const tools = document.querySelectorAll('.tool-item');
  const emptyState = document.getElementById('empty-state');
  const resetSearchBtn = document.getElementById('reset-search');

  let currentFilter = 'popular'; 
  let currentSearch = '';

  function filterTools() {
    let visibleCount = 0;

    tools.forEach(tool => {
        // @ts-ignore
        const cat = tool.dataset.cat;
        // @ts-ignore
        const isPopular = tool.dataset.popular === 'true'; 
        // @ts-ignore
        const title = tool.dataset.title;
        
        let matchFilter = 
            currentFilter === 'all' || 
            (currentFilter === 'popular' && isPopular) || 
            (currentFilter !== 'popular' && currentFilter !== 'all' && cat === currentFilter);

        let matchSearch = title.includes(currentSearch);

        if (matchFilter && matchSearch) {
            tool.classList.remove('hidden');
            tool.classList.add('animate-fade-in-up');
            visibleCount++;
        } else {
            tool.classList.add('hidden');
            tool.classList.remove('animate-fade-in-up');
        }
    });

    if (visibleCount === 0) {
        emptyState?.classList.remove('hidden');
    } else {
        emptyState?.classList.add('hidden');
    }
  }

  function setActiveFilter(filterId) {
    currentFilter = filterId;
    
    // Update Desktop Buttons
    filterBtns.forEach(btn => {
        // @ts-ignore
        if(btn.dataset.filter === filterId) {
            btn.className = "filter-btn active px-4 py-2 rounded-full text-sm font-bold bg-slate-900 text-white dark:bg-white dark:text-slate-900 shadow-md scale-105 border border-transparent transition-all whitespace-nowrap";
        } else {
            btn.className = "filter-btn px-4 py-2 rounded-full text-sm font-medium text-slate-500 hover:bg-white hover:border-slate-200 dark:hover:bg-slate-800 dark:hover:border-slate-700 transition-all whitespace-nowrap border border-transparent";
        }
    });

    // Update Mobile Select
    if(mobileFilter) (mobileFilter as HTMLSelectElement).value = filterId;

    filterTools();
  }

  // --- EVENTS ---

  filterBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
        // @ts-ignore
        setActiveFilter(btn.dataset.filter);
    });
  });

  mobileFilter?.addEventListener('change', (e) => {
    // @ts-ignore
    setActiveFilter(e.target.value);
  });

  searchInput?.addEventListener('input', (e) => {
    // @ts-ignore
    currentSearch = e.target.value.toLowerCase();
    
    // Auto switch to 'all' if searching in popular (optional UX choice)
    if (currentSearch.length > 0 && currentFilter === 'popular') {
        setActiveFilter('all');
    } else {
        filterTools();
    }
  });

  resetSearchBtn?.addEventListener('click', () => {
    if(searchInput) (searchInput as HTMLInputElement).value = '';
    currentSearch = '';
    setActiveFilter('popular');
  });

  // Init Default
  setActiveFilter('popular');

</script>

<style>
  .animate-fade-in { animation: fadeIn 0.8s ease-out forwards; }
  .animate-fade-in-up { animation: fadeInUp 0.4s ease-out forwards; }

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  /* Custom Scrollbar Cantik untuk Tabs */
  .custom-scrollbar::-webkit-scrollbar {
    height: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: #cbd5e1;
    border-radius: 20px;
  }
  .dark .custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: #334155;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background-color: #94a3b8;
  }
</style>