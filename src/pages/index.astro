---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';

// --- 1. DATA KATEGORI ---
const categories = [
  { id: "popular", name: "🔥 Favorit", nameKey: "index.popular" },
  { id: "all", name: "📚 Semua", nameKey: "index.all" },
  { id: "pdf", name: "📄 PDF", nameKey: "index.pdf" },
  { id: "image", name: "🖼️ Image", nameKey: "index.image" },
  { id: "dev", name: "💻 Dev", nameKey: "index.dev" },
  { id: "security", name: "🔒 Security", nameKey: "index.security" },
  { id: "calc", name: "🧮 Calc", nameKey: "index.calc" },
  { id: "utils", name: "⚡ Utils", nameKey: "index.utils" },
  { id: "file", name: "📂 File", nameKey: "index.file" }
];

// --- 2. DATA TOOLS ---
const allTools = [
  // --- SPECIAL FEATURED ---
  { cat: "pdf", popular: true, titleKey: "tool.pdf_mas_aul", title: "PDF Mas Aul", descKey: "tool.pdf_mas_aul_desc", desc: "Satu tempat untuk semua kebutuhan PDF.", href: "/pdf", color: "rose", icon: '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="M9 15h6"/>' },

  // --- IMAGE TOOLS ---
  { cat: "image", popular: true, titleKey: "tool.studio_editor", title: "Studio Editor", descKey: "tool.studio_editor_desc", desc: "Edit foto, filter, crop, & grading.", href: "/image/editor", color: "pink", icon: '<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>' },
  { cat: "image", popular: true, titleKey: "tool.image_compressor", title: "Image Compressor", descKey: "tool.image_compressor_desc", desc: "Kecilkan ukuran gambar.", href: "/image/compressor", color: "emerald", icon: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><polyline points="11 3 11 11 14 8 17 11 17 3"/><path d="m21 15-5-5L5 21"/>' },
  { cat: "image", popular: false, titleKey: "tool.image_converter", title: "Image Converter", descKey: "tool.image_converter_desc", desc: "Ubah format PNG/JPG/WEBP.", href: "/image/converter", color: "sky", icon: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>' },
  { cat: "image", popular: false, titleKey: "tool.color_picker", title: "Color Picker", descKey: "tool.color_picker_desc", desc: "Ambil warna dari gambar.", href: "/image/color", color: "pink", icon: '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>' },
  { cat: "image", popular: false, titleKey: "tool.html_to_image", title: "HTML to Image", descKey: "tool.html_to_image_desc", desc: "Convert kode HTML jadi gambar.", href: "/image/html-to-img", color: "pink", icon: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><polyline points="11 3 11 11 14 8 17 11 17 3"/>' },

  // --- PDF TOOLS ---
  { cat: "pdf", popular: false, titleKey: "tool.merge_pdf", title: "Merge PDF", descKey: "tool.merge_pdf_desc", desc: "Gabungkan banyak file PDF.", href: "/pdf/merge", color: "rose", icon: '<path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>' },
  { cat: "pdf", popular: false, titleKey: "tool.compress_pdf", title: "Compress PDF", descKey: "tool.compress_pdf_desc", desc: "Kecilkan ukuran file PDF.", href: "/pdf/compress", color: "emerald", icon: '<path d="M4 14l6 6 6-6"/><path d="M12 20v-9"/><path d="M20 10c0-4.418-3.582-8-8-8s-8 3.582-8 8"/>' },
  { cat: "pdf", popular: false, titleKey: "tool.pdf_to_jpg", title: "PDF to JPG", descKey: "tool.pdf_to_jpg_desc", desc: "Ubah halaman PDF jadi gambar.", href: "/pdf/to-jpg", color: "yellow", icon: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>' },
  { cat: "pdf", popular: false, titleKey: "tool.watermark", title: "Watermark", descKey: "tool.watermark_desc", desc: "Tambah cap air di dokumen.", href: "/pdf/watermark", color: "cyan", icon: '<path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/><path d="M9 12l2 2l4 -4"/>' },
  
  // --- PRODUCTIVITY TOOLS ---
  { cat: "utils", popular: true, titleKey: "tool.wa_link_builder", title: "WA Link Builder", descKey: "tool.wa_link_builder_desc", desc: "Buat link WA dengan style.", href: "/utils/wa-builder", color: "emerald", icon: '<path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"/><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/><path d="M21 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { cat: "utils", popular: true, titleKey: "tool.qr_generator", title: "QR Generator", descKey: "tool.qr_generator_desc", desc: "Buat QR code instan.", href: "/utils/qr", color: "indigo", icon: '<rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect>' },
  { cat: "utils", popular: true, titleKey: "tool.dev_jokes", title: "Dev Jokes", descKey: "tool.dev_jokes_desc", desc: "Pembangkit mood coding.", href: "/utils/jokes", color: "cyan", icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M8 11h.01"/><path d="M16 11h.01"/><path d="M9 16c1.5 1.5 4.5 1.5 6 0"/>' },
  { cat: "utils", popular: false, titleKey: "tool.brainstorm_facts", title: "Brainstorm Facts", descKey: "tool.brainstorm_facts_desc", desc: "Generator ide & fakta.", href: "/utils/brainstorm", color: "amber", icon: '<path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548 5.478A1 1 0 0 1 14.458 22H9.542a1 1 0 0 1-.995-.91l-.548-5.478z"/>' },
  { cat: "utils", popular: false, titleKey: "tool.pomodoro_timer", title: "Pomodoro Timer", descKey: "tool.pomodoro_timer_desc", desc: "Timer fokus kerja.", href: "/utils/pomodoro", color: "rose", icon: '<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>' },
  { cat: "utils", popular: false, titleKey: "tool.todo_list", title: "Todo List", descKey: "tool.todo_list_desc", desc: "Catatan tugas simpel.", href: "/utils/todo", color: "violet", icon: '<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>' },
  { cat: "utils", popular: false, titleKey: "tool.word_counter", title: "Word Counter", descKey: "tool.word_counter_desc", desc: "Hitung kata & karakter.", href: "/utils/word-counter", color: "pink", icon: '<path d="M4 7V4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v3"/><path d="M4 12h16"/><path d="M4 17h16"/><path d="M4 22h12"/>' },
  { cat: "utils", popular: false, titleKey: "tool.stopwatch", title: "Stopwatch", descKey: "tool.stopwatch_desc", desc: "Penghitung waktu.", href: "/utils/stopwatch", color: "cyan", icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>' },

  // --- DEVELOPER TOOLS ---
  { cat: "dev", popular: true, titleKey: "tool.my_ip", title: "My IP Address", descKey: "tool.my_ip_desc", desc: "Cek IP Public & ISP.", href: "/dev/my-ip", color: "blue", icon: '<circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>' },
  { cat: "dev", popular: false, titleKey: "tool.json_formatter", title: "JSON Formatter", descKey: "tool.json_formatter_desc", desc: "Rapikan kode JSON.", href: "/dev/json", color: "amber", icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M10 12a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1"/><path d="M14 12a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1"/>' },
  { cat: "dev", popular: false, titleKey: "tool.cors_proxy", title: "CORS Proxy", descKey: "tool.cors_proxy_desc", desc: "Bypass CORS browser.", href: "/dev/proxy", color: "violet", icon: '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>' },
  { cat: "dev", popular: false, titleKey: "tool.base64_tool", title: "Base64 Tool", descKey: "tool.base64_tool_desc", desc: "Encode/decode Base64.", href: "/dev/base64", color: "orange", icon: '<polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/>' },
  { cat: "dev", popular: false, titleKey: "tool.cron_generator", title: "Cron Generator", descKey: "tool.cron_generator_desc", desc: "Buat jadwal Cron Job.", href: "/dev/cron", color: "orange", icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>' },
  { cat: "dev", popular: false, titleKey: "tool.url_encoder", title: "URL Encoder", descKey: "tool.url_encoder_desc", desc: "Encode parameter URL.", href: "/dev/url", color: "teal", icon: '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>' },
  { cat: "dev", popular: false, titleKey: "tool.markdown_editor", title: "Markdown Editor", descKey: "tool.markdown_editor_desc", desc: "Tulis & preview MD.", href: "/dev/markdown", color: "gray", icon: '<path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/>' },
  { cat: "dev", popular: false, titleKey: "tool.diff_checker", title: "Diff Checker", descKey: "tool.diff_checker_desc", desc: "Bandingkan dua teks.", href: "/dev/diff", color: "orange", icon: '<path d="M16 3h5v5"/><path d="M4 20L21 3"/><path d="M21 16v5h-5"/><path d="M15 15l5 5"/><path d="M4 4l5 5"/>' },
  { cat: "dev", popular: false, titleKey: "tool.timestamp_conv", title: "Timestamp Conv.", descKey: "tool.timestamp_conv_desc", desc: "Unix timestamp ke tanggal.", href: "/dev/timestamp", color: "violet", icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>' },
  { cat: "dev", popular: false, titleKey: "tool.css_shadow", title: "CSS Shadow", descKey: "tool.css_shadow_desc", desc: "Generator box-shadow.", href: "/dev/css-shadow", color: "pink", icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M22 22 2 2"/>' },
  
  // --- CALCULATOR TOOLS ---
  { cat: "calc", popular: true, titleKey: "tool.currency_calc", title: "Currency Calc", descKey: "tool.currency_calc_desc", desc: "Kurs mata uang live.", href: "/calc/currency", color: "emerald", icon: '<path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>' },
  { cat: "calc", popular: true, titleKey: "tool.age_calculator", title: "Age Calculator", descKey: "tool.age_calculator_desc", desc: "Hitung umur detail.", href: "/calc/age", color: "blue", icon: '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>' },
  { cat: "calc", popular: true, titleKey: "tool.bmi_calculator", title: "BMI Calculator", descKey: "tool.bmi_calculator_desc", desc: "Cek berat badan ideal.", href: "/calc/bmi", color: "teal", icon: '<path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><line x1="17.5" y1="15" x2="9" y2="15"/>' },
  { cat: "calc", popular: false, titleKey: "tool.unit_converter", title: "Unit Converter", descKey: "tool.unit_converter_desc", desc: "Konversi satuan.", href: "/calc/unit", color: "lime", icon: '<path d="M21 6H3"/><path d="M10 12H3"/><path d="M10 18H3"/><path d="M14 6v14"/><path d="M8 6v14"/>' },
  { cat: "calc", popular: false, titleKey: "tool.number_base", title: "Number Base", descKey: "tool.number_base_desc", desc: "Bin/Oct/Dec/Hex.", href: "/calc/number", color: "cyan", icon: '<path d="M4 10h12"/><path d="M4 14h9"/><path d="M19 6a3 3 0 0 1 0 6h-4a3 3 0 0 1 0-6h4Z"/><path d="M19 18a3 3 0 0 1 0-6h-4a3 3 0 0 1 0 6h4Z"/>' },
  
  // --- FILE & SECURITY ---
  { cat: "file", popular: false, titleKey: "tool.csv_to_json", title: "CSV to JSON", descKey: "tool.csv_to_json_desc", desc: "Ubah CSV/Excel ke JSON.", href: "/file/csv-json", color: "blue", icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="m10 13 2 2 2-2"/><path d="M12 18v-5"/>' },
  { cat: "file", popular: true, titleKey: "tool.pdf_to_markdown", title: "PDF to Markdown", descKey: "tool.pdf_to_markdown_desc", desc: "Ekstrak teks PDF jadi Markdown.", href: "/file/pdf-to-md", color: "orange", icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M9 15h6"/><path d="M12 18V12"/>' },
  { cat: "security", popular: true, titleKey: "tool.password_gen", title: "Password Gen", descKey: "tool.password_gen_desc", desc: "Buat password kuat.", href: "/security/password", color: "emerald", icon: '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>' },
  { cat: "security", popular: false, titleKey: "tool.hash_generator", title: "Hash Generator", descKey: "tool.hash_generator_desc", desc: "MD5, SHA-1, SHA-256.", href: "/security/hash", color: "blue", icon: '<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>' },
  { cat: "security", popular: false, titleKey: "tool.uuid_generator", title: "UUID Generator", descKey: "tool.uuid_generator_desc", desc: "Buat Unique ID.", href: "/security/uuid", color: "purple", icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 7h10"/><path d="M7 12h10"/><path d="M7 17h10"/>' },
];
---

<BaseLayout pageTitle="Dashboard">

  <div class="fixed top-0 left-0 w-full h-full overflow-hidden -z-10 pointer-events-none">
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-indigo-500/10 rounded-full blur-[100px] animate-pulse-slow"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-cyan-500/10 rounded-full blur-[100px] animate-pulse-slow animation-delay-2000"></div>
    <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-[0.03] dark:opacity-[0.05]"></div>
  </div>

  <section class="text-center pt-16 pb-12 px-4 animate-fade-in-down">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 text-xs font-bold uppercase tracking-wider mb-6 border border-indigo-100 dark:border-indigo-800" data-i18n="index.badge">
      🚀 Productivity Booster
    </div>
    
    <h1 class="text-4xl md:text-6xl font-extrabold mb-6 text-slate-900 dark:text-white tracking-tight leading-tight">
      My <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-cyan-500">Toolbox</span>
    </h1>
    
    <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed mb-8">
      <span data-i18n="index.subtitle_start">Koleksi</span> {allTools.length}+ <span data-i18n="index.subtitle_end">tools ringan untuk kebutuhan harian. Semuanya berjalan di browser,</span> <span class="font-semibold text-slate-800 dark:text-slate-200" data-i18n="index.subtitle_safe">tanpa install, data aman.</span>
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
       <button id="explore-btn" class="px-6 py-2.5 bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-bold rounded-full shadow-lg hover:scale-105 transition-transform" data-i18n="index.explore">
         Jelajahi Tools
       </button>
       <button id="random-tool-btn" class="px-6 py-2.5 bg-white dark:bg-slate-800/50 text-slate-700 dark:text-white font-semibold rounded-full border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors flex items-center justify-center gap-2" data-i18n="index.random">
         <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
         Random Tool
       </button>
    </div>
  </section>

  <section id="recent-section" class="max-w-7xl mx-auto px-4 mb-10 hidden">
    <div class="bg-white/60 dark:bg-slate-900/60 backdrop-blur-md rounded-2xl shadow-sm border border-slate-200/60 dark:border-slate-800/60 p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span data-i18n="index.recent_title">Baru Digunakan</span>
        </h2>
        <button id="clear-recent" class="text-xs text-rose-500 hover:text-rose-600 font-medium transition-colors" data-i18n="index.clear_recent">Hapus Riwayat</button>
      </div>
      <div id="recent-tools" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-3">
         </div>
    </div>
  </section>

  <div class="sticky top-0 z-40 w-full backdrop-blur-xl bg-white/70 dark:bg-slate-950/70 border-b border-slate-200/50 dark:border-slate-800/50 transition-all duration-300 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col md:flex-row gap-4 items-center justify-between">
        
       <div class="hidden md:flex flex-1 min-w-0 w-full relative group">
          <div class="absolute left-0 top-0 bottom-0 w-8 bg-gradient-to-r from-white dark:from-slate-950 to-transparent z-10 pointer-events-none"></div>
          <div class="absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-white dark:from-slate-950 to-transparent z-10 pointer-events-none"></div>

          <div class="flex gap-2 overflow-x-auto py-2 px-6 custom-scrollbar scroll-smooth" id="desktop-filters">
             {categories.map((cat, index) => (
                <button 
                   class={`filter-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 whitespace-nowrap border shrink-0
                   ${index === 0 
                       ? 'bg-slate-900 text-white dark:bg-white dark:text-slate-900 border-transparent shadow-md' 
                       : 'bg-transparent text-slate-600 dark:text-slate-400 border-transparent hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white'}`} 
                   data-filter={cat.id}
                   data-i18n={cat.nameKey}
                >
                   {cat.name}
                </button>
             ))}
          </div>
       </div>

       <div class="md:hidden w-full relative">
          <select id="mobile-filter" class="appearance-none w-full py-3 px-4 pr-10 rounded-xl bg-slate-100 dark:bg-slate-900 border-none text-slate-800 dark:text-white font-semibold outline-none focus:ring-2 focus:ring-indigo-500 transition-all">
             {categories.map(cat => (
                <option value={cat.id} data-i18n={`index.${cat.id}`}>{cat.name}</option>
             ))}
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-500">
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
          </div>
       </div>

       <div class="flex gap-2 w-full md:w-auto shrink-0">
           <div class="relative shrink-0">
               <select id="sort-select" class="appearance-none h-full pl-3 pr-8 py-2.5 rounded-full bg-slate-100 dark:bg-slate-800/50 border-transparent text-sm font-medium text-slate-600 dark:text-slate-300 outline-none focus:ring-2 focus:ring-indigo-500 cursor-pointer">
                   <option value="popular" data-i18n="index.sort_popular">Populer</option>
                   <option value="name" data-i18n="index.sort_az">A-Z</option>
               </select>
               <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-slate-500">
                   <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
               </div>
           </div>

           <div class="relative w-full md:w-64 group">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-4 w-4 text-slate-400 group-focus-within:text-indigo-500 transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
              </div>
              <input 
                type="text" 
                id="search-input" 
                placeholder="Cari tools..." data-i18n-attr="placeholder" data-i18n="search.placeholder"
                class="w-full pl-9 pr-12 py-2.5 rounded-full bg-slate-100 dark:bg-slate-800/50 border-transparent focus:bg-white dark:focus:bg-slate-900 border focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none text-sm transition-all text-slate-800 dark:text-white placeholder:text-slate-400" 
              />
              <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                 <kbd class="hidden md:inline-flex items-center h-5 px-1.5 border border-slate-300 dark:border-slate-600 rounded bg-slate-200 dark:bg-slate-700 font-sans text-[10px] font-medium text-slate-500 dark:text-slate-400">Ctrl K</kbd>
              </div>
           </div>
       </div>

    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-8 pb-32 min-h-[60vh]">
    <div class="flex justify-between items-end mb-6 px-1">
        <h2 id="results-count" class="text-xl font-bold text-slate-800 dark:text-white" data-i18n="index.favorites">Favorit Saya</h2>
    </div>

    <div id="tools-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
       {allTools.map((tool) => (
          <div 
            class="tool-item h-full" 
            data-cat={tool.cat} 
            data-popular={tool.popular ? "true" : "false"} 
            data-title={tool.title.toLowerCase()}
            data-name={tool.titleKey || tool.title}
            data-color={tool.color}
            data-icon={tool.icon}
          >
             <ToolCard 
                title={tool.title}
                desc={tool.desc}
                href={tool.href}
                icon={tool.icon}
                color={tool.color}
                titleKey={tool.titleKey}
                descKey={tool.descKey}
             />
          </div>
       ))}
    </div>

    <div id="empty-state" class="hidden flex flex-col items-center justify-center py-20 text-center animate-fade-in">
       <div class="w-20 h-20 bg-slate-100 dark:bg-slate-800 rounded-full flex items-center justify-center mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-slate-400"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg>
       </div>
       <h3 class="text-lg font-bold text-slate-800 dark:text-white mb-2" data-i18n="index.empty_title">Tidak ditemukan</h3>
       <p class="text-slate-500 text-sm max-w-xs mx-auto mb-6" data-i18n="index.empty_desc">Coba kata kunci lain atau reset filter.</p>
       <button id="reset-search" class="px-5 py-2 bg-slate-900 dark:bg-white text-white dark:text-slate-900 rounded-full text-sm font-bold hover:scale-105 transition-transform" data-i18n="index.reset">
         Reset Filter
       </button>
    </div>
  </div>

</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const mobileFilter = document.getElementById('mobile-filter');
      const searchInput = document.getElementById('search-input');
      const sortSelect = document.getElementById('sort-select');
      const tools = document.querySelectorAll('.tool-item');
      const emptyState = document.getElementById('empty-state');
      const resetSearchBtn = document.getElementById('reset-search');
      const resultsCountTitle = document.getElementById('results-count');
      const recentSection = document.getElementById('recent-section');
      const recentToolsContainer = document.getElementById('recent-tools');
      const clearRecentBtn = document.getElementById('clear-recent');
      const exploreBtn = document.getElementById('explore-btn');
      const randomToolBtn = document.getElementById('random-tool-btn');
      const toolsGrid = document.getElementById('tools-grid');

      const urlParams = new URLSearchParams(window.location.search);
      let currentFilter = urlParams.get('cat') || 'popular'; 
      let currentSearch = '';
      let currentSort = 'popular';

      function getRecentTools() {
        try {
            const recent = localStorage.getItem('recentTools');
            return recent ? JSON.parse(recent) : [];
        } catch(e) { return []; }
      }

      function updateRecentDisplay() {
        const recent = getRecentTools();
        if (!recentSection || !recentToolsContainer) return;

        if (recent.length === 0) {
            recentSection.classList.add('hidden');
            return;
        }

        recentSection.classList.remove('hidden');
        recentToolsContainer.innerHTML = recent.map(item => {
            let color = item.color || 'indigo';
            let icon = item.icon || '';
            
            if (!icon) {
                const toolEl = Array.from(tools).find(t => t.querySelector('a')?.getAttribute('href')?.split('?')[0] === item.href);
                if(toolEl) {
                    color = toolEl.getAttribute('data-color') || 'indigo';
                    icon = toolEl.getAttribute('data-icon') || '';
                }
            }

            return `
            <a href="${item.href}" class="group flex flex-col items-center justify-center p-3 rounded-xl bg-slate-50 dark:bg-slate-800/50 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 border border-transparent hover:border-indigo-100 dark:hover:border-indigo-800 transition-all">
                <div class="w-8 h-8 mb-2 rounded-lg bg-${color}-100 dark:bg-${color}-900/30 text-${color}-600 dark:text-${color}-400 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${icon}</svg>
                </div>
                <span class="text-[10px] font-bold text-slate-600 dark:text-slate-300 text-center leading-tight line-clamp-2">${item.title}</span>
            </a>
            `;
        }).join('');
      }

      function saveToRecent(href, title, color, icon) {
         let recent = getRecentTools();
         recent = recent.filter(t => t.href !== href);
         recent.unshift({ href, title, color, icon });
         recent = recent.slice(0, 6);
         localStorage.setItem('recentTools', JSON.stringify(recent));
         updateRecentDisplay();
      }

      tools.forEach(tool => {
         const link = tool.querySelector('a');
         if(link) {
            link.addEventListener('click', () => {
                const href = link.getAttribute('href')?.split('?')[0]; 
                const title = tool.getAttribute('data-name');
                const color = tool.getAttribute('data-color');
                const icon = tool.getAttribute('data-icon');
                if(href && title) saveToRecent(href, title, color, icon);
            });
         }
      });

      clearRecentBtn?.addEventListener('click', () => {
         localStorage.removeItem('recentTools');
         updateRecentDisplay();
      });

      const updateLinkParams = (activeCat) => {
         const cat = activeCat === 'popular' ? '' : activeCat;
         tools.forEach(tool => {
            const link = tool.querySelector('a');
            if(link) {
               const url = new URL(link.href, window.location.origin);
               if(cat) url.searchParams.set('from_cat', cat);
               else url.searchParams.delete('from_cat');
               link.href = url.toString();
            }
         });
      };

      function renderTools() {
        const toolsArray = Array.from(tools);
        let visibleCount = 0;

        if(currentSort === 'name') {
            toolsArray.sort((a, b) => {
                const nameA = a.getAttribute('data-name') || '';
                const nameB = b.getAttribute('data-name') || '';
                return nameA.localeCompare(nameB);
            });
        } else {
             toolsArray.sort((a, b) => {
                 const aPop = a.getAttribute('data-popular') === 'true' ? 1 : 0;
                 const bPop = b.getAttribute('data-popular') === 'true' ? 1 : 0;
                 const nameA = a.getAttribute('data-name') || '';
                 const nameB = b.getAttribute('data-name') || '';
                 return bPop - aPop || nameA.localeCompare(nameB);
             });
        }
        
        if(toolsGrid) {
            toolsGrid.innerHTML = '';
            toolsArray.forEach(el => toolsGrid.appendChild(el));
        }

        toolsArray.forEach((tool, index) => {
            const cat = tool.getAttribute('data-cat');
            const isPopular = tool.getAttribute('data-popular') === 'true'; 
            const title = tool.getAttribute('data-title') || '';
            
            let matchFilter = 
                currentFilter === 'all' || 
                (currentFilter === 'popular' && isPopular) || 
                (currentFilter !== 'popular' && currentFilter !== 'all' && cat === currentFilter);

            let matchSearch = title.includes(currentSearch);

            if (matchFilter && matchSearch) {
                tool.classList.remove('hidden');
                tool.classList.add('animate-fade-in-up');
                
                // Add tiny stagger delay
                tool.style.animationDelay = `${(index % 10) * 30}ms`;
                
                visibleCount++;
            } else {
                tool.classList.add('hidden');
                tool.classList.remove('animate-fade-in-up');
                tool.style.animationDelay = '0ms';
            }
        });

        if(resultsCountTitle) {
            if(currentSearch) {
            const resultsText = (window._tToast) ? window._tToast('Hasil') : 'Hasil';
            const toolsText = (window._tToast) ? window._tToast('Tools') : 'Tools';
            resultsCountTitle.textContent = resultsText + ': ' + visibleCount + ' ' + toolsText;
        }
            else {
                const activeBtn = Array.from(filterBtns).find(b => b.getAttribute('data-filter') === currentFilter);
                resultsCountTitle.textContent = activeBtn ? activeBtn.textContent.trim() : ((window._tToast) ? window._tToast('Tools') : 'Tools');
            }
        }

        if (visibleCount === 0) {
            emptyState?.classList.remove('hidden');
            toolsGrid?.classList.add('hidden');
        } else {
            emptyState?.classList.add('hidden');
            toolsGrid?.classList.remove('hidden');
        }
      }

      function setActiveFilter(filterId) {
        currentFilter = filterId;
        const newUrl = new URL(window.location.href);
        if (filterId === 'popular') newUrl.searchParams.delete('cat');
        else newUrl.searchParams.set('cat', filterId);
        window.history.replaceState({}, '', newUrl);

        filterBtns.forEach(btn => {
            if(btn.getAttribute('data-filter') === filterId) {
                btn.className = "filter-btn px-5 py-1.5 rounded-full text-sm font-bold bg-slate-900 text-white dark:bg-white dark:text-slate-900 shadow-md transform scale-105 border-transparent transition-all whitespace-nowrap shrink-0";
            } else {
                btn.className = "filter-btn px-5 py-1.5 rounded-full text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white border-transparent transition-all whitespace-nowrap shrink-0";
            }
        });

        if(mobileFilter) mobileFilter.value = filterId;
        renderTools();
        updateLinkParams(filterId);
      }

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-filter');
            if(id) setActiveFilter(id);
        });
      });

      mobileFilter?.addEventListener('change', (e) => {
        setActiveFilter(e.target.value);
      });

      searchInput?.addEventListener('input', (e) => {
        currentSearch = e.target.value.toLowerCase();
        if (currentSearch.length > 0 && currentFilter === 'popular') setActiveFilter('all');
        else renderTools();
      });

      sortSelect?.addEventListener('change', (e) => {
         currentSort = e.target.value;
         renderTools();
      });

      resetSearchBtn?.addEventListener('click', () => {
        if(searchInput) searchInput.value = '';
        currentSearch = '';
        setActiveFilter('popular');
      });

      exploreBtn?.addEventListener('click', () => {
         const grid = document.getElementById('tools-grid');
         grid?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });

      randomToolBtn?.addEventListener('click', () => {
         const visibleTools = Array.from(tools).filter(t => !t.classList.contains('hidden'));
         if(visibleTools.length > 0) {
             const random = visibleTools[Math.floor(Math.random() * visibleTools.length)];
             random.querySelector('a')?.click();
         }
      });

      document.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
          e.preventDefault();
          searchInput?.focus();
        }
        if (e.key === 'Escape' && currentSearch) {
             if(searchInput) searchInput.value = '';
             currentSearch = '';
             renderTools();
        }
      });

      updateRecentDisplay();
      setActiveFilter(currentFilter);
  });
</script>

<style>
  .animate-fade-in-down { animation: fadeInDown 0.6s ease-out forwards; }
  .animate-fade-in-up { animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .animate-pulse-slow { animation: pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
  
  @keyframes fadeInDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); scale: 0.95; } to { opacity: 1; transform: translateY(0); scale: 1; } }
  
  /* Scrollbar Tetap Ada & Cantik */
  .custom-scrollbar::-webkit-scrollbar {
    height: 4px;
    display: block;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: #cbd5e1;
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background-color: #94a3b8;
  }
  .custom-scrollbar {
     scrollbar-width: thin;
     scrollbar-color: #cbd5e1 transparent;
  }
</style>