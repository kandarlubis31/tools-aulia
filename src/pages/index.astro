---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';

// --- 1. DATA KATEGORI (Tetap) ---
const categories = [
  { id: "popular", name: "🔥 Favorit" }, // Nama dipendekkan biar rapi di mobile
  { id: "all", name: "📚 Semua" },
  { id: "pdf", name: "📄 PDF" },
  { id: "image", name: "🖼️ Image" },
  { id: "dev", name: "💻 Dev" },
  { id: "security", name: "🔒 Sec" },
  { id: "calc", name: "🧮 Calc" },
  { id: "utils", name: "⚡ Utils" },
  { id: "file", name: "📂 File" }
];

// --- 2. DATA TOOLS (Data Original Kamu) ---
const allTools = [
  // --- IMAGE TOOLS ---
  { cat: "image", popular: true, title: "Studio Editor", desc: "Edit foto, filter, crop, & color grading ala Snapseed.", href: "/image/editor", color: "pink", icon: '<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>' },
  { cat: "image", popular: true, title: "Image Compressor", desc: "Kecilkan ukuran gambar JPG/PNG/WEBP.", href: "/image/compressor", color: "emerald", icon: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><polyline points="11 3 11 11 14 8 17 11 17 3"/><path d="m21 15-5-5L5 21"/>' },
  { cat: "image", popular: false, title: "Image Converter", desc: "Ubah format gambar PNG/JPG/WEBP.", href: "/image/converter", color: "sky", icon: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>' },
  { cat: "image", popular: false, title: "Color Picker", desc: "Ambil kode warna dari gambar.", href: "/image/color", color: "pink", icon: '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>' },
  { cat: "image", popular: false, title: "HTML to Image", desc: "Convert kode HTML/CSS jadi gambar.", href: "/image/html-to-img", color: "pink", icon: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><polyline points="11 3 11 11 14 8 17 11 17 3"/>' },

  // --- PDF TOOLS ---
  { cat: "pdf", popular: true, title: "Merge PDF", desc: "Gabungkan banyak file PDF jadi satu.", href: "/pdf/merge", color: "rose", icon: '<path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>' },
  { cat: "pdf", popular: true, title: "Compress PDF", desc: "Kecilkan ukuran file PDF.", href: "/pdf/compress", color: "emerald", icon: '<path d="M4 14l6 6 6-6"/><path d="M12 20v-9"/><path d="M20 10c0-4.418-3.582-8-8-8s-8 3.582-8 8"/>' },
  { cat: "pdf", popular: false, title: "Split PDF", desc: "Pisah halaman PDF.", href: "/pdf/split", color: "orange", icon: '<line x1="12" y1="3" x2="12" y2="21"/><path d="M8 8l-4 4 4 4"/><path d="M16 8l4 4-4 4"/>' },
  { cat: "pdf", popular: false, title: "Rotate PDF", desc: "Putar orientasi halaman.", href: "/pdf/rotate", color: "blue", icon: '<path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/>' },
  { cat: "pdf", popular: false, title: "PDF to JPG", desc: "Ubah halaman PDF jadi gambar.", href: "/pdf/to-jpg", color: "yellow", icon: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>' },
  { cat: "pdf", popular: false, title: "JPG to PDF", desc: "Ubah gambar jadi PDF.", href: "/pdf/jpg-to-pdf", color: "yellow", icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/>' },
  { cat: "pdf", popular: false, title: "Watermark", desc: "Tambah cap air di dokumen.", href: "/pdf/watermark", color: "cyan", icon: '<path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/><path d="M9 12l2 2l4 -4"/>' },
  { cat: "pdf", popular: false, title: "Page Numbers", desc: "Tambah nomor halaman otomatis.", href: "/pdf/page-numbers", color: "slate", icon: '<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>' },
  { cat: "pdf", popular: false, title: "Sign PDF", desc: "Tanda tangan digital.", href: "/pdf/sign", color: "emerald", icon: '<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>' },
  { cat: "pdf", popular: false, title: "Delete Pages", desc: "Hapus halaman tertentu.", href: "/pdf/delete", color: "rose", icon: '<path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>' },
  { cat: "pdf", popular: false, title: "Reorder Pages", desc: "Atur ulang urutan halaman.", href: "/pdf/reorder", color: "indigo", icon: '<line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>' },
  { cat: "pdf", popular: false, title: "Extract Pages", desc: "Ambil halaman tertentu.", href: "/pdf/extract", color: "teal", icon: '<path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M16 22h2a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v4"/><path d="M14 22v-4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2Z"/>' },
  { cat: "pdf", popular: false, title: "HTML to PDF", desc: "Convert HTML ke PDF.", href: "/pdf/html-to-pdf", color: "purple", icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>' },
  { cat: "pdf", popular: false, title: "PDF to PPT", desc: "Convert PDF ke PowerPoint.", href: "/pdf/to-ppt", color: "orange", icon: '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><rect x="8" y="13" width="8" height="4"/>' },
  { cat: "pdf", popular: false, title: "Edit Metadata", desc: "Ubah Judul & Author PDF.", href: "/pdf/metadata", color: "pink", icon: '<circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>' },
  { cat: "pdf", popular: false, title: "Grayscale PDF", desc: "Ubah jadi hitam putih.", href: "/pdf/grayscale", color: "gray", icon: '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>' },

  // --- PRODUCTIVITY TOOLS ---
  { cat: "utils", popular: true, title: "WA Link Builder", desc: "Buat link WA dengan text style.", href: "/utils/wa-builder", color: "emerald", icon: '<path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"/><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/><path d="M21 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { cat: "utils", popular: true, title: "QR Generator", desc: "Buat QR code instan.", href: "/utils/qr", color: "indigo", icon: '<rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect>' },
  { cat: "utils", popular: true, title: "Dev Jokes", desc: "Pembangkit mood coding.", href: "/utils/jokes", color: "cyan", icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M8 11h.01"/><path d="M16 11h.01"/><path d="M9 16c1.5 1.5 4.5 1.5 6 0"/>' },
  { cat: "utils", popular: false, title: "Brainstorm & Facts", desc: "Generator ide & fakta.", href: "/utils/brainstorm", color: "amber", icon: '<path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548 5.478A1 1 0 0 1 14.458 22H9.542a1 1 0 0 1-.995-.91l-.548-5.478z"/>' },
  { cat: "utils", popular: false, title: "Pomodoro Timer", desc: "Timer fokus kerja.", href: "/utils/pomodoro", color: "rose", icon: '<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>' },
  { cat: "utils", popular: false, title: "Todo List", desc: "Catatan tugas simpel.", href: "/utils/todo", color: "violet", icon: '<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>' },
  { cat: "utils", popular: false, title: "Word Counter", desc: "Hitung kata & karakter.", href: "/utils/word-counter", color: "pink", icon: '<path d="M4 7V4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v3"/><path d="M4 12h16"/><path d="M4 17h16"/><path d="M4 22h12"/>' },
  { cat: "utils", popular: false, title: "Stopwatch", desc: "Penghitung waktu.", href: "/utils/stopwatch", color: "cyan", icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>' },
  { cat: "utils", popular: false, title: "Lorem Ipsum", desc: "Generate dummy text.", href: "/utils/lorem", color: "gray", icon: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/>' },

  // --- DEVELOPER TOOLS ---
  { cat: "dev", popular: true, title: "My IP Address", desc: "Cek IP Public & ISP.", href: "/dev/my-ip", color: "blue", icon: '<circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>' },
  { cat: "dev", popular: false, title: "JSON Formatter", desc: "Rapikan kode JSON.", href: "/dev/json", color: "amber", icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M10 12a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1"/><path d="M14 12a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1"/>' },
  { cat: "dev", popular: false, title: "CORS Proxy", desc: "Bypass CORS browser.", href: "/dev/proxy", color: "violet", icon: '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>' },
  { cat: "dev", popular: false, title: "Base64 Tool", desc: "Encode/decode Base64.", href: "/dev/base64", color: "orange", icon: '<polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/>' },
  { cat: "dev", popular: false, title: "Cron Generator", desc: "Buat jadwal Cron Job.", href: "/dev/cron", color: "orange", icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>' },
  { cat: "dev", popular: false, title: "URL Encoder", desc: "Encode parameter URL.", href: "/dev/url", color: "teal", icon: '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>' },
  { cat: "dev", popular: false, title: "Markdown Editor", desc: "Tulis & preview MD.", href: "/dev/markdown", color: "gray", icon: '<path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/>' },
  { cat: "dev", popular: false, title: "Diff Checker", desc: "Bandingkan dua teks.", href: "/dev/diff", color: "orange", icon: '<path d="M16 3h5v5"/><path d="M4 20L21 3"/><path d="M21 16v5h-5"/><path d="M15 15l5 5"/><path d="M4 4l5 5"/>' },
  { cat: "dev", popular: false, title: "Timestamp Conv.", desc: "Unix timestamp ke tanggal.", href: "/dev/timestamp", color: "violet", icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>' },
  { cat: "dev", popular: false, title: "CSS Shadow", desc: "Generator box-shadow.", href: "/dev/css-shadow", color: "pink", icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M22 22 2 2"/>' },
  
  // --- CALCULATOR TOOLS ---
  { cat: "calc", popular: true, title: "Currency Calc", desc: "Kurs mata uang live.", href: "/calc/currency", color: "emerald", icon: '<path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>' },
  { cat: "calc", popular: true, title: "Age Calculator", desc: "Hitung umur detail.", href: "/calc/age", color: "blue", icon: '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>' },
  { cat: "calc", popular: false, title: "BMI Calculator", desc: "Cek berat badan ideal.", href: "/calc/bmi", color: "teal", icon: '<path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><line x1="17.5" y1="15" x2="9" y2="15"/>' },
  { cat: "calc", popular: false, title: "Unit Converter", desc: "Konversi satuan.", href: "/calc/unit", color: "lime", icon: '<path d="M21 6H3"/><path d="M10 12H3"/><path d="M10 18H3"/><path d="M14 6v14"/><path d="M8 6v14"/>' },
  { cat: "calc", popular: false, title: "Number Base", desc: "Bin/Oct/Dec/Hex.", href: "/calc/number", color: "cyan", icon: '<path d="M4 10h12"/><path d="M4 14h9"/><path d="M19 6a3 3 0 0 1 0 6h-4a3 3 0 0 1 0-6h4Z"/><path d="M19 18a3 3 0 0 1 0-6h-4a3 3 0 0 1 0 6h4Z"/>' },
  { cat: "calc", popular: false, title: "Case Converter", desc: "Ubah format teks.", href: "/calc/case", color: "fuchsia", icon: '<path d="M4 7V4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v3"/><path d="M9 20h6"/><line x1="12" y1="4" x2="12" y2="20"/>' },
  { cat: "calc", popular: false, title: "Percentage Calc", desc: "Hitung persen & diskon.", href: "/calc/percentage", color: "indigo", icon: '<line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/>' },
  
  // --- FILE TOOLS ---
  { cat: "file", popular: false, title: "CSV to JSON", desc: "Ubah CSV/Excel ke JSON.", href: "/file/csv-json", color: "blue", icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="m10 13 2 2 2-2"/><path d="M12 18v-5"/>' },
  
  // --- SECURITY TOOLS ---
  { cat: "security", popular: true, title: "Password Gen", desc: "Buat password kuat.", href: "/security/password", color: "emerald", icon: '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>' },
  { cat: "security", popular: false, title: "Hash Generator", desc: "MD5, SHA-1, SHA-256.", href: "/security/hash", color: "blue", icon: '<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>' },
  { cat: "security", popular: false, title: "UUID Generator", desc: "Buat Unique ID.", href: "/security/uuid", color: "purple", icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 7h10"/><path d="M7 12h10"/><path d="M7 17h10"/>' },
];
---

<BaseLayout pageTitle="Dashboard">
  
  <div id="dashboard-loader" class="fixed inset-0 z-[100] bg-slate-50 dark:bg-slate-900 flex flex-col justify-center items-center transition-opacity duration-500">
    <div class="relative w-16 h-16 mb-4">
        <div class="absolute inset-0 rounded-full border-4 border-slate-200 dark:border-slate-800"></div>
        <div class="absolute inset-0 rounded-full border-4 border-t-rose-500 animate-spin"></div>
    </div>
    <p class="text-sm font-bold text-slate-500 animate-pulse">Menyiapkan Toolbox...</p>
  </div>

  <section class="relative pt-24 pb-16 overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-4xl bg-gradient-to-b from-rose-50/50 to-transparent dark:from-rose-900/10 pointer-events-none -z-10 rounded-full blur-3xl"></div>
    
    <div class="relative max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center justify-center p-3 mb-6 bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700">
        <div class="bg-gradient-to-br from-rose-500 to-orange-500 text-white p-2 rounded-lg">
           <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="M9 15h6"/></svg>
        </div>
      </div>
      
      <h1 class="text-4xl md:text-6xl font-extrabold mb-6 text-slate-900 dark:text-white tracking-tight leading-tight">
        My <span class="text-transparent bg-clip-text bg-gradient-to-r from-rose-600 to-orange-600">Toolbox</span>
      </h1>
      
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed mb-10">
        Koleksi tools web utility lengkap. Semuanya berjalan di browser (Client-Side), data kamu aman, dan 100% gratis.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button id="explore-btn" class="px-8 py-3.5 bg-rose-600 hover:bg-rose-700 text-white font-bold rounded-full shadow-lg shadow-rose-600/20 hover:shadow-xl transition-all duration-200 transform hover:-translate-y-1">
          Jelajahi Tools
        </button>
        <button id="random-tool-btn" class="px-8 py-3.5 bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-200 font-bold rounded-full shadow-sm hover:shadow-md border border-slate-200 dark:border-slate-700 transition-all duration-200 transform hover:-translate-y-1 flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-rose-500"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
          Tool Acak
        </button>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 mb-10">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-700 p-6">
      <div class="flex items-center justify-between mb-6 border-b border-slate-100 dark:border-slate-700 pb-4">
        <h2 class="text-lg font-bold text-slate-800 dark:text-white flex items-center gap-2">
          <span class="flex h-2 w-2 relative">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-rose-500"></span>
          </span>
          Terakhir Digunakan
        </h2>
        <button id="clear-recent" class="text-xs font-medium text-slate-400 hover:text-rose-600 dark:hover:text-rose-400 transition-colors">
          Hapus Riwayat
        </button>
      </div>
      
      <div id="recent-tools" class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
        <div class="col-span-full flex flex-col items-center justify-center py-8 text-slate-400 dark:text-slate-500 opacity-60">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          <p class="text-sm">Belum ada history</p>
        </div>
      </div>
    </div>
  </section>

  <div class="sticky top-0 z-40 bg-slate-50/80 dark:bg-slate-900/80 backdrop-blur-xl border-y border-slate-200 dark:border-slate-800 py-4 mb-10 transition-all shadow-sm">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row gap-4 items-center justify-between">
      
       <div class="hidden md:block flex-1 min-w-0 w-full overflow-hidden">
          <div class="flex gap-2 overflow-x-auto pb-1 custom-scrollbar" id="desktop-filters">
              {categories.map((cat, index) => (
                 <button 
                    class={`filter-btn flex items-center gap-2 px-4 py-2 rounded-full text-sm transition-all whitespace-nowrap border
                    ${index === 0 
                        ? 'bg-rose-600 text-white border-rose-600 shadow-md shadow-rose-600/20 font-bold active' 
                        : 'bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 border-slate-200 dark:border-slate-700 hover:border-rose-300 dark:hover:border-rose-700'}`} 
                    data-filter={cat.id}
                 >
                    {cat.name}
                 </button>
              ))}
          </div>
       </div>

       <div class="md:hidden w-full relative">
          <select id="mobile-filter" class="appearance-none cursor-pointer w-full p-3 pr-10 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-800 dark:text-white font-semibold outline-none focus:border-rose-500 focus:ring-1 focus:ring-rose-500 transition-all">
              {categories.map(cat => (
                 <option value={cat.id}>{cat.name}</option>
              ))}
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-500">
            <svg class="h-4 w-4 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
          </div>
       </div>

       <div class="relative w-full md:w-72 shrink-0 group">
          <input type="text" id="search-input" placeholder="Cari (tekan Ctrl + K)..." class="w-full pl-11 pr-4 py-2.5 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 focus:border-rose-500 focus:ring-1 focus:ring-rose-500 outline-none text-sm transition-all shadow-sm text-slate-800 dark:text-white" />
          <div class="absolute left-4 top-2.5 text-slate-400 group-focus-within:text-rose-500 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </div>
          <button id="clear-search" class="hidden absolute right-3 top-2.5 text-slate-400 hover:text-rose-500 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
       </div>

    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 pb-32">
    <div class="flex justify-between items-center mb-6 px-1">
      <h2 id="results-count" class="text-lg font-bold text-slate-800 dark:text-white">
        Menampilkan {allTools.filter(t => t.popular).length} tools
      </h2>
      <div class="flex items-center gap-2">
        <span class="text-sm text-slate-500 dark:text-slate-400 hidden sm:inline">Urutkan:</span>
        <select id="sort-select" class="text-sm bg-transparent border-none font-semibold text-rose-600 dark:text-rose-400 focus:ring-0 cursor-pointer">
          <option value="popular">🔥 Populer</option>
          <option value="name">🔤 Nama</option>
          <option value="recent">✨ Terbaru</option>
        </select>
      </div>
    </div>
    
    <div id="tools-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
       {allTools.map((tool) => (
          <div 
            class="tool-item hidden h-full transition-all duration-300" 
            data-cat={tool.cat} 
            data-popular={tool.popular ? "true" : "false"} 
            data-title={tool.title.toLowerCase()}
            data-name={tool.title}
            data-recent="0"
          >
             {/* Note: Props ToolCard diteruskan apa adanya */}
             <ToolCard 
                title={tool.title}
                desc={tool.desc}
                href={tool.href}
                icon={tool.icon}
                color={tool.color}
             />
          </div>
       ))}
    </div>

    <div id="empty-state" class="hidden flex-col items-center justify-center py-24 animate-fade-in">
       <div class="w-20 h-20 bg-slate-100 dark:bg-slate-800 rounded-full flex items-center justify-center mb-6 text-slate-300 dark:text-slate-600">
         <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M8 11h6"/></svg>
       </div>
       <h3 class="text-xl font-bold text-slate-800 dark:text-white">Tidak ada tools yang cocok</h3>
       <p class="text-slate-500 mt-2 mb-6">Coba kata kunci lain atau reset filter.</p>
       <button id="reset-search" class="px-6 py-2.5 bg-slate-900 dark:bg-white text-white dark:text-slate-900 rounded-full font-bold hover:shadow-lg transition-all transform hover:-translate-y-1">
         Reset Filter
       </button>
    </div>
    
    <div class="mt-20 border-t border-slate-200 dark:border-slate-800 pt-10 text-center">
      <p class="text-slate-500 dark:text-slate-400 mb-4">Butuh tools custom? Atau nemu bug?</p>
      <div class="flex justify-center gap-4">
        <a href="https://github.com/kandarlubis31" target="_blank" class="text-slate-400 hover:text-rose-600 transition-colors">
          <span class="sr-only">GitHub</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
        </a>
        <a href="https://paklubis.my.id" target="_blank" class="text-slate-400 hover:text-rose-600 transition-colors">
          <span class="sr-only">Website</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </a>
      </div>
    </div>
  </div>

</BaseLayout>

<script>
  // LOGIC TETAP SAMA, HANYA UPDATE CLASS NAME AGAR SESUAI TEMA BARU (ROSE)
  document.addEventListener('astro:page-load', () => {
      
      const dashboardLoader = document.getElementById('dashboard-loader');
      const filterBtns = document.querySelectorAll('.filter-btn');
      const mobileFilter = document.getElementById('mobile-filter');
      const searchInput = document.getElementById('search-input');
      const clearSearchBtn = document.getElementById('clear-search');
      const sortSelect = document.getElementById('sort-select');
      const tools = document.querySelectorAll('.tool-item');
      const emptyState = document.getElementById('empty-state');
      const resetSearchBtn = document.getElementById('reset-search');
      const resultsCount = document.getElementById('results-count');
      const recentTools = document.getElementById('recent-tools');
      const clearRecentBtn = document.getElementById('clear-recent');
      const exploreBtn = document.getElementById('explore-btn');
      const randomToolBtn = document.getElementById('random-tool-btn');

      const urlParams = new URLSearchParams(window.location.search);
      const categoryParam = urlParams.get('cat');
      
      let currentFilter = categoryParam || 'popular'; 
      let currentSearch = '';
      let currentSort = 'popular';

      function getRecentTools() {
        const recent = localStorage.getItem('recentTools');
        return recent ? JSON.parse(recent) : [];
      }

      function saveToRecent(toolHref) {
        let recent = getRecentTools();
        recent = recent.filter(t => t.href !== toolHref);
        const tool = Array.from(tools).find(t => t.querySelector('a')?.href === toolHref);
        if (tool) {
          // @ts-ignore
          const title = tool.dataset.name;
          recent.unshift({ href: toolHref, title, timestamp: Date.now() });
          recent = recent.slice(0, 6);
          localStorage.setItem('recentTools', JSON.stringify(recent));
          updateRecentTools();
        }
      }

      function updateRecentTools() {
        const recent = getRecentTools();
        if(!recentTools) return;

        if (recent.length === 0) {
          recentTools.innerHTML = `
            <div class="col-span-full flex flex-col items-center justify-center py-8 text-slate-400 dark:text-slate-500 opacity-60">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              <p class="text-sm">Belum ada history</p>
            </div>
          `;
          return;
        }

        recentTools.innerHTML = recent.map(tool => {
          const toolData = Array.from(tools).find(t => t.querySelector('a')?.href === tool.href);
          if (!toolData) return '';
          
          const card = toolData.querySelector('a'); 
          // Extract icon logic
          // @ts-ignore
          const color = card.querySelector('div').className.match(/bg-(\w+)-100/)?.[1] || 'blue';
          // @ts-ignore
          const icon = card.querySelector('svg')?.innerHTML || '';
          
          // Style Updated for Recent Items
          return `
            <a href="${tool.href}" class="group flex flex-col items-center p-3 rounded-xl bg-slate-50 dark:bg-slate-700/30 hover:bg-slate-100 dark:hover:bg-slate-700 border border-transparent hover:border-slate-200 dark:hover:border-slate-600 transition-all">
              <div class="w-10 h-10 bg-${color}-100 dark:bg-${color}-900/30 text-${color}-600 dark:text-${color}-400 rounded-lg flex items-center justify-center mb-2 group-hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${icon}</svg>
              </div>
              <span class="text-xs text-slate-600 dark:text-slate-300 text-center truncate w-full font-medium group-hover:text-rose-600 dark:group-hover:text-rose-400 transition-colors">${tool.title}</span>
            </a>
          `;
        }).join('');
      }

      const updateLinkParams = (activeCat) => {
         const cat = activeCat === 'popular' ? '' : activeCat;
         tools.forEach(tool => {
            const link = tool.querySelector('a');
            if(link) {
               const url = new URL(link.href, window.location.origin);
               if(cat) url.searchParams.set('from_cat', cat);
               else url.searchParams.delete('from_cat');
               link.href = url.toString();
               link.removeEventListener('click', handleToolClick);
               link.addEventListener('click', handleToolClick);
            }
         });
      };

      function handleToolClick(e) {
         // @ts-ignore
         const href = e.currentTarget.href;
         const url = new URL(href);
         const cleanHref = url.pathname;
         saveToRecent(cleanHref);
      }

      function sortTools(sortBy) {
        const toolsArray = Array.from(tools);
        switch(sortBy) {
          case 'name':
            // @ts-ignore
            toolsArray.sort((a, b) => a.dataset.name.localeCompare(b.dataset.name));
            break;
          case 'recent':
            // @ts-ignore
            toolsArray.sort((a, b) => b.dataset.popular.localeCompare(a.dataset.popular)); 
            break;
          case 'popular':
          default:
            toolsArray.sort((a, b) => {
              // @ts-ignore
              const aPopular = a.dataset.popular === 'true' ? 1 : 0;
              // @ts-ignore
              const bPopular = b.dataset.popular === 'true' ? 1 : 0;
              return bPopular - aPopular;
            });
            break;
        }
        
        const container = document.getElementById('tools-grid');
        if(container) {
            container.innerHTML = '';
            toolsArray.forEach(tool => container.appendChild(tool));
        }
      }

      function filterTools() {
        let visibleCount = 0;

        tools.forEach(tool => {
            // @ts-ignore
            const cat = tool.dataset.cat;
            // @ts-ignore
            const isPopular = tool.dataset.popular === 'true'; 
            // @ts-ignore
            const title = tool.dataset.title;
            
            let matchFilter = 
                currentFilter === 'all' || 
                (currentFilter === 'popular' && isPopular) || 
                (currentFilter !== 'popular' && currentFilter !== 'all' && cat === currentFilter);

            let matchSearch = title.includes(currentSearch);

            if (matchFilter && matchSearch) {
                tool.classList.remove('hidden');
                tool.classList.add('animate-fade-in-up');
                visibleCount++;
            } else {
                tool.classList.add('hidden');
                tool.classList.remove('animate-fade-in-up');
            }
        });

        if(resultsCount) resultsCount.textContent = `Menampilkan ${visibleCount} tools`;

        if (visibleCount === 0) {
            emptyState?.classList.remove('hidden');
            emptyState?.classList.add('flex'); // Add flex for centering
        } else {
            emptyState?.classList.add('hidden');
            emptyState?.classList.remove('flex');
        }
      }

      function setActiveFilter(filterId) {
        currentFilter = filterId;
        
        const newUrl = new URL(window.location.href);
        if (filterId === 'popular') newUrl.searchParams.delete('cat');
        else newUrl.searchParams.set('cat', filterId);
        window.history.replaceState({}, '', newUrl);

        filterBtns.forEach(btn => {
            // @ts-ignore
            if(btn.dataset.filter === filterId) {
                // ACTIVE STATE (Updated to Rose Theme)
                btn.className = "filter-btn active flex items-center gap-2 px-4 py-2 rounded-full text-sm font-bold bg-rose-600 text-white shadow-md shadow-rose-600/20 scale-105 border border-rose-600 transition-all whitespace-nowrap";
            } else {
                // INACTIVE STATE
                btn.className = "filter-btn flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-700 hover:border-rose-300 dark:hover:border-rose-700 transition-all whitespace-nowrap";
            }
        });

        if(mobileFilter) (mobileFilter as HTMLSelectElement).value = filterId;

        filterTools();
        updateLinkParams(filterId);
      }

      // --- EVENTS ---
      filterBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            // @ts-ignore
            setActiveFilter(btn.dataset.filter);
        });
      });

      mobileFilter?.addEventListener('change', (e) => {
        // @ts-ignore
        setActiveFilter(e.target.value);
      });

      searchInput?.addEventListener('input', (e) => {
        // @ts-ignore
        currentSearch = e.target.value.toLowerCase();
        
        if (currentSearch.length > 0) {
          clearSearchBtn?.classList.remove('hidden');
        } else {
          clearSearchBtn?.classList.add('hidden');
        }
        
        if (currentSearch.length > 0 && currentFilter === 'popular') {
            setActiveFilter('all');
        } else {
            filterTools();
        }
      });

      clearSearchBtn?.addEventListener('click', () => {
        if(searchInput) (searchInput as HTMLInputElement).value = '';
        currentSearch = '';
        clearSearchBtn?.classList.add('hidden');
        filterTools();
      });

      sortSelect?.addEventListener('change', (e) => {
        // @ts-ignore
        currentSort = e.target.value;
        sortTools(currentSort);
      });

      resetSearchBtn?.addEventListener('click', () => {
        if(searchInput) (searchInput as HTMLInputElement).value = '';
        currentSearch = '';
        clearSearchBtn?.classList.add('hidden');
        setActiveFilter('popular');
      });

      clearRecentBtn?.addEventListener('click', () => {
        localStorage.removeItem('recentTools');
        updateRecentTools();
      });

      exploreBtn?.addEventListener('click', () => {
        document.getElementById('tools-grid')?.scrollIntoView({ behavior: 'smooth' });
      });

      randomToolBtn?.addEventListener('click', () => {
        // Only select from currently visible tools if filtered, or all if preferred
        // Let's use allTools to be safe
        const randomIndex = Math.floor(Math.random() * tools.length);
        const randomTool = tools[randomIndex];
        const link = randomTool.querySelector('a');
        if (link) {
          link.click();
        }
      });

      document.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
          e.preventDefault();
          searchInput?.focus();
        }
        if (e.key === 'Escape' && searchInput?.value) {
          // @ts-ignore
          searchInput.value = '';
          currentSearch = '';
          clearSearchBtn?.classList.add('hidden');
          filterTools();
        }
      });

      // INIT
      updateRecentTools();
      sortTools('popular');
      setActiveFilter(currentFilter);
      updateLinkParams(currentFilter);
      
      if (dashboardLoader) {
         setTimeout(() => {
             dashboardLoader.classList.add('opacity-0', 'pointer-events-none');
         }, 150); 
      }
  });
</script>

<style>
  .animate-fade-in { animation: fadeIn 0.8s ease-out forwards; }
  .animate-fade-in-up { animation: fadeInUp 0.4s ease-out forwards; }

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  .custom-scrollbar::-webkit-scrollbar { height: 4px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background-color: #e2e8f0; border-radius: 20px; }
  .dark .custom-scrollbar::-webkit-scrollbar-thumb { background-color: #334155; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background-color: #cbd5e1; }
</style>