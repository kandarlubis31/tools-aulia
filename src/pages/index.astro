  { cat: "dev", popular: false, title: "CORS Proxy", desc: "Test API dari browser tanpa masalah CORS.", href: "/dev/proxy", color: "violet", icon: '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>' },
  { cat: "dev", popular: false, title: "Base64 Converter", desc: "Encode/decode text atau gambar ke Base64.", href: "/dev/base64", color: "orange", icon: '<polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/>' },
