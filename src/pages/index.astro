  { cat: "security", popular: true, title: "Password Gen", desc: "Buat password yang kuat dan acak.", href: "/security/password", color: "emerald", icon: '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>' },
  { cat: "security", popular: false, title: "Hash Generator", desc: "Generate hash MD5, SHA-1, SHA-256.", href: "/security/hash", color: "blue", icon: '<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>' },
  { cat: "security", popular: false, title: "UUID Generator", desc: "Buat Unique ID untuk database atau identifier.", href: "/security/uuid", color: "purple", icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 7h10"/><path d="M7 12h10"/><path d="M7 17h10"/>' },
  
