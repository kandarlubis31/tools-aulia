---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Halaman Tidak Ditemukan">
  <div class="min-h-[70vh] flex flex-col items-center justify-center text-center px-4">
    <div class="relative w-32 h-32 mb-6 opacity-80">
       <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full text-slate-300 dark:text-slate-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M2 10h20"/><path d="M9.5 15.5 14.5 15.5"/><path d="M12 13v5"/></svg>
       <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-3xl font-bold text-slate-400 dark:text-slate-600">404</span>
       </div>
    </div>

    <h1 class="text-3xl md:text-5xl font-extrabold text-slate-800 dark:text-white mb-3" data-i18n="404.heading">
      Tersesat?
    </h1>
    <p class="text-slate-600 dark:text-slate-400 mb-8 max-w-sm mx-auto leading-relaxed" data-i18n="404.desc">
      Halaman yang kamu cari sepertinya sudah dipindahkan atau tidak ada di server kami.
    </p>

    <a href="/" class="group px-8 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-full transition-all hover:scale-105 shadow-lg shadow-indigo-500/30 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      <span data-i18n="404.back">Kembali ke Dashboard</span>
    </a>
  </div>
</BaseLayout>