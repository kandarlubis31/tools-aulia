---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="BMI Calculator">
  <div class="max-w-6xl mx-auto px-4 min-h-[60vh]">
    <div class="text-center mb-10 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-matte-900 dark:text-white">
        BMI Calculator
      </h1>
      <p class="text-matte-400 dark:text-matte-300">
        Hitung Indeks Massa Tubuh Anda dan dapatkan rekomendasi kesehatan yang tepat.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 animate-fade-in pb-20">
      <div class="lg:col-span-2">
        <div class="card-base p-8">
          
          <div class="flex justify-center mb-8">
            <div class="inline-flex p-1 bg-matte-100 dark:bg-matte-700 rounded-lg">
              <button id="metric-btn" class="unit-btn px-6 py-2 rounded-md text-sm font-bold bg-white dark:bg-matte-600 shadow-sm text-teal-600 dark:text-teal-400 transition-all" data-i18n="label.metric">Metrik (kg/cm)</button>
              <button id="imperial-btn" class="unit-btn px-6 py-2 rounded-md text-sm font-medium text-matte-500 hover:text-matte-700 dark:text-matte-400 dark:hover:text-matte-200 transition-all" data-i18n="label.imperial">Imperial (lbs/ft)</button>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            
            <div id="height-input-container">
              <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.height">
                Tinggi Badan <span class="metric-unit text-matte-400 font-normal">(cm)</span><span class="imperial-unit hidden text-matte-400 font-normal">(ft/in)</span>
              </label>
              
              <input type="number" id="height" class="metric-input w-full p-3 rounded-xl bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border outline-none focus:border-accent-blue transition-all" placeholder="170" data-i18n-attr="placeholder" data-i18n="ph.height" />
              
              <div class="imperial-input hidden flex gap-3">
                <div class="relative flex-1">
                    <input type="number" id="height-ft" class="w-full p-3 rounded-xl bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border outline-none focus:border-accent-blue transition-all" placeholder="5" data-i18n-attr="placeholder" data-i18n="ph.height_ft" />
                    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-matte-400 text-sm font-bold">ft</span>
                </div>
                <div class="relative flex-1">
                    <input type="number" id="height-in" class="w-full p-3 rounded-xl bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border outline-none focus:border-accent-blue transition-all" placeholder="7" data-i18n-attr="placeholder" data-i18n="ph.height_in" />
                    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-matte-400 text-sm font-bold">in</span>
                </div>
              </div>
            </div>
            
            <div id="weight-input-container">
              <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.weight">
                Berat Badan <span class="metric-unit text-matte-400 font-normal">(kg)</span><span class="imperial-unit hidden text-matte-400 font-normal">(lbs)</span>
              </label>
              <div class="relative">
                  <input type="number" id="weight" class="w-full p-3 rounded-xl bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border outline-none focus:border-accent-blue transition-all" placeholder="65" data-i18n-attr="placeholder" data-i18n="ph.weight" />
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div>
              <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.age">Usia</label>
              <input type="number" id="age" class="w-full p-3 rounded-xl bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border outline-none focus:border-accent-blue transition-all" placeholder="25" min="2" max="120" data-i18n-attr="placeholder" data-i18n="ph.age" />
            </div>
            
            <div>
              <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2" data-i18n="label.gender">Jenis Kelamin</label>
              <div class="flex gap-4 pt-1">
                <label class="flex items-center cursor-pointer group">
                  <input type="radio" name="gender" value="male" class="w-5 h-5 text-teal-600 focus:ring-teal-500 border-gray-300" checked />
                  <span class="ml-2 text-sm font-medium text-matte-700 dark:text-white group-hover:text-teal-600 transition-colors" data-i18n="label.male">Pria</span>
                </label>
                <label class="flex items-center cursor-pointer group">
                  <input type="radio" name="gender" value="female" class="w-5 h-5 text-teal-600 focus:ring-teal-500 border-gray-300" />
                  <span class="ml-2 text-sm font-medium text-matte-700 dark:text-white group-hover:text-teal-600 transition-colors" data-i18n="label.female">Wanita</span>
                </label>
              </div>
            </div>
          </div>

          <button id="calc-btn" class="w-full bg-matte-900 dark:bg-white text-white dark:text-matte-900 font-bold py-3.5 rounded-xl transition-all mb-8" data-i18n="btn.calculate_bmi">
            Hitung BMI Sekarang
          </button>

          <div id="result" class="hidden animate-fade-in-up">
            <div class="bg-matte-50 dark:bg-matte-900/50 rounded-2xl p-6 border border-matte-200 dark:border-matte-700">
                <div class="text-center mb-8 relative">
                  <div class="absolute inset-0 flex items-center justify-center opacity-10 pointer-events-none">
                      <svg class="w-48 h-48 text-teal-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
                  </div>
                  <p class="text-sm font-bold text-matte-500 uppercase tracking-widest mb-1" data-i18n="label.your_bmi_score">Skor BMI Anda</p>
                  <div class="text-6xl font-black text-matte-800 dark:text-white mb-3 tracking-tight" id="bmi-score">0.0</div>
                  <div class="inline-block px-5 py-2 rounded-full text-sm font-bold uppercase tracking-wider shadow-sm transition-colors" id="bmi-status">Normal</div>
                </div>

                <div class="mb-8 relative px-2">
                  <div class="h-4 w-full bg-gradient-to-r from-blue-400 via-green-400 via-yellow-400 via-orange-400 to-red-500 rounded-full"></div>
                  <div class="absolute top-5 left-0 w-full flex justify-between text-[10px] font-bold text-matte-400 px-1">
                      <span>16</span><span>18.5</span><span>25</span><span>30</span><span>35</span><span>40</span>
                  </div>
                  <div id="bmi-indicator" class="absolute -top-1 w-6 h-6 bg-white dark:bg-matte-800 border-4 border-matte-800 dark:border-white rounded-full shadow-lg transform -translate-x-1/2 transition-all duration-700" style="left: 0%"></div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                  <div class="card-base p-4">
                    <h4 class="text-xs font-bold text-matte-400 uppercase mb-1" data-i18n="label.ideal_weight">Berat Ideal</h4>
                    <p class="text-xl font-bold text-teal-600 dark:text-teal-400" id="ideal-weight">0 - 0 kg</p>
                  </div>
                  <div class="card-base p-4">
                    <h4 class="text-xs font-bold text-matte-400 uppercase mb-1" data-i18n="label.category">Kategori</h4>
                    <p class="text-xl font-bold text-matte-700 dark:text-matte-200" id="bmi-category">Normal</p>
                  </div>
                </div>

                <div class="bg-teal-50 dark:bg-teal-900/20 p-5 rounded-xl border border-teal-100 dark:border-teal-800 mb-6">                  <h4 class="text-sm font-bold text-teal-800 dark:text-teal-300 mb-2 flex items-center gap-2" data-i18n="label.health_advice">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0118 0z"></path></svg>
                      Saran Kesehatan
                  </h4>
                  <p class="text-sm text-teal-700 dark:text-teal-400 leading-relaxed" id="health-recommendation">-</p>
                </div>

                <div class="flex gap-3">                    <button id="save-btn" class="flex-1 bg-teal-600 text-white font-bold py-2.5 px-4 rounded-xl hover:bg-teal-700 transition-colors shadow-md flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                    <span data-i18n="btn.save">Simpan</span>
                  </button>
                  <button id="share-btn" class="flex-1 bg-white dark:bg-matte-800 text-matte-700 dark:text-white border border-matte-200 dark:border-matte-700 font-bold py-2.5 px-4 rounded-xl hover:bg-matte-50 dark:hover:bg-matte-700 transition-colors shadow-sm flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                    <span data-i18n="btn.share">Bagikan</span>
                  </button>
                </div>
            </div>
          </div>

        </div>
      </div>

      <div class="space-y-6">
        
        <div class="card-base p-6">
          <h3 class="text-lg font-bold text-matte-700 dark:text-white mb-4" data-i18n="label.bmi_classification">Klasifikasi BMI</h3>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between items-center p-2 rounded hover:bg-matte-50 dark:hover:bg-matte-700/50">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-blue-400 rounded-full"></div>
                <span class="text-matte-400 dark:text-matte-300" data-i18n="text.underweight">Kurus</span>
              </div>
              <span class="font-mono font-bold text-matte-700 dark:text-white">&lt; 18.5</span>
            </div>
            <div class="flex justify-between items-center p-2 rounded bg-green-50 dark:bg-green-900/10 border border-green-100 dark:border-green-800">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-green-500 rounded-full shadow-sm"></div>
                <span class="text-matte-800 dark:text-matte-200 font-bold" data-i18n="status.normal">Normal</span>
              </div>
              <span class="font-mono font-bold text-matte-800 dark:text-matte-200">18.5 - 24.9</span>
            </div>
            <div class="flex justify-between items-center p-2 rounded hover:bg-matte-50 dark:hover:bg-matte-700/50">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
                <span class="text-matte-400 dark:text-matte-300" data-i18n="text.overweight">Gemuk</span>
              </div>
              <span class="font-mono font-bold text-matte-700 dark:text-white">25.0 - 29.9</span>
            </div>
            <div class="flex justify-between items-center p-2 rounded hover:bg-matte-50 dark:hover:bg-matte-700/50">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
                <span class="text-matte-400 dark:text-matte-300" data-i18n="text.obesity_1">Obesitas I</span>
              </div>
              <span class="font-mono font-bold text-matte-700 dark:text-white">30.0 - 34.9</span>
            </div>
            <div class="flex justify-between items-center p-2 rounded hover:bg-matte-50 dark:hover:bg-matte-700/50">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-red-500 rounded-full"></div>
                <span class="text-matte-400 dark:text-matte-300" data-i18n="text.obesity_2">Obesitas II</span>
              </div>
              <span class="font-mono font-bold text-matte-700 dark:text-white">35.0 - 39.9</span>
            </div>
            <div class="flex justify-between items-center p-2 rounded hover:bg-matte-50 dark:hover:bg-matte-700/50">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-red-700 rounded-full"></div>
                <span class="text-matte-400 dark:text-matte-300" data-i18n="text.obesity_3">Obesitas III</span>
              </div>
              <span class="font-mono font-bold text-matte-700 dark:text-white">&ge; 40.0</span>
            </div>
          </div>
        </div>

        <div class="card-base p-6">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-bold text-matte-700 dark:text-white" data-i18n="label.history">Riwayat</h3>
            <button id="clear-history-btn" class="text-xs font-bold text-red-500 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 px-2 py-1 rounded transition-colors" data-i18n="btn.clear_all">Hapus Semua</button>
          </div>
          <div id="history-container" class="space-y-3 max-h-80 overflow-y-auto custom-scrollbar pr-1">
            <p class="text-sm text-matte-400 text-center py-6" data-i18n="text.no_calc_history">Belum ada riwayat perhitungan.</p>
          </div>
        </div>

      </div>
    </div>
  </div>

  
</BaseLayout>



<script>
  // Elements
  const metricBtn = document.getElementById('metric-btn');
  const imperialBtn = document.getElementById('imperial-btn');
  const heightInput = document.getElementById('height');
  const heightFtInput = document.getElementById('height-ft');
  const heightInInput = document.getElementById('height-in');
  const weightInput = document.getElementById('weight');
  const ageInput = document.getElementById('age');
  const calcBtn = document.getElementById('calc-btn');
  const resultDiv = document.getElementById('result');
  const bmiScoreEl = document.getElementById('bmi-score');
  const bmiStatusEl = document.getElementById('bmi-status');
  const bmiIndicatorEl = document.getElementById('bmi-indicator');
  const idealWeightEl = document.getElementById('ideal-weight');
  const bmiCategoryEl = document.getElementById('bmi-category');
  const healthRecommendationEl = document.getElementById('health-recommendation');
  const saveBtn = document.getElementById('save-btn');
  const shareBtn = document.getElementById('share-btn');
  const clearHistoryBtn = document.getElementById('clear-history-btn');
  const historyContainer = document.getElementById('history-container');

  // State
  let isMetric = true;
  let bmiHistory = JSON.parse(localStorage.getItem('bmiHistory') || '[]');

  // Initialize
  document.addEventListener('astro:page-load', () => {
    renderHistory();
  });

  // Toggle Units
  function toggleUnits(metric) {
    isMetric = metric;
    
    // UI Update
    if (isMetric) {
        metricBtn.classList.add('bg-white', 'dark:bg-matte-600', 'shadow-sm', 'text-teal-600', 'dark:text-teal-400');
        metricBtn.classList.remove('text-matte-500', 'hover:text-matte-700', 'dark:text-matte-400');
        imperialBtn.classList.remove('bg-white', 'dark:bg-matte-600', 'shadow-sm', 'text-teal-600', 'dark:text-teal-400');
        imperialBtn.classList.add('text-matte-500', 'hover:text-matte-700', 'dark:text-matte-400');
        
        document.querySelectorAll('.metric-unit').forEach(el => el.classList.remove('hidden'));
        document.querySelectorAll('.imperial-unit').forEach(el => el.classList.add('hidden'));
        document.querySelectorAll('.metric-input').forEach(el => el.classList.remove('hidden'));
        document.querySelectorAll('.imperial-input').forEach(el => el.classList.add('hidden'));

        // Conversion Logic (Imperial -> Metric)
        if (heightFtInput.value || heightInInput.value) {
            const ft = parseFloat(heightFtInput.value) || 0;
            const inches = parseFloat(heightInInput.value) || 0;
            const totalInches = (ft * 12) + inches;
            heightInput.value = (totalInches * 2.54).toFixed(1);
        }
        if (weightInput.value) {
            const lbs = parseFloat(weightInput.value) || 0;
            weightInput.value = (lbs * 0.453592).toFixed(1);
        }

    } else {
        imperialBtn.classList.add('bg-white', 'dark:bg-matte-600', 'shadow-sm', 'text-teal-600', 'dark:text-teal-400');
        imperialBtn.classList.remove('text-matte-500', 'hover:text-matte-700', 'dark:text-matte-400');
        metricBtn.classList.remove('bg-white', 'dark:bg-matte-600', 'shadow-sm', 'text-teal-600', 'dark:text-teal-400');
        metricBtn.classList.add('text-matte-500', 'hover:text-matte-700', 'dark:text-matte-400');

        document.querySelectorAll('.metric-unit').forEach(el => el.classList.add('hidden'));
        document.querySelectorAll('.imperial-unit').forEach(el => el.classList.remove('hidden'));
        document.querySelectorAll('.metric-input').forEach(el => el.classList.add('hidden'));
        document.querySelectorAll('.imperial-input').forEach(el => el.classList.remove('hidden'));

        // Conversion Logic (Metric -> Imperial)
        if (heightInput.value) {
            const cm = parseFloat(heightInput.value) || 0;
            const totalInches = cm / 2.54;
            const ft = Math.floor(totalInches / 12);
            const inches = (totalInches % 12).toFixed(1);
            heightFtInput.value = ft;
            heightInInput.value = inches;
        }
        if (weightInput.value) {
            const kg = parseFloat(weightInput.value) || 0;
            weightInput.value = (kg * 2.20462).toFixed(1);
        }
    }
  }

  metricBtn.addEventListener('click', () => toggleUnits(true));
  imperialBtn.addEventListener('click', () => toggleUnits(false));

  // Calculate BMI
  calcBtn.addEventListener('click', () => {
    let height, weight;
    
    if (isMetric) {
      height = parseFloat(heightInput.value) / 100; // cm to m
      weight = parseFloat(weightInput.value);
    } else {
      const ft = parseFloat(heightFtInput.value) || 0;
      const inches = parseFloat(heightInInput.value) || 0;
      height = ((ft * 12) + inches) * 0.0254; // total inches to m
      weight = parseFloat(weightInput.value) * 0.453592; // lbs to kg
    }
    
    const heightEl = document.getElementById(isMetric ? 'height' : 'height-ft');
    const weightEl = document.getElementById('weight');
    let hasError = false;
    if (!height || height <= 0) {
      showInlineError(heightEl, window._tToast ? window._tToast('Masukkan tinggi yang valid!') : 'Masukkan tinggi yang valid!');
      hasError = true;
    }
    if (!weight || weight <= 0) {
      showInlineError(weightEl, window._tToast ? window._tToast('Masukkan berat yang valid!') : 'Masukkan berat yang valid!');
      hasError = true;
    }
    if (hasError) {
      window.showToast(window._tToast ? window._tToast('Lengkapi data dengan benar!') : 'Lengkapi data dengan benar!', 'error');
      return;
    }
    
    const bmi = weight / (height * height);
    const bmiFixed = bmi.toFixed(1);
    
    clearInlineErrors();
    updateResultUI(bmi, bmiFixed, height, weight);
  });

  function updateResultUI(bmi, bmiFixed, height, weight) {
    // FIX VARIABLE NAMING: using 'indicatorPosition' instead of 'indicatorPercent'
    let status, color, indicatorPosition, rec;

    // Logic Categories
    if (bmi < 18.5) {
        status = 'Kurus';
        color = 'bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400';
        indicatorPosition = Math.min(18, (bmi / 18.5) * 20); // 0-20%
        rec = "Anda berada di kategori berat badan kurang. Fokus pada asupan nutrisi padat energi dan protein. Latihan beban dapat membantu membangun massa otot.";
    } else if (bmi < 25) {
        status = 'Normal';
        color = 'bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400';
        indicatorPosition = 20 + ((bmi - 18.5) / 6.5) * 20; // 20-40%
        rec = "Selamat! Berat badan Anda ideal. Pertahankan pola makan seimbang dan aktivitas fisik rutin untuk menjaga kesehatan jantung dan metabolisme.";
    } else if (bmi < 30) {
        status = 'Gemuk';
        color = 'bg-yellow-100 text-yellow-600 dark:bg-yellow-900/30 dark:text-yellow-400';
        indicatorPosition = 40 + ((bmi - 25) / 5) * 20; // 40-60%
        rec = "Anda memiliki berat badan berlebih. Coba kurangi porsi makan sedikit, perbanyak sayuran, dan tingkatkan durasi olahraga harian Anda.";
    } else if (bmi < 35) {
        status = 'Obesitas I';
        color = 'bg-orange-100 text-orange-600 dark:bg-orange-900/30 dark:text-orange-400';
        indicatorPosition = 60 + ((bmi - 30) / 5) * 20; // 60-80%
        rec = "Indikasi obesitas tingkat 1. Disarankan berkonsultasi dengan ahli gizi untuk program penurunan berat badan yang aman dan efektif.";
    } else {
        status = 'Obesitas II+';
        color = 'bg-red-100 text-red-600 dark:bg-red-900/30 dark:text-red-400';
        indicatorPosition = Math.min(98, 80 + ((bmi - 35) / 10) * 20); // 80-100%
        rec = "Resiko kesehatan meningkat signifikan. Sangat disarankan pemeriksaan kesehatan menyeluruh dan pendampingan medis untuk manajemen berat badan.";
    }

    // Ideal Weight Calculation (Normal BMI 18.5 - 24.9)
    let minIdeal, maxIdeal;
    minIdeal = (18.5 * height * height).toFixed(1);
    maxIdeal = (24.9 * height * height).toFixed(1);
    
    if (!isMetric) {
        minIdeal = (minIdeal * 2.20462).toFixed(1);
        maxIdeal = (maxIdeal * 2.20462).toFixed(1);
    }

    // Update DOM
    bmiScoreEl.textContent = bmiFixed;
    bmiStatusEl.textContent = status;
    bmiStatusEl.className = `inline-block px-5 py-2 rounded-full text-sm font-bold uppercase tracking-wider shadow-sm transition-colors ${color}`;
    
    bmiIndicatorEl.style.left = `${indicatorPosition}%`;
    
    idealWeightEl.textContent = `${minIdeal} - ${maxIdeal} ${isMetric ? 'kg' : 'lbs'}`;
    bmiCategoryEl.textContent = status;
    healthRecommendationEl.textContent = rec;

    resultDiv.classList.remove('hidden');
    resultDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // Save Function
  saveBtn.addEventListener('click', () => {
    const bmi = bmiScoreEl.textContent;
    const status = bmiStatusEl.textContent;
    
    // Get formatted inputs for history display
    let hStr, wStr;
    if (isMetric) {
        hStr = `${heightInput.value} cm`;
        wStr = `${weightInput.value} kg`;
    } else {
        hStr = `${heightFtInput.value}' ${heightInInput.value}"`;
        wStr = `${weightInput.value} lbs`;
    }

    const item = {
        id: Date.now(),
        date: new Date().toLocaleDateString('id-ID', { day: 'numeric', month: 'short', hour: '2-digit', minute:'2-digit'}),
        bmi: bmi,
        status: status,
        height: hStr,
        weight: wStr
    };

    bmiHistory.unshift(item);
    if (bmiHistory.length > 20) bmiHistory.pop();
    
    localStorage.setItem('bmiHistory', JSON.stringify(bmiHistory));
    renderHistory();
    window.showToast(window._tToast ? window._tToast('Disimpan ke riwayat!') : 'Disimpan ke riwayat!', 'success');
  });

  // Share Function
  shareBtn.addEventListener('click', () => {
    const text = `Skor BMI saya: ${bmiScoreEl.textContent} (${bmiStatusEl.textContent}). Cek kalkulator ini!`;
    if (navigator.share) {
        navigator.share({ title: 'Hasil BMI', text: text }).catch(() => {
            navigator.clipboard.writeText(text);
            window.showToast(window._tToast ? window._tToast('Hasil disalin ke clipboard!') : 'Hasil disalin ke clipboard!', 'success');
        });
    } else {
        navigator.clipboard.writeText(text);
        showToast(window._tToast ? window._tToast('Hasil disalin ke clipboard!') : 'Hasil disalin ke clipboard!', 'success');
    }
  });

  // History Management
  function renderHistory() {
    if (bmiHistory.length === 0) {
        historyContainer.innerHTML = '<p class="text-sm text-matte-400 text-center py-6">Belum ada riwayat perhitungan.</p>';
        return;
    }

    historyContainer.innerHTML = bmiHistory.map(item => `
        <div class="p-3 bg-matte-50 dark:bg-matte-700/50 rounded-xl border border-matte-100 dark:border-matte-700 flex justify-between items-center group hover:bg-white dark:hover:bg-matte-700 transition-all shadow-sm">
            <div>
                <div class="flex items-center gap-2 mb-1">
                    <span class="text-lg font-black text-matte-700 dark:text-white">${item.bmi}</span>
                    <span class="text-[10px] font-bold uppercase px-1.5 py-0.5 rounded bg-matte-200 dark:bg-matte-600 text-matte-600 dark:text-matte-300">${item.status}</span>
                </div>
                <div class="text-xs text-matte-500 dark:text-matte-400 flex gap-2">
                    <span>${item.height}</span> &bull; <span>${item.weight}</span> &bull; <span>${item.date}</span>
                </div>
            </div>
            <button onclick="deleteItem(${item.id})" class="p-2 text-matte-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors opacity-0 group-hover:opacity-100">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
            </button>
        </div>
    `).join('');
  }

  // Global Delete Function
  window.deleteItem = (id) => {
    bmiHistory = bmiHistory.filter(i => i.id !== id);
    localStorage.setItem('bmiHistory', JSON.stringify(bmiHistory));
    renderHistory();
    window.showToast(window._tToast ? window._tToast('Item dihapus') : 'Item dihapus', 'success');
  };

  clearHistoryBtn.addEventListener('click', () => {
    if(confirm(window._tToast ? window._tToast('Hapus semua riwayat?') : 'Hapus semua riwayat?')) {
        bmiHistory = [];
        localStorage.setItem('bmiHistory', JSON.stringify(bmiHistory));
        renderHistory();
        window.showToast(window._tToast ? window._tToast('Riwayat dibersihkan') : 'Riwayat dibersihkan', 'success');
    }
  });

  function showInlineError(el, msg) {
    if (!el) return;
    el.classList.add('border-red-500', 'dark:border-red-500');
    let errEl = el.parentElement?.querySelector('.inline-error');
    if (!errEl) {
      errEl = document.createElement('p');
      errEl.className = 'inline-error text-red-500 text-xs mt-1 font-bold animate-fade-in';
      el.parentElement?.appendChild(errEl);
    }
    errEl.textContent = msg;
  }

  function clearInlineErrors() {
    document.querySelectorAll('.inline-error').forEach(el => el.remove());
    [heightInput, heightFtInput, heightInInput, weightInput, ageInput].forEach(el => {
      el?.classList.remove('border-red-500', 'dark:border-red-500');
    });
  }

</script>