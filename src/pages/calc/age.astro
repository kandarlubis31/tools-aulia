---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Age Calculator Ultimate">
  <div class="max-w-4xl mx-auto px-4 min-h-[85vh] py-10">
    
    <div class="text-center mb-10 animate-on-scroll">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500 tracking-tight">
        Age Master
      </h1>
      <p class="text-slate-600 dark:text-slate-400 text-lg" data-i18n="header.age_desc">
        Bukan sekadar hitung umur. Lihat perjalanan waktu hidupmu dalam angka.
      </p>
    </div>

    <div class="bg-white dark:bg-slate-800 p-8 rounded-3xl shadow-xl border border-slate-200 dark:border-slate-700 mb-8">
      <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2 uppercase tracking-wider" data-i18n="label.birth_date">Kapan kamu lahir?</label>
      <div class="flex gap-4 flex-col sm:flex-row">
          <input type="date" id="dob" class="flex-1 p-4 rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 outline-none focus:ring-2 focus:ring-blue-500 font-bold text-slate-800 dark:text-white transition-all cursor-pointer" />
          <button id="calc-btn" class="px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-all shadow-lg shadow-blue-500/30 active:scale-95 transform" data-i18n="btn.calculate_age">
              Hitung Umur
          </button>
      </div>
      <p id="error-msg" class="text-red-500 text-sm mt-3 font-bold hidden animate-pulse bg-red-50 dark:bg-red-900/20 p-2 rounded-lg border border-red-200 dark:border-red-800" data-i18n="error.invalid_date">⚠️ Hmm, ada yang salah dengan tanggal yang kamu pilih</p>
    </div>

    <div id="result" class="hidden flex-col gap-6 animate-fade-in-up">
        
        <div class="grid grid-cols-3 gap-4">
            <div class="p-6 bg-blue-50 dark:bg-blue-900/20 rounded-2xl border border-blue-100 dark:border-blue-800 text-center shadow-sm hover:shadow-md transition-shadow">
                <span id="years" class="text-4xl md:text-5xl font-black text-blue-600 dark:text-blue-400 block mb-1">0</span>
                <span class="text-[10px] md:text-xs font-bold text-slate-500 uppercase tracking-widest" data-i18n="label.years">Tahun</span>
            </div>
            <div class="p-6 bg-slate-50 dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 text-center shadow-sm hover:shadow-md transition-shadow">
                <span id="months" class="text-3xl md:text-4xl font-black text-slate-700 dark:text-slate-200 block mb-1">0</span>
                <span class="text-[10px] md:text-xs font-bold text-slate-500 uppercase tracking-widest" data-i18n="label.months">Bulan</span>
            </div>
            <div class="p-6 bg-slate-50 dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 text-center shadow-sm hover:shadow-md transition-shadow">
                <span id="days" class="text-3xl md:text-4xl font-black text-slate-700 dark:text-slate-200 block mb-1">0</span>
                <span class="text-[10px] md:text-xs font-bold text-slate-500 uppercase tracking-widest" data-i18n="label.days">Hari</span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm relative overflow-hidden group hover:border-amber-200 dark:hover:border-amber-800 transition-colors">
                <div class="absolute top-0 right-0 w-20 h-20 bg-amber-100 dark:bg-amber-900/20 rounded-bl-full -mr-10 -mt-10 transition-transform group-hover:scale-110"></div>
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4" data-i18n="label.next_birthday">Ulang Tahun Berikutnya</h3>
                <div class="flex items-end gap-2 mb-2">
                    <span id="next-bday-count" class="text-4xl font-black text-amber-500">0</span>
                    <span class="text-sm font-bold text-slate-500 mb-1.5" data-i18n="label.days_left">Hari Lagi</span>
                </div>
                <p id="next-bday-date" class="text-sm font-medium text-slate-600 dark:text-slate-300">Jatuh pada hari...</p>
            </div>

            <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm relative overflow-hidden group hover:border-purple-200 dark:hover:border-purple-800 transition-colors">
                <div class="absolute top-0 right-0 w-20 h-20 bg-purple-100 dark:bg-purple-900/20 rounded-bl-full -mr-10 -mt-10 transition-transform group-hover:scale-110"></div>
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4" data-i18n="label.birth_day">Hari Kelahiran</h3>
                <div class="flex items-center gap-3">
                    <div class="p-3 bg-purple-100 dark:bg-purple-900/30 text-purple-600 rounded-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                    </div>
                    <div>
                        <p id="born-day" class="text-2xl font-bold text-slate-800 dark:text-white">Senin</p>
                        <p class="text-xs text-slate-500" data-i18n="text.born_on_this_day">Kamu lahir di hari ini.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-slate-50 dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800">
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6 text-center" data-i18n="label.life_stats">Statistik Kehidupan</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
                <div class="p-2">
                    <p id="total-months" class="text-xl font-bold text-slate-700 dark:text-slate-200">0</p>
                    <p class="text-[10px] text-slate-400 uppercase mt-1" data-i18n="label.total_months">Total Bulan</p>
                </div>
                <div class="p-2 border-l border-slate-200 dark:border-slate-800">
                    <p id="total-weeks" class="text-xl font-bold text-slate-700 dark:text-slate-200">0</p>
                    <p class="text-[10px] text-slate-400 uppercase mt-1" data-i18n="label.total_weeks">Total Minggu</p>
                </div>
                <div class="p-2 border-l border-slate-200 dark:border-slate-800">
                    <p id="total-days" class="text-xl font-bold text-slate-700 dark:text-slate-200">0</p>
                    <p class="text-[10px] text-slate-400 uppercase mt-1" data-i18n="label.total_days">Total Hari</p>
                </div>
                <div class="p-2 border-l border-slate-200 dark:border-slate-800">
                    <p id="total-hours" class="text-xl font-bold text-slate-700 dark:text-slate-200">0</p>
                    <p class="text-[10px] text-slate-400 uppercase mt-1" data-i18n="label.total_hours">Total Jam</p>
                </div>
            </div>
        </div>

        <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm">
            <h3 class="text-lg font-bold text-slate-800 dark:text-white mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M12 2v20M2 12h20"/></svg>
                <span data-i18n="label.unique_comparisons">Perbandingan Unik</span>
            </h3>
            <div id="comparisons" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 mt-4">
            <button id="save-result" class="flex-1 px-6 py-3 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 font-bold rounded-xl hover:bg-blue-200 dark:hover:bg-blue-900/50 transition-colors flex items-center justify-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg>
                <span data-i18n="btn.save_result">Simpan Hasil</span>
            </button>
            <button id="share-result" class="flex-1 px-6 py-3 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300 font-bold rounded-xl hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors flex items-center justify-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                <span data-i18n="btn.share">Bagikan</span>
            </button>
        </div>

    </div>

  </div>
</BaseLayout>

<script>
  // --- UTILS ---
  const formatNumber = (num) => new Intl.NumberFormat('id-ID').format(num);
  const daysID = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'];
  const monthsID = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'];

  // --- DATA ---
  const comparisons = [
    { title: "Umur Anjing", factor: 7, unit: "Tahun", icon: "🐕" },
    { title: "Umur Kucing", factor: 6, unit: "Tahun", icon: "🐱" },
    { title: "Detak Jantung", factor: 42048000, unit: "Kali", icon: "❤️" }, // ~80 bpm
    { title: "Kedipan Mata", factor: 7884000, unit: "Kali", icon: "👁️" }, // ~15-20 times/min
    { title: "Tidur", factor: 0.33, unit: "Tahun", icon: "💤" }, // ~8 hours/day
    { title: "Perjalanan Bumi", factor: 940000000, unit: "Km", icon: "🌍" } // Orbit distance per year
  ];

  // --- ELEMENTS ---
  const dobInput = document.getElementById('dob');
  const btn = document.getElementById('calc-btn');
  const resBox = document.getElementById('result');
  const errorMsg = document.getElementById('error-msg');
  const comparisonsEl = document.getElementById('comparisons');
  const saveBtn = document.getElementById('save-result');
  const shareBtn = document.getElementById('share-result');

  let currentAgeData = {};

  // --- MAIN LOGIC ---
  btn.addEventListener('click', () => {
    errorMsg.classList.add('hidden');
    resBox.classList.add('hidden');

    if (!dobInput.value) {
        var errMsg1 = (window._tToast) ? window._tToast('Eh, lupa masukkan tanggal lahir kamu!') : 'Eh, lupa masukkan tanggal lahir kamu!';
        showError("⚠️ " + errMsg1);
        return;
    }

    const dob = new Date(dobInput.value);
    const now = new Date();

    if (dob > now) {
        var errMsg2 = (window._tToast) ? window._tToast('Kamu dari masa depan ya? Pilih tanggal yang valid.') : 'Kamu dari masa depan ya? Pilih tanggal yang valid.';
        showError("⚠️ " + errMsg2);
        return;
    }

    // Calc Age
    let years = now.getFullYear() - dob.getFullYear();
    let months = now.getMonth() - dob.getMonth();
    let days = now.getDate() - dob.getDate();

    if (days < 0) {
        months--;
        days += new Date(now.getFullYear(), now.getMonth(), 0).getDate();
    }
    if (months < 0) {
        years--;
        months += 12;
    }

    // Calc Next Birthday
    const currentYear = now.getFullYear();
    let nextBirthday = new Date(currentYear, dob.getMonth(), dob.getDate());
    if (now > nextBirthday) nextBirthday.setFullYear(currentYear + 1);

    const timeDiff = nextBirthday - now;
    const daysToNextBday = Math.ceil(timeDiff / (1000 * 60 * 60 * 24));
    const nextBdayDayName = daysID[nextBirthday.getDay()];
    const nextBdayDateString = `${nextBirthday.getDate()} ${monthsID[nextBirthday.getMonth()]} ${nextBirthday.getFullYear()}`;

    // Calc Total Stats
    const totalTimeDiff = now - dob;
    const totalDays = Math.floor(totalTimeDiff / (1000 * 60 * 60 * 24));
    const totalWeeks = Math.floor(totalDays / 7);
    const totalMonths = (years * 12) + months;
    const totalHours = Math.floor(totalTimeDiff / (1000 * 60 * 60));

    // Store Data
    currentAgeData = { years, months, days, totalDays };

    // Update UI
    updateText('years', years);
    updateText('months', months);
    updateText('days', days);
    updateText('next-bday-count', daysToNextBday);
    var fallsOnText = (window._tToast) ? window._tToast('Jatuh pada hari') : 'Jatuh pada hari';
    updateText('next-bday-date', fallsOnText + ' ' + nextBdayDayName + ', ' + nextBdayDateString);
    updateText('born-day', daysID[dob.getDay()]);
    updateText('total-months', formatNumber(totalMonths));
    updateText('total-weeks', formatNumber(totalWeeks));
    updateText('total-days', formatNumber(totalDays));
    updateText('total-hours', formatNumber(totalHours));

    renderComparisons(years, totalDays);

    resBox.classList.remove('hidden');
    resBox.classList.add('flex');
    
    if(window.innerWidth < 768) {
        resBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  function showError(msg) {
      errorMsg.innerText = msg;
      errorMsg.classList.remove('hidden');
  }

  function updateText(id, text) {
      document.getElementById(id).innerText = text;
  }

  function renderComparisons(years, totalDays) {
      comparisonsEl.innerHTML = '';
      // Pick 4 random
      const shuffled = [...comparisons].sort(() => 0.5 - Math.random()).slice(0, 4);
      
      shuffled.forEach(comp => {
          let val = 0;
          if (comp.unit === 'Tahun') val = years * comp.factor;
          else if (comp.unit === 'Km') val = years * comp.factor; // Based on years
          else val = totalDays * 24 * 60 * (comp.factor / (24*60*365)); // Approx for heart/blink based on daily rate if factor is yearly? No, factor is raw.
          
          // Simplified logic for this demo
          if(comp.title.includes('Anjing') || comp.title.includes('Kucing')) val = Math.floor(years * comp.factor);
          else if(comp.title.includes('Tidur')) val = (years * comp.factor).toFixed(1);
          else if(comp.title.includes('Bumi')) val = formatNumber(years * comp.factor);
          else val = formatNumber(Math.floor(totalDays * (comp.factor / 365))); // Adjust logic as needed

          const div = document.createElement('div');
          div.className = 'flex items-center gap-3 p-4 bg-slate-50 dark:bg-slate-700/50 rounded-xl border border-slate-100 dark:border-slate-700';
          div.innerHTML = `
            <div class="text-3xl">${comp.icon}</div>
            <div>
                <p class="text-xs text-slate-500 dark:text-slate-400 font-bold uppercase">${comp.title}</p>
                <p class="text-lg font-bold text-slate-800 dark:text-white">${val} ${comp.unit}</p>
            </div>
          `;
          comparisonsEl.appendChild(div);
      });
  }

  // --- ACTIONS ---
  saveBtn.addEventListener('click', () => {
      if (!currentAgeData.years && currentAgeData.years !== 0) return;
      
      const history = JSON.parse(localStorage.getItem('ageHistory') || '[]');
      history.unshift({
          date: new Date().toLocaleDateString('id-ID'),
          age: `${currentAgeData.years} Thn ${currentAgeData.months} Bln`
      });
      if(history.length > 5) history.pop();
      
      localStorage.setItem('ageHistory', JSON.stringify(history));
      window.showToast((window._tToast) ? window._tToast('Hasil berhasil disimpan!') : 'Hasil berhasil disimpan!', 'success');
  });

  shareBtn.addEventListener('click', () => {
      if (!currentAgeData.years && currentAgeData.years !== 0) return;
      const text = `Saya sudah hidup selama ${formatNumber(currentAgeData.totalDays)} hari (${currentAgeData.years} Tahun)! Hitung umurmu di sini.`;
      
      if (navigator.share) {
          navigator.share({ title: 'Age Master', text: text }).catch(() => {});
      } else {
          navigator.clipboard.writeText(text);
          window.showToast((window._tToast) ? window._tToast('Teks disalin ke clipboard!') : 'Teks disalin ke clipboard!', 'success');
      }
  });

  // Set Max Date Today
  const today = new Date().toISOString().split('T')[0];
  dobInput.setAttribute('max', today);
</script>