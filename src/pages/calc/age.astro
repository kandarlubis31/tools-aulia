---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Age Calculator Ultimate">
  <div class="max-w-4xl mx-auto px-4 min-h-[85vh] py-10">
    
    <div class="text-center mb-10 animate-on-scroll">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-matte-900 dark:text-white tracking-tight">
        Age Master
      </h1>
      <p class="text-matte-400 dark:text-matte-300 text-lg" data-i18n="header.age_desc">
        Bukan sekadar hitung umur. Lihat perjalanan waktu hidupmu dalam angka.
      </p>
    </div>

    <div class="card-base p-8 mb-8">
      <label class="block text-sm font-semibold text-matte-700 dark:text-white mb-2 uppercase tracking-wider" data-i18n="label.birth_date">Kapan kamu lahir?</label>
      <div class="flex gap-4 flex-col sm:flex-row">
          <input type="date" id="dob" class="flex-1 p-4 rounded-xl bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border outline-none focus:border-accent-blue font-bold text-matte-800 dark:text-white transition-all cursor-pointer" />
          <button id="calc-btn" class="px-8 py-4 bg-matte-900 dark:bg-white text-white dark:text-matte-900 font-bold rounded-xl transition-all active:scale-95" data-i18n="btn.calculate_age">
              Hitung Umur
          </button>
      </div>
      <p id="error-msg" class="text-red-500 text-sm mt-3 font-bold hidden animate-pulse bg-red-50 dark:bg-red-900/20 p-2 rounded-lg border border-red-200 dark:border-red-800" data-i18n="error.invalid_date">⚠️ Hmm, ada yang salah dengan tanggal yang kamu pilih</p>
    </div>

    <!-- Saved History -->
    <div id="history-section" class="hidden mb-8">
      <div class="card-base p-5">
        <div class="flex items-center justify-between mb-3">
          <h3 class="section-title flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span data-i18n="label.history">Riwayat</span>
          </h3>
          <button id="clear-age-history" class="text-[10px] font-bold text-rose-500 hover:text-rose-600 transition-colors px-2 py-1 rounded-lg hover:bg-rose-50 dark:hover:bg-rose-900/10" data-i18n="btn.clear">Hapus</button>
        </div>
        <div id="age-history-list" class="space-y-1.5 max-h-32 overflow-y-auto">
          <p class="text-xs text-matte-400 italic text-center py-3" data-i18n="text.no_history">Belum ada riwayat</p>
        </div>
      </div>
    </div>

    <div id="result" class="hidden flex-col gap-6 animate-fade-in-up">
        
        <!-- Age Progress Bar -->
        <div class="card-base p-5">
          <div class="flex justify-between items-center mb-2">
            <span class="text-[10px] font-bold text-matte-400 uppercase tracking-wider">Progress Tahun ke-<span id="current-year-number">1</span></span>
            <span id="year-progress-pct" class="text-xs font-bold text-blue-500">0%</span>
          </div>
          <div class="w-full h-2.5 bg-matte-100 dark:bg-matte-700 rounded-full overflow-hidden">
            <div id="year-progress-bar" class="h-full bg-gradient-to-r from-blue-500 to-cyan-400 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
        </div>

        <!-- Live Seconds Counter -->
        <div class="bg-gradient-to-br from-blue-500 to-cyan-500 text-white p-6 rounded-2xl shadow-lg text-center relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -mr-10 -mt-10"></div>
          <div class="absolute bottom-0 left-0 w-24 h-24 bg-white/5 rounded-full -ml-8 -mb-8"></div>
          <p class="text-[10px] font-bold uppercase tracking-widest opacity-80 mb-1" data-i18n="label.total_seconds">Kamu sudah hidup selama</p>
          <p id="live-seconds" class="text-3xl md:text-4xl font-black mb-1 font-mono tracking-wider">0</p>
          <p class="text-[10px] font-bold uppercase tracking-widest opacity-80 mb-4">detik — dan terus bertambah!</p>
          <div class="flex items-center justify-center gap-4 text-xs font-medium">
            <span><span id="live-minutes" class="font-bold">0</span> menit</span>
            <span class="opacity-40">|</span>
            <span><span id="live-hours" class="font-bold">0</span> jam</span>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-3">
            <div class="p-5 bg-blue-50 dark:bg-blue-900/20 rounded-2xl border border-blue-100 dark:border-blue-800 text-center shadow-sm hover:shadow-md transition-shadow">
                <span id="years" class="text-3xl md:text-4xl font-black text-blue-600 dark:text-blue-400 block mb-1">0</span>
                <span class="text-[10px] md:text-xs font-bold text-matte-500 uppercase tracking-widest" data-i18n="label.years">Tahun</span>
            </div>
            <div class="p-5 bg-matte-50 dark:bg-matte-800 rounded-2xl border border-matte-200 dark:border-matte-700 text-center shadow-sm hover:shadow-md transition-shadow">
                <span id="months" class="text-2xl md:text-3xl font-black text-matte-700 dark:text-matte-200 block mb-1">0</span>
                <span class="text-[10px] md:text-xs font-bold text-matte-500 uppercase tracking-widest" data-i18n="label.months">Bulan</span>
            </div>
            <div class="p-5 bg-matte-50 dark:bg-matte-800 rounded-2xl border border-matte-200 dark:border-matte-700 text-center shadow-sm hover:shadow-md transition-shadow">
                <span id="days" class="text-2xl md:text-3xl font-black text-matte-700 dark:text-matte-200 block mb-1">0</span>
                <span class="text-[10px] md:text-xs font-bold text-matte-500 uppercase tracking-widest" data-i18n="label.days">Hari</span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="card-base p-5 relative overflow-hidden group transition-all">
                <div class="absolute top-0 right-0 w-16 h-16 bg-amber-100 dark:bg-amber-900/20 rounded-bl-full -mr-8 -mt-8 transition-transform group-hover:scale-110"></div>
                <h3 class="section-title mb-3" data-i18n="label.next_birthday">Ulang Tahun Berikutnya</h3>
                <div class="flex items-end gap-2 mb-1">
                    <span id="next-bday-count" class="text-3xl font-black text-amber-500">0</span>
                    <span class="text-xs font-bold text-matte-500 mb-1" data-i18n="label.days_left">Hari Lagi</span>
                </div>
                <p id="next-bday-date" class="text-xs font-medium text-matte-600 dark:text-matte-400">Jatuh pada hari...</p>
            </div>

            <div class="card-base p-5 relative overflow-hidden group transition-all">
                <div class="absolute top-0 right-0 w-16 h-16 bg-purple-100 dark:bg-purple-900/20 rounded-bl-full -mr-8 -mt-8 transition-transform group-hover:scale-110"></div>
                <h3 class="section-title mb-3" data-i18n="label.birth_day">Hari Kelahiran</h3>
                <div class="flex items-center gap-3">
                    <div class="p-2 bg-purple-100 dark:bg-purple-900/30 text-purple-600 rounded-lg shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                    </div>
                    <div class="min-w-0">
                        <p id="born-day" class="text-lg font-bold text-matte-800 dark:text-white truncate">Senin</p>
                        <p class="text-[10px] text-matte-400" data-i18n="text.born_on_this_day">Kamu lahir di hari ini.</p>
                    </div>
                </div>
            </div>

            <div class="card-base p-5 relative overflow-hidden group transition-all">
                <div class="absolute top-0 right-0 w-16 h-16 bg-rose-100 dark:bg-rose-900/20 rounded-bl-full -mr-8 -mt-8 transition-transform group-hover:scale-110"></div>
                <h3 class="section-title mb-3" data-i18n="label.zodiac">Zodiak & Shio</h3>
                <div class="flex items-center gap-3">
                    <div class="p-2 bg-rose-100 dark:bg-rose-900/30 text-rose-600 rounded-lg shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    </div>
                    <div class="min-w-0">
                        <p id="zodiac-text" class="text-sm font-bold text-matte-800 dark:text-white truncate">-</p>
                        <p id="shio-text" class="text-[10px] text-matte-400 truncate">-</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-matte-100 dark:bg-surface-hover p-5 rounded-2xl border border-matte-200 dark:border-surface-border">
            <h3 class="section-title mb-4 text-center" data-i18n="label.life_stats">Statistik Kehidupan</h3>
            <div class="grid grid-cols-2 md:grid-cols-5 gap-3 text-center">
                <div class="p-2">
                    <p id="total-months" class="text-lg font-bold text-matte-700 dark:text-white">0</p>
                    <p class="text-[9px] text-matte-400 uppercase mt-1" data-i18n="label.total_months">Bulan</p>
                </div>
                <div class="p-2">
                    <p id="total-weeks" class="text-lg font-bold text-matte-700 dark:text-white">0</p>
                    <p class="text-[9px] text-matte-400 uppercase mt-1" data-i18n="label.total_weeks">Minggu</p>
                </div>
                <div class="p-2">
                    <p id="total-days" class="text-lg font-bold text-matte-700 dark:text-white">0</p>
                    <p class="text-[9px] text-matte-400 uppercase mt-1" data-i18n="label.total_days">Hari</p>
                </div>
                <div class="p-2">
                    <p id="total-hours" class="text-lg font-bold text-matte-700 dark:text-white">0</p>
                    <p class="text-[9px] text-matte-400 uppercase mt-1" data-i18n="label.total_hours">Jam</p>
                </div>
                <div class="p-2">
                    <p id="total-minutes" class="text-lg font-bold text-matte-700 dark:text-white">0</p>
                    <p class="text-[9px] text-matte-400 uppercase mt-1" data-i18n="label.minutes">Menit</p>
                </div>
            </div>
        </div>

        <div class="card-base p-6">
            <h3 class="text-lg font-bold text-matte-800 dark:text-white mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M12 2v20M2 12h20"/></svg>
                <span data-i18n="label.unique_comparisons">Perbandingan Unik</span>
            </h3>
            <div id="comparisons" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 mt-4">
            <button id="save-result" class="flex-1 px-6 py-3 bg-matte-100 dark:bg-surface-elevated text-matte-500 dark:text-matte-300 font-bold rounded-xl hover:bg-matte-200 dark:hover:bg-surface-hover transition-colors flex items-center justify-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg>
                <span data-i18n="btn.save_result">Simpan Hasil</span>
            </button>
            <button id="share-result" class="flex-1 px-6 py-3 bg-matte-100 dark:bg-surface-elevated text-matte-500 dark:text-matte-300 font-bold rounded-xl hover:bg-matte-200 dark:hover:bg-surface-hover transition-colors flex items-center justify-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                <span data-i18n="btn.share">Bagikan</span>
            </button>
        </div>

    </div>

  </div>
</BaseLayout>

<script>
  // ================================================================
  // UTILS
  // ================================================================
  const formatNumber = (num: number) => new Intl.NumberFormat('id-ID').format(num);
  const daysID = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'];
  const monthsID = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'];

  // Zodiak & Shio
  const zodiacs = [
    { name: '♑ Capricorn', start: { m: 1, d: 1 }, end: { m: 1, d: 19 } }, // Keeps as capricorn until jan 19
    { name: '♒ Aquarius', start: { m: 1, d: 20 }, end: { m: 2, d: 18 } },
    { name: '♓ Pisces', start: { m: 2, d: 19 }, end: { m: 3, d: 20 } },
    { name: '♈ Aries', start: { m: 3, d: 21 }, end: { m: 4, d: 19 } },
    { name: '♉ Taurus', start: { m: 4, d: 20 }, end: { m: 5, d: 20 } },
    { name: '♊ Gemini', start: { m: 5, d: 21 }, end: { m: 6, d: 20 } },
    { name: '♋ Cancer', start: { m: 6, d: 21 }, end: { m: 7, d: 22 } },
    { name: '♌ Leo', start: { m: 7, d: 23 }, end: { m: 8, d: 22 } },
    { name: '♍ Virgo', start: { m: 8, d: 23 }, end: { m: 9, d: 22 } },
    { name: '♎ Libra', start: { m: 9, d: 23 }, end: { m: 10, d: 22 } },
    { name: '♏ Scorpio', start: { m: 10, d: 23 }, end: { m: 11, d: 21 } },
    { name: '♐ Sagittarius', start: { m: 11, d: 22 }, end: { m: 12, d: 21 } },
    { name: '♑ Capricorn', start: { m: 12, d: 22 }, end: { m: 12, d: 31 } },
  ];

  const shioAnimals = ['🐭 Tikus', '🐮 Kerbau', '🐯 Macan', '🐰 Kelinci', '🐉 Naga', '🐍 Ular', '🐴 Kuda', '🐑 Kambing', '🐵 Monyet', '🐔 Ayam', '🐶 Anjing', '🐷 Babi'];

  // --- DATA ---
  const comparisons = [
    { title: "Umur Anjing", calc: (y: number) => Math.floor(y * 7), unit: "Tahun", icon: "🐕" },
    { title: "Umur Kucing", calc: (y: number) => Math.floor(y * 6), unit: "Tahun", icon: "🐱" },
    { title: "Detak Jantung", calc: (y: number) => formatNumber(Math.floor(y * 42048000)), unit: "Kali", icon: "❤️" },
    { title: "Kedipan Mata", calc: (y: number) => formatNumber(Math.floor(y * 7884000)), unit: "Kali", icon: "👁️" },
    { title: "Tidur", calc: (y: number) => (y * 0.33).toFixed(1), unit: "Tahun", icon: "💤" },
    { title: "Jalan Bumi", calc: (y: number) => formatNumber(Math.floor(y * 940000000)), unit: "Km", icon: "🌍" },
    { title: "Nafas", calc: (y: number) => formatNumber(Math.floor(y * 10512000)), unit: "Kali", icon: "💨" },
    { title: "Makan (x3/hari)", calc: (y: number) => formatNumber(Math.floor(y * 1095)), unit: "Kali", icon: "🍽️" },
  ];

  // ================================================================
  // ELEMENTS
  // ================================================================
  const dobInput = document.getElementById('dob') as HTMLInputElement;
  const btn = document.getElementById('calc-btn');
  const resBox = document.getElementById('result');
  const errorMsg = document.getElementById('error-msg');
  const comparisonsEl = document.getElementById('comparisons');
  const saveBtn = document.getElementById('save-result');
  const shareBtn = document.getElementById('share-result');

  let currentAgeData: any = {};
  let liveTimer: any = null;
  let dobDate: Date | null = null;

  // ================================================================
  // ZODIAC & SHIO
  // ================================================================
  function getZodiac(month: number, day: number): string {
    const dateNum = month * 100 + day;
    for (const z of zodiacs) {
      const start = z.start.m * 100 + z.start.d;
      const end = z.end.m * 100 + z.end.d;
      if (dateNum >= start && dateNum <= end) return z.name;
    }
    return '♑ Capricorn';
  }

  function getShio(year: number): string {
    return shioAnimals[(year - 4) % 12];
  }

  // ================================================================
  // LIVE COUNTER
  // ================================================================
  function startLiveCounter(dob: Date) {
    if (liveTimer) clearInterval(liveTimer);
    dobDate = dob;
    
    const updateLive = () => {
      if (!dobDate) return;
      const now = new Date();
      const diff = now.getTime() - dobDate.getTime();
      const totalSeconds = Math.floor(diff / 1000);
      
      updateText('live-seconds', formatNumber(totalSeconds));
      updateText('live-minutes', formatNumber(Math.floor(totalSeconds / 60)));
      updateText('live-hours', formatNumber(Math.floor(totalSeconds / 3600)));
    };
    
    updateLive();
    liveTimer = setInterval(updateLive, 1000);
  }

  function stopLiveCounter() {
    if (liveTimer) {
      clearInterval(liveTimer);
      liveTimer = null;
    }
  }

  // ================================================================
  // HISTORY
  // ================================================================
  function renderAgeHistory() {
    const section = document.getElementById('history-section');
    const list = document.getElementById('age-history-list');
    if (!section || !list) return;
    
    try {
      const history = JSON.parse(localStorage.getItem('ageHistory') || '[]');
      if (history.length === 0) {
        section.classList.add('hidden');
        return;
      }
      section.classList.remove('hidden');
      list.innerHTML = history.map((h: any) => `
        <div class="flex items-center justify-between px-3 py-2 rounded-lg bg-matte-50 dark:bg-matte-900/50 text-xs">
          <span class="text-matte-500">${h.date}</span>
          <span class="font-bold text-matte-700 dark:text-matte-300">${h.age}</span>
        </div>
      `).join('');
    } catch {}
  }

  // ================================================================
  // MAIN LOGIC
  // ================================================================
  function calculateAge() {
    errorMsg.classList.add('hidden');
    resBox.classList.add('hidden');

    if (!dobInput.value) {
      var errMsg1 = (window._tToast) ? window._tToast('Eh, lupa masukkan tanggal lahir kamu!') : 'Eh, lupa masukkan tanggal lahir kamu!';
      showError("⚠️ " + errMsg1);
      return;
    }

    const dob = new Date(dobInput.value);
    const now = new Date();

    if (isNaN(dob.getTime())) {
      showError("⚠️ Tanggal tidak valid");
      return;
    }

    if (dob > now) {
      var errMsg2 = (window._tToast) ? window._tToast('Kamu dari masa depan ya? Pilih tanggal yang valid.') : 'Kamu dari masa depan ya? Pilih tanggal yang valid.';
      showError("⚠️ " + errMsg2);
      return;
    }

    // Stop previous live counter
    stopLiveCounter();

    // Calc Age
    let years = now.getFullYear() - dob.getFullYear();
    let months = now.getMonth() - dob.getMonth();
    let days = now.getDate() - dob.getDate();

    if (days < 0) {
      months--;
      days += new Date(now.getFullYear(), now.getMonth(), 0).getDate();
    }
    if (months < 0) {
      years--;
      months += 12;
    }

    // Calc Next Birthday
    const currentYear = now.getFullYear();
    let nextBirthday = new Date(currentYear, dob.getMonth(), dob.getDate());
    if (now > nextBirthday) nextBirthday.setFullYear(currentYear + 1);

    const timeDiff = nextBirthday.getTime() - now.getTime();
    const daysToNextBday = Math.ceil(timeDiff / (1000 * 60 * 60 * 24));
    const nextBdayDayName = daysID[nextBirthday.getDay()];
    const nextBdayDateString = `${nextBirthday.getDate()} ${monthsID[nextBirthday.getMonth()]} ${nextBirthday.getFullYear()}`;

    // Calc Total Stats
    const totalTimeDiff = now.getTime() - dob.getTime();
    const totalDays = Math.floor(totalTimeDiff / (1000 * 60 * 60 * 24));
    const totalWeeks = Math.floor(totalDays / 7);
    const totalMonths = (years * 12) + months;
    const totalHours = Math.floor(totalTimeDiff / (1000 * 60 * 60));
    const totalMinutes = Math.floor(totalTimeDiff / (1000 * 60));

    // Year progress
    const yearStart = new Date(now.getFullYear(), 0, 1);
    const yearEnd = new Date(now.getFullYear() + 1, 0, 1);
    const yearProgress = ((now.getTime() - yearStart.getTime()) / (yearEnd.getTime() - yearStart.getTime())) * 100;

    // Zodiak & Shio
    const zodiac = getZodiac(dob.getMonth() + 1, dob.getDate());
    const shio = getShio(dob.getFullYear());

    // Store Data
    currentAgeData = { years, months, days, totalDays };

    // Update UI
    updateText('years', years);
    updateText('months', months);
    updateText('days', days);
    updateText('next-bday-count', daysToNextBday);
    var fallsOnText = (window._tToast) ? window._tToast('Jatuh pada hari') : 'Jatuh pada hari';
    updateText('next-bday-date', fallsOnText + ' ' + nextBdayDayName + ', ' + nextBdayDateString);
    updateText('born-day', daysID[dob.getDay()]);
    
    // Zodiak & Shio
    updateText('zodiac-text', zodiac);
    updateText('shio-text', 'Shio ' + shio);
    
    // Stats
    updateText('total-months', formatNumber(totalMonths));
    updateText('total-weeks', formatNumber(totalWeeks));
    updateText('total-days', formatNumber(totalDays));
    updateText('total-hours', formatNumber(totalHours));
    updateText('total-minutes', formatNumber(totalMinutes));
    
    // Year progress bar
    updateText('current-year-number', years + 1);
    updateText('year-progress-pct', Math.round(yearProgress) + '%');
    const bar = document.getElementById('year-progress-bar');
    if (bar) bar.style.width = yearProgress + '%';

    renderComparisons(years);
    
    // Start live counter
    startLiveCounter(dob);

    resBox.classList.remove('hidden');
    resBox.classList.add('flex');
    
    if (window.innerWidth < 768) {
      resBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  function showError(msg: string) {
    if (errorMsg) {
      errorMsg.innerText = msg;
      errorMsg.classList.remove('hidden');
    }
  }

  function updateText(id: string, text: string | number) {
    const el = document.getElementById(id);
    if (el) el.innerText = String(text);
  }

  function renderComparisons(years: number) {
    if (!comparisonsEl) return;
    comparisonsEl.innerHTML = '';
    // Pick 4 random from the array deterministically based on year
    const shuffled = [...comparisons];
    // Fisher-Yates with seed from year for consistency
    for (let i = shuffled.length - 1; i > 0; i--) {
      const seed = (years * 31 + i * 7) % 100;
      const j = Math.floor(seed / 100 * (i + 1));
      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    const picked = shuffled.slice(0, 4);
    
    picked.forEach(comp => {
      let val = comp.calc(years);
      const div = document.createElement('div');
      div.className = 'flex items-center gap-3 p-3 bg-matte-50 dark:bg-matte-700/50 rounded-xl border border-matte-100 dark:border-matte-700';
      div.innerHTML = `
        <div class="text-2xl">${comp.icon}</div>
        <div class="min-w-0">
          <p class="text-[10px] text-matte-400 font-bold uppercase truncate">${comp.title}</p>
          <p class="text-base font-bold text-matte-800 dark:text-white">${val} ${comp.unit}</p>
        </div>
      `;
      comparisonsEl.appendChild(div);
    });
  }

  // ================================================================
  // EVENTS
  // ================================================================
  btn?.addEventListener('click', calculateAge);
  
  // Auto-calculate on date change (if not the first empty value)
  dobInput?.addEventListener('input', () => {
    if (dobInput.value) calculateAge();
  });
  
  // Enter key support
  dobInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') calculateAge();
  });

  // ================================================================
  // ACTIONS
  // ================================================================
  saveBtn?.addEventListener('click', () => {
    if (!currentAgeData.years && currentAgeData.years !== 0) return;
    
    const history = JSON.parse(localStorage.getItem('ageHistory') || '[]');
    history.unshift({
      date: new Date().toLocaleDateString('id-ID'),
      age: `${currentAgeData.years} Thn ${currentAgeData.months} Bln`
    });
    if (history.length > 10) history.pop();
    
    localStorage.setItem('ageHistory', JSON.stringify(history));
    renderAgeHistory();
    window.showToast((window._tToast) ? window._tToast('Hasil berhasil disimpan!') : 'Hasil berhasil disimpan!', 'success');
  });

  shareBtn?.addEventListener('click', () => {
    if (!currentAgeData.years && currentAgeData.years !== 0) return;
    const text = `Saya sudah hidup selama ${formatNumber(currentAgeData.totalDays)} hari (${currentAgeData.years} Tahun)! Hitung umurmu di sini.`;
    
    if (navigator.share) {
      navigator.share({ title: 'Age Master', text: text }).catch(() => {});
    } else {
      navigator.clipboard.writeText(text);
      window.showToast((window._tToast) ? window._tToast('Teks disalin ke clipboard!') : 'Teks disalin ke clipboard!', 'success');
    }
  });

  // Clear history
  document.getElementById('clear-age-history')?.addEventListener('click', () => {
    localStorage.removeItem('ageHistory');
    renderAgeHistory();
    window.showToast('Riwayat dibersihkan!', 'success');
  });

  // Set Max Date Today
  const today = new Date().toISOString().split('T')[0];
  dobInput?.setAttribute('max', today);
  
  // Render history on load
  renderAgeHistory();
  
  // Cleanup interval on page navigation
  document.addEventListener('astro:after-swap', () => {
    stopLiveCounter();
  });
</script>