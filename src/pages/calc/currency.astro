---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Real-time Currency Converter">
  <div class="max-w-xl mx-auto px-4 min-h-[60vh]">
    <div class="text-center mb-8 pt-8 animate-on-scroll">
      <h1 class="text-3xl font-extrabold mb-2 text-transparent bg-clip-text bg-gradient-to-r from-green-500 to-emerald-600">
        Konversi Mata Uang
      </h1>
      <p class="text-slate-600 dark:text-slate-400">
        Kurs live real-time (Update harian/jam).
      </p>
    </div>

    <div class="bg-white dark:bg-slate-800 p-8 rounded-3xl border border-slate-200 dark:border-slate-700 shadow-2xl animate-fade-in relative overflow-hidden">
      
      <div id="loading" class="absolute inset-0 bg-white/90 dark:bg-slate-900/90 z-20 flex items-center justify-center backdrop-blur-sm transition-opacity duration-300">
        <div class="flex flex-col items-center gap-2">
            <svg class="animate-spin h-8 w-8 text-emerald-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            <span class="text-sm font-bold text-emerald-600">Sinkronisasi Data...</span>
        </div>
      </div>

      <div class="space-y-6">
        
        <div>
            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Jumlah Uang</label>
            <input type="number" id="amount" value="1" min="0" class="w-full p-4 text-2xl font-bold rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-600 focus:border-emerald-500 outline-none transition-all text-slate-800 dark:text-white placeholder-slate-400" placeholder="0" />
        </div>

        <div class="flex items-center gap-2">
            <div class="flex-1">
                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Dari</label>
                <div class="relative">
                    <select id="from-currency" class="w-full p-3 rounded-xl bg-slate-100 dark:bg-slate-700 border border-transparent hover:border-slate-300 dark:hover:border-slate-600 font-bold text-slate-700 dark:text-slate-200 cursor-pointer outline-none appearance-none text-center">
                        <option value="USD">🇺🇸 USD</option>
                        <option value="IDR">🇮🇩 IDR</option>
                        <option value="EUR">🇪🇺 EUR</option>
                        <option value="SGD">🇸🇬 SGD</option>
                        <option value="MYR">🇲🇾 MYR</option>
                        <option value="JPY">🇯🇵 JPY</option>
                        <option value="GBP">🇬🇧 GBP</option>
                        <option value="AUD">🇦🇺 AUD</option>
                        <option value="CNY">🇨🇳 CNY</option>
                        <option value="KRW">🇰🇷 KRW</option>
                        <option value="SAR">🇸🇦 SAR</option>
                        <option value="THB">🇹🇭 THB</option>
                    </select>
                </div>
            </div>

            <button id="swap-btn" class="mt-5 p-3 rounded-full bg-slate-100 dark:bg-slate-700 text-emerald-600 hover:bg-emerald-100 hover:scale-110 transition-all shadow-sm group">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-180 transition-transform duration-300"><path d="M7.5 14.25L2.25 9l5.25-5.25"/><path d="M2.25 9h19.5"/><path d="M16.5 9.75L21.75 15l-5.25 5.25"/><path d="M21.75 15H2.25"/></svg>
            </button>

            <div class="flex-1">
                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Ke</label>
                <div class="relative">
                    <select id="to-currency" class="w-full p-3 rounded-xl bg-slate-100 dark:bg-slate-700 border border-transparent hover:border-slate-300 dark:hover:border-slate-600 font-bold text-slate-700 dark:text-slate-200 cursor-pointer outline-none appearance-none text-center">
                        <option value="IDR" selected>🇮🇩 IDR</option>
                        <option value="USD">🇺🇸 USD</option>
                        <option value="EUR">🇪🇺 EUR</option>
                        <option value="SGD">🇸🇬 SGD</option>
                        <option value="MYR">🇲🇾 MYR</option>
                        <option value="JPY">🇯🇵 JPY</option>
                        <option value="GBP">🇬🇧 GBP</option>
                        <option value="AUD">🇦🇺 AUD</option>
                        <option value="CNY">🇨🇳 CNY</option>
                        <option value="KRW">🇰🇷 KRW</option>
                        <option value="SAR">🇸🇦 SAR</option>
                        <option value="THB">🇹🇭 THB</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="bg-emerald-50 dark:bg-emerald-900/20 p-6 rounded-2xl border border-emerald-100 dark:border-emerald-800 text-center transition-all hover:shadow-md">
            <p class="text-sm text-emerald-600 dark:text-emerald-400 font-medium mb-1">Hasil Konversi</p>
            <div id="result" class="text-3xl md:text-4xl font-extrabold text-slate-800 dark:text-white break-words tracking-tight">
                ...
            </div>
            <p id="rate-info" class="text-xs text-slate-400 mt-2 font-mono">1 USD = ... IDR</p>
        </div>

        <p class="text-[10px] text-center text-slate-400">
            Data provided by open.er-api.com. Auto-update saat koneksi tersedia.
        </p>

      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // 1. DATA DARURAT (Snapshot Data)
  // Ini kunci agar tidak stuck loading. Data ini dipakai DULUAN sebelum fetch API selesai.
  const fallbackRates = {
    "USD": 1, "IDR": 16400, "EUR": 0.92, "SGD": 1.35, "MYR": 4.71,
    "JPY": 157.8, "GBP": 0.78, "AUD": 1.50, "CNY": 7.25, "KRW": 1380,
    "SAR": 3.75, "THB": 36.5
  };

  // Elements
  const amountEl = document.getElementById('amount');
  const fromEl = document.getElementById('from-currency');
  const toEl = document.getElementById('to-currency');
  const resultEl = document.getElementById('result');
  const rateInfoEl = document.getElementById('rate-info');
  const swapBtn = document.getElementById('swap-btn');
  const loadingEl = document.getElementById('loading');

  // Gunakan fallback dulu biar UI langsung aktif
  let rates = fallbackRates;

  // Fungsi Utama: Ambil Data
  async function initCurrency() {
    // 1. Langsung hitung pakai data fallback (Instant UX)
    calculate();
    
    // 2. Cek Cache LocalStorage (Biar lebih akurat dari fallback)
    const cached = localStorage.getItem('simpleRates');
    if (cached) {
        try {
            const parsed = JSON.parse(cached);
            // Validasi cache 24 jam
            if (Date.now() - parsed.timestamp < 24 * 60 * 60 * 1000) {
                rates = parsed.rates;
                calculate();
                console.log('⚡ Menggunakan Cache');
            }
        } catch (e) {}
    }

    // 3. Matikan Loading Screen SEGERA (Max 500ms)
    // Kita gak mau user nunggu API. Biarkan API jalan di background.
    setTimeout(() => {
        loadingEl.style.opacity = '0';
        setTimeout(() => loadingEl.classList.add('hidden'), 300);
    }, 500);

    // 4. Update Data Terbaru di Background (Silent)
    try {
        const response = await fetch('https://open.er-api.com/v6/latest/USD');
        const data = await response.json();
        
        if (data && data.rates) {
            rates = data.rates;
            // Update UI lagi dengan data baru
            calculate();
            // Simpan ke cache
            localStorage.setItem('simpleRates', JSON.stringify({
                rates: data.rates,
                timestamp: Date.now()
            }));
            console.log('✅ Data terbaru berhasil diambil');
        }
    } catch (error) {
        console.warn('⚠️ Gagal update data, menggunakan cache/fallback.');
        // Gak perlu alert user, karena kalkulator tetap jalan pakai fallback.
    }
  }

  function formatCurrency(num, currency) {
    try {
        return new Intl.NumberFormat('id-ID', { 
            style: 'currency', 
            currency: currency, 
            maximumFractionDigits: 2 
        }).format(num);
    } catch (e) {
        return num.toLocaleString();
    }
  }

  function calculate() {
    const amount = parseFloat(amountEl.value);
    const from = fromEl.value;
    const to = toEl.value;

    // Proteksi jika rates belum siap (seharusnya aman karena ada fallback)
    if (!rates[from] || !rates[to] || isNaN(amount)) {
        return;
    }

    // Rumus Cross Rate (Base USD)
    // RateFrom = Berapa USD untuk 1 unit From
    // RateTo = Berapa USD untuk 1 unit To
    const rateFrom = rates[from];
    const rateTo = rates[to];

    const converted = (amount / rateFrom) * rateTo;
    const singleUnit = (1 / rateFrom) * rateTo;

    resultEl.innerText = formatCurrency(converted, to);
    rateInfoEl.innerText = `1 ${from} = ${formatCurrency(singleUnit, to)}`;
  }

  // Event Listeners
  [amountEl, fromEl, toEl].forEach(el => el.addEventListener('input', calculate));

  swapBtn.addEventListener('click', () => {
    const temp = fromEl.value;
    fromEl.value = toEl.value;
    toEl.value = temp;
    
    // Animasi putar icon manual lewat class sudah ada di HTML
    calculate();
  });

  // Jalankan saat load
  document.addEventListener('DOMContentLoaded', initCurrency);

</script>