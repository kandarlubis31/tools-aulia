---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Real-time Currency Converter">
  <div class="max-w-xl mx-auto px-4 min-h-[60vh]">
    <div class="text-center mb-8 pt-8 animate-fade-in">
      <h1 class="text-3xl font-extrabold mb-2 text-matte-900 dark:text-white" data-i18n="header.currency">
        Konversi Mata Uang
      </h1>
      <p class="text-matte-400 dark:text-matte-300" data-i18n="header.currency_desc">
        Kurs live real-time dengan smart caching.
      </p>
    </div>

    <div class="card-base p-8 animate-fade-in-up relative overflow-hidden">
      
      <div id="loading" class="absolute inset-0 bg-white/90 dark:bg-matte-900/90 z-20 flex items-center justify-center backdrop-blur-sm transition-opacity duration-500">
        <div class="flex flex-col items-center gap-2">
            <svg class="animate-spin h-8 w-8 text-emerald-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            <span class="text-sm font-bold text-emerald-600" data-i18n="msg.syncing">Sinkronisasi Data...</span>
        </div>
      </div>

      <div class="space-y-6">
        
        <div>
            <label class="section-title mb-1" data-i18n="label.amount_money">Jumlah Uang</label>
            
            <input type="number" id="amount" value="1" min="0" class="w-full p-4 text-2xl font-bold rounded-xl bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border focus:border-accent-blue outline-none transition-all text-matte-800 dark:text-white placeholder-matte-400" placeholder="0" />

            <div class="flex flex-wrap gap-2 mt-3">
                <button class="shortcut-btn px-3 py-1 text-xs font-bold rounded-md bg-matte-200 dark:bg-matte-700 text-matte-600 dark:text-matte-300 hover:bg-emerald-100 hover:text-emerald-700 dark:hover:bg-emerald-900 transition-colors" data-multiply="100">
                    <span data-i18n="shortcut.hundreds">+00 (Ratus)</span>
                </button>
                <button class="shortcut-btn px-3 py-1 text-xs font-bold rounded-md bg-matte-200 dark:bg-matte-700 text-matte-600 dark:text-matte-300 hover:bg-emerald-100 hover:text-emerald-700 dark:hover:bg-emerald-900 transition-colors" data-multiply="1000">
                    <span data-i18n="shortcut.thousands">+000 (Ribu)</span>
                </button>
                <button class="shortcut-btn px-3 py-1 text-xs font-bold rounded-md bg-matte-200 dark:bg-matte-700 text-matte-600 dark:text-matte-300 hover:bg-emerald-100 hover:text-emerald-700 dark:hover:bg-emerald-900 transition-colors" data-multiply="1000000">
                    <span data-i18n="shortcut.millions">+Juta (000.000)</span>
                </button>
                <button id="reset-amount" class="px-3 py-1 text-xs font-bold rounded-md bg-rose-100 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400 hover:bg-rose-200 transition-colors ml-auto" data-i18n="btn.reset">
                    Reset
                </button>
            </div>
        </div>

        <div class="flex items-center gap-2">
            <div class="flex-1">
                <label class="section-title mb-1" data-i18n="label.from">Dari</label>
                <div class="relative">
                    <label for="from-currency" class="sr-only">Mata Uang Asal</label>
                    <select id="from-currency" class="w-full p-3 rounded-xl bg-matte-100 dark:bg-matte-700 border border-transparent hover:border-matte-300 dark:hover:border-matte-600 font-bold text-matte-700 dark:text-matte-200 cursor-pointer outline-none appearance-none text-center">
                        <option value="USD">🇺🇸 USD</option>
                        <option value="IDR">🇮🇩 IDR</option>
                        <option value="EUR">🇪🇺 EUR</option>
                        <option value="SGD">🇸🇬 SGD</option>
                        <option value="MYR">🇲🇾 MYR</option>
                        <option value="JPY">🇯🇵 JPY</option>
                        <option value="GBP">🇬🇧 GBP</option>
                        <option value="AUD">🇦🇺 AUD</option>
                        <option value="CNY">🇨🇳 CNY</option>
                        <option value="KRW">🇰🇷 KRW</option>
                        <option value="SAR">🇸🇦 SAR</option>
                        <option value="THB">🇹🇭 THB</option>
                    </select>
                </div>
            </div>

            <button id="swap-btn" class="mt-5 p-3 rounded-full bg-matte-100 dark:bg-matte-700 text-emerald-600 hover:bg-emerald-100 hover:scale-110 transition-all shadow-sm group">
                <svg id="swap-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-500"><path d="M7.5 14.25L2.25 9l5.25-5.25"/><path d="M2.25 9h19.5"/><path d="M16.5 9.75L21.75 15l-5.25 5.25"/><path d="M21.75 15H2.25"/></svg>
            </button>

            <div class="flex-1">
                <label class="section-title mb-1" data-i18n="label.to">Ke</label>
                <div class="relative">
                    <label for="to-currency" class="sr-only">Mata Uang Tujuan</label>
                    <select id="to-currency" class="w-full p-3 rounded-xl bg-matte-100 dark:bg-matte-700 border border-transparent hover:border-matte-300 dark:hover:border-matte-600 font-bold text-matte-700 dark:text-matte-200 cursor-pointer outline-none appearance-none text-center">
                        <option value="IDR" selected>🇮🇩 IDR</option>
                        <option value="USD">🇺🇸 USD</option>
                        <option value="EUR">🇪🇺 EUR</option>
                        <option value="SGD">🇸🇬 SGD</option>
                        <option value="MYR">🇲🇾 MYR</option>
                        <option value="JPY">🇯🇵 JPY</option>
                        <option value="GBP">🇬🇧 GBP</option>
                        <option value="AUD">🇦🇺 AUD</option>
                        <option value="CNY">🇨🇳 CNY</option>
                        <option value="KRW">🇰🇷 KRW</option>
                        <option value="SAR">🇸🇦 SAR</option>
                        <option value="THB">🇹🇭 THB</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="bg-matte-100 dark:bg-surface-hover p-6 rounded-2xl border border-matte-200 dark:border-surface-border text-center transition-all">
            <p class="text-sm text-emerald-600 dark:text-emerald-400 font-medium mb-1" data-i18n="msg.conversion_result">Hasil Konversi</p>
            <div id="result" class="text-3xl md:text-4xl font-extrabold text-matte-800 dark:text-white break-words tracking-tight">
                ...
            </div>
            <p id="rate-info" class="text-xs text-matte-400 mt-2 font-mono">1 USD = ... IDR</p>
        </div>

        <p class="text-[10px] text-center text-matte-400" data-i18n="msg.data_source">
            Sumber data: open.er-api.com. Diperbarui otomatis.
        </p>

      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  // Menggunakan astro:page-load agar script jalan setiap navigasi (View Transitions)
  document.addEventListener('astro:page-load', () => {
    
    // 1. SELECTORS & NULL CHECKS
    const amountEl = document.getElementById('amount');
    const fromEl = document.getElementById('from-currency');
    const toEl = document.getElementById('to-currency');
    const resultEl = document.getElementById('result');
    const rateInfoEl = document.getElementById('rate-info');
    const swapBtn = document.getElementById('swap-btn');
    const swapIcon = document.getElementById('swap-icon');
    const loadingEl = document.getElementById('loading');
    
    // Selectors baru untuk shortcut
    const shortcutBtns = document.querySelectorAll('.shortcut-btn');
    const resetAmountBtn = document.getElementById('reset-amount');

    // Kalau elemen utama gak ada (misal beda halaman), stop script
    if (!amountEl || !fromEl || !toEl || !resultEl) return;

    // 2. DATA
    const fallbackRates = {
        "USD": 1, "IDR": 16400, "EUR": 0.92, "SGD": 1.35, "MYR": 4.71,
        "JPY": 157.8, "GBP": 0.78, "AUD": 1.50, "CNY": 7.25, "KRW": 1380,
        "SAR": 3.75, "THB": 36.5
    };
    
    let rates = fallbackRates;

    // 3. FUNGSI LOGIC
    function formatCurrency(num, currency) {
        try {
            return new Intl.NumberFormat('id-ID', { 
                style: 'currency', 
                currency: currency, 
                maximumFractionDigits: 2 
            }).format(num);
        } catch (e) {
            return num.toLocaleString();
        }
    }

    function calculate() {
        // Handle input kosong atau negatif
        let val = parseFloat(amountEl.value);
        if (isNaN(val) || val < 0) val = 0;

        const from = fromEl.value;
        const to = toEl.value;

        if (!rates[from] || !rates[to]) return;

        // Rumus Cross Rate
        const rateFrom = rates[from];
        const rateTo = rates[to];
        
        const converted = (val / rateFrom) * rateTo;
        const singleUnit = (1 / rateFrom) * rateTo;

        resultEl.innerText = formatCurrency(converted, to);
        rateInfoEl.innerText = `1 ${from} = ${formatCurrency(singleUnit, to)}`;
    }

    async function initCurrency() {
        // Cek Cache LocalStorage
        const cached = localStorage.getItem('simpleRates');
        let usedCache = false;

        if (cached) {
            try {
                const parsed = JSON.parse(cached);
                // Validasi umur cache (24 jam)
                if (Date.now() - parsed.timestamp < 24 * 60 * 60 * 1000) {
                    rates = parsed.rates;
                    calculate();
                    usedCache = true;
                    // Hilangkan loading segera jika ada cache
                    loadingEl.style.opacity = '0';
                    setTimeout(() => loadingEl.classList.add('hidden'), 300);
                }
            } catch (e) {}
        }

        // Kalau tidak ada cache, hitung pakai fallback dulu
        if (!usedCache) calculate();

        // Fetch Data Terbaru di Background
        try {
            const response = await fetch('https://open.er-api.com/v6/latest/USD');
            const data = await response.json();
            
            if (data && data.rates) {
                rates = data.rates;
                calculate(); // Update UI dengan data live
                
                // Simpan cache
                localStorage.setItem('simpleRates', JSON.stringify({
                    rates: data.rates,
                    timestamp: Date.now()
                }));
            }
        } catch (error) {
        } finally {
            // Pastikan loading hilang
            if (loadingEl) {
                loadingEl.style.opacity = '0';
                setTimeout(() => loadingEl.classList.add('hidden'), 500);
            }
        }
    }

    // 4. EVENT LISTENERS UTAMA
    amountEl.addEventListener('input', calculate);
    fromEl.addEventListener('change', calculate);
    toEl.addEventListener('change', calculate);

    swapBtn.addEventListener('click', () => {
        // Animasi icon
        swapIcon.classList.add('rotate-180');
        setTimeout(() => swapIcon.classList.remove('rotate-180'), 500);

        // Tukar value
        const temp = fromEl.value;
        fromEl.value = toEl.value;
        toEl.value = temp;
        
        calculate();
    });

    // 5. EVENT LISTENERS SHORTCUT (New Feature)
    if (shortcutBtns) {
        shortcutBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                // Ambil nilai sekarang
                let currentVal = parseFloat(amountEl.value) || 0;
                // Kalau 0, set jadi 1 dulu biar bisa dikali
                if(currentVal === 0) currentVal = 1; 

                // Ambil multiplier dari data attribute HTML
                const multiplier = parseFloat(btn.dataset.multiply);
                
                // Kalkulasi
                amountEl.value = currentVal * multiplier;

                // Visual feedback (flash green)
                amountEl.classList.add('bg-emerald-100', 'dark:bg-emerald-900');
                setTimeout(() => amountEl.classList.remove('bg-emerald-100', 'dark:bg-emerald-900'), 200);

                // Update hasil
                calculate();
            });
        });
    }

    if (resetAmountBtn) {
        resetAmountBtn.addEventListener('click', () => {
            amountEl.value = "1";
            calculate();
            // Focus balik ke input biar user bisa langsung ketik
            amountEl.focus();
        });
    }

    // Jalankan init
    initCurrency();
  });
</script>