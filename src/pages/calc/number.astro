---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Number Base Converter">
  <div class="max-w-3xl mx-auto px-4 min-h-[60vh]">
    <div class="text-center mb-10 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-matte-900 dark:text-white" data-i18n="header.number">
        Base Converter
      </h1>
      <p class="text-matte-400 dark:text-matte-300" data-i18n="header.number_desc">
        Konversi angka Biner, Oktal, Desimal, dan Hexadesimal secara instan.
      </p>
    </div>

    <div class="card-base p-8 animate-fade-in space-y-6">
      
      <div>
         <label class="section-title mb-1" data-i18n="label.decimal">Decimal (10)</label>
         <input type="text" id="inp-dec" class="base-input w-full p-3 font-mono text-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border rounded-lg outline-none focus:border-accent-blue transition-colors" placeholder="0-9" data-i18n-attr="placeholder" data-i18n="ph.decimal" />
      </div>

      <div>
         <label class="section-title mb-1" data-i18n="label.binary">Binary (2)</label>
         <input type="text" id="inp-bin" class="base-input w-full p-3 font-mono text-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border rounded-lg outline-none focus:border-accent-blue transition-colors" placeholder="0-1" data-i18n-attr="placeholder" data-i18n="ph.binary" />
      </div>

      <div>
         <label class="section-title mb-1" data-i18n="label.hex">Hexadecimal (16)</label>
         <input type="text" id="inp-hex" class="base-input w-full p-3 font-mono text-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border rounded-lg outline-none focus:border-accent-blue transition-colors uppercase" placeholder="0-9, A-F" data-i18n-attr="placeholder" data-i18n="ph.hex" />
      </div>

      <div>
         <label class="section-title mb-1" data-i18n="label.octal">Octal (8)</label>
         <input type="text" id="inp-oct" class="base-input w-full p-3 font-mono text-lg bg-matte-100 dark:bg-surface-hover border border-matte-200 dark:border-surface-border rounded-lg outline-none focus:border-accent-blue transition-colors" placeholder="0-7" data-i18n-attr="placeholder" data-i18n="ph.octal" />
      </div>

      <div class="flex justify-end pt-4">
         <button id="clear-btn" class="text-sm font-bold text-rose-500 hover:text-rose-600 px-4 py-2 hover:bg-matte-100 dark:hover:bg-surface-hover rounded-lg transition" data-i18n="btn.reset">Reset</button>
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
  const dec = document.getElementById('inp-dec');
  const bin = document.getElementById('inp-bin');
  const hex = document.getElementById('inp-hex');
  const oct = document.getElementById('inp-oct');
  const clearBtn = document.getElementById('clear-btn');

  function update(val, radix) {
    if (val === '') {
        reset();
        return;
    }
    
    // Parse int dari basis asal
    const num = parseInt(val, radix);
    
    if (isNaN(num)) return; // Stop jika input invalid

    // Update field lain (jangan update field sumber agar kursor gak lompat)
    if (radix !== 10) dec.value = num.toString(10);
    if (radix !== 2) bin.value = num.toString(2);
    if (radix !== 16) hex.value = num.toString(16).toUpperCase();
    if (radix !== 8) oct.value = num.toString(8);
  }

  // Event Listeners
  dec.addEventListener('input', (e) => update(e.target.value, 10));
  bin.addEventListener('input', (e) => update(e.target.value, 2));
  hex.addEventListener('input', (e) => update(e.target.value, 16));
  oct.addEventListener('input', (e) => update(e.target.value, 8));

  function reset() {
    [dec, bin, hex, oct].forEach(el => el.value = '');
  }

  clearBtn.addEventListener('click', reset);
  });
</script>
