---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Case Converter">
  <div class="max-w-4xl mx-auto px-4 min-h-[60vh]">
    <div class="text-center mb-8 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-matte-900 dark:text-white">
        Case Converter
      </h1>
      <p class="text-matte-400 dark:text-matte-300" data-i18n="header.case_desc">
        Ubah format huruf teks Anda dengan satu klik.
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-2 mb-6 animate-fade-in">
       <button class="case-btn bg-matte-100 dark:bg-surface-elevated hover:bg-matte-200 dark:hover:bg-surface-hover text-matte-500 dark:text-matte-300 hover:text-accent-blue px-4 py-2 rounded-lg font-bold text-sm transition" data-case="upper">UPPERCASE</button>
       <button class="case-btn bg-matte-100 dark:bg-surface-elevated hover:bg-matte-200 dark:hover:bg-surface-hover text-matte-500 dark:text-matte-300 hover:text-accent-blue px-4 py-2 rounded-lg font-bold text-sm transition" data-case="lower">lowercase</button>
       <button class="case-btn bg-matte-100 dark:bg-surface-elevated hover:bg-matte-200 dark:hover:bg-surface-hover text-matte-500 dark:text-matte-300 hover:text-accent-blue px-4 py-2 rounded-lg font-bold text-sm transition" data-case="title">Title Case</button>
       <button class="case-btn bg-matte-100 dark:bg-surface-elevated hover:bg-matte-200 dark:hover:bg-surface-hover text-matte-500 dark:text-matte-300 hover:text-accent-blue px-4 py-2 rounded-lg font-bold text-sm transition" data-case="sentence">Sentence case</button>
       <button class="case-btn bg-matte-100 dark:bg-surface-elevated hover:bg-matte-200 dark:hover:bg-surface-hover text-matte-500 dark:text-matte-300 hover:text-accent-blue px-4 py-2 rounded-lg font-bold text-sm transition" data-case="camel">camelCase</button>
       <button class="case-btn bg-matte-100 dark:bg-surface-elevated hover:bg-matte-200 dark:hover:bg-surface-hover text-matte-500 dark:text-matte-300 hover:text-accent-blue px-4 py-2 rounded-lg font-bold text-sm transition" data-case="snake">snake_case</button>
       <button class="case-btn bg-matte-100 dark:bg-surface-elevated hover:bg-matte-200 dark:hover:bg-surface-hover text-matte-500 dark:text-matte-300 hover:text-accent-blue px-4 py-2 rounded-lg font-bold text-sm transition" data-case="kebab">kebab-case</button>
    </div>

    <div class="flex flex-col h-96 card-base overflow-hidden animate-fade-in">
       <div class="bg-matte-100 dark:bg-surface-hover px-4 py-2 border-b border-matte-200 dark:border-surface-border flex justify-between items-center">
          <span class="section-title" data-i18n="text.case_editor">Text Editor</span>
          <div class="flex gap-2">
             <button id="copy-btn" class="text-xs font-bold text-accent-blue hover:opacity-80">Copy</button>
             <button id="clear-btn" class="text-xs font-bold text-rose-500 hover:text-rose-600 ml-2">Clear</button>
          </div>
       </div>
       <textarea id="text-input" class="flex-1 w-full p-6 font-sans text-lg bg-transparent text-matte-800 dark:text-white outline-none resize-none" placeholder="Ketik atau tempel teks di sini..." data-i18n-attr="placeholder" data-i18n="ph.type_or_paste"></textarea>
       
       <div class="bg-matte-100 dark:bg-surface-hover px-4 py-2 border-t border-matte-200 dark:border-surface-border text-xs text-matte-400">
          <span id="char-count">0 <span data-i18n="text.characters">karakter</span></span> | <span id="word-count">0 <span data-i18n="text.words">kata</span></span>
       </div>
    </div>

  </div>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
  const input = document.getElementById('text-input');
  const copyBtn = document.getElementById('copy-btn');
  const clearBtn = document.getElementById('clear-btn');
  const charCount = document.getElementById('char-count');
  const wordCount = document.getElementById('word-count');
  const btns = document.querySelectorAll('.case-btn');

  function updateCounts() {
    const val = input.value;
    const charNum = charCount.querySelector('span') || charCount;
    const wordNum = wordCount.querySelector('span') || wordCount;
    if (charNum && charNum !== charCount) {
      charCount.childNodes[0].textContent = val.length + ' ';
    } else {
      charCount.innerText = val.length + ' karakter';
    }
    const wordCountVal = val.trim().split(/\s+/).filter(w => w).length;
    if (wordNum && wordNum !== wordCount) {
      wordCount.childNodes[0].textContent = wordCountVal + ' ';
    } else {
      wordCount.innerText = wordCountVal + ' kata';
    }
  }

  function convert(type) {
    let val = input.value;
    if(!val) return;

    switch(type) {
        case 'upper': 
            val = val.toUpperCase(); 
            break;
        case 'lower': 
            val = val.toLowerCase(); 
            break;
        case 'title': 
            val = val.toLowerCase().replace(/(?:^|\s)\w/g, a => a.toUpperCase());
            break;
        case 'sentence': 
            val = val.toLowerCase().replace(/(^\w|\.\s+\w)/gm, a => a.toUpperCase());
            break;
        case 'camel':
            val = val.toLowerCase().replace(/[^a-zA-Z0-9]+(.)/g, (m, chr) => chr.toUpperCase());
            break;
        case 'snake':
            val = val && val.match(/[A-Z]{2,}(?=[A-Z][a-z]+[0-9]*|\b)|[A-Z]?[a-z]+[0-9]*|[A-Z]|[0-9]+/g)
                      .map(x => x.toLowerCase())
                      .join('_');
            break;
        case 'kebab':
            val = val && val.match(/[A-Z]{2,}(?=[A-Z][a-z]+[0-9]*|\b)|[A-Z]?[a-z]+[0-9]*|[A-Z]|[0-9]+/g)
                      .map(x => x.toLowerCase())
                      .join('-');
            break;
    }
    input.value = val;
    updateCounts();
  }

  btns.forEach(btn => {
    btn.addEventListener('click', (e) => convert(e.target.dataset.case));
  });

  input.addEventListener('input', updateCounts);
  
  copyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(input.value);
    window.showToast(window._tToast ? window._tToast('Teks disalin!') : 'Teks disalin!', "success");
  });

  clearBtn.addEventListener('click', () => {
    input.value = '';
    updateCounts();
    input.focus();
  });
  });
</script>
