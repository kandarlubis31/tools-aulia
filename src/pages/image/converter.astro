---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Image Converter (PNG/JPG/WebP)">
  <div class="flex flex-col items-center justify-center min-h-[60vh]">
    
    <div class="max-w-xl w-full card-base p-8 text-center">
      <h1 class="text-3xl font-bold mb-2 text-matte-900 dark:text-white" data-i18n="header.converter">
        Image Converter (PNG/JPG/WebP)
      </h1>
      <p class="text-matte-400 dark:text-matte-300 mb-8" data-i18n="header.converter_desc">Ubah format gambar (PNG, JPG, WebP) instan tanpa upload ke server.</p>

      <div 
        id="drop-zone"
        class="border-2 border-dashed border-matte-200 dark:border-surface-border rounded-xl p-10 cursor-pointer hover:border-accent-blue hover:bg-matte-100 dark:hover:bg-surface-hover transition-all group"
      >
        <div class="flex flex-col items-center gap-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-matte-400 group-hover:text-sky-400 transition-colors">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
          <span class="text-matte-400 dark:text-matte-300 font-medium" data-i18n="text.click_drag_png">Klik atau Tarik File Gambar ke sini</span>
          <input type="file" id="file-input" accept="image/png, image/jpeg, image/webp" class="hidden" />
        </div>
      </div>

      <div id="result-area" class="hidden mt-8 animate-fade-in">
        <div class="flex justify-center mb-6">
          <img id="preview-img" class="max-h-48 rounded-lg border border-matte-200 dark:border-matte-600 shadow-lg" alt="Converted image preview" loading="lazy" />
        </div>
        
        <div class="flex gap-4 justify-center">
          <button id="convert-btn" class="bg-matte-900 dark:bg-white text-white dark:text-matte-900 px-6 py-2 rounded-lg font-bold transition-all active:scale-95" data-i18n="btn.download_jpg">
            Download JPG
          </button>
          <button id="reset-btn" class="text-matte-400 dark:text-matte-300 hover:text-accent-blue px-4 py-2 transition-colors" data-i18n="btn.reset">
            Reset
          </button>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const resultArea = document.getElementById('result-area');
  const previewImg = document.getElementById('preview-img') as HTMLImageElement;
  const convertBtn = document.getElementById('convert-btn');
  const resetBtn = document.getElementById('reset-btn');

  let currentFile: File | null = null;

  // 1. Handle File Input
  if (dropZone && fileInput) {
    dropZone.addEventListener('click', () => fileInput.click());
    
    fileInput.addEventListener('change', (e) => {
      if (fileInput.files && fileInput.files[0]) {
        handleFile(fileInput.files[0]);
      }
    });

    // Drag & Drop Handling
    // PERBAIKAN DI SINI: Syntax event listener dirapikan
    dropZone.addEventListener('dragover', (e) => { 
      e.preventDefault(); 
      dropZone.classList.add('border-sky-500'); 
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('border-sky-500');
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('border-sky-500');
      if (e.dataTransfer?.files[0]) handleFile(e.dataTransfer.files[0]);
    });
  }

  function handleFile(file: File) {
    if (!['image/png', 'image/jpeg', 'image/webp'].includes(file.type)) {
      window.showToast?.(window._tToast ? window._tToast('Format tidak didukung! Upload PNG, JPG, atau WebP.') : 'Format tidak didukung! Upload PNG, JPG, atau WebP.', 'error');
      return;
    }
    currentFile = file;
    
    const reader = new FileReader();
    reader.onload = (e) => {
      if(previewImg && e.target && dropZone && resultArea) {
        previewImg.src = e.target.result as string;
        dropZone.classList.add('hidden');
        resultArea.classList.remove('hidden');
      }
    };
    reader.readAsDataURL(file);
  }

  // 2. Logic Konversi (Canvas Magic)
  convertBtn?.addEventListener('click', () => {
    if (!previewImg.src) return;

    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d');
    const img = new Image();

    img.onload = () => {
      canvas.width = img.width;
      canvas.height = img.height;
      
      // Fill background putih (karena JPG gak support transparan)
      if(ctx) {
        ctx.fillStyle = '#FFFFFF'; 
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(img, 0, 0);
      }

      // Convert ke JPG Data URL
      const jpgUrl = canvas.toDataURL('image/jpeg', 0.9); // 0.9 = Kualitas 90%
      
      // Trigger Download Otomatis
      const link = document.createElement('a');
      link.download = `converted-${Date.now()}.jpg`;
      link.href = jpgUrl;
      link.click();
    };
    
    img.src = previewImg.src;
  });

  // 3. Reset
  resetBtn?.addEventListener('click', () => {
    currentFile = null;
    if(fileInput) fileInput.value = '';
    resultArea?.classList.add('hidden');
    dropZone?.classList.remove('hidden');
  });
</script>

<style>
  .animate-fade-in { animation: fadeIn 0.5s ease-out; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>
