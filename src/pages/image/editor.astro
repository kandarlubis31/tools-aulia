---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Studio Editor">
  <div class="max-w-7xl mx-auto px-4 py-8 h-[calc(100vh-80px)] flex flex-col">
    
    <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4 animate-fade-in">
      <div>
        <h1 class="text-2xl font-bold text-matte-800 dark:text-white flex items-center gap-2">
          <span class="bg-pink-100 dark:bg-pink-900/30 text-pink-600 p-2 rounded-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="M9 15h6"/></svg>
          </span>
          Studio Editor
        </h1>
        <p class="text-sm text-matte-400 dark:text-matte-300 mt-1">Edit foto dengan filter dan alat profesional</p>
      </div>
      
      <div class="flex gap-2">
        <label class="cursor-pointer px-4 py-2 bg-matte-100 dark:bg-surface-elevated hover:bg-matte-200 dark:hover:bg-surface-hover text-matte-500 dark:text-matte-300 rounded-lg font-bold transition-colors flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          Buka Foto
          <input type="file" id="file-input" accept="image/*" class="hidden">
        </label>
        <button id="download-btn" class="px-4 py-2 bg-pink-600 hover:bg-pink-700 text-white rounded-lg font-bold transition-colors flex items-center gap-2 opacity-50 cursor-not-allowed" disabled>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Simpan
        </button>
      </div>
    </div>

    <div class="flex-1 flex flex-col lg:flex-row gap-6 overflow-hidden animate-fade-in-up">
      
      <div class="flex-1 bg-surface-hover dark:bg-matte-900/50 rounded-2xl border border-matte-200 dark:border-surface-border relative overflow-hidden flex items-center justify-center group select-none">
        
        <div id="placeholder" class="text-center p-8">
          <div class="inline-flex items-center justify-center w-20 h-20 bg-matte-200 dark:bg-surface rounded-full mb-4 text-matte-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
          </div>
          <p class="text-matte-500 font-medium">Buka foto untuk mulai mengedit</p>
          <p class="text-matte-400 text-sm mt-2">Mendukung format: JPG, PNG, GIF, WebP</p>
        </div>

        <div id="image-container" class="hidden relative w-full h-full flex items-center justify-center">
          <img id="preview-img" class="max-w-full max-h-full object-contain transition-all duration-100" alt="Edited image preview" loading="lazy" />
          <div id="zoom-controls" class="absolute bottom-4 right-4 bg-white/90 dark:bg-surface/90 backdrop-blur rounded-lg shadow-lg flex items-center p-1">
            <button id="zoom-out" class="p-2 hover:bg-matte-100 dark:hover:bg-surface-hover rounded transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            </button>
            <span id="zoom-level" class="px-2 text-xs font-mono">100%</span>
            <button id="zoom-in" class="p-2 hover:bg-matte-100 dark:hover:bg-surface-hover rounded transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            </button>
            <button id="zoom-fit" class="p-2 hover:bg-matte-100 dark:hover:bg-surface-hover rounded transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
            </button>
          </div>
        </div>
        
        <div id="compare-container" class="hidden absolute inset-0 overflow-hidden">
          <div id="compare-slider" class="absolute inset-0">
            <div id="compare-before" class="absolute inset-0 flex items-center justify-center">
              <img id="original-img" class="max-w-full max-h-full object-contain" alt="Original image" loading="lazy" />
            </div>
            <div id="compare-after" class="absolute inset-0 flex items-center justify-center" style="clip-path: inset(0 0 0 50%);">
              <img id="edited-img" class="max-w-full max-h-full object-contain" alt="Edited image" loading="lazy" />
            </div>
            <div id="compare-handle" class="absolute top-0 bottom-0 w-1 bg-white shadow-lg cursor-ew-resize" style="left: 50%;">
              <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-white rounded-full p-1 shadow-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </div>
            </div>
          </div>
        </div>

        <div id="toolbar" class="hidden absolute top-4 left-4 bg-white/90 dark:bg-surface/90 backdrop-blur rounded-lg shadow-lg flex items-center p-1">
          <button id="compare-btn" class="p-2 hover:bg-matte-100 dark:hover:bg-surface-hover rounded transition-colors" title="Bandingkan">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </button>
          <button id="undo-btn" class="p-2 hover:bg-matte-100 dark:hover:bg-surface-hover rounded transition-colors" title="Undo (Ctrl+Z)">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"/><path d="M21 17a9 9 0 00-9-9 9 9 0 00-6 2.3L3 13"/></svg>
          </button>
          <button id="redo-btn" class="p-2 hover:bg-matte-100 dark:hover:bg-surface-hover rounded transition-colors" title="Redo (Ctrl+Y)">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 7v6h-6"/><path d="M3 17a9 9 0 019-9 9 9 0 016 2.3l3 2.7"/></svg>
          </button>
        </div>

        <!-- Crop Overlay -->
        <div id="crop-overlay" class="hidden absolute inset-0 z-20 cursor-crosshair" style="background: rgba(0,0,0,0.6);">
          <div id="crop-box" class="absolute border-2 border-white shadow-[0_0_0_9999px_rgba(0,0,0,0.5)]" style="display:none;">
            <!-- corner handles -->
            <div class="crop-handle absolute -top-1.5 -left-1.5 w-3 h-3 bg-white rounded-sm shadow cursor-nw-resize" data-handle="nw"></div>
            <div class="crop-handle absolute -top-1.5 -right-1.5 w-3 h-3 bg-white rounded-sm shadow cursor-ne-resize" data-handle="ne"></div>
            <div class="crop-handle absolute -bottom-1.5 -left-1.5 w-3 h-3 bg-white rounded-sm shadow cursor-sw-resize" data-handle="sw"></div>
            <div class="crop-handle absolute -bottom-1.5 -right-1.5 w-3 h-3 bg-white rounded-sm shadow cursor-se-resize" data-handle="se"></div>
            <!-- edge handles -->
            <div class="crop-handle absolute top-1/2 -translate-y-1/2 -left-1 w-2 h-6 bg-white rounded-sm shadow cursor-w-resize" data-handle="w"></div>
            <div class="crop-handle absolute top-1/2 -translate-y-1/2 -right-1 w-2 h-6 bg-white rounded-sm shadow cursor-e-resize" data-handle="e"></div>
            <div class="crop-handle absolute left-1/2 -translate-x-1/2 -top-1 w-6 h-2 bg-white rounded-sm shadow cursor-n-resize" data-handle="n"></div>
            <div class="crop-handle absolute left-1/2 -translate-x-1/2 -bottom-1 w-6 h-2 bg-white rounded-sm shadow cursor-s-resize" data-handle="s"></div>
            <!-- rule of thirds grid -->
            <div class="absolute inset-0 pointer-events-none">
              <div class="absolute left-1/3 top-0 bottom-0 border-l border-white/30"></div>
              <div class="absolute left-2/3 top-0 bottom-0 border-l border-white/30"></div>
              <div class="absolute top-1/3 left-0 right-0 border-t border-white/30"></div>
              <div class="absolute top-2/3 left-0 right-0 border-t border-white/30"></div>
            </div>
          </div>
          <div id="crop-actions" class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-3 bg-white dark:bg-surface rounded-xl shadow-xl p-2 z-30" style="display:none;">
            <button id="crop-cancel-btn" class="px-4 py-2 text-sm font-bold text-matte-500 hover:bg-matte-100 dark:hover:bg-surface-hover rounded-lg transition-colors">Batal</button>
            <button id="crop-apply-btn" class="px-4 py-2 text-sm font-bold bg-pink-600 hover:bg-pink-700 text-white rounded-lg transition-colors shadow-lg shadow-pink-500/20">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="inline mr-1.5 -mt-0.5"><path d="M6.13 1L6 16a2 2 0 0 0 2 2h15"/><path d="M1 6.13L16 6a2 2 0 0 1 2 2v15"/></svg>
              Crop
            </button>
          </div>
        </div>

      </div>

      <div class="w-full lg:w-80 flex flex-col card-base overflow-hidden h-[50vh] lg:h-auto">
        
        <div class="flex border-b border-matte-200 dark:border-surface-border">
          <button class="tab-btn flex-1 py-3 text-sm font-bold text-pink-600 border-b-2 border-pink-600 bg-pink-50 dark:bg-matte-700" data-target="adjust">Adjust</button>
          <button class="tab-btn flex-1 py-3 text-sm font-bold text-matte-500 hover:text-matte-700 dark:text-matte-400 dark:hover:text-matte-200" data-target="filters">Filters</button>
          <button class="tab-btn flex-1 py-3 text-sm font-bold text-matte-500 hover:text-matte-700 dark:text-matte-400 dark:hover:text-matte-200" data-target="transform">Transform</button>
          <button class="tab-btn flex-1 py-3 text-sm font-bold text-matte-500 hover:text-matte-700 dark:text-matte-400 dark:hover:text-matte-200" data-target="export">Export</button>
        </div>

        <div class="flex-1 overflow-y-auto p-5 custom-scrollbar relative">
          
          <div id="panel-adjust" class="space-y-5">
            <div class="control-group">
              <div class="flex justify-between mb-1">
                <label class="section-title">Brightness</label>
                <span class="text-xs font-mono text-matte-700 dark:text-matte-300 val-display">100%</span>
              </div>
              <input type="range" class="slider w-full h-2 bg-matte-200 rounded-lg appearance-none cursor-pointer accent-pink-500" min="0" max="200" value="100" data-filter="brightness">
            </div>

            <div class="control-group">
              <div class="flex justify-between mb-1">
                <label class="section-title">Contrast</label>
                <span class="text-xs font-mono text-matte-700 dark:text-matte-300 val-display">100%</span>
              </div>
              <input type="range" class="slider w-full h-2 bg-matte-200 rounded-lg appearance-none cursor-pointer accent-pink-500" min="0" max="200" value="100" data-filter="contrast">
            </div>

            <div class="control-group">
              <div class="flex justify-between mb-1">
                <label class="section-title">Saturation</label>
                <span class="text-xs font-mono text-matte-700 dark:text-matte-300 val-display">100%</span>
              </div>
              <input type="range" class="slider w-full h-2 bg-matte-200 rounded-lg appearance-none cursor-pointer accent-pink-500" min="0" max="200" value="100" data-filter="saturate">
            </div>

            <div class="control-group">
              <div class="flex justify-between mb-1">
                <label class="section-title">Hue</label>
                <span class="text-xs font-mono text-matte-700 dark:text-matte-300 val-display">0°</span>
              </div>
              <input type="range" class="slider w-full h-2 bg-matte-200 rounded-lg appearance-none cursor-pointer accent-pink-500" min="0" max="360" value="0" data-filter="hue">
            </div>

            <div class="control-group">
              <div class="flex justify-between mb-1">
                <label class="section-title">Sepia</label>
                <span class="text-xs font-mono text-matte-700 dark:text-matte-300 val-display">0%</span>
              </div>
              <input type="range" class="slider w-full h-2 bg-matte-200 rounded-lg appearance-none cursor-pointer accent-pink-500" min="0" max="100" value="0" data-filter="sepia">
            </div>

            <div class="control-group">
              <div class="flex justify-between mb-1">
                <label class="section-title">Grayscale</label>
                <span class="text-xs font-mono text-matte-700 dark:text-matte-300 val-display">0%</span>
              </div>
              <input type="range" class="slider w-full h-2 bg-matte-200 rounded-lg appearance-none cursor-pointer accent-pink-500" min="0" max="100" value="0" data-filter="grayscale">
            </div>

            <div class="control-group">
              <div class="flex justify-between mb-1">
                <label class="section-title">Blur</label>
                <span class="text-xs font-mono text-matte-700 dark:text-matte-300 val-display">0px</span>
              </div>
              <input type="range" class="slider w-full h-2 bg-matte-200 rounded-lg appearance-none cursor-pointer accent-pink-500" min="0" max="10" value="0" step="0.1" data-filter="blur">
            </div>
          </div>

          <div id="panel-filters" class="hidden grid grid-cols-2 gap-3">
             </div>

          <div id="panel-transform" class="hidden space-y-4">
             <div>
                <label class="text-xs font-bold uppercase text-matte-500 mb-2 block">Rotate</label>
                <div class="flex gap-2">
                   <button class="transform-btn flex-1 py-2 bg-surface-hover dark:bg-surface-hover rounded-lg hover:bg-pink-100 dark:hover:bg-pink-900/30 text-matte-600 dark:text-matte-300 transition-colors" data-action="rotate-left">
                      ↺ -90°
                   </button>
                   <button class="transform-btn flex-1 py-2 bg-surface-hover dark:bg-surface-hover rounded-lg hover:bg-pink-100 dark:hover:bg-pink-900/30 text-matte-600 dark:text-matte-300 transition-colors" data-action="rotate-right">
                      ↻ +90°
                   </button>
                </div>
             </div>
             <div>
                <label class="text-xs font-bold uppercase text-matte-500 mb-2 block">Flip</label>
                <div class="flex gap-2">
                   <button class="transform-btn flex-1 py-2 bg-surface-hover dark:bg-surface-hover rounded-lg hover:bg-pink-100 dark:hover:bg-pink-900/30 text-matte-600 dark:text-matte-300 transition-colors" data-action="flip-x">
                      ↔ Horizontal
                   </button>
                   <button class="transform-btn flex-1 py-2 bg-surface-hover dark:bg-surface-hover rounded-lg hover:bg-pink-100 dark:hover:bg-pink-900/30 text-matte-600 dark:text-matte-300 transition-colors" data-action="flip-y">
                      ↕ Vertical
                   </button>
                </div>
             </div>
             <div>
                <label class="text-xs font-bold uppercase text-matte-500 mb-2 block">Crop</label>
                <button id="crop-btn" class="w-full py-2 bg-surface-hover dark:bg-surface-hover rounded-lg hover:bg-pink-100 dark:hover:bg-pink-900/30 text-matte-600 dark:text-matte-300 transition-colors">
                   <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline mr-2"><path d="M6.13 1L6 16a2 2 0 0 0 2 2h15"/><path d="M1 6.13L16 6a2 2 0 0 1 2 2v15"/></svg>
                   Crop Image
                </button>
             </div>
          </div>

          <div id="panel-export" class="hidden space-y-4">
            <div>
              <label class="text-xs font-bold uppercase text-matte-500 mb-2 block">Format</label>
              <div class="grid grid-cols-3 gap-2">
                <button class="export-format-btn py-2 bg-surface-hover dark:bg-surface-hover rounded-lg hover:bg-pink-100 dark:hover:bg-pink-900/30 text-matte-600 dark:text-matte-300 transition-colors text-sm font-medium" data-format="png">
                  PNG
                </button>
                <button class="export-format-btn py-2 bg-surface-hover dark:bg-surface-hover rounded-lg hover:bg-pink-100 dark:hover:bg-pink-900/30 text-matte-600 dark:text-matte-300 transition-colors text-sm font-medium" data-format="jpeg">
                  JPEG
                </button>
                <button class="export-format-btn py-2 bg-surface-hover dark:bg-surface-hover rounded-lg hover:bg-pink-100 dark:hover:bg-pink-900/30 text-matte-600 dark:text-matte-300 transition-colors text-sm font-medium" data-format="webp">
                  WebP
                </button>
              </div>
            </div>
            <div id="quality-control" class="hidden">
              <div class="flex justify-between mb-1">
                <label class="section-title">Quality</label>
                <span class="text-xs font-mono text-matte-700 dark:text-matte-300 quality-display">90%</span>
              </div>
              <input type="range" class="quality-slider w-full h-2 bg-matte-200 rounded-lg appearance-none cursor-pointer accent-pink-500" min="10" max="100" value="90" step="5">
            </div>
            <div>
              <label class="text-xs font-bold uppercase text-matte-500 mb-2 block">Size</label>
              <div class="grid grid-cols-2 gap-2">
                <button class="export-size-btn py-2 bg-surface-hover dark:bg-surface-hover rounded-lg hover:bg-pink-100 dark:hover:bg-pink-900/30 text-matte-600 dark:text-matte-300 transition-colors text-sm font-medium" data-size="original">
                  Original
                </button>
                <button class="export-size-btn py-2 bg-surface-hover dark:bg-surface-hover rounded-lg hover:bg-pink-100 dark:hover:bg-pink-900/30 text-matte-600 dark:text-matte-300 transition-colors text-sm font-medium" data-size="half">
                  50%
                </button>
                <button class="export-size-btn py-2 bg-surface-hover dark:bg-surface-hover rounded-lg hover:bg-pink-100 dark:hover:bg-pink-900/30 text-matte-600 dark:text-matte-300 transition-colors text-sm font-medium" data-size="quarter">
                  25%
                </button>
                <button class="export-size-btn py-2 bg-surface-hover dark:bg-surface-hover rounded-lg hover:bg-pink-100 dark:hover:bg-pink-900/30 text-matte-600 dark:text-matte-300 transition-colors text-sm font-medium" data-size="custom">
                  Custom
                </button>
              </div>
            </div>
            <div id="custom-size" class="hidden grid grid-cols-2 gap-2">
              <input type="number" id="custom-width" placeholder="Width (px)" class="px-3 py-2 bg-surface-hover dark:bg-surface-hover rounded-lg text-matte-700 dark:text-matte-300">
              <input type="number" id="custom-height" placeholder="Height (px)" class="px-3 py-2 bg-surface-hover dark:bg-surface-hover rounded-lg text-matte-700 dark:text-matte-300">
            </div>
          </div>

        </div>

        <div class="p-4 border-t border-matte-200 dark:border-surface-border bg-matte-100 dark:bg-surface-hover">
           <button id="reset-all" class="w-full py-2 text-sm font-bold text-matte-500 hover:text-red-500 transition-colors flex items-center justify-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
              Reset Semua
           </button>
        </div>

      </div>

    </div>
  </div>
</BaseLayout>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    
    // --- ELEMENTS ---
    const fileInput = document.getElementById('file-input');
    const placeholder = document.getElementById('placeholder');
    const imageContainer = document.getElementById('image-container');
    const previewImg = document.getElementById('preview-img');
    const originalImg = document.getElementById('original-img');
    const editedImg = document.getElementById('edited-img');
    const downloadBtn = document.getElementById('download-btn');
    const resetBtn = document.getElementById('reset-all');
    const compareBtn = document.getElementById('compare-btn');
    const undoBtn = document.getElementById('undo-btn');
    const redoBtn = document.getElementById('redo-btn');
    const toolbar = document.getElementById('toolbar');
    const compareContainer = document.getElementById('compare-container');
    const compareSlider = document.getElementById('compare-slider');
    const compareHandle = document.getElementById('compare-handle');
    const zoomControls = document.getElementById('zoom-controls');
    const zoomInBtn = document.getElementById('zoom-in');
    const zoomOutBtn = document.getElementById('zoom-out');
    const zoomFitBtn = document.getElementById('zoom-fit');
    const zoomLevel = document.getElementById('zoom-level');
    const tabBtns = document.querySelectorAll('.tab-btn');
    const panels = {
       adjust: document.getElementById('panel-adjust'),
       filters: document.getElementById('panel-filters'),
       transform: document.getElementById('panel-transform'),
       export: document.getElementById('panel-export')
    };
    const sliders = document.querySelectorAll('.slider');
    const transformBtns = document.querySelectorAll('.transform-btn');
    const cropBtn = document.getElementById('crop-btn');
    const filtersContainer = document.getElementById('panel-filters');
    const exportFormatBtns = document.querySelectorAll('.export-format-btn');
    const exportSizeBtns = document.querySelectorAll('.export-size-btn');
    const qualityControl = document.getElementById('quality-control');
    const qualitySlider = document.querySelector('.quality-slider');
    const qualityDisplay = document.querySelector('.quality-display');
    const customSize = document.getElementById('custom-size');
    const customWidth = document.getElementById('custom-width');
    const customHeight = document.getElementById('custom-height');

    // --- STATE ---
    let defaultSettings = {
       brightness: 100,
       contrast: 100,
       saturate: 100,
       hue: 0,
       sepia: 0,
       grayscale: 0,
       blur: 0,
       rotate: 0,
       flipX: 1,
       flipY: 1
    };
    
    let settings = { ...defaultSettings };
    let originalFileUrl = null;
    let history = [];
    let historyIndex = -1;
    let zoomScale = 1;
    let exportFormat = 'png';
    let exportQuality = 0.9;
    let exportSize = 'original';
    let isComparing = false;
    let isDraggingCompare = false;

    // --- PRESETS DATA ---
    const presets = [
       { name: "Normal", filter: {} },
       { name: "Vintage", filter: { sepia: 40, contrast: 120, brightness: 110, saturate: 80 } },
       { name: "B&W", filter: { grayscale: 100, contrast: 110 } },
       { name: "Techno", filter: { saturate: 200, contrast: 120 } },
       { name: "Soft", filter: { brightness: 110, contrast: 90, saturate: 90, blur: 0.5 } },
       { name: "Dark", filter: { brightness: 80, contrast: 130, saturate: 110 } },
       { name: "Warm", filter: { brightness: 105, saturate: 120, hue: 10 } },
       { name: "Cold", filter: { brightness: 105, saturate: 110, hue: 190 } },
       { name: "Dramatic", filter: { contrast: 150, brightness: 90, saturate: 120 } },
       { name: "Faded", filter: { contrast: 85, brightness: 105, saturate: 80 } },
    ];

    // --- INIT PRESETS UI ---
    presets.forEach(preset => {
       const btn = document.createElement('button');
       btn.className = "p-3 rounded-xl border border-matte-200 dark:border-matte-700 bg-matte-50 dark:bg-matte-700/50 hover:bg-pink-50 dark:hover:bg-pink-900/20 hover:border-pink-300 transition-all text-sm font-bold text-matte-600 dark:text-matte-300";
       btn.textContent = preset.name;
       btn.onclick = () => applyPreset(preset.filter);
       filtersContainer.appendChild(btn);
    });

    // --- CORE LOGIC ---

    function applyFilterStyles(element, isPreview = true) {
       if (!element) return;
       
       // CSS Filter String
       const filterString = `
          brightness(${settings.brightness}%) 
          contrast(${settings.contrast}%) 
          saturate(${settings.saturate}%) 
          hue-rotate(${settings.hue}deg)
          sepia(${settings.sepia}%) 
          grayscale(${settings.grayscale}%) 
          blur(${settings.blur}px)
       `;

       // Transform String
       const transformString = `
          rotate(${settings.rotate}deg) 
          scale(${settings.flipX}, ${settings.flipY})
       `;

       element.style.filter = filterString;
       element.style.transform = transformString;
    }

    function updatePreview() {
       applyFilterStyles(previewImg);
       if (editedImg) applyFilterStyles(editedImg);
    }

    function saveToHistory() {
       // Remove any states after current index
       history = history.slice(0, historyIndex + 1);
       
       // Add new state
       history.push({ ...settings });
       historyIndex++;
       
       // Limit history to 20 states
       if (history.length > 20) {
          history.shift();
          historyIndex--;
       }
       
       updateHistoryButtons();
    }

    function updateHistoryButtons() {
       undoBtn.disabled = historyIndex <= 0;
       redoBtn.disabled = historyIndex >= history.length - 1;
       
       undoBtn.classList.toggle('opacity-50', historyIndex <= 0);
       undoBtn.classList.toggle('cursor-not-allowed', historyIndex <= 0);
       
       redoBtn.classList.toggle('opacity-50', historyIndex >= history.length - 1);
       redoBtn.classList.toggle('cursor-not-allowed', historyIndex >= history.length - 1);
    }

    function applyPreset(presetFilter) {
       // Save current state to history before applying preset
       saveToHistory();
       
       // Reset color settings first, keep transform
       const currentTransform = { rotate: settings.rotate, flipX: settings.flipX, flipY: settings.flipY };
       settings = { ...defaultSettings, ...presetFilter, ...currentTransform };
       
       // Update Sliders UI
       sliders.forEach(slider => {
          const key = slider.dataset.filter;
          if (settings[key] !== undefined) {
             slider.value = settings[key];
             // Update text label beside slider
             const display = slider.parentElement.querySelector('.val-display');
             const unit = key === 'blur' ? 'px' : key === 'hue' ? '°' : '%';
             display.textContent = settings[key] + unit;
          }
       });
       
       updatePreview();
    }

    function updateZoom() {
       previewImg.style.transform = `scale(${zoomScale})`;
       zoomLevel.textContent = Math.round(zoomScale * 100) + '%';
       
       zoomOutBtn.disabled = zoomScale <= 0.25;
       zoomOutBtn.classList.toggle('opacity-50', zoomScale <= 0.25);
       zoomOutBtn.classList.toggle('cursor-not-allowed', zoomScale <= 0.25);
       
       zoomInBtn.disabled = zoomScale >= 3;
       zoomInBtn.classList.toggle('opacity-50', zoomScale >= 3);
       zoomInBtn.classList.toggle('cursor-not-allowed', zoomScale >= 3);
    }

    function toggleCompareMode() {
       isComparing = !isComparing;
       
       if (isComparing) {
          // Set up comparison
          imageContainer.classList.add('hidden');
          compareContainer.classList.remove('hidden');
          originalImg.src = originalFileUrl;
          editedImg.src = originalFileUrl;
          applyFilterStyles(editedImg);
          compareBtn.classList.add('bg-pink-100', 'dark:bg-pink-900/30');
       } else {
          // Exit comparison
          imageContainer.classList.remove('hidden');
          compareContainer.classList.add('hidden');
          compareBtn.classList.remove('bg-pink-100', 'dark:bg-pink-900/30');
       }
    }

    function setupCompareSlider() {
       let startX = 0;
       let currentX = 50; // percentage
       
       const updateSliderPosition = (x) => {
          const rect = compareSlider.getBoundingClientRect();
          const percentage = Math.max(0, Math.min(100, ((x - rect.left) / rect.width) * 100));
          currentX = percentage;
          
          compareHandle.style.left = `${percentage}%`;
          document.getElementById('compare-after').style.clipPath = `inset(0 0 0 ${percentage}%)`;
       };
       
       compareHandle.addEventListener('mousedown', (e) => {
          isDraggingCompare = true;
          startX = e.clientX;
          e.preventDefault();
       });
       
       document.addEventListener('mousemove', (e) => {
          if (!isDraggingCompare) return;
          updateSliderPosition(e.clientX);
       });
       
       document.addEventListener('mouseup', () => {
          isDraggingCompare = false;
       });
       
       // Touch events for mobile
       compareHandle.addEventListener('touchstart', (e) => {
          isDraggingCompare = true;
          startX = e.touches[0].clientX;
          e.preventDefault();
       });
       
       document.addEventListener('touchmove', (e) => {
          if (!isDraggingCompare) return;
          updateSliderPosition(e.touches[0].clientX);
       });
       
       document.addEventListener('touchend', () => {
          isDraggingCompare = false;
       });
    }

    // --- EVENT LISTENERS ---

    // 1. File Upload
    fileInput.addEventListener('change', (e) => {
       const file = e.target.files[0];
       if (!file) return;

       if (originalFileUrl) URL.revokeObjectURL(originalFileUrl);
       originalFileUrl = URL.createObjectURL(file);
       
       previewImg.src = originalFileUrl;
       imageContainer.classList.remove('hidden');
       placeholder.classList.add('hidden');
       downloadBtn.disabled = false;
       downloadBtn.classList.remove('opacity-50', 'cursor-not-allowed');
       toolbar.classList.remove('hidden');
       zoomControls.classList.remove('hidden');
       
       // Reset settings on new file
       settings = { ...defaultSettings };
       history = [{ ...settings }];
       historyIndex = 0;
       zoomScale = 1;
       updateZoom();
       updateHistoryButtons();
       applyPreset({});
    });

    // 2. Sliders
    sliders.forEach(slider => {
       slider.addEventListener('input', (e) => {
          const key = e.target.dataset.filter;
          const val = parseFloat(e.target.value);
          settings[key] = val;
          
          // Update Text Display
          const display = e.target.parentElement.querySelector('.val-display');
          const unit = key === 'blur' ? 'px' : key === 'hue' ? '°' : '%';
          display.textContent = val + unit;

          updatePreview();
       });
       
       slider.addEventListener('change', () => {
          saveToHistory();
       });
    });

    // 3. Transform Buttons
    transformBtns.forEach(btn => {
       btn.addEventListener('click', () => {
          saveToHistory();
          
          const action = btn.dataset.action;
          if (action === 'rotate-left') settings.rotate -= 90;
          if (action === 'rotate-right') settings.rotate += 90;
          if (action === 'flip-x') settings.flipX = settings.flipX === 1 ? -1 : 1;
          if (action === 'flip-y') settings.flipY = settings.flipY === 1 ? -1 : 1;
          updatePreview();
       });
    });

    // 4. Crop System
    let isCropping = false;
    let cropData = { x: 0, y: 0, w: 0, h: 0 };
    let cropDragMode = null; // 'draw' | handle key
    let cropDragStart = { x: 0, y: 0 };
    let cropBoxStart = { x: 0, y: 0, w: 0, h: 0 };

    const cropOverlay = document.getElementById('crop-overlay');
    const cropBox = document.getElementById('crop-box');
    const cropActions = document.getElementById('crop-actions');
    const cropApplyBtn = document.getElementById('crop-apply-btn');
    const cropCancelBtn = document.getElementById('crop-cancel-btn');

    function enterCropMode() {
      if (!previewImg || !previewImg.naturalWidth) return;
      isCropping = true;
      cropOverlay.classList.remove('hidden');
      imageContainer.style.pointerEvents = 'auto';
      zoomControls.classList.add('hidden');
      toolbar.classList.add('hidden');
      cropBox.style.display = 'none';
      cropActions.style.display = 'none';
      cropData = { x: 0, y: 0, w: 0, h: 0 };
      // Reset preview (hide filters temporarily for accurate crop)
      previewImg.style.filter = '';
      previewImg.style.transform = '';
      window.showToast?.(window._tToast ? window._tToast('Drag untuk memilih area crop') : 'Drag untuk memilih area crop', 'info');
    }

    function exitCropMode(restore = true) {
      isCropping = false;
      cropOverlay.classList.add('hidden');
      zoomControls.classList.remove('hidden');
      toolbar.classList.remove('hidden');
      cropBox.style.display = 'none';
      cropActions.style.display = 'none';
      if (restore) {
        updatePreview();
      }
    }

    function updateCropBox() {
      const imgRect = previewImg.getBoundingClientRect();
      const overlayRect = cropOverlay.getBoundingClientRect();
      const offsetX = imgRect.left - overlayRect.left;
      const offsetY = imgRect.top - overlayRect.top;

      cropBox.style.left = `${offsetX + cropData.x}px`;
      cropBox.style.top = `${offsetY + cropData.y}px`;
      cropBox.style.width = `${cropData.w}px`;
      cropBox.style.height = `${cropData.h}px`;
      cropBox.style.display = 'block';
      cropActions.style.display = 'flex';
    }

    function getImageCoords(clientX, clientY) {
      const imgRect = previewImg.getBoundingClientRect();
      return {
        x: clientX - imgRect.left,
        y: clientY - imgRect.top
      };
    }

    function clampCropToImage(x, y, w, h) {
      const dw = previewImg.clientWidth;
      const dh = previewImg.clientHeight;
      if (x < 0) { w += x; x = 0; }
      if (y < 0) { h += y; y = 0; }
      if (x + w > dw) w = dw - x;
      if (y + h > dh) h = dh - y;
      return { x: Math.max(0, x), y: Math.max(0, y), w: Math.max(1, w), h: Math.max(1, h) };
    }

    cropOverlay.addEventListener('mousedown', (e) => {
      if (!isCropping) return;
      const coords = getImageCoords(e.clientX, e.clientY);
      cropDragMode = 'draw';
      cropDragStart = { x: coords.x, y: coords.y };
      cropData = { x: coords.x, y: coords.y, w: 0, h: 0 };
      cropBox.style.display = 'none';
    });

    document.addEventListener('mousemove', (e) => {
      if (!isCropping || !cropDragMode) return;
      const coords = getImageCoords(e.clientX, e.clientY);
      
      if (cropDragMode === 'draw') {
        cropData.x = Math.min(coords.x, cropDragStart.x);
        cropData.y = Math.min(coords.y, cropDragStart.y);
        cropData.w = Math.abs(coords.x - cropDragStart.x);
        cropData.h = Math.abs(coords.y - cropDragStart.y);
        cropData = clampCropToImage(cropData.x, cropData.y, cropData.w, cropData.h);
        updateCropBox();
      } else if (cropDragMode && cropDragMode.startsWith('handle-')) {
        const handle = cropDragMode.replace('handle-', '');
        const dx = coords.x - cropDragStart.x;
        const dy = coords.y - cropDragStart.y;
        let { x, y, w, h } = cropBoxStart;

        if (handle.includes('n')) { y += dy; h -= dy; }
        if (handle.includes('s')) { h += dy; }
        if (handle.includes('w')) { x += dx; w -= dx; }
        if (handle.includes('e')) { w += dx; }

        const clamped = clampCropToImage(x, y, w, h);
        cropData = { ...clamped };
        updateCropBox();
      }
    });

    document.addEventListener('mouseup', () => {
      if (cropDragMode) {
        cropDragMode = null;
        if (cropData.w > 2 && cropData.h > 2) {
          cropActions.style.display = 'flex';
        }
      }
    });

    // Handle resize handles
    cropOverlay.addEventListener('mousedown', (e) => {
      const handle = e.target.closest('.crop-handle');
      if (!handle || !isCropping) return;
      e.stopPropagation();
      e.preventDefault();
      cropDragMode = `handle-${handle.dataset.handle}`;
      cropDragStart = getImageCoords(e.clientX, e.clientY);
      cropBoxStart = { ...cropData };
    }, true);

    // Touch support
    cropOverlay.addEventListener('touchstart', (e) => {
      if (!isCropping) return;
      const touch = e.touches[0];
      const coords = getImageCoords(touch.clientX, touch.clientY);
      cropDragMode = 'draw';
      cropDragStart = { x: coords.x, y: coords.y };
      cropData = { x: coords.x, y: coords.y, w: 0, h: 0 };
      cropBox.style.display = 'none';
    });

    document.addEventListener('touchmove', (e) => {
      if (!isCropping || !cropDragMode) return;
      const touch = e.touches[0];
      const coords = getImageCoords(touch.clientX, touch.clientY);
      if (cropDragMode === 'draw') {
        cropData.x = Math.min(coords.x, cropDragStart.x);
        cropData.y = Math.min(coords.y, cropDragStart.y);
        cropData.w = Math.abs(coords.x - cropDragStart.x);
        cropData.h = Math.abs(coords.y - cropDragStart.y);
        cropData = clampCropToImage(cropData.x, cropData.y, cropData.w, cropData.h);
        updateCropBox();
      }
    });

    document.addEventListener('touchend', () => {
      if (cropDragMode && cropData.w > 2 && cropData.h > 2) {
        cropActions.style.display = 'flex';
      }
      cropDragMode = null;
    });

    cropApplyBtn.addEventListener('click', () => {
      if (!cropData.w || !cropData.h) return;
      saveToHistory();
      
      const canvas = document.createElement('canvas');
      const scaleX = previewImg.naturalWidth / previewImg.clientWidth;
      const scaleY = previewImg.naturalHeight / previewImg.clientHeight;
      
      canvas.width = cropData.w * scaleX;
      canvas.height = cropData.h * scaleY;
      
      const ctx = canvas.getContext('2d');
      ctx.drawImage(
        previewImg,
        cropData.x * scaleX, cropData.y * scaleY,
        cropData.w * scaleX, cropData.h * scaleY,
        0, 0,
        canvas.width, canvas.height
      );
      
      const croppedDataUrl = canvas.toDataURL('image/png');
      if (originalFileUrl) URL.revokeObjectURL(originalFileUrl);
      previewImg.src = croppedDataUrl;
      originalFileUrl = croppedDataUrl;
      
      exitCropMode(false);
      updatePreview();
      window.showToast?.(window._tToast ? window._tToast('Crop berhasil!') : 'Crop berhasil!', 'success');
    });

    cropCancelBtn.addEventListener('click', () => {
      exitCropMode(true);
    });

    cropBtn.addEventListener('click', () => {
      if (!previewImg || !previewImg.naturalWidth) {
        window.showToast?.(window._tToast ? window._tToast('Buka gambar terlebih dahulu') : 'Buka gambar terlebih dahulu', 'info');
        return;
      }
      enterCropMode();
    });

    // 5. Tabs Switching
    tabBtns.forEach(btn => {
       btn.addEventListener('click', () => {
          // Reset Active State
          tabBtns.forEach(b => {
             b.classList.remove('text-pink-600', 'border-b-2', 'border-pink-600', 'bg-pink-50', 'dark:bg-matte-700');
             b.classList.add('text-matte-500', 'dark:text-matte-400');
          });
          // Hide all panels
          Object.values(panels).forEach(p => p.classList.add('hidden'));

          // Set Active
          btn.classList.add('text-pink-600', 'border-b-2', 'border-pink-600', 'bg-pink-50', 'dark:bg-matte-700');
          btn.classList.remove('text-matte-500', 'dark:text-matte-400');
          
          const target = btn.dataset.target;
          panels[target].classList.remove('hidden');
          
          // Grid layout for filters
          if (target === 'filters') panels[target].classList.add('grid');
       });
    });

    // 6. Zoom Controls
    zoomInBtn.addEventListener('click', () => {
       zoomScale = Math.min(3, zoomScale + 0.25);
       updateZoom();
    });

    zoomOutBtn.addEventListener('click', () => {
       zoomScale = Math.max(0.25, zoomScale - 0.25);
       updateZoom();
    });

    zoomFitBtn.addEventListener('click', () => {
       zoomScale = 1;
       updateZoom();
    });

    // 7. Compare Button
    compareBtn.addEventListener('click', toggleCompareMode);
    setupCompareSlider();

    // 8. Undo/Redo
    undoBtn.addEventListener('click', () => {
       if (historyIndex > 0) {
          historyIndex--;
          settings = { ...history[historyIndex] };
          
          // Update UI
          sliders.forEach(slider => {
             const key = slider.dataset.filter;
             if (settings[key] !== undefined) {
                slider.value = settings[key];
                const display = slider.parentElement.querySelector('.val-display');
                const unit = key === 'blur' ? 'px' : key === 'hue' ? '°' : '%';
                display.textContent = settings[key] + unit;
             }
          });
          
          updatePreview();
          updateHistoryButtons();
       }
    });

    redoBtn.addEventListener('click', () => {
       if (historyIndex < history.length - 1) {
          historyIndex++;
          settings = { ...history[historyIndex] };
          
          // Update UI
          sliders.forEach(slider => {
             const key = slider.dataset.filter;
             if (settings[key] !== undefined) {
                slider.value = settings[key];
                const display = slider.parentElement.querySelector('.val-display');
                const unit = key === 'blur' ? 'px' : key === 'hue' ? '°' : '%';
                display.textContent = settings[key] + unit;
             }
          });
          
          updatePreview();
          updateHistoryButtons();
       }
    });

    // 9. Export Controls
    exportFormatBtns.forEach(btn => {
       btn.addEventListener('click', () => {
          exportFormat = btn.dataset.format;
          
          // Update UI
          exportFormatBtns.forEach(b => {
             b.classList.remove('bg-pink-100', 'dark:bg-pink-900/30', 'text-pink-600');
             b.classList.add('bg-matte-100', 'dark:bg-matte-700', 'text-matte-600', 'dark:text-matte-300');
          });
          
          btn.classList.remove('bg-matte-100', 'dark:bg-matte-700', 'text-matte-600', 'dark:text-matte-300');
          btn.classList.add('bg-pink-100', 'dark:bg-pink-900/30', 'text-pink-600');
          
          // Show/hide quality control based on format
          if (exportFormat === 'jpeg' || exportFormat === 'webp') {
             qualityControl.classList.remove('hidden');
          } else {
             qualityControl.classList.add('hidden');
          }
       });
    });

    exportSizeBtns.forEach(btn => {
       btn.addEventListener('click', () => {
          exportSize = btn.dataset.size;
          
          // Update UI
          exportSizeBtns.forEach(b => {
             b.classList.remove('bg-pink-100', 'dark:bg-pink-900/30', 'text-pink-600');
             b.classList.add('bg-matte-100', 'dark:bg-matte-700', 'text-matte-600', 'dark:text-matte-300');
          });
          
          btn.classList.remove('bg-matte-100', 'dark:bg-matte-700', 'text-matte-600', 'dark:text-matte-300');
          btn.classList.add('bg-pink-100', 'dark:bg-pink-900/30', 'text-pink-600');
          
          // Show/hide custom size inputs
          if (exportSize === 'custom') {
             customSize.classList.remove('hidden');
             // Set default values
             if (!customWidth.value) customWidth.value = previewImg.naturalWidth;
             if (!customHeight.value) customHeight.value = previewImg.naturalHeight;
          } else {
             customSize.classList.add('hidden');
          }
       });
    });

    qualitySlider.addEventListener('input', (e) => {
       exportQuality = e.target.value / 100;
       qualityDisplay.textContent = e.target.value + '%';
    });

    // 10. Reset All
    resetBtn.addEventListener('click', () => {
       saveToHistory();
       settings = { ...defaultSettings };
       applyPreset({});
    });

    // 11. Keyboard Shortcuts (pakai named function biar bisa di-cleanup)
    function handleKeydown(e) {
       // Only apply shortcuts when not in input fields
       if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
       
       // Ctrl/Cmd + Z for undo
       if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) {
          e.preventDefault();
          undoBtn.click();
       }
       
       // Ctrl/Cmd + Shift + Z or Ctrl/Cmd + Y for redo
       if (((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'z') || 
           ((e.ctrlKey || e.metaKey) && e.key === 'y')) {
          e.preventDefault();
          redoBtn.click();
       }
       
       // Ctrl/Cmd + S for save/download
       if ((e.ctrlKey || e.metaKey) && e.key === 's') {
          e.preventDefault();
          if (!downloadBtn.disabled) downloadBtn.click();
       }
       
       // Space to toggle compare
       if (e.key === ' ' && !downloadBtn.disabled) {
          e.preventDefault();
          compareBtn.click();
       }
    }
    document.addEventListener('keydown', handleKeydown);
    // Cleanup on Astro page leave (SPA navigation)
    document.addEventListener('astro:page-leave', () => {
      document.removeEventListener('keydown', handleKeydown);
      // Reset crop and compare states to prevent leaked listeners from firing
      isCropping = false;
      isDraggingCompare = false;
      cropDragMode = null;
    });

    // 12. DOWNLOAD (CANVAS RENDERING)
    downloadBtn.addEventListener('click', () => {
       if (!previewImg || !previewImg.src || !previewImg.naturalWidth) return;

       const originalHTML = downloadBtn.innerHTML;
       downloadBtn.innerText = window._tToast ? window._tToast('Menyimpan...') : 'Menyimpan...';
       downloadBtn.disabled = true;

       try {
         // Create temporary canvas
         const canvas = document.createElement('canvas');
         const ctx = canvas.getContext('2d');
         if (!ctx) throw new Error('Canvas context gagal');
         
         // Determine output dimensions
         let outputWidth, outputHeight;
         const naturalWidth = previewImg.naturalWidth;
         const naturalHeight = previewImg.naturalHeight;
         
         if (exportSize === 'original') {
            outputWidth = naturalWidth;
            outputHeight = naturalHeight;
         } else if (exportSize === 'half') {
            outputWidth = Math.floor(naturalWidth / 2);
            outputHeight = Math.floor(naturalHeight / 2);
         } else if (exportSize === 'quarter') {
            outputWidth = Math.floor(naturalWidth / 4);
            outputHeight = Math.floor(naturalHeight / 4);
         } else if (exportSize === 'custom') {
            outputWidth = parseInt(customWidth.value) || naturalWidth;
            outputHeight = parseInt(customHeight.value) || naturalHeight;
         }

         if (!outputWidth || !outputHeight) throw new Error('Dimensi output invalid');
         
         // Handle Rotation Dimensions swap
         const rotationRad = (settings.rotate * Math.PI) / 180;
         const absCos = Math.abs(Math.cos(rotationRad));
         const absSin = Math.abs(Math.sin(rotationRad));
         
         // Calculate canvas size to fit rotated image
         const rotatedWidth = naturalWidth * absCos + naturalHeight * absSin;
         const rotatedHeight = naturalWidth * absSin + naturalHeight * absCos;
         
         // Scale to output size while maintaining aspect ratio
         const scale = Math.min(outputWidth / rotatedWidth, outputHeight / rotatedHeight);
         
         canvas.width = outputWidth;
         canvas.height = outputHeight;

         // Apply Filters to Context
         ctx.filter = `
            brightness(${settings.brightness}%) 
            contrast(${settings.contrast}%) 
            saturate(${settings.saturate}%) 
            hue-rotate(${settings.hue}deg)
            sepia(${settings.sepia}%) 
            grayscale(${settings.grayscale}%) 
            blur(${settings.blur}px)
         `;

         // Apply Transforms (Translate to center, Rotate, Scale, Draw)
         ctx.translate(canvas.width / 2, canvas.height / 2);
         ctx.rotate(rotationRad);
         ctx.scale(settings.flipX * scale, settings.flipY * scale);
         
         // Draw image centered
         ctx.drawImage(previewImg, -naturalWidth / 2, -naturalHeight / 2);

         // Determine output format and quality
         let mimeType, fileExt;
         if (exportFormat === 'jpeg') {
            mimeType = 'image/jpeg';
            fileExt = 'jpg';
         } else if (exportFormat === 'webp') {
            mimeType = 'image/webp';
            fileExt = 'webp';
         } else {
            mimeType = 'image/png';
            fileExt = 'png';
         }
         
         // Download
         const link = document.createElement('a');
         link.download = 'studio-edited-' + Date.now() + '.' + fileExt;
         link.href = canvas.toDataURL(mimeType, exportQuality);
         link.click();

         downloadBtn.innerHTML = originalHTML;
         downloadBtn.disabled = false;
       } catch (e) {
         downloadBtn.innerHTML = originalHTML;
         downloadBtn.disabled = false;
         window.showToast?.(window._tToast ? window._tToast('Gagal menyimpan gambar.') : 'Gagal menyimpan gambar.', 'error');
       }
    });

  });
</script>