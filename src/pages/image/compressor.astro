---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Image Compressor">
  <div class="max-w-5xl mx-auto px-4 min-h-[80vh]">
    <div class="text-center mb-10 pt-8 animate-on-scroll">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3 text-matte-900 dark:text-white" data-i18n="header.image_compressor">
        Image Compressor
      </h1>
      <p class="text-matte-400 dark:text-matte-300" data-i18n="header.image_compressor_desc">
        Kompres ukuran file gambar (JPG/PNG/WEBP) langsung di browser.
      </p>
    </div>

    <div id="drop-zone" class="max-w-2xl mx-auto border-3 border-dashed border-matte-300 dark:border-matte-600 rounded-3xl p-12 cursor-pointer hover:border-emerald-500 hover:bg-emerald-50 dark:hover:bg-matte-800/50 transition-all group text-center animate-on-scroll">
      <div class="w-20 h-20 bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </div>
      <h3 class="text-2xl font-bold text-matte-700 dark:text-matte-200 mb-2" data-i18n="text.upload_image">Upload Gambar</h3>
      <p class="text-sm text-matte-500" data-i18n="text.supported_formats">JPG, PNG, WEBP (Max 5MB)</p>
      <input type="file" id="file-input" accept="image/*" class="hidden" />
    </div>

    <div id="workspace" class="hidden grid grid-cols-1 lg:grid-cols-2 gap-8 pb-20 animate-fade-in">
      
      <div class="card-base p-6 h-fit">
         <h3 class="font-bold text-lg mb-6 border-b border-matte-200 dark:border-surface-border pb-2" data-i18n="label.compression_settings">Pengaturan Kompresi</h3>
         
         <div class="mb-6">
            <label class="flex justify-between text-sm font-semibold text-matte-700 dark:text-white mb-2">
               <span data-i18n="label.quality">Kualitas</span>
               <span id="quality-val" class="text-emerald-500">80%</span>
            </label>
            <input type="range" id="quality" min="1" max="100" value="80" class="w-full h-2 bg-matte-200 dark:bg-matte-700 rounded-lg appearance-none cursor-pointer accent-emerald-500" />
         </div>

         <div class="grid grid-cols-2 gap-4 mb-6 text-center">
            <div class="p-3 bg-matte-100 dark:bg-surface-hover rounded-xl">
               <div class="text-xs text-matte-500 uppercase font-bold" data-i18n="text.original_label">Original</div>
               <div id="size-original" class="text-lg font-bold text-matte-700 dark:text-matte-300">0 KB</div>
            </div>
            <div class="p-3 bg-matte-100 dark:bg-surface-hover rounded-xl border border-matte-200 dark:border-surface-border">
               <div class="text-xs text-emerald-600 dark:text-emerald-400 uppercase font-bold" data-i18n="text.compressed_label">Compressed</div>
               <div id="size-compressed" class="text-lg font-bold text-emerald-600 dark:text-emerald-400">0 KB</div>
            </div>
         </div>

         <div id="savings-badge" class="text-center text-sm font-bold text-emerald-600 mb-6 hidden">
            <span data-i18n="text.save_percent">Hemat</span> <span id="savings-val">0%</span>!
         </div>

         <button id="download-btn" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 px-6 rounded-xl shadow-lg transition-all active:scale-95 flex items-center justify-center gap-2" data-i18n="btn.download_result">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download Hasil
         </button>
      </div>

      <div class="flex flex-col items-center justify-center bg-matte-100 dark:bg-surface-hover p-4 rounded-2xl border border-matte-200 dark:border-surface-border">
         <p class="section-title mb-2" data-i18n="text.result_preview">Preview Hasil</p>
         <img id="preview-img" class="max-w-full max-h-[500px] rounded shadow-lg object-contain" alt="Compressed image preview" />
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input');
  const workspace = document.getElementById('workspace');
  const previewImg = document.getElementById('preview-img');
  const qualityInp = document.getElementById('quality');
  const qualityVal = document.getElementById('quality-val');
  const sizeOri = document.getElementById('size-original');
  const sizeComp = document.getElementById('size-compressed');
  const downloadBtn = document.getElementById('download-btn');
  const savingsBadge = document.getElementById('savings-badge');
  const savingsVal = document.getElementById('savings-val');

  const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5MB
  let originalFile = null;
  let compressedBlob = null;
  let _compressPending = false; // guard concurrent calls
  let debounceTimer;

  function formatBytes(bytes, decimals = 2) {
    if (!+bytes) return '0 Bytes';
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return `${parseFloat((bytes / Math.pow(k, i)).toFixed(dm))} ${sizes[i]}`;
  }

  async function compressImage() {
    if (!originalFile || _compressPending) return;

    _compressPending = true;
    try {
      const quality = parseInt(qualityInp.value) / 100;
      
      // Create Image Bitmap
      const img = await createImageBitmap(originalFile);
      
      // Create Canvas
      const canvas = document.createElement('canvas');
      canvas.width = img.width;
      canvas.height = img.height;
      
      const ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0);

      // Convert to Blob with quality
      let mimeType = originalFile.type === 'image/png' ? 'image/jpeg' : originalFile.type;
      
      canvas.toBlob((blob) => {
          if (!blob) { _compressPending = false; return; }
          compressedBlob = blob;
          const url = URL.createObjectURL(blob);
          if (previewImg) previewImg.src = url;
          
          // Update Stats
          if (sizeComp) sizeComp.innerText = formatBytes(blob.size);
          
          const saving = ((originalFile.size - blob.size) / originalFile.size) * 100;
          if (savingsBadge && savingsVal) {
            if (saving > 0) {
              savingsBadge.classList.remove('hidden');
              savingsVal.innerText = `${saving.toFixed(1)}%`;
            } else {
              savingsBadge.classList.add('hidden');
            }
          }
          _compressPending = false;
      }, mimeType, quality);
    } catch (e) {
      _compressPending = false;
    }
  }

  // Events
  dropZone.addEventListener('click', () => fileInput.click());

  fileInput.addEventListener('change', (e) => {
    if (fileInput.files[0]) {
        originalFile = fileInput.files[0];
        
        // Validate file size
        if (originalFile.size > MAX_FILE_SIZE) {
          window.showToast?.(window._tToast ? window._tToast('File terlalu besar! Maksimal 5MB.') : 'File terlalu besar! Maksimal 5MB.', 'error');
          fileInput.value = ''; // reset input
          return;
        }

        dropZone.classList.add('hidden');
        workspace.classList.remove('hidden');
        workspace.classList.add('grid');
        
        if (sizeOri) sizeOri.innerText = formatBytes(originalFile.size);
        compressImage(); // Initial compress
    }
  });

  qualityInp.addEventListener('input', (e) => {
    qualityVal.innerText = `${e.target.value}%`;
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(compressImage, 300);
  });

  downloadBtn.addEventListener('click', () => {
    if (!compressedBlob) return;
    const link = document.createElement('a');
    link.href = URL.createObjectURL(compressedBlob);
    let ext = originalFile.name.split('.').pop();
    if (compressedBlob.type === 'image/jpeg' && ext !== 'jpg' && ext !== 'jpeg') ext = 'jpg';
    
    link.download = `compressed-${originalFile.name.replace(/\.[^/.]+$/, "")}.${ext}`;
    link.click();
    window.showToast?.(window._tToast ? window._tToast("Gambar berhasil diunduh!") : "Gambar berhasil diunduh!", "success");
  });
</script>
