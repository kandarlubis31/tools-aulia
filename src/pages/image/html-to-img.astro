---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Code to Image Converter">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js" async></script>

  <script type="text/template" id="tpl-card">
<style>
  body { 
    margin: 0; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
    height: 100vh;
    font-family: sans-serif;
    background: transparent;
  }
  .card { 
    background: white; 
    padding: 40px; 
    border-radius: 20px; 
    box-shadow: 0 20px 50px rgba(0,0,0,0.2); 
    text-align: center; 
    width: 350px; 
    border-top: 6px solid #6366f1;
  }
  h1 { color: #1e293b; margin: 0 0 10px; font-size: 24px; }
  p { color: #64748b; margin: 0; font-size: 14px; }
  .badge { 
    background: #e0e7ff; 
    color: #4338ca; 
    padding: 6px 16px; 
    border-radius: 99px; 
    font-size: 12px; 
    font-weight: bold; 
    display: inline-block;
    margin-top: 20px;
  }
</style>
<div class="card">
  <h1>Aulia Lubis</h1>
  <p>Full Stack Developer</p>
  <div class="badge">Open to Work</div>
</div>
  </script>

  <script type="text/template" id="tpl-quote">
<style>
  body { 
    margin: 0; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
    height: 100vh;
    background: #fff1f2;
    font-family: serif;
  }
  .quote-box {
    text-align: center;
    max-width: 500px;
    padding: 50px;
    border: 4px solid #fda4af;
    background: white;
    box-shadow: 10px 10px 0 #fda4af;
  }
  p { font-size: 28px; color: #881337; font-style: italic; line-height: 1.4; }
  cite { display: block; margin-top: 24px; font-weight: bold; color: #fb7185; font-style: normal; text-transform: uppercase; letter-spacing: 2px; font-size: 12px; }
</style>
<div class="quote-box">
  <p>"Code is like humor. When you have to explain it, it’s bad."</p>
  <cite>— Cory House</cite>
</div>
  </script>

  <script type="text/template" id="tpl-button">
<style>
  body { 
    margin: 0; 
    height: 100vh; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
  }
  .btn {
    background: linear-gradient(to right, #ec4899, #8b5cf6);
    color: white;
    padding: 16px 48px;
    font-size: 20px;
    border-radius: 16px;
    font-family: sans-serif;
    font-weight: 800;
    box-shadow: 0 10px 30px -10px rgba(236, 72, 153, 0.6);
    border: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
  }
</style>
<button class="btn">Click Me!</button>
  </script>

  <script type="text/template" id="tpl-social">
<style>
  body { 
    margin: 0; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
    height: 100vh;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    font-family: sans-serif;
  }
  .post {
    width: 400px;
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  }
  .post-header {
    padding: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #e0e7ff;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4338ca;
    font-weight: bold;
  }
  .username { font-weight: bold; color: #1e293b; }
  .post-image {
    width: 100%;
    height: 200px;
    background: #f1f5f9;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #64748b;
  }
  .post-content { padding: 16px; }
  .post-text { margin-bottom: 12px; color: #334155; }
  .post-stats { display: flex; gap: 16px; color: #64748b; font-size: 14px; }
</style>
<div class="post">
  <div class="post-header">
    <div class="avatar">JD</div>
    <div class="username">John Doe</div>
  </div>
  <div class="post-image">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
  </div>
  <div class="post-content">
    <div class="post-text">Just launched my new project! #webdev #design</div>
    <div class="post-stats">
      <span>❤️ 247</span><span>💬 42</span><span>🔄 18</span>
    </div>
  </div>
</div>
  </script>

  <div class="max-w-7xl mx-auto px-4 py-8 min-h-[85vh]">
    <header class="text-center mb-10 animate-on-scroll">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-indigo-500 to-violet-600 rounded-2xl mb-4 shadow-lg shadow-indigo-500/30">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
      </div>
      <h1 class="text-matte-900 dark:text-white text-4xl font-extrabold mb-3 tracking-tight">
        Code to Image
      </h1>
      <p class="text-matte-600 dark:text-matte-400 max-w-2xl mx-auto text-lg">
        Tulis HTML & CSS dalam satu editor, langsung jadi gambar.
      </p>
    </header>

    <div class="grid lg:grid-cols-2 gap-8 mb-8">
      
      <div class="card-base overflow-hidden flex flex-col h-full animate-fade-in">
        <div class="bg-surface-hover dark:bg-matte-900/50 px-6 py-4 border-b border-matte-200 dark:border-surface-border flex justify-between items-center">
          <h2 class="font-bold text-matte-700 dark:text-matte-200 flex items-center gap-2">
            <span>📝</span> Editor Code
          </h2>
          <div class="flex items-center gap-2">
            <label for="template-select" class="sr-only">Template</label>
             <select id="template-select" class="text-xs bg-white dark:bg-matte-800 border border-matte-300 dark:border-surface-border rounded-lg px-2 py-1 text-matte-600 dark:text-matte-300 focus:outline-none focus:ring-2 focus:ring-accent-blue">
               <option value="">📂 Pilih Template...</option>
               <option value="tpl-card">Business Card</option>
               <option value="tpl-quote">Quote Card</option>
               <option value="tpl-button">Modern Button</option>
               <option value="tpl-social">Social Post</option>
            </select>
            <button id="copy-btn" class="text-xs bg-accent-blue hover:bg-blue-600 text-white px-2 py-1 rounded-lg transition-colors" data-i18n="btn.copy">📋 Copy</button>
          </div>
        </div>
        
        <div class="p-0 flex-1 relative min-h-[400px]">
          <textarea 
            id="code-input" 
            class="w-full h-full p-6 bg-matte-900 text-pink-300 font-mono text-sm leading-relaxed outline-none resize-none"
            spellcheck="false"
            placeholder=""
          ></textarea>
        </div>

        <div class="p-4 border-t border-matte-200 dark:border-surface-border bg-surface-hover dark:bg-matte-900/30 grid grid-cols-4 gap-3">
            <div>
                <label class="block text-[10px] font-bold text-matte-500 uppercase mb-1">Lebar</label>
                <input type="number" id="width-input" value="800" min="100" max="2000" class="w-full px-2 py-1.5 bg-white dark:bg-surface border border-matte-300 dark:border-surface-border rounded text-matte-800 dark:text-matte-200 text-xs font-bold" />
            </div>
            <div>
                <label class="block text-[10px] font-bold text-matte-500 uppercase mb-1">Tinggi</label>
                <input type="text" id="height-input" value="auto" class="w-full px-2 py-1.5 bg-white dark:bg-surface border border-matte-300 dark:border-surface-border rounded text-matte-800 dark:text-matte-200 text-xs font-bold" placeholder="auto" />
            </div>
            <div>
                <label class="block text-[10px] font-bold text-matte-500 uppercase mb-1">Format</label>
                <label for="format-select" class="sr-only">Format Output</label>
                 <select id="format-select" class="w-full px-2 py-1.5 bg-white dark:bg-surface border border-matte-300 dark:border-surface-border rounded text-matte-800 dark:text-matte-200 text-xs font-bold">
                    <option value="png">PNG</option>
                    <option value="jpeg">JPEG</option>
                    <option value="webp">WebP</option>
                </select>
            </div>
            <div class="flex items-end gap-2">
                <button id="clear-btn" class="flex-1 py-1.5 text-xs font-bold text-matte-500 hover:text-red-500 border border-matte-300 dark:border-surface-border rounded hover:bg-surface-hover dark:hover:bg-matte-800 transition-colors" data-i18n="btn.clear">Clear</button>
            </div>
        </div>
      </div>

      <div class="card-base overflow-hidden flex flex-col animate-fade-in" style="animation-delay: 0.1s;">
        <div class="bg-gradient-to-r from-indigo-500 to-violet-600 px-6 py-4 flex justify-between items-center">
          <h2 class="text-white font-bold flex items-center gap-2">
            <span>👁️</span> Live Preview
          </h2>
          <div class="flex items-center gap-2">
            <button id="refresh-btn" class="text-xs text-white/90 bg-white/20 hover:bg-white/30 px-3 py-1 rounded transition-colors" data-i18n="btn.run_refresh">Run / Refresh</button>
            <button id="fullscreen-btn" class="text-xs text-white/90 bg-white/20 hover:bg-white/30 px-3 py-1 rounded transition-colors">
              ⛶
            </button>
          </div>
        </div>
        
        <div class="p-6 flex-1 bg-surface-hover dark:bg-matte-900 flex flex-col items-center justify-center min-h-[400px] relative overflow-hidden checkerboard">
          <div id="preview-empty" class="text-center p-8 hidden">
            <p class="text-matte-400 dark:text-matte-500 text-sm">Preview kosong</p>
          </div>
          <div id="preview-content" class="shadow-2xl transition-all duration-300 origin-top"></div>
        </div>

        <div class="p-4 border-t border-matte-200 dark:border-surface-border bg-white dark:bg-surface">
            <div class="flex gap-3">
                <button id="download-btn" disabled class="flex-1 px-6 py-3 bg-gradient-to-r from-indigo-500 to-violet-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-500/25 hover:shadow-indigo-500/40 transform hover:-tranmatte-y-0.5 active:tranmatte-y-0 transition-all flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    <span data-i18n="btn.download_image">Download Image</span>
                </button>
                <button id="share-btn" class="px-6 py-3 bg-white dark:bg-surface-hover text-accent-blue dark:text-accent-blue font-bold rounded-xl shadow-md hover:shadow-lg transform hover:-tranmatte-y-0.5 active:tranmatte-y-0 transition-all flex items-center justify-center gap-2 border border-matte-200 dark:border-surface-border">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                    Share
                </button>
            </div>
        </div>
      </div>
    </div>


  </div>

  <div id="fullscreen-modal" class="fixed inset-0 bg-black bg-opacity-90 z-50 hidden flex items-center justify-center p-4">
    <div class="relative w-full h-full max-w-6xl max-h-full">
      <button id="close-fullscreen" class="absolute top-4 right-4 text-white bg-black bg-opacity-50 rounded-full p-2 hover:bg-opacity-75 transition-colors z-10">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
      <div id="fullscreen-content" class="w-full h-full flex items-center justify-center"></div>
    </div>
  </div>

</BaseLayout>

<style>
  .checkerboard {
    background-image: linear-gradient(45deg, #e5e7eb 25%, transparent 25%), linear-gradient(-45deg, #e5e7eb 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #e5e7eb 75%), linear-gradient(-45deg, transparent 75%, #e5e7eb 75%);
    background-size: 20px 20px;
    background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
  }
  html.dark .checkerboard {
    background-image: linear-gradient(45deg, #1e293b 25%, transparent 25%), linear-gradient(-45deg, #1e293b 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #1e293b 75%), linear-gradient(-45deg, transparent 75%, #1e293b 75%);
  }
  @keyframes fade-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fade-in { animation: fade-in 0.5s ease-out forwards; }
</style>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    // Elements
    const codeInput = document.getElementById('code-input');
    const widthInput = document.getElementById('width-input');
    const heightInput = document.getElementById('height-input');
    const formatSelect = document.getElementById('format-select');
    const templateSelect = document.getElementById('template-select');
    const downloadBtn = document.getElementById('download-btn');
    const clearBtn = document.getElementById('clear-btn');
    const refreshBtn = document.getElementById('refresh-btn');
    const copyBtn = document.getElementById('copy-btn');
    const shareBtn = document.getElementById('share-btn');
    const fullscreenBtn = document.getElementById('fullscreen-btn');
    const previewContent = document.getElementById('preview-content');
    const previewEmpty = document.getElementById('preview-empty');

    const fullscreenModal = document.getElementById('fullscreen-modal');
    const fullscreenContent = document.getElementById('fullscreen-content');
    const closeFullscreen = document.getElementById('close-fullscreen');

    // 1. Initial Load from Template Script
    const initialTpl = document.getElementById('tpl-card').innerHTML.trim();
    codeInput.value = initialTpl;

    // 2. RENDER PREVIEW (IFrame)
    function renderPreview() {
      const code = codeInput.value.trim();
      const width = parseInt(widthInput.value) || 800;
      const height = heightInput.value === 'auto' ? 'auto' : parseInt(heightInput.value);

      if (!code) {
        previewContent.innerHTML = '';
        previewContent.classList.add('hidden');
        previewEmpty.classList.remove('hidden');
        downloadBtn.disabled = true;
        return;
      }

      previewEmpty.classList.add('hidden');
      previewContent.classList.remove('hidden');
      previewContent.innerHTML = '';

      const iframe = document.createElement('iframe');
      iframe.style.width = width + 'px';
      iframe.style.height = height === 'auto' ? '400px' : height + 'px';
      iframe.style.border = 'none';
      iframe.style.background = 'transparent';
      iframe.scrolling = 'no'; 
      
      const containerWidth = previewContent.parentElement.offsetWidth;
      if(width > containerWidth) {
         const scale = (containerWidth - 40) / width;
         iframe.style.transform = `scale(${scale})`;
         iframe.style.transformOrigin = 'top center';
      } else {
         iframe.style.transform = 'none';
      }

      previewContent.appendChild(iframe);

      const doc = iframe.contentWindow.document;
      doc.open();
      // Inject user code + CSS Reset
      doc.write(`<!DOCTYPE html><html><head><style>* { box-sizing: border-box; } body { margin: 0; padding: 0; min-height: 100vh; overflow: hidden; }</style></head><body>${code}</body></html>`);
      doc.close();

      iframe.onload = () => {
          if (height === 'auto') {
            const bodyHeight = doc.body.scrollHeight;
            const htmlHeight = doc.documentElement.scrollHeight;
            const finalHeight = Math.max(bodyHeight, htmlHeight, 400);
            iframe.style.height = finalHeight + 'px';
          }
          downloadBtn.removeAttribute('disabled');
      };
    }

    // 3. GENERATE & DOWNLOAD
    function generateAndDownload() {
      const iframe = previewContent.querySelector('iframe');
      if (!iframe) return;

      const originalBtnText = downloadBtn.innerHTML;
      downloadBtn.innerText = window._tToast ? window._tToast("⏳ Rendering...") : "⏳ Rendering...";
      downloadBtn.setAttribute('disabled', 'true');

      const body = iframe.contentWindow.document.body;

      if (typeof html2canvas === 'undefined') {
          // Poll until library loads
          setTimeout(generateAndDownload, 100);
          return;
      }

      const width = parseInt(widthInput.value) || 800;
      const height = heightInput.value === 'auto' ? iframe.offsetHeight : parseInt(heightInput.value);

      html2canvas(body, {
          useCORS: true,
          scale: 2, 
          logging: false,
          width: width,
          windowWidth: width,
          height: height,
          windowHeight: height,
          backgroundColor: null
      }).then(canvas => {
          const format = formatSelect.value;
          const mime = format === 'png' ? 'image/png' : format === 'jpeg' ? 'image/jpeg' : 'image/webp';
          const quality = format === 'jpeg' || format === 'webp' ? 0.9 : 1.0;
          
          const link = document.createElement('a');
          link.download = `code-img-${Date.now()}.${format}`;
          link.href = canvas.toDataURL(mime, quality);
          link.click();

          downloadBtn.innerHTML = originalBtnText;
          downloadBtn.removeAttribute('disabled');
          window.showToast?.(window._tToast ? window._tToast('Gambar berhasil disimpan!') : 'Gambar berhasil disimpan!', 'success');
      }).catch(err => {
          // console.error(err);
          window.showToast?.(window._tToast ? window._tToast('Gagal render gambar.') : 'Gagal render gambar.', 'error');
          downloadBtn.innerHTML = originalBtnText;
          downloadBtn.removeAttribute('disabled');
      });
    }

    // 4. Listeners
    let debounceTimer;
    [codeInput, widthInput, heightInput].forEach(input => {
        input.addEventListener('input', () => {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(renderPreview, 800);
        });
    });

    templateSelect.addEventListener('change', (e) => {
        const tplId = e.target.value;
        if (tplId) {
            // Get content from script template
            const content = document.getElementById(tplId).innerHTML.trim();
            codeInput.value = content;
            renderPreview();
        }
    });

    clearBtn.addEventListener('click', () => {
        codeInput.value = '';
        renderPreview();
    });

    refreshBtn.addEventListener('click', renderPreview);
    downloadBtn.addEventListener('click', generateAndDownload);
    
    copyBtn.addEventListener('click', () => {
        codeInput.select();
        document.execCommand('copy');
        window.showToast?.(window._tToast ? window._tToast('Kode berhasil disalin!') : 'Kode berhasil disalin!', 'success');
    });

    // Share API
    shareBtn.addEventListener('click', async () => {
        const iframe = previewContent.querySelector('iframe');
        if (!iframe) return;
        
        const originalBtnText = shareBtn.innerHTML;
        shareBtn.innerText = window._tToast ? window._tToast("⏳") : "⏳";
        shareBtn.disabled = true;

        try {
            const body = iframe.contentWindow.document.body;
            const canvas = await html2canvas(body, { 
                useCORS: true, scale: 2, logging: false, backgroundColor: null 
            });
            canvas.toBlob(async (blob) => {
                const file = new File([blob], "share.png", { type: "image/png" });
                if (navigator.share && navigator.canShare({ files: [file] })) {
                    await navigator.share({ files: [file], title: "Code Image" });
                    window.showToast?.(window._tToast ? window._tToast('Berhasil dibagikan!') : 'Berhasil dibagikan!', 'success');
                } else {
                    window.showToast?.(window._tToast ? window._tToast('Browser tidak support share.') : 'Browser tidak support share.', 'error');
                }
                shareBtn.innerHTML = originalBtnText;
                shareBtn.disabled = false;
            });
        } catch (e) {
            shareBtn.innerHTML = originalBtnText;
            shareBtn.disabled = false;
        }
    });

    // Fullscreen
    fullscreenBtn.addEventListener('click', () => {
        const iframe = previewContent.querySelector('iframe');
        if (!iframe) return;
        fullscreenContent.innerHTML = '';
        const clone = iframe.cloneNode(true);
        clone.style.transform = 'none';
        clone.style.width = '100%';
        clone.style.height = '100%';
        fullscreenContent.appendChild(clone);
        fullscreenModal.classList.remove('hidden');
    });

    closeFullscreen.addEventListener('click', () => fullscreenModal.classList.add('hidden'));
    fullscreenModal.addEventListener('click', (e) => {
        if(e.target === fullscreenModal) fullscreenModal.classList.add('hidden');
    });

    // Initial
    renderPreview();
  });
</script>